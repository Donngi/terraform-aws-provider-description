{
	"mcpServers": {
		"aws-knowledge-mcp-server": {
			"command": "uvx",
			"args": ["fastmcp", "run", "https://knowledge-mcp.global.api.aws"]
		},
		"awslabs.terraform-mcp-server": {
			"command": "uvx",
			"args": ["awslabs.terraform-mcp-server@latest"],
			"env": {
				"FASTMCP_LOG_LEVEL": "ERROR"
			}
		},
		"context7": {
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp"]
		}
	}
}
