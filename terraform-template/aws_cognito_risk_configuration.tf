#########################################################################
# Cognito Risk Configuration
#########################################################################
# Amazon Cognito のユーザープールに対する高度なセキュリティ機能の設定
# 不正なアクセスや侵害された認証情報からユーザーアカウントを保護します
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/cognito_risk_configuration
# Generated: 2026-02-13
#
# NOTE: このテンプレートは、Cognito Advanced Securityの設定に必要な全パラメータを含んでいます。
#       アカウント乗っ取り保護、侵害された認証情報の検出、IP範囲ベースの例外設定が可能です。

resource "aws_cognito_risk_configuration" "example" {

  #########################################################################
  # Basic Configuration（基本設定）
  #########################################################################

  # 設定内容: ユーザープールの識別子
  # 設定可能な値: 有効なCognito User Pool ID
  # 省略時: 必須パラメータのため、省略不可
  user_pool_id = "us-east-1_XXXXXXXXX"

  # 設定内容: クライアントアプリケーションの識別子
  # 設定可能な値: 有効なCognito User Pool Client ID
  # 省略時: 設定なし（全クライアントに適用）
  # 備考: 指定した場合、特定のクライアントアプリにのみリスク設定を適用
  client_id = "1234567890abcdefghijklmnop"

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョン名（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

#########################################################################
# Account Takeover Risk Configuration（アカウント乗っ取りリスク設定）
#########################################################################

# 設定内容: アカウント乗っ取り試行を検出した際の動作設定
# 省略時: アカウント乗っ取り保護機能が無効化
account_takeover_risk_configuration {

  #-----------------------------------------------------------------------
  # Actions（アクション設定）
  #-----------------------------------------------------------------------

  # 設定内容: リスクレベルごとの対応アクション定義（必須）
  actions {

    # 設定内容: 低リスク時のアクション
    # 省略時: 低リスク時の保護が無効化
    low_action {
      # 設定内容: 実行するアクションの種類
      # 設定可能な値: BLOCK（ブロック）, MFA_IF_CONFIGURED（MFA要求）, MFA_REQUIRED（MFA必須）, NO_ACTION（アクションなし）
      # 省略時: 必須パラメータのため、省略不可
      event_action = "NO_ACTION"

      # 設定内容: ユーザーに通知を送信するかどうか
      # 設定可能な値: true（通知する）, false（通知しない）
      # 省略時: 必須パラメータのため、省略不可
      notify = false
    }

    # 設定内容: 中リスク時のアクション
    # 省略時: 中リスク時の保護が無効化
    medium_action {
      # 設定内容: 実行するアクションの種類
      # 設定可能な値: BLOCK（ブロック）, MFA_IF_CONFIGURED（MFA要求）, MFA_REQUIRED（MFA必須）, NO_ACTION（アクションなし）
      # 省略時: 必須パラメータのため、省略不可
      event_action = "MFA_IF_CONFIGURED"

      # 設定内容: ユーザーに通知を送信するかどうか
      # 設定可能な値: true（通知する）, false（通知しない）
      # 省略時: 必須パラメータのため、省略不可
      notify = true
    }

    # 設定内容: 高リスク時のアクション
    # 省略時: 高リスク時の保護が無効化
    high_action {
      # 設定内容: 実行するアクションの種類
      # 設定可能な値: BLOCK（ブロック）, MFA_IF_CONFIGURED（MFA要求）, MFA_REQUIRED（MFA必須）, NO_ACTION（アクションなし）
      # 省略時: 必須パラメータのため、省略不可
      event_action = "BLOCK"

      # 設定内容: ユーザーに通知を送信するかどうか
      # 設定可能な値: true（通知する）, false（通知しない）
      # 省略時: 必須パラメータのため、省略不可
      notify = true
    }
  }

  #-----------------------------------------------------------------------
  # Notify Configuration（通知設定）
  #-----------------------------------------------------------------------

  # 設定内容: リスク検出時のメール通知設定
  # 省略時: メール通知が無効化
  notify_configuration {
    # 設定内容: 通知メール送信に使用するSES送信元ARN（必須）
    # 設定可能な値: 有効なSES Identity ARN
    # 省略時: 必須パラメータのため、省略不可
    source_arn = "arn:aws:ses:us-east-1:123456789012:identity/example.com"

    # 設定内容: 送信元メールアドレス
    # 設定可能な値: 有効なメールアドレス形式
    # 省略時: SES Identityのデフォルト送信元を使用
    from = "no-reply@example.com"

    # 設定内容: 返信先メールアドレス
    # 設定可能な値: 有効なメールアドレス形式
    # 省略時: 返信先が設定されない
    reply_to = "support@example.com"

    # 設定内容: アカウントブロック時の通知メール内容
    # 省略時: ブロック時の通知メールが送信されない
    block_email {
      # 設定内容: メールの件名（必須）
      # 省略時: 必須パラメータのため、省略不可
      subject = "不正なアクセスをブロックしました"

      # 設定内容: HTMLメール本文（必須）
      # 省略時: 必須パラメータのため、省略不可
      html_body = "<p>お客様のアカウントで不正なアクセスが検出されたため、ブロックしました。</p>"

      # 設定内容: テキストメール本文（必須）
      # 省略時: 必須パラメータのため、省略不可
      text_body = "お客様のアカウントで不正なアクセスが検出されたため、ブロックしました。"
    }

    # 設定内容: MFA要求時の通知メール内容
    # 省略時: MFA要求時の通知メールが送信されない
    mfa_email {
      # 設定内容: メールの件名（必須）
      # 省略時: 必須パラメータのため、省略不可
      subject = "多要素認証が必要です"

      # 設定内容: HTMLメール本文（必須）
      # 省略時: 必須パラメータのため、省略不可
      html_body = "<p>お客様のアカウントで疑わしいアクティビティが検出されました。多要素認証を実施してください。</p>"

      # 設定内容: テキストメール本文（必須）
      # 省略時: 必須パラメータのため、省略不可
      text_body = "お客様のアカウントで疑わしいアクティビティが検出されました。多要素認証を実施してください。"
    }

    # 設定内容: アクションなし時の通知メール内容
    # 省略時: アクションなし時の通知メールが送信されない
    no_action_email {
      # 設定内容: メールの件名（必須）
      # 省略時: 必須パラメータのため、省略不可
      subject = "疑わしいアクティビティを検出しました"

      # 設定内容: HTMLメール本文（必須）
      # 省略時: 必須パラメータのため、省略不可
      html_body = "<p>お客様のアカウントで疑わしいアクティビティが検出されました。ご確認ください。</p>"

      # 設定内容: テキストメール本文（必須）
      # 省略時: 必須パラメータのため、省略不可
      text_body = "お客様のアカウントで疑わしいアクティビティが検出されました。ご確認ください。"
    }
  }
}

#########################################################################
# Compromised Credentials Risk Configuration（侵害された認証情報リスク設定）
#########################################################################

# 設定内容: 漏洩した認証情報の使用を検出した際の動作設定
# 省略時: 侵害された認証情報の保護機能が無効化
compromised_credentials_risk_configuration {

  # 設定内容: 監視対象のイベントタイプフィルター
  # 設定可能な値: SIGN_IN（サインイン）, PASSWORD_CHANGE（パスワード変更）, SIGN_UP（サインアップ）のセット
  # 省略時: すべてのイベントタイプを監視
  event_filter = ["SIGN_IN", "PASSWORD_CHANGE"]

  #-----------------------------------------------------------------------
  # Actions（アクション設定）
  #-----------------------------------------------------------------------

  # 設定内容: 侵害された認証情報を検出した際のアクション（必須）
  actions {
    # 設定内容: 実行するアクションの種類
    # 設定可能な値: BLOCK（ブロック）, NO_ACTION（アクションなし）
    # 省略時: 必須パラメータのため、省略不可
    event_action = "BLOCK"
  }
}

#########################################################################
# Risk Exception Configuration（リスク例外設定）
#########################################################################

# 設定内容: リスク評価の例外条件設定
# 省略時: 例外設定なし（すべてのIPアドレスが評価対象）
risk_exception_configuration {

  # 設定内容: 常にブロックするIPアドレス範囲リスト
  # 設定可能な値: CIDR表記のIPアドレス範囲のセット
  # 省略時: ブロックリストが設定されない
  # 備考: このリストに含まれるIPからのアクセスは無条件でブロック
  blocked_ip_range_list = [
    "192.0.2.0/24",
    "198.51.100.0/24"
  ]

  # 設定内容: リスク評価をスキップするIPアドレス範囲リスト
  # 設定可能な値: CIDR表記のIPアドレス範囲のセット
  # 省略時: スキップリストが設定されない
  # 備考: このリストに含まれるIPからのアクセスはリスク評価されない（信頼できるIPレンジ）
  skipped_ip_range_list = [
    "203.0.113.0/24"
  ]
}

}

#########################################################################
# Attributes Reference
#########################################################################

# id - リソースの識別子（user_pool_id:client_id または user_pool_id のいずれかの形式）
