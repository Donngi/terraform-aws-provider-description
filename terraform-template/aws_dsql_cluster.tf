#---------------------------------------------------------------
# Amazon Aurora DSQL Cluster
#---------------------------------------------------------------
#
# Amazon Aurora DSQL (Distributed SQL) クラスターを管理するリソースです。
# Aurora DSQL は、フルマネージドの分散SQLデータベースサービスで、
# 強力な一貫性、高可用性、PostgreSQL互換のインターフェースを提供します。
#
# 主な特徴:
#   - 分散アーキテクチャによる高可用性とスケーラビリティ
#   - マルチリージョン展開のサポート
#   - PostgreSQL互換のSQLインターフェース
#   - サーバーレスで自動スケーリング
#
# AWS公式ドキュメント:
#   - Aurora DSQL 概要: https://docs.aws.amazon.com/aurora-dsql/latest/userguide/what-is.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/dsql_cluster
#
# Provider Version: 6.28.0
# Generated: 2026-01-22
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_dsql_cluster" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # deletion_protection_enabled (Optional, Computed)
  # 設定内容: クラスターの削除保護を有効にするかどうかを指定します。
  # 設定可能な値:
  #   - true: 削除保護を有効化。クラスターを削除する前に無効化が必要
  #   - false: 削除保護を無効化 (デフォルト)
  # 用途: 本番環境のクラスターを誤って削除することを防止
  # 注意: 削除保護が有効な場合、force_destroy を true に設定しない限り削除できません
  deletion_protection_enabled = true

  # force_destroy (Optional, Computed)
  # 設定内容: deletion_protection_enabled が true でもクラスターを強制削除するかどうかを指定します。
  # 設定可能な値:
  #   - true: 削除保護が有効でも強制的に削除
  #   - false: 削除保護が有効な場合は削除しない (デフォルト)
  # 用途: テスト環境などで迅速にリソースをクリーンアップする場合に使用
  # 注意: 本番環境では false のままにすることを推奨
  force_destroy = false

  #-------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------

  # kms_encryption_key (Optional, Computed)
  # 設定内容: DSQL クラスター内のデータを暗号化する AWS KMS キーの ARN を指定します。
  # 設定可能な値:
  #   - KMS キーの ARN: カスタマーマネージドキーを使用 (例: "arn:aws:kms:us-east-1:123456789012:key/...")
  #   - "AWS_OWNED_KMS_KEY": AWS マネージドキーを使用 (デフォルト)
  # 用途: セキュリティ要件に応じてカスタマーマネージドキーで暗号化する場合に指定
  # 注意: クラスター作成後に変更するとクラスターが再作成されます
  kms_encryption_key = "AWS_OWNED_KMS_KEY"

  #-------------------------------------------------------------
  # マルチリージョン設定
  #-------------------------------------------------------------

  # multi_region_properties (Optional)
  # 設定内容: マルチリージョンクラスターの設定を指定します。
  # 用途: 複数リージョンにまたがる高可用性構成を構築する場合に使用
  # 注意: witness_region を設定するとマルチリージョンクラスターになります。
  #       この設定を変更するとクラスターが再作成されます。
  multi_region_properties {
    # witness_region (Optional)
    # 設定内容: マルチリージョンクラスターのウィットネスリージョンを指定します。
    # 設定可能な値: 有効な AWS リージョンコード (例: "us-west-2", "eu-west-1")
    # 用途: マルチリージョンクラスターにおいて、フェイルオーバー時の
    #       クォーラム (定足数) を維持するための第三のリージョン
    # 注意: この設定を行うとクラスターがマルチリージョンクラスターになります。
    #       変更するとリソースが再作成されます。
    witness_region = null

    # clusters (Optional, Computed)
    # 設定内容: このクラスターとピアリングしている DSQL クラスターの ARN のセットを指定します。
    # 設定可能な値: DSQL クラスターの ARN の文字列セット
    # 用途: マルチリージョン構成で複数のクラスターを接続する場合に使用
    # 注意: この属性は Computed でもあり、ピアリング設定後に自動的に更新されます
    clusters = null
  }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional, Computed)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード (例: "us-east-1", "ap-northeast-1")
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 用途: リソースの識別、コスト配分、アクセス制御などに使用
  # 注意: プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-dsql-cluster"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を設定します。
  # 用途: クラスターの作成、更新、削除に長時間かかる場合にタイムアウトを調整
  timeouts {
    # create (Optional)
    # 設定内容: クラスター作成のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列 (例: "30s", "5m", "2h45m")
    # 省略時: プロバイダーのデフォルト値を使用
    create = "30m"

    # update (Optional)
    # 設定内容: クラスター更新のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列 (例: "30s", "5m", "2h45m")
    # 省略時: プロバイダーのデフォルト値を使用
    update = "30m"

    # delete (Optional)
    # 設定内容: クラスター削除のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列 (例: "30s", "5m", "2h45m")
    # 省略時: プロバイダーのデフォルト値を使用
    # 注意: 削除操作のタイムアウト設定は、削除前に状態が保存される場合にのみ適用されます
    delete = "30m"
  }
}

#---------------------------------------------------------------
