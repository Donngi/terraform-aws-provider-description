#-------------------------------------------------------------------------------------------------------
# AWS EC2 Default Credit Specification
#-------------------------------------------------------------------------------------------------------
# Resource: aws_ec2_default_credit_specification
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# NOTE:
#   EC2インスタンスファミリーのデフォルトCPUクレジット設定を定義するリソース。
#   バーストパフォーマンスインスタンス（T2/T3/T3a/T4g）のアカウント全体のデフォルトCPUクレジット動作を
#   指定します。インスタンス起動時に明示的な設定がない場合、このデフォルト値が適用されます。
#
# 【用途】
#   - アカウント全体でのT系インスタンスのCPUクレジットポリシー統一管理
#   - バーストパフォーマンスインスタンスの課金モデル（standard/unlimited）の一括制御
#   - リージョン単位でのデフォルトクレジット動作の設定
#
# 【主要な機能】
#   - インスタンスファミリー単位でのCPUクレジットモード設定
#   - standard（クレジット枯渇時はベースライン性能に制限）とunlimited（追加料金で無制限）の選択
#   - リージョン別のデフォルト設定管理
#
# 【参考ドキュメント】
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_default_credit_specification
#   - https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/burstable-credits-baseline-concepts.html
#
#-------------------------------------------------------------------------------------------------------

#---------------------------------------------------------------------------------------------------
# リソース定義
#---------------------------------------------------------------------------------------------------
resource "aws_ec2_default_credit_specification" "example" {
  #---------------------------------------------------------------------------------------------------
  # 基本設定
  #---------------------------------------------------------------------------------------------------
  # 設定内容: インスタンスファミリー（t2、t3、t3a、t4gのいずれか）
  # 設定可能な値: "t2" | "t3" | "t3a" | "t4g"
  # ※リージョン内の指定ファミリーに対するデフォルトCPUクレジット設定を定義
  instance_family = "t3"

  # 設定内容: CPUクレジットモード
  # 設定可能な値:
  #   - "standard": クレジット枯渇時はベースラインパフォーマンスに制限（追加課金なし）
  #   - "unlimited": クレジット枯渇後も追加料金でフルパフォーマンス継続
  # ※アカウント内で起動される該当ファミリーのインスタンスに適用されるデフォルト値
  cpu_credits = "standard"

  #---------------------------------------------------------------------------------------------------
  # リージョン設定
  #---------------------------------------------------------------------------------------------------
  # 設定内容: このリソースを管理するリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # ※異なるリージョンで異なるデフォルト設定を適用する場合に指定
  region = "us-east-1"

  #---------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #---------------------------------------------------------------------------------------------------
  # timeouts {
  #   # 設定内容: 作成操作のタイムアウト時間
  #   # 省略時: デフォルトタイムアウトを使用
  #   # 形式: "30s"、"5m"、"2h"などの期間文字列
  #   create = "10m"
  #
  #   # 設定内容: 更新操作のタイムアウト時間
  #   # 省略時: デフォルトタイムアウトを使用
  #   # 形式: "30s"、"5m"、"2h"などの期間文字列
  #   update = "10m"
  # }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference
#-------------------------------------------------------------------------------------------------------
# 以下の属性がリソース作成後に参照可能:
#
# - id: リソース識別子（形式: "region,instance_family"）
# - cpu_credits: 設定されたCPUクレジットモード
# - instance_family: 設定されたインスタンスファミリー
# - region: リソースが管理されているリージョン
#-------------------------------------------------------------------------------------------------------
