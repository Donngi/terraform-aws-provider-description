#-----------------------------------------------------------------------
# RDS オプショングループ (aws_db_option_group)
#-----------------------------------------------------------------------
# 用途: RDSデータベースエンジンに追加機能やプラグインを設定
# - Oracle TDE、SQL Server監査、MySQLレプリケーションなどのオプション設定
# - オプションごとにポート番号やセキュリティグループを個別に設定可能
# - エンジンのメジャーバージョンごとに専用のオプショングループを管理
# 公式ドキュメント: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/USER_WorkingWithOptionGroups.html
# Terraformドキュメント: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/db_option_group
#
# Provider Version: 6.28.0
# Generated: 2026-02-14
# NOTE: このテンプレートは参考用です。実際の使用時は不要なパラメータを削除してください。

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_db_option_group" "example" {
  # 設定内容: データベースエンジン名
  # 設定可能な値: mysql, oracle-ee, oracle-ee-cdb, oracle-se2, oracle-se2-cdb, postgres, sqlserver-ee, sqlserver-se, sqlserver-ex, sqlserver-web など
  # 省略時: 設定不可（必須）
  engine_name = "mysql"

  # 設定内容: エンジンのメジャーバージョン（例: 8.0, 19など）
  # 設定可能な値: エンジンごとに異なる（例: MySQL 8.0, Oracle 19, SQL Server 15.00など）
  # 省略時: 設定不可（必須）
  major_engine_version = "8.0"

  # 設定内容: オプショングループの名前（最大255文字、小文字英数字とハイフンのみ）
  # 設定可能な値: 小文字英数字、ハイフン、アンダースコアで構成される文字列
  # 省略時: Terraformが自動生成（name_prefixが優先される）
  name = "mysql-option-group"

  # 設定内容: オプショングループ名のプレフィックス（最大255文字）
  # 設定可能な値: 小文字英数字、ハイフン、アンダースコアで構成される文字列
  # 省略時: Terraformが自動生成（nameが優先される）
  name_prefix = "mysql-"

  #-----------------------------------------------------------------------
  # 説明とメタデータ
  #-----------------------------------------------------------------------

  # 設定内容: オプショングループの説明文（最大255文字）
  # 設定可能な値: 任意の文字列
  # 省略時: "Managed by Terraform"
  option_group_description = "MySQL option group for application database"

  # 設定内容: このリソースが管理されるAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # データベースオプション
  #-----------------------------------------------------------------------

  # 設定内容: データベースエンジンに追加する機能やプラグインの設定
  # 設定可能な値: エンジンごとに利用可能なオプションが異なる
  option {
    # 設定内容: オプション名（例: MARIADB_AUDIT_PLUGIN, OEM, TDEなど）
    # 設定可能な値: エンジンとバージョンに応じた利用可能なオプション名
    # 省略時: 設定不可（必須）
    option_name = "MARIADB_AUDIT_PLUGIN"

    # 設定内容: オプションのバージョン（一部のオプションでサポート）
    # 設定可能な値: オプションごとに利用可能なバージョン番号
    # 省略時: デフォルトバージョンが使用される
    # version = "1.0"

    # 設定内容: オプションで使用するポート番号（一部のオプションで必須）
    # 設定可能な値: 1150-65535（Oracleオプションなど、ポートが必要なオプションで指定）
    # 省略時: オプションのデフォルトポートが使用される
    # port = 1158

    # 設定内容: DBセキュリティグループのリスト（EC2-Classic環境用）
    # 設定可能な値: DB セキュリティグループ名のセット
    # 省略時: セキュリティグループなし
    # db_security_group_memberships = ["db-security-group-1"]

    # 設定内容: VPCセキュリティグループIDのリスト
    # 設定可能な値: セキュリティグループIDのセット（例: sg-xxxxxxxxxxxxxxxxx）
    # 省略時: セキュリティグループなし
    # vpc_security_group_memberships = ["sg-12345678"]

    # オプション固有のパラメータ設定
    option_settings {
      # 設定内容: オプション設定のパラメータ名
      # 設定可能な値: オプションごとに定義された設定項目名
      # 省略時: 設定不可（必須）
      name = "SERVER_AUDIT_EVENTS"

      # 設定内容: パラメータに設定する値
      # 設定可能な値: パラメータごとに定義された有効な値
      # 省略時: 設定不可（必須）
      value = "CONNECT,QUERY_DDL"
    }

    option_settings {
      name  = "SERVER_AUDIT_FILE_ROTATIONS"
      value = "37"
    }
  }

  # 複数のオプションを設定する例
  # option {
  #   option_name = "MEMCACHED"
  #   port        = 11211
  #
  #   vpc_security_group_memberships = ["sg-87654321"]
  # }

  #-----------------------------------------------------------------------
  # ライフサイクル管理
  #-----------------------------------------------------------------------

  # 設定内容: Terraform destroy実行時にオプショングループを削除しない
  # 設定可能な値: true（削除をスキップ）、false（削除を実行）
  # 省略時: false（通常の削除動作）
  skip_destroy = false

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグのマップ
  # 設定可能な値: キーと値のペアのマップ（最大50タグ）
  # 省略時: タグなし
  tags = {
    Name        = "mysql-option-group"
    Environment = "production"
    Managed     = "terraform"
  }

  # 設定内容: プロバイダーレベルのdefault_tagsとこのリソースのtagsをマージした全タグ
  # 設定可能な値: キーと値のペアのマップ（読み取り専用、設定不可）
  # 省略時: tagsとdefault_tagsの組み合わせ
  tags_all = {}

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 設定内容: オプショングループ削除のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 15m, 1h）
    # 省略時: 15m
    delete = "15m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   説明: オプショングループ名
#   型: string
#
# - arn
#   説明: オプショングループのARN
#   型: string
#   例: arn:aws:rds:us-east-1:123456789012:og:mysql-option-group
#
# - region
#   説明: オプショングループが作成されたリージョン
#   型: string
#   例: us-east-1
#
# - name
#   説明: オプショングループ名（name_prefixを使用した場合は生成された名前）
#   型: string
#
# - tags_all
#   説明: リソースに付与されたすべてのタグ（default_tags含む）
#   型: map(string)
