#---------------------------------------------------------------
# AWS IAM Server Certificate
#---------------------------------------------------------------
#
# IAMにサーバー証明書をアップロード・管理するリソースです。
# サーバー証明書はHTTPS接続を有効にするために使用される
# SSL/TLS証明書であり、IAMに保存してELB等のAWSサービスと
# 連携させることができます。なお、ACM（AWS Certificate Manager）が
# 利用可能なリージョンでは、ACMの使用が推奨されます。
#
# AWS公式ドキュメント:
#   - IAM サーバー証明書の管理: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_server-certs.html
#   - サーバー証明書の操作: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_server-certs_manage.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/iam_server_certificate
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iam_server_certificate" "example" {
  #-------------------------------------------------------------
  # 名前設定
  #-------------------------------------------------------------

  # name (Optional, Forces new resource)
  # 設定内容: IAMサーバー証明書の名前を指定します。
  # 設定可能な値: 大文字・小文字の英数字および特殊文字 `_`, `+`, `=`, `,`, `.`, `@`, `-` を含む文字列（最大128文字）
  # 省略時: Terraformがランダムな一意の名前を生成します。
  # 注意: name_prefix と排他的（どちらか一方のみ指定可能）。
  name = "my-server-certificate"

  # name_prefix (Optional, Forces new resource)
  # 設定内容: IAMサーバー証明書名のプレフィックスを指定します。
  #           Terraformが後ろにランダムな一意のサフィックスを付加して名前を生成します。
  # 設定可能な値: 文字列
  # 注意: name と排他的（どちらか一方のみ指定可能）。
  name_prefix = null

  #-------------------------------------------------------------
  # 証明書設定
  #-------------------------------------------------------------

  # certificate_body (Required)
  # 設定内容: PEM形式のパブリック証明書の内容を指定します。
  # 設定可能な値: PEM形式の証明書文字列（-----BEGIN CERTIFICATE-----で始まる）
  # 注意: Terraform内でfile()関数を使用してファイルから読み込むことを推奨します。
  certificate_body = file("self-ca-cert.pem")

  # certificate_chain (Optional)
  # 設定内容: PEM形式の証明書チェーン（中間CA証明書）の内容を指定します。
  # 設定可能な値: PEM形式の証明書チェーン文字列
  # 省略時: 証明書チェーンなし
  # 注意: ルート証明書を含む完全な証明書チェーンを指定してください。
  certificate_chain = null

  # private_key (Required)
  # 設定内容: PEM形式の秘密鍵の内容を指定します。
  # 設定可能な値: PEM形式の秘密鍵文字列（-----BEGIN RSA PRIVATE KEY-----等で始まる）
  # 注意: この属性は機密情報（sensitive）として扱われます。Terraform stateファイルに
  #       プレーンテキストで保存されるため、stateファイルのアクセス制御に注意してください。
  private_key = file("test-key.pem")

  #-------------------------------------------------------------
  # パス設定
  #-------------------------------------------------------------

  # path (Optional)
  # 設定内容: サーバー証明書のパスを指定します。
  #           IAMリソースを論理的にグループ化するために使用します。
  #           CloudFrontで使用する場合は /cloudfront/ で始まるパスを指定する必要があります。
  # 設定可能な値: 先頭と末尾がスラッシュ（/）で始まる文字列、またはスラッシュ（/）単体。
  #              ASCII文字（\u0021 〜 \u007F）を含められます（最大512文字）。
  # 省略時: "/" (ルートパス)
  # 参考: https://docs.aws.amazon.com/IAM/latest/UserGuide/Using_Identifiers.html
  path = "/"

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "my-server-certificate"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # delete (Optional)
    # 設定内容: リソース削除操作のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "5m", "2h" 等のGoのtime.Duration形式の文字列
    # 省略時: デフォルトのタイムアウト値が適用されます。
    delete = "15m"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: AWSによって割り当てられたサーバー証明書のARN
#
# - expiration: 証明書の有効期限（ISO 8601形式）
#
# - id: サーバー証明書のID（name と同じ値）
#
# - tags_all: プロバイダーの default_tags 設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#
# - upload_date: 証明書がアップロードされた日時（ISO 8601形式）
#---------------------------------------------------------------
