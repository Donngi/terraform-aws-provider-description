#######################################################################
# AWS Network Manager Global Network
#######################################################################
# AWS Network Managerのグローバルネットワークを作成するリソース。
# グローバルネットワークはAWS Transit Gateway、SD-WAN、オンプレミス
# デバイスなど複数のネットワーク要素を統合管理するための論理的な
# コンテナとして機能する。
#
# 主な用途:
# - マルチリージョン・マルチアカウントのWAN管理
# - Transit Gatewayをグローバルネットワークへ登録
# - オンプレミスデバイスやリンクの一元管理
# - ネットワークトポロジーの可視化
#
# 参考: https://docs.aws.amazon.com/network-manager/latest/cloudwan/what-is-cloudwan.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/networkmanager_global_network
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_networkmanager_global_network" "example" {
  #-----------------------------------------------------------------------
  # グローバルネットワーク基本設定
  #-----------------------------------------------------------------------

  # グローバルネットワークの説明
  # 設定内容: ネットワークの用途や目的を記述する自由テキスト
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なしで作成される
  description = "グローバルWAN管理ネットワーク"

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # タイムアウト設定ブロック（オプション）
  # 設定内容: リソース操作のタイムアウト時間を設定する
  timeouts {
    # 作成タイムアウト
    # 設定内容: リソース作成時のタイムアウト時間
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "10m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウト値を使用
    create = "10m"

    # 更新タイムアウト
    # 設定内容: リソース更新時のタイムアウト時間
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "10m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウト値を使用
    update = "10m"

    # 削除タイムアウト
    # 設定内容: リソース削除時のタイムアウト時間
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "10m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウト値を使用
    delete = "10m"
  }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # リソースタグ
  # 設定内容: グローバルネットワークに付与するタグ（キー・バリューペア）
  # 設定可能な値: 任意のキーと値のペアのマップ
  # 省略時: タグなしで作成される
  # 注意: プロバイダーのdefault_tagsと重複するキーは上書きされる
  tags = {
    Name        = "example-global-network"
    Environment = "production"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   グローバルネットワークのID
#
# - arn
#   グローバルネットワークのARN
#
# - tags_all
#   リソースに割り当てられたすべてのタグ
#   （プロバイダーのdefault_tagsから継承されたタグを含む）
#-----------------------------------------------------------------------
