#---------------------------------------------------------------
# AWS EBS Encryption By Default
#---------------------------------------------------------------
#
# AWSアカウントの現在のリージョンにおけるデフォルトのEBS暗号化を
# 有効または無効にするリソースです。
# デフォルト暗号化を有効にすると、そのリージョンで作成される
# 新しいEBSボリュームとスナップショットが自動的に暗号化されます。
#
# 注意: このTerraformリソースを削除すると、デフォルトEBS暗号化が無効になります。
#
# リージョンのデフォルトKMSキーを管理する場合は、`aws_ebs_default_kms_key`
# リソースを参照してください。
#
# AWS公式ドキュメント:
#   - EBS暗号化: https://docs.aws.amazon.com/ebs/latest/userguide/ebs-encryption.html
#   - デフォルト暗号化の有効化: https://docs.aws.amazon.com/ebs/latest/userguide/encryption-by-default.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ebs_encryption_by_default
#
# Provider Version: 6.28.0
# Generated: 2026-01-22
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_ebs_encryption_by_default" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # enabled (Optional)
  # 設定内容: デフォルトEBS暗号化を有効にするかどうかを指定します。
  # 設定可能な値:
  #   - true: デフォルト暗号化を有効化（新しいボリュームとスナップショットが自動的に暗号化される）
  #   - false: デフォルト暗号化を無効化
  # 省略時: true
  # 注意事項:
  #   - デフォルト暗号化を有効にしても、既存のボリュームやスナップショットには影響しません。
  #   - デフォルト暗号化が有効な場合、暗号化をサポートしていないインスタンスタイプは起動できなくなります。
  #   - 暗号化されたスナップショットを別のKMSキーにコピーすると、追加のストレージコストが発生します。
  #   - リージョン単位の設定であり、そのリージョン内の個々のボリュームやスナップショットで無効にすることはできません。
  # 関連機能: AWS KMS
  #   暗号化には対称暗号化KMSキーが使用されます。
  #   キーを指定しない場合、デフォルトのEBS暗号化用KMSキーが使用されます。
  #   - https://docs.aws.amazon.com/ebs/latest/userguide/ebs-encryption.html
  enabled = true

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

