#
# Attributes Reference:
#   id - IP アクセスコントロールグループの ID
#
#---------------------------------------------------------------

resource "aws_workspaces_ip_group" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # 設定内容: IP アクセスコントロールグループの名前
  # 設定可能な値: 任意の文字列
  name = "example-ip-group"

  # 設定内容: IP アクセスコントロールグループの説明
  # 省略時: 説明なし
  description = "Example WorkSpaces IP group"

  # 設定内容: リソースを管理するリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"

  #-------------------------------------------------------------
  # IP ルール設定
  #-------------------------------------------------------------

  # 設定内容: 許可する IP アドレス範囲のルール（複数指定可能）
  rules {
    # 設定内容: 許可する IP アドレスまたは CIDR ブロック
    # 設定可能な値: "203.0.113.0/24" のような CIDR 表記、または単一 IP アドレス
    source = "203.0.113.0/24"

    # 設定内容: このルールの説明
    # 省略時: 説明なし
    description = "オフィス IP アドレス範囲"
  }

  # rules {
