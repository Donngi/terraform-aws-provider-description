#-----------------------------------------------------------------------
# AWS Pinpoint SMS Voice V2 電話番号 (aws_pinpointsmsvoicev2_phone_number)
#-----------------------------------------------------------------------
#
# Amazon Pinpoint SMS Voice V2 の電話番号リソースを管理する。
# SMSまたは音声メッセージの送受信に使用する電話番号を取得・設定する。
# ロングコード、ショートコード、10DLC、フリーダイヤルなどの番号種別をサポートする。
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/pinpointsmsvoicev2_phone_number
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
#
# NOTE:
#   - number_type に "SHORT_CODE" を指定する場合はAWSへの申請・審査が必要
#   - 10DLC番号を使用する場合は registration_id でキャンペーン登録IDを紐付けること
#   - two_way_channel_enabled を true にする場合は two_way_channel_arn も必須
#   - 削除保護が有効な電話番号は terraform destroy 前に手動で無効化が必要
#
# Attributes Reference:
#   arn                      - 電話番号リソースのARN
#   id                       - 電話番号IDと同一
#   phone_number             - 取得した電話番号（E.164形式）
#   monthly_leasing_price    - 月額リース料金
#   tags_all                 - プロバイダーのデフォルトタグを含む全タグのマップ
#-----------------------------------------------------------------------

resource "aws_pinpointsmsvoicev2_phone_number" "example" {

  #-----------------------------------------------------------------------
  # 必須設定
  #-----------------------------------------------------------------------

  # 設定内容: 電話番号を取得するISOカントリーコード（ISO 3166-1 alpha-2形式）
  # 設定可能な値: "US", "JP", "GB", "CA", "AU" など（AWSがサポートする国コード）
  iso_country_code = "US"

  # 設定内容: 送信するメッセージの種類
  # 設定可能な値: "TRANSACTIONAL"（取引メッセージ）, "PROMOTIONAL"（プロモーションメッセージ）
  message_type = "TRANSACTIONAL"

  # 設定内容: 電話番号の使用可能な機能のセット
  # 設定可能な値: "SMS"（SMS送受信）, "VOICE"（音声通話）
  number_capabilities = ["SMS"]

  # 設定内容: 取得する電話番号の種類
  # 設定可能な値: "LONG_CODE"（ロングコード）, "SHORT_CODE"（ショートコード）,
  #              "TEN_DLC"（10桁ローカルコード）, "TOLL_FREE"（フリーダイヤル）,
  #              "SIMULATOR"（シミュレーター）
  number_type = "LONG_CODE"

  #-----------------------------------------------------------------------
  # オプション設定 - オプトアウトリスト
  #-----------------------------------------------------------------------

  # 設定内容: この電話番号に関連付けるオプトアウトリスト名
  # 設定可能な値: 既存のオプトアウトリスト名（文字列）
  # 省略時: アカウントのデフォルトオプトアウトリストが使用される
  opt_out_list_name = null

  # 設定内容: オプトアウト処理をAWSではなく自分で管理するかどうか
  # 設定可能な値: true（自己管理）, false（AWS管理）
  # 省略時: false（AWS管理）
  self_managed_opt_outs_enabled = null

  #-----------------------------------------------------------------------
  # オプション設定 - 双方向通信
  #-----------------------------------------------------------------------

  # 設定内容: 双方向メッセージング（受信メッセージ）を有効にするかどうか
  # 設定可能な値: true（有効）, false（無効）
  # 省略時: false
  two_way_channel_enabled = null

  # 設定内容: 受信メッセージを転送するSNSトピックまたはKinesisストリームのARN
  # 設定可能な値: SNSトピックARN または Kinesis Data StreamsのARN
  # 省略時: なし（two_way_channel_enabledがtrueの場合は必須）
  two_way_channel_arn = null

  # 設定内容: 双方向チャネルへのアクセスに使用するIAMロールのARN
  # 設定可能な値: IAMロールのARN文字列
  # 省略時: なし
  two_way_channel_role = null

  #-----------------------------------------------------------------------
  # オプション設定 - 保護と登録
  #-----------------------------------------------------------------------

  # 設定内容: 誤削除防止の削除保護を有効にするかどうか
  # 設定可能な値: true（有効）, false（無効）
  # 省略時: false
  deletion_protection_enabled = null

  # 設定内容: この電話番号に関連付ける登録ID（10DLCキャンペーン登録など）
  # 設定可能な値: 既存の登録IDの文字列
  # 省略時: なし
  registration_id = null

  #-----------------------------------------------------------------------
  # オプション設定 - リージョン
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: "us-east-1", "eu-west-1" などのリージョンコード
  # 省略時: プロバイダー設定のリージョンが使用される
  region = null

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグのマップ
  # 省略時: タグなし
  tags = {
    Name = "example-phone-number"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 設定内容: 作成操作のタイムアウト時間
    # 設定可能な値: "30s", "5m", "1h" などの期間文字列
    # 省略時: プロバイダーデフォルト
    create = "30m"

    # 設定内容: 更新操作のタイムアウト時間
    # 設定可能な値: "30s", "5m", "1h" などの期間文字列
    # 省略時: プロバイダーデフォルト
    update = "30m"

    # 設定内容: 削除操作のタイムアウト時間
    # 設定可能な値: "30s", "5m", "1h" などの期間文字列
    # 省略時: プロバイダーデフォルト
    delete = "30m"
  }
}
