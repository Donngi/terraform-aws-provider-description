# ============================================================
# AWS EFS Backup Policy
# ============================================================
# リソース概要:
#   Amazon Elastic File System (EFS) の自動バックアップポリシーを管理するリソース。
#   既存のファイルシステムに対して、自動バックアップのオン/オフを制御します。
#
# 主な用途:
#   - EFSファイルシステムの自動バックアップを有効化
#   - AWS Backupとの統合による定期的なバックアップ実行
#   - データ保護とディザスタリカバリ対策の実装
#
# 公式ドキュメント:
#   https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/efs_backup_policy
#   https://docs.aws.amazon.com/efs/latest/ug/automatic-backups.html
#
# Provider Version: 6.28.0
# ============================================================

# ------------------------------------------------------------
# 前提条件: EFSファイルシステムの作成
# ------------------------------------------------------------
# バックアップポリシーを適用するためのEFSファイルシステム
resource "aws_efs_file_system" "example" {
  creation_token = "my-product"

  tags = {
    Name = "example-efs"
  }
}

# ------------------------------------------------------------
# EFS Backup Policy
# ------------------------------------------------------------
resource "aws_efs_backup_policy" "example" {
  # ============================================================
  # 必須パラメータ
  # ============================================================

  # ------------------------------------------------------------
  # file_system_id (必須)
  # ------------------------------------------------------------
  # 説明: バックアップポリシーを適用するEFSファイルシステムのID
  # 型: string
  # 例: "fs-ccfc0d65"
  #
  # 注意点:
  #   - 既存のEFSファイルシステムのIDを指定する必要があります
  #   - ファイルシステムが存在しない場合はエラーになります
  # ------------------------------------------------------------
  file_system_id = aws_efs_file_system.example.id

  # ------------------------------------------------------------
  # backup_policy (必須)
  # ------------------------------------------------------------
  # 説明: バックアップポリシーの設定を定義するブロック
  # 型: object
  #
  # ネストされたパラメータ:
  #   - status (必須): バックアップポリシーのステータス
  #
  # AWS Backupとの統合:
  #   - 自動バックアップが有効化されると、AWS Backupサービスが
  #     デフォルトで日次バックアップを実行します
  #   - バックアップ設定の詳細はAWS Backupコンソールで編集可能です
  # ------------------------------------------------------------
  backup_policy {
    # ------------------------------------------------------------
    # status (必須)
    # ------------------------------------------------------------
    # 説明: バックアップポリシーのステータス
    # 型: string
    # 有効な値:
    #   - "ENABLED": 自動バックアップが有効（推奨）
    #   - "DISABLED": 自動バックアップが無効
    #
    # 動作の詳細:
    #   - ENABLED: EFSが自動的に日次バックアップを実行
    #     * AWS Backupサービスと統合
    #     * インクリメンタルバックアップを実施
    #     * システムタグ "aws:elasticfilesystem:default-backup" が追加
    #   - DISABLED: 自動バックアップを停止
    #
    # パフォーマンスへの影響:
    #   - バックアップはバーストクレジットを消費しません
    #   - ファイル操作の制限には影響しません
    #   - バックアップ速度: 約2,000ファイル/秒または400 MBps
    #
    # ベストプラクティス:
    #   - 本番環境では ENABLED を推奨
    #   - バックアップ中の整合性を保つため、可能であれば
    #     オフピーク時にバックアップをスケジュール
    #   - 最大バックアップ期間は30日間
    # ------------------------------------------------------------
    status = "ENABLED"
  }

  # ============================================================
  # オプションパラメータ
  # ============================================================

  # ------------------------------------------------------------
  # region (オプション)
  # ------------------------------------------------------------
  # 説明: このリソースが管理されるAWSリージョン
  # 型: string
  # デフォルト: プロバイダー設定のリージョン
  #
  # 使用例:
  #   region = "us-west-2"
  #
  # 注意点:
  #   - 通常はプロバイダー設定を使用するため指定不要
  #   - マルチリージョン構成の場合に明示的に指定
  # ------------------------------------------------------------
  # region = "ap-northeast-1"
}

# ============================================================
# 出力値
# ============================================================
# バックアップポリシーの属性を出力

# ------------------------------------------------------------
# id
# ------------------------------------------------------------
# 説明: ファイルシステムを識別するID
# 値: file_system_id と同じ値 (例: "fs-ccfc0d65")
# ------------------------------------------------------------
output "backup_policy_id" {
  description = "The ID of the EFS file system with backup policy"
  value       = aws_efs_backup_policy.example.id
}

output "file_system_id" {
  description = "The EFS file system ID"
  value       = aws_efs_backup_policy.example.file_system_id
}

# ============================================================
# 使用例とベストプラクティス
# ============================================================
#
# 1. 基本的な使用方法:
#    - 既存のEFSファイルシステムに対してバックアップを有効化
#    - 自動的にAWS Backupと統合される
#
# 2. バックアップの仕組み:
#    - デフォルトで日次バックアップが実行される
#    - インクリメンタルバックアップ方式を採用
#    - 完全復元に必要な参照データを保持
#
# 3. コスト最適化:
#    - 使用頻度の低いバックアップはコールドストレージに移行可能
#    - AWS Backupの料金体系に基づいて課金
#
# 4. セキュリティ考慮事項:
#    - 必要なIAM権限:
#      * elasticfilesystem:backup
#      * elasticfilesystem:restore
#    - バックアップボールトのアクセスポリシーで削除制御
#
# 5. 復元時の注意:
#    - 復元速度: 約1,500ファイル/秒または200 MBps
#    - 整合性を保つため、バックアップ中はアプリケーションを
#      一時停止することを推奨
#
# 6. モニタリング:
#    - AWS Backupコンソールでバックアップジョブの状態を確認
#    - CloudWatchでバックアップメトリクスを監視
#
# 7. マルチリージョン対策:
#    - EFS Replicationと組み合わせてクロスリージョンDR構成を実現
#    - 各リージョンのファイルシステムに個別にバックアップポリシーを設定
#
# 8. 制限事項:
#    - AWS Backupはリソースごとに1つの同時バックアップのみ実行
#    - バックアップの最大期間は30日間
#    - 一部リージョンでは利用不可（Asia Pacific (Thailand)、
#      Asia Pacific (Malaysia)、Mexico (Central)、
#      Asia Pacific (Taipei)、Canada West (Calgary)など）
#
# ============================================================
