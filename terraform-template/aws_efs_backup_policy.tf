#-------------------------------------------------------------------------------------------------------
# AWS EFS Backup Policy (aws_efs_backup_policy)
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/efs_backup_policy
#
# NOTE: このファイルは参考用テンプレートです。実際の使用時は環境に応じて設定値を変更してください。
#
# 用途:
#   - EFSファイルシステムのAWS Backupによる自動バックアップを有効化・無効化する
#   - 日次バックアップをデフォルトで有効にし、データ保護を実現
#   - AWS Backupサービスと連携して増分バックアップを実行
#
# 主な機能:
#   - 自動バックアップポリシーの設定 (ENABLED/DISABLED)
#   - AWS Backupとの統合
#   - デフォルトバックアッププランの自動作成
#
# ユースケース:
#   - 本番環境のEFSファイルシステムのデータ保護
#   - コンプライアンス要件に基づくバックアップ管理
#   - ディザスタリカバリ対策
#
# 制約事項:
#   - 既存のファイルシステムに対してのみ設定可能
#   - 自動バックアップはAWS Backupサービスを使用するため追加料金が発生
#   - バックアップ中のファイルシステム変更は整合性に影響する可能性あり
#
# 参考資料:
#   - https://docs.aws.amazon.com/efs/latest/ug/automatic-backups.html
#   - https://docs.aws.amazon.com/efs/latest/ug/awsbackup.html
#   - https://docs.aws.amazon.com/efs/latest/ug/API_BackupPolicy.html
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# 基本設定
#-------------------------------------------------------------------------------------------------------
resource "aws_efs_backup_policy" "example" {
  # file_system_id - 必須
  # 設定内容: バックアップポリシーを適用するEFSファイルシステムのID
  # 設定可能な値: 有効なEFSファイルシステムID (fs-xxxxxxxx形式)
  # 参照例: aws_efs_file_system.main.id
  file_system_id = "fs-12345678"

  #-------------------------------------------------------------------------------------------------------
  # バックアップポリシー設定
  #-------------------------------------------------------------------------------------------------------
  backup_policy {
    # status - 必須
    # 設定内容: 自動バックアップの状態を指定
    # 設定可能な値:
    #   - ENABLED: 自動バックアップを有効化（AWS Backupが日次バックアップを実行）
    #   - DISABLED: 自動バックアップを無効化
    #   - ENABLING: 有効化処理中（読み取り専用）
    #   - DISABLING: 無効化処理中（読み取り専用）
    # 省略時: 明示的な設定が必要（デフォルト値なし）
    # 備考:
    #   - ENABLEDに設定すると、aws:elasticfilesystem:default-backupタグが自動付与される
    #   - AWS Backupコンソールでバックアッププランの詳細設定が可能
    #   - ENABLING/DISABLINGはAWSが遷移中に設定する状態値
    status = "ENABLED"
  }

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定（オプション）
  #-------------------------------------------------------------------------------------------------------
  # region - 任意
  # 設定内容: リソースを管理するAWSリージョンを明示的に指定
  # 設定可能な値: 有効なAWSリージョンコード (例: ap-northeast-1, us-east-1)
  # 省略時: プロバイダー設定のリージョンを使用
  # 備考:
  #   - マルチリージョン構成で明示的なリージョン指定が必要な場合に使用
  #   - 通常はプロバイダーレベルでのリージョン設定で十分
  region = "ap-northeast-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# 以下の属性を他のリソースから参照できます:
#
# - id
#   リソースID（file_system_idと同じ値）
#
# - file_system_id
#   バックアップポリシーが適用されているファイルシステムのID
#
# - region
#   リソースが管理されているAWSリージョン
