#-----------------------------------------------------------------------
# AWS Config 構成アグリゲーター
#-----------------------------------------------------------------------
# 複数のアカウントおよびリージョンからAWS Configの構成データとコンプライアンスデータを
# 集約するアグリゲーターを作成します。
# 組織レベルまたは個別アカウントレベルでの集約に対応します。
#
# Provider Version: 6.28.0
# Generated: 2026-02-13
# NOTE: account_aggregation_sourceとorganization_aggregation_sourceは排他的です。
#       どちらか一方のみを指定してください。
#
# 参考: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/config_configuration_aggregator
#-----------------------------------------------------------------------

resource "aws_config_configuration_aggregator" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------
  # 設定内容: アグリゲーターの名前（一意な識別子）
  name = "example-aggregator"

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定で指定したリージョンが使用されます
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # アカウント集約ソース設定
  # （個別のアカウントIDを指定して集約する場合）
  #-----------------------------------------------------------------------
  account_aggregation_source {
    # 設定内容: 集約対象とする個別のAWSアカウントIDのリスト
    account_ids = [
      "123456789012",
      "210987654321"
    ]

    # 設定内容: 全リージョンからデータを集約するかどうか
    # 設定可能な値: true（全リージョン）、false（特定リージョンのみ）
    # 省略時: falseが適用され、regionsで指定したリージョンのみ集約されます
    all_regions = true

    # 設定内容: 集約対象とする特定のリージョンリスト（all_regionsがfalseの場合に使用）
    # regions = [
    #   "ap-northeast-1",
    #   "us-east-1"
    # ]
  }

  #-----------------------------------------------------------------------
  # 組織集約ソース設定
  # （AWS Organizations配下の全アカウントから集約する場合）
  #-----------------------------------------------------------------------
  # organization_aggregation_source {
  #   # 設定内容: 組織内のアカウントにアクセスするために使用するIAMロールのARN
  #   # 注意: AWSConfigRoleForOrganizationsなど、適切な権限を持つロールを指定してください
  #   role_arn = "arn:aws:iam::123456789012:role/AWSConfigRoleForOrganizations"
  #
  #   # 設定内容: 全リージョンからデータを集約するかどうか
  #   # 設定可能な値: true（全リージョン）、false（特定リージョンのみ）
  #   # 省略時: falseが適用され、regionsで指定したリージョンのみ集約されます
  #   all_regions = true
  #
  #   # 設定内容: 集約対象とする特定のリージョンリスト（all_regionsがfalseの場合に使用）
  #   # regions = [
  #   #   "ap-northeast-1",
  #   #   "us-east-1"
  #   # ]
  # }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # 設定内容: アグリゲーターに付与するタグ（キー・バリューのマップ）
  tags = {
    Name        = "example-config-aggregator"
    Environment = "production"
    ManagedBy   = "Terraform"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# arn
#   - アグリゲーターのARN（Amazon Resource Name）
#   - 形式: arn:aws:config:リージョン:アカウントID:config-aggregator/aggregator-名前
#
# id
#   - アグリゲーターの識別子（通常はname属性と同じ値）
#
# tags_all
#   - デフォルトタグとリソース固有のタグを統合したマップ
#   - プロバイダーレベルのdefault_tagsとマージされた結果
#
# region
#   - アグリゲーターが作成されたリージョン
