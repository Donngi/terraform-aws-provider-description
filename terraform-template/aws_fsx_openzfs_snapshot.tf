#-------------------------------------------------------------------------------------------------------
# Resource: aws_fsx_openzfs_snapshot
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/fsx_openzfs_snapshot
# NOTE: このテンプレートは参考例であり、実際の使用時には環境に応じた調整が必要です
#-------------------------------------------------------------------------------------------------------
# リソース名: aws_fsx_openzfs_snapshot
# ユースケース: Amazon FSx for OpenZFSボリュームのポイントインタイムスナップショットを作成・管理
# 利用シーン:
#   - データ保護とバックアップ管理
#   - ボリュームの特定時点における読み取り専用イメージの作成
#   - スナップショットからのクローンボリュームまたはフルコピーボリュームの作成
#   - 誤削除や変更からのファイル回復
#   - テスト環境やステージング環境の迅速な構築
# 関連リソース:
#   - aws_fsx_openzfs_file_system: スナップショット元となるFSx for OpenZFSファイルシステム
#   - aws_fsx_openzfs_volume: スナップショット元となる子ボリューム
# 公式ドキュメント: https://docs.aws.amazon.com/fsx/latest/OpenZFSGuide/snapshots-openzfs.html
#-------------------------------------------------------------------------------------------------------

resource "aws_fsx_openzfs_snapshot" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------------------------------------------------

  # name - スナップショット名
  # 設定内容: スナップショットの識別名（最大203文字の英数字、_, -, :, . が使用可能）
  # 制約: 必須項目、1~203文字
  # 推奨値: スナップショットの目的や作成日時を含むわかりやすい名前
  name = "production-volume-snapshot-20240115"

  # volume_id - ボリュームID
  # 設定内容: スナップショットを作成するボリュームのID（ルートボリュームまたは子ボリューム）
  # 制約: 必須項目
  # 設定可能な値:
  #   - aws_fsx_openzfs_file_system.root_volume_id: ファイルシステムのルートボリューム
  #   - aws_fsx_openzfs_volume.id: 子ボリューム
  # 補足: スナップショットはボリュームの特定時点の読み取り専用イメージを作成
  volume_id = aws_fsx_openzfs_file_system.example.root_volume_id

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------

  # region - リソース管理リージョン
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用される
  # 補足: 通常は省略してプロバイダー設定に従うことを推奨
  region = "us-west-2"

  #-------------------------------------------------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------------------------------------------------

  # tags - リソースタグ
  # 設定内容: スナップショットに付与するタグのマップ
  # 省略時: タグなし（プロバイダーのdefault_tagsは適用される）
  # 補足: コスト管理、リソース分類、運用管理に活用
  tags = {
    Name        = "production-volume-snapshot"
    Environment = "production"
    Purpose     = "daily-backup"
    CreatedBy   = "terraform"
    ManagedBy   = "ops-team"
  }

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------

  # timeouts - 操作タイムアウト設定
  # 設定内容: 各操作のタイムアウト時間を指定
  # 省略時: デフォルトのタイムアウト値が使用される
  # 補足: 大規模ボリュームの場合はタイムアウトを延長することを推奨
  timeouts {
    # create - 作成操作のタイムアウト
    # 設定内容: スナップショット作成操作の最大待機時間
    # 省略時: デフォルト値が使用される
    # 推奨値: ボリュームサイズに応じて調整（通常30分で十分）
    create = "30m"

    # update - 更新操作のタイムアウト
    # 設定内容: スナップショット更新操作（タグ変更など）の最大待機時間
    # 省略時: デフォルト値が使用される
    update = "30m"

    # delete - 削除操作のタイムアウト
    # 設定内容: スナップショット削除操作の最大待機時間
    # 省略時: デフォルト値が使用される
    # 補足: クローンボリュームが存在する場合は削除不可
    delete = "30m"

    # read - 読み取り操作のタイムアウト
    # 設定内容: スナップショット情報読み取り操作の最大待機時間
    # 省略時: デフォルト値が使用される
    read = "30m"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# - id: スナップショットの識別子（例: fsvolsnap-12345678）
# - arn: スナップショットのAmazon Resource Name（ARN）
# - creation_time: スナップショットの作成日時（ISO 8601形式）
# - tags_all: リソースに割り当てられたすべてのタグ（プロバイダーdefault_tags含む）
#
# 参照例:
#   aws_fsx_openzfs_snapshot.example.id
#   aws_fsx_openzfs_snapshot.example.arn
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# 補足説明
#-------------------------------------------------------------------------------------------------------
# - スナップショットは読み取り専用で、ボリュームの特定時点のイメージを保持
# - スナップショットはボリュームと同じストレージに保存され、変更部分のみが容量を消費
# - クローンボリュームはスナップショットから即座に作成可能で、初期状態では追加容量不要
# - フルコピーボリュームはスナップショットの完全独立コピーで、作成に時間がかかる
# - スナップショットからボリュームがクローンされている場合、そのスナップショットは削除不可
# - 個別ファイルの復元は .zfs/snapshot ディレクトリから手動で実行可能
# - カスタムスナップショットスケジュールはAWS ConsoleまたはAPIで設定可能
# - スナップショットのライフサイクル状態: PENDING、CREATING、AVAILABLE、DELETING
#-------------------------------------------------------------------------------------------------------
