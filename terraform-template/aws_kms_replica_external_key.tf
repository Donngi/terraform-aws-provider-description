#---------------------------------------------------------------
# AWS KMS マルチリージョンレプリカ外部キー
#---------------------------------------------------------------
#
# 外部キーマテリアルを使用するKMSマルチリージョンレプリカキーを
# プロビジョニングするリソースです。
# プライマリキーは別のAWSリージョンに存在し、本リソースはそのレプリカを作成します。
# 外部キーマテリアルはユーザー自身が生成・管理し、Base64エンコードして
# インポートします。プライマリキーと同じキーマテリアルを使用する必要があります。
#
# AWS公式ドキュメント:
#   - KMS マルチリージョンキーへのキーマテリアルのインポート: https://docs.aws.amazon.com/kms/latest/developerguide/multi-region-keys-import.html
#   - 外部キーマテリアルのインポートに関する考慮事項: https://docs.aws.amazon.com/kms/latest/developerguide/importing-keys-considerations.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/kms_replica_external_key
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_kms_replica_external_key" "example" {
  #-------------------------------------------------------------
  # プライマリキー設定
  #-------------------------------------------------------------

  # primary_key_arn (Required)
  # 設定内容: レプリカ元となるマルチリージョンプライマリキーのARNを指定します。
  # 設定可能な値: 有効なKMSマルチリージョンプライマリキーのARN
  # 注意: プライマリキーは同じAWSパーティションの異なるリージョンに存在する必要があります。
  #       各リージョンに対して1つのプライマリキーにつき1つのレプリカのみ作成できます。
  primary_key_arn = "arn:aws:kms:us-east-1:123456789012:key/mrk-1234abcd12ab34cd56ef1234567890ab"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-west-2）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: KMSキーの説明を指定します。
  # 設定可能な値: 最大8192文字の文字列
  # 省略時: 説明なし
  description = "Multi-Region replica key"

  # enabled (Optional)
  # 設定内容: レプリカキーを有効にするかを指定します。
  # 設定可能な値:
  #   - true: キーを有効化。暗号化オペレーションに使用可能
  #   - false: キーを無効化。暗号化オペレーションには使用不可
  # 省略時: キーマテリアルがインポートされていない場合はfalse、インポート済みかつ未期限切れの場合はtrue
  # 注意: キーマテリアルのインポート待ち状態（PendingImport）ではfalseのみ設定可能
  enabled = true

  #-------------------------------------------------------------
  # キーマテリアル設定
  #-------------------------------------------------------------

  # key_material_base64 (Optional)
  # 設定内容: インポートするBase64エンコードされた256ビット対称暗号化キーマテリアルを指定します。
  # 設定可能な値: Base64エンコードされた256ビット（32バイト）の対称キーマテリアル
  # 省略時: キーはPendingImport状態のままとなり、暗号化オペレーションに使用できません。
  # 注意: KMSキーはこのキーマテリアルに永続的に関連付けられます。
  #       同じキーマテリアルを再インポートすることは可能ですが、異なるキーマテリアルはインポートできません。
  #       プライマリキーと同一のキーマテリアルを使用する必要があります。
  #       このフィールドはセンシティブ情報として扱われます。
  # 参考: https://docs.aws.amazon.com/kms/latest/developerguide/importing-keys-import-key-material.html
  key_material_base64 = "base64encodedkeymaterial=="

  # valid_to (Optional)
  # 設定内容: インポートしたキーマテリアルの有効期限を指定します。
  # 設定可能な値: RFC3339形式の日時文字列（例: "2027-12-31T00:00:00Z"）
  # 省略時: キーマテリアルは期限切れにならず、有効期限なしで使用できます。
  # 注意: 有効期限が切れると、AWS KMSはキーマテリアルを削除し、キーが使用不能になります。
  #       有効期限を設定する場合はキーマテリアルの再インポートが必要になります。
  valid_to = null

  #-------------------------------------------------------------
  # 削除設定
  #-------------------------------------------------------------

  # deletion_window_in_days (Optional)
  # 設定内容: KMSキーが削除されるまでの待機期間を日数で指定します。
  # 設定可能な値: 7〜30の整数
  # 省略時: 30日
  # 注意: 待機期間終了後、AWS KMSはKMSキーを削除します。削除されたKMSキーは復元できません。
  deletion_window_in_days = 30

  #-------------------------------------------------------------
  # キーポリシー設定
  #-------------------------------------------------------------

  # policy (Optional)
  # 設定内容: KMSキーに割り当てるキーポリシーをJSON形式で指定します。
  # 設定可能な値: 有効なIAMポリシーJSON文字列
  # 省略時: AWS KMSがデフォルトキーポリシーをKMSキーに割り当てます。
  # 参考: https://docs.aws.amazon.com/kms/latest/developerguide/key-policies.html#key-policy-default
  policy = null

  # bypass_policy_lockout_safety_check (Optional)
  # 設定内容: キーポリシーのロックアウト安全チェックをバイパスするかを指定します。
  # 設定可能な値:
  #   - true: 安全チェックをバイパス。KMSキーが管理不能になるリスクが高まります
  #   - false: 安全チェックを実行（推奨）
  # 省略時: false
  # 注意: このフラグをtrueに設定することは慎重に行ってください。
  #       KMSキーが管理不能になる可能性があります。
  # 参考: https://docs.aws.amazon.com/kms/latest/developerguide/key-policies.html#key-policy-default-allow-root-enable-iam
  bypass_policy_lockout_safety_check = false

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: レプリカキーに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 注意: プロバイダーのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-kms-replica-key"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: レプリカキーのARN。関連するマルチリージョンキーのキーARNは
#        リージョン値のみが異なります。
#
# - expiration_model: キーマテリアルの有効期限モデル。
#                     キーマテリアルのインポート待ち状態では空文字列。
#                     それ以外は "KEY_MATERIAL_EXPIRES" または "KEY_MATERIAL_DOES_NOT_EXPIRE"。
#
# - key_id: レプリカキーのキーID。関連するマルチリージョンキーは同じキーIDを共有します。
#
# - key_state: レプリカキーの状態（例: Enabled, Disabled, PendingImport）。
#
# - key_usage: KMSキーで使用可能な暗号化オペレーション。
#              マルチリージョンキーの共有プロパティです。
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
