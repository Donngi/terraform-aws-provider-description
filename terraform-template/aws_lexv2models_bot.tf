resource "aws_lexv2models_bot" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: ボットの名前を指定します。
  # 設定可能な値: 最大100文字の英数字、ハイフン、アンダースコア
  # 省略時: 省略不可
  name = "example-lexv2-bot"

  # role_arn (Required)
  # 設定内容: Lex がボットを実行する際に使用する IAM ロールの ARN を指定します。
  # 設定可能な値: 有効な IAM ロールの ARN 文字列
  # 省略時: 省略不可
  role_arn = aws_iam_role.example.arn

  # idle_session_ttl_in_seconds (Required)
  # 設定内容: セッションのアイドルタイムアウト（秒）を指定します。
  # 設定可能な値: 60〜86400 の整数
  # 省略時: 省略不可
  idle_session_ttl_in_seconds = 300

  # description (Optional)
  # 設定内容: ボットの説明を指定します。
  # 設定可能な値: 最大200文字の文字列
  # 省略時: 説明なし
  description = "Amazon Lex V2 ボットのサンプルテンプレートです。"

  # type (Optional)
  # 設定内容: ボットのタイプを指定します。
  # 設定可能な値:
  #   - "Bot": 通常のボット
  #   - "BotNetwork": 複数のボットを組み合わせたネットワークボット
  # 省略時: "Bot"
  # 注意: "BotNetwork" を指定した場合は members ブロックでメンバーボットを定義してください。
  type = "Bot"

  # test_bot_alias_tags (Optional)
  # 設定内容: テストボットエイリアスに付与するタグのマップを指定します。
  # 設定可能な値: キーと値が文字列のマップ（例: { "Env" = "test" }）
  # 省略時: タグなし
  test_bot_alias_tags = {
    "Env" = "dev"
  }

  # tags (Optional)
  # 設定内容: ボットに付与するタグのマップを指定します。
  # 設定可能な値: キーと値が文字列のマップ（例: { "Env" = "prod" }）
  # 省略時: タグなし
  tags = {
    "Name" = "example-lexv2-bot"
    "Env"  = "dev"
  }

  #-------------------------------------------------------------
  # データプライバシー設定
  #-------------------------------------------------------------

  # data_privacy (Required)
  # 設定内容: ボットのデータプライバシー設定を指定するブロックです。
  # 省略時: 省略不可
  data_privacy {

    # child_directed (Required)
    # 設定内容: ボットが COPPA（児童オンラインプライバシー保護法）の対象かどうかを指定します。
    # 設定可能な値:
    #   - true: 13歳未満の子ども向けサービスに使用するボット
    #   - false: 子ども向けではないボット
    # 省略時: 省略不可
    # 注意: 誤った値を設定すると法的責任を負う場合があります。
    child_directed = false
  }

  #-------------------------------------------------------------
  # ネットワークボット メンバー設定
  #-------------------------------------------------------------

  # members (Optional)
  # 設定内容: ネットワークボットを構成するメンバーボットを指定するブロックです。
  # 省略時: メンバーなし（type = "Bot" の場合は不要）
  # 注意: type = "BotNetwork" の場合にメンバーボットを定義します。
  # members {
  #
  #   # id (Required)
  #   # 設定内容: メンバーボットの ID を指定します。
  #   # 設定可能な値: 有効なボット ID 文字列
  #   # 省略時: 省略不可
  #   id = "メンバーボットのID"
  #
  #   # name (Required)
  #   # 設定内容: メンバーボットの名前を指定します。
  #   # 設定可能な値: 有効なボット名文字列
  #   # 省略時: 省略不可
  #   name = "メンバーボットの名前"
  #
  #   # version (Required)
  #   # 設定内容: メンバーボットのバージョンを指定します。
  #   # 設定可能な値: 有効なボットバージョン文字列（例: "1", "2"）
  #   # 省略時: 省略不可
  #   version = "1"
  #
  #   # alias_id (Required)
  #   # 設定内容: メンバーボットのエイリアス ID を指定します。
  #   # 設定可能な値: 有効なエイリアス ID 文字列
  #   # 省略時: 省略不可
  #   alias_id = "メンバーボットのエイリアスID"
  #
  #   # alias_name (Required)
  #   # 設定内容: メンバーボットのエイリアス名を指定します。
  #   # 設定可能な値: 有効なエイリアス名文字列
  #   # 省略時: 省略不可
  #   alias_name = "メンバーボットのエイリアス名"
  # }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を設定するブロックです。
  timeouts {

    # create (Optional)
    # 設定内容: リソース作成時のタイムアウト時間を指定します。
    # 設定可能な値: Goの time.Duration 形式の文字列（例: "30s", "5m", "1h"）
    # 省略時: デフォルトタイムアウト
    create = "5m"

    # update (Optional)
    # 設定内容: リソース更新時のタイムアウト時間を指定します。
    # 設定可能な値: Goの time.Duration 形式の文字列（例: "30s", "5m", "1h"）
    # 省略時: デフォルトタイムアウト
    update = "5m"

    # delete (Optional)
    # 設定内容: リソース削除時のタイムアウト時間を指定します。
    # 設定可能な値: Goの time.Duration 形式の文字列（例: "30s", "5m", "1h"）
    # 省略時: デフォルトタイムアウト
    delete = "5m"
  }
}

