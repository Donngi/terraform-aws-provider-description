#-----------------------------------------------
# AWS CloudHSM v2 Cluster (aws_cloudhsm_v2_cluster)
#-----------------------------------------------
# AWS CloudHSM v2のクラスタリソース定義
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/cloudhsm_v2_cluster
# Generated: 2026-02-12
#
# CloudHSM v2は、AWSクラウド内で暗号化キーの生成・保管・管理を行うための
# ハードウェアセキュリティモジュール(HSM)を提供するマネージドサービス。
# クラスタは1つ以上のHSMで構成される論理的な単位であり、高可用性と
# 負荷分散を実現する。
#
# 主な用途:
# - 暗号化キーの安全な保管と管理
# - FIPS 140-3レベル3準拠のセキュリティ要件への対応
# - SSL/TLS証明書の秘密鍵管理
# - データベース暗号化のマスターキー管理
# - コード署名用の秘密鍵管理
# - PKI(公開鍵基盤)の認証局における鍵管理
#
# 制限事項:
# - クラスタのモード(FIPS/非FIPS)は作成後に変更不可
# - HSMタイプは作成後に変更不可（ただしhsm1.mediumからhsm2m.mediumへの移行は可能）
# - 最小1つ以上のHSMがクラスタ内で稼働している必要がある
# - サブネットは異なるアベイラビリティゾーンに配置することが推奨される
#
# NOTE:
# - hsm2m.mediumの使用が推奨される（hsm1.mediumは新規作成不可）
# - 高可用性のため、複数のAZにまたがるサブネット配置を推奨
# - モードとHSMタイプは作成後変更不可のため事前に要件を確認すること
#
# 関連リソース:
# - aws_cloudhsm_v2_hsm: クラスタ内の個別HSMインスタンス
# - aws_security_group: クラスタのセキュリティグループ（自動作成されるが参照可能）
# - aws_subnet: HSMを配置するサブネット
# - aws_vpc: クラスタが所属するVPC
#-----------------------------------------------

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.28.0"
    }
  }
}

#-----------------------------------------------
# 基本設定
#-----------------------------------------------

resource "aws_cloudhsm_v2_cluster" "example" {
  # 設定内容: HSMのタイプを指定
  # 設定可能な値:
  #   - hsm1.medium: 旧世代HSM（FIPS 140-2準拠、新規作成不可）
  #   - hsm2m.medium: 現行世代HSM（FIPS 140-3準拠、推奨）
  # 補足:
  #   - hsm2m.mediumは最大16,666キー（非対称鍵は3,333キー）を保存可能
  #   - hsm1.mediumは最大3,300キーを保存可能
  #   - 2024年6月10日以降はhsm2m.mediumの使用が推奨される
  #   - 作成後のHSMタイプ変更は不可（移行は別途対応が必要）
  hsm_type = "hsm2m.medium"

  # 設定内容: HSMを配置するサブネットIDのリスト
  # 補足:
  #   - 最低1つのサブネットが必要
  #   - 高可用性のため、異なるAZに複数のサブネットを指定することを推奨
  #   - 指定したサブネット内にHSMのENI（Elastic Network Interface）が作成される
  #   - サブネットは同一VPC内である必要がある
  #   - 各サブネットには十分な空きIPアドレスが必要
  subnet_ids = [
    "subnet-12345678",
    "subnet-87654321",
  ]

  #-----------------------------------------------
  # クラスタモード設定
  #-----------------------------------------------

  # 設定内容: クラスタの動作モードを指定
  # 設定可能な値:
  #   - FIPS: FIPS検証済みの鍵とアルゴリズムのみを使用
  #   - NON_FIPS: FIPS検証済みおよび非検証の鍵とアルゴリズムを使用可能
  # 省略時: hsm_typeに応じた推奨値が設定される
  # 補足:
  #   - hsm1.mediumはFIPSモードのみサポート
  #   - hsm2m.mediumはFIPSモードと非FIPSモードの両方をサポート
  #   - モードは作成後に変更不可
  #   - FIPSモードのバックアップはFIPSモードのクラスタにのみ復元可能
  #   - 非FIPSモードのバックアップは非FIPSモードのクラスタにのみ復元可能
  mode = "FIPS"

  #-----------------------------------------------
  # バックアップからの復元設定
  #-----------------------------------------------

  # 設定内容: 復元元となるバックアップの識別子を指定
  # 補足:
  #   - 既存のクラスタバックアップからクラスタを復元する場合に使用
  #   - バックアップIDまたはクラスタIDを指定可能
  #   - 復元先クラスタのモードは復元元と一致する必要がある
  #   - hsm1.mediumのバックアップはhsm2m.mediumのFIPSモードクラスタに復元可能
  #   - hsm2m.mediumのバックアップはhsm2m.mediumのクラスタにのみ復元可能
  source_backup_identifier = null # 例: "backup-1a2b3c4d5e6f7g8h"

  #-----------------------------------------------
  # リージョン設定
  #-----------------------------------------------

  # 設定内容: クラスタを作成するAWSリージョンを指定
  # 省略時: プロバイダー設定のリージョンが使用される
  # 補足:
  #   - CloudHSMが利用可能なリージョンでのみ指定可能
  #   - 明示的に指定することで、プロバイダー設定と異なるリージョンに作成可能
  #   - リージョン間でのクラスタ移動は不可
  region = null # 例: "ap-northeast-1"

  #-----------------------------------------------
  # タグ設定
  #-----------------------------------------------

  # 設定内容: クラスタに付与するタグのキーと値のマップ
  # 補足:
  #   - コスト配分、リソース管理、アクセス制御に使用
  #   - タグはクラスタ自体に適用され、配下のHSMには自動的に継承されない
  tags = {
    Name        = "production-hsm-cluster"
    Environment = "production"
    ManagedBy   = "terraform"
    CostCenter  = "security"
  }

  # 設定内容: プロバイダーのdefault_tagsとリソース固有のtagsをマージしたすべてのタグ
  # 補足:
  #   - 読み取り専用の計算属性
  #   - プロバイダーレベルで設定されたタグが自動的に含まれる
  #   - 通常は明示的に設定する必要はない
  # tags_all = {}

  #-----------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------

  timeouts {
    # 設定内容: クラスタ作成時のタイムアウト時間
    # 省略時: 120分
    # 補足: クラスタの初期化とセキュリティグループの作成に時間がかかる場合がある
    create = "120m"

    # 設定内容: クラスタ更新時のタイムアウト時間
    # 省略時: 120分
    # 補足: タグの更新など軽微な変更の場合は短時間で完了する
    update = "120m"

    # 設定内容: クラスタ削除時のタイムアウト時間
    # 省略時: 120分
    # 補足:
    #   - クラスタ内のすべてのHSMを削除してからクラスタを削除する必要がある
    #   - HSMの削除に時間がかかる場合がある
    delete = "120m"
  }
}

#-----------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------
# このリソースの作成後に参照できる属性:
#
# - id: クラスタID（cluster_idと同じ値）
# - cluster_id: CloudHSM v2クラスタの一意な識別子
# - cluster_state: クラスタの現在の状態（CREATE_IN_PROGRESS, UNINITIALIZED,
#   INITIALIZE_IN_PROGRESS, INITIALIZED, ACTIVE, UPDATE_IN_PROGRESS,
#   DELETE_IN_PROGRESS, DELETED, DEGRADED）
# - vpc_id: クラスタが所属するVPCのID（subnet_idsから自動判定）
# - security_group_id: クラスタ用に自動作成されるセキュリティグループのID
# - cluster_certificates: クラスタの証明書情報を含むリストオブジェクト
#   - cluster_certificate: クラスタ証明書
#   - cluster_csr: クラスタ証明書署名要求
#   - aws_hardware_certificate: AWSハードウェア証明書
#   - hsm_certificate: HSM証明書
#   - manufacturer_hardware_certificate: 製造元ハードウェア証明書
#-----------------------------------------------
