#---------------------------------------------------------------
# Amazon Redshift Event Subscription
#---------------------------------------------------------------
#
# Amazon Redshiftのイベント通知サブスクリプションを管理するリソースです。
# 指定したSNSトピックに対してRedshiftクラスター、スナップショット、
# パラメーターグループ、セキュリティグループなどのイベントを通知します。
#
# AWS公式ドキュメント:
#   https://docs.aws.amazon.com/redshift/latest/mgmt/working-with-event-notifications.html
#
# Terraform Registry:
#   https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/redshift_event_subscription
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_redshift_event_subscription" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # 設定内容: サブスクリプションの名前
  # 設定可能な値: 英数字またはハイフンで構成される一意な名前（最大255文字）
  # 省略時: 必須項目のため省略不可
  name = "my-redshift-event-subscription"

  # 設定内容: イベント通知先のSNSトピックのARN
  # 設定可能な値: 有効なSNSトピックのARN
  # 省略時: 必須項目のため省略不可
  sns_topic_arn = "arn:aws:sns:ap-northeast-1:123456789012:redshift-events"

  #-------------------------------------------------------------
  # フィルター設定
  #-------------------------------------------------------------

  # 設定内容: 通知を受け取るイベントのソースタイプ
  # 設定可能な値:
  #   "cluster"                 - クラスターイベント
  #   "cluster-parameter-group" - パラメーターグループイベント
  #   "cluster-security-group"  - セキュリティグループイベント
  #   "cluster-snapshot"        - スナップショットイベント
  #   "scheduled-action"        - スケジュールアクションイベント
  # 省略時: 全ソースタイプのイベントを通知
  source_type = "cluster"

  # 設定内容: 通知を受け取る特定のソースリソースのIDリスト
  # 設定可能な値: source_typeに応じたリソースIDのリスト
  # 省略時: source_typeに属する全リソースのイベントを通知
  source_ids = ["my-redshift-cluster"]

  # 設定内容: 通知を受け取るイベントカテゴリのセット
  # 設定可能な値（クラスターの場合の例）:
  #   "availability", "backup", "configuration", "deletion",
  #   "failover", "failure", "maintenance", "monitoring",
  #   "notification", "recovery", "restoration", "scaling"
  # 省略時: 全カテゴリのイベントを通知
  event_categories = ["availability", "failure", "maintenance"]

  # 設定内容: 通知を受け取るイベントの重大度
  # 設定可能な値: "INFO"（情報）、"ERROR"（エラー）
  # 省略時: 全重大度のイベントを通知
  severity = "ERROR"

  #-------------------------------------------------------------
  # 有効化設定
  #-------------------------------------------------------------

  # 設定内容: サブスクリプションを有効にするかどうか
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: true（有効）
  enabled = true

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1、us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # 設定内容: リソースに付与するタグのマップ
  # 設定可能な値: キーと値のペアで構成されるマップ（最大50個）
  # 省略時: タグなし
  tags = {
    Name        = "my-redshift-event-subscription"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # 設定内容: リソース作成のタイムアウト時間
    # 設定可能な値: Goのtime.Duration形式（例: "30m"、"1h"）
    # 省略時: デフォルトタイムアウトを使用
    create = "40m"

    # 設定内容: リソース更新のタイムアウト時間
    # 省略時: デフォルトタイムアウトを使用
    update = "40m"

    # 設定内容: リソース削除のタイムアウト時間
    # 省略時: デフォルトタイムアウトを使用
    delete = "40m"
  }
}

#---------------------------------------------------------------
# Attributes Reference（読み取り専用属性）
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: サブスクリプションのARN
# - customer_aws_id: サブスクリプションを所有するAWSアカウントID
# - status: サブスクリプションのステータス
# - tags_all: 継承タグを含む全タグマップ
#---------------------------------------------------------------
