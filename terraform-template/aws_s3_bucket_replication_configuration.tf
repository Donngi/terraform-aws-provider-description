#---------------------------------------------------------------
# AWS S3 Bucket Replication Configuration
#---------------------------------------------------------------
#
# S3バケットのレプリケーション設定をプロビジョニングするリソースです。
# クロスリージョンレプリケーション（CRR）またはセームリージョンレプリケーション（SRR）の
# ルールを管理します。バケット単位で最大1,000件のルールを定義でき、
# プレフィックスやタグ条件による絞り込み、暗号化レプリカ、削除マーカーの
# レプリケーション、レプリケーション時間制御（RTC）などの高度な設定も可能です。
#
# 注意: レプリケーションを有効にするにはソースバケットのバージョニングを
#       有効にする必要があります（aws_s3_bucket_versioning リソースを使用）。
#       また、レプリケーション実行用のIAMロールに適切な権限を付与してください。
#
# AWS公式ドキュメント:
#   - S3 レプリケーション設定:
#     https://docs.aws.amazon.com/AmazonS3/latest/userguide/replication.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/s3_bucket_replication_configuration
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_s3_bucket_replication_configuration" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # bucket (Required)
  # 設定内容: レプリケーション設定を適用するソースS3バケット名を指定します。
  # 設定可能な値: 既存のS3バケット名
  bucket = "example-source-bucket"

  # role (Required)
  # 設定内容: S3がバケット間でオブジェクトをレプリケートするために引き受けるIAMロールのARNを指定します。
  # 設定可能な値: 有効なIAMロールARN（例: arn:aws:iam::123456789012:role/s3-replication-role）
  role = "arn:aws:iam::123456789012:role/s3-replication-role"

  #-------------------------------------------------------------
  # オプション設定
  #-------------------------------------------------------------

  # token (Optional)
  # 設定内容: Batchレプリケーション操作の実行に必要なトークンを指定します。
  #           Organizations内のバケット間でのレプリケーション設定時に必要になる場合があります。
  # 設定可能な値: 任意の文字列
  # 省略時: トークンを使用しない
  token = null

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # レプリケーションルール設定
  #-------------------------------------------------------------

  # rule (Required)
  # 設定内容: レプリケーションルールを定義します。
  #           複数のruleブロックを指定することで複数ルールを管理できます（最大1,000件）。
  rule {
    # id (Optional)
    # 設定内容: ルールを一意に識別するIDを指定します。
    # 設定可能な値: 任意の文字列（最大255文字）
    # 省略時: S3が自動生成
    id = "example-replication-rule"

    # status (Required)
    # 設定内容: このレプリケーションルールを有効にするかどうかを指定します。
    # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
    status = "Enabled"

    # priority (Optional)
    # 設定内容: ルールの優先度を指定します。複数のルールが同一オブジェクトに
    #           一致する場合、優先度の高いルールが適用されます（数値が高いほど優先）。
    # 設定可能な値: 0以上の整数
    # 省略時: 単一ルールのみの場合は不要。複数ルール使用時は設定を推奨
    priority = 1

    # prefix (Optional, Deprecated)
    # 設定内容: レプリケーション対象オブジェクトのキー名プレフィックスを指定します。
    #           非推奨です。代わりにfilterブロック内のprefixを使用してください。
    # 設定可能な値: 任意の文字列
    # 省略時: filterブロックで指定
    # prefix = "logs/"

    #-----------------------------------------------------------
    # フィルター設定
    #-----------------------------------------------------------

    # filter (Optional)
    # 設定内容: レプリケーション対象オブジェクトを絞り込む条件を指定します。
    #           最大1つのブロックを指定できます。
    # 省略時: バケット内の全オブジェクトがレプリケーション対象になります
    filter {
      # prefix (Optional)
      # 設定内容: レプリケーション対象オブジェクトのキー名プレフィックスを指定します。
      # 設定可能な値: 任意の文字列（例: "logs/", "images/"）
      # 省略時: プレフィックスによるフィルタリングなし
      prefix = "logs/"

      # tag (Optional)
      # 設定内容: 単一タグでオブジェクトを絞り込む場合に指定します。
      #           複数条件を組み合わせる場合はandブロックを使用してください。
      # 省略時: タグによるフィルタリングなし
      tag {
        # key (Required)
        # 設定内容: フィルタリング条件のタグキーを指定します。
        # 設定可能な値: 任意の文字列
        key = "environment"

        # value (Required)
        # 設定内容: フィルタリング条件のタグ値を指定します。
        # 設定可能な値: 任意の文字列
        value = "production"
      }

      # and (Optional)
      # 設定内容: 複数のフィルタ条件（プレフィックスとタグ）をAND条件で
      #           組み合わせる場合に使用します。
      # 省略時: 単一条件のフィルタリングを使用
      and {
        # prefix (Optional)
        # 設定内容: AND条件のプレフィックスを指定します。
        # 設定可能な値: 任意の文字列
        # 省略時: プレフィックスによるフィルタリングなし
        prefix = null

        # tags (Optional)
        # 設定内容: AND条件のタグセットをマップ形式で指定します。
        # 設定可能な値: キーと値のペアのマップ
        # 省略時: タグによるフィルタリングなし
        tags = {
          environment = "production"
          department  = "engineering"
        }
      }
    }

    #-----------------------------------------------------------
    # レプリケーション先設定
    #-----------------------------------------------------------

    # destination (Required)
    # 設定内容: レプリケーション先の設定を定義します。
    #           最低1つ、最大1つのブロックを指定します。
    destination {
      # bucket (Required)
      # 設定内容: レプリケーション先バケットのARNを指定します。
      # 設定可能な値: 有効なS3バケットARN（例: arn:aws:s3:::my-destination-bucket）
      bucket = "arn:aws:s3:::example-destination-bucket"

      # account (Optional)
      # 設定内容: レプリケーション先バケットを所有するAWSアカウントIDを指定します。
      #           クロスアカウントレプリケーションの場合に指定します。
      # 設定可能な値: AWSアカウントID（12桁の数字）
      # 省略時: レプリカオブジェクトの所有者はソースオブジェクト所有者と同じになります
      account = null

      # storage_class (Optional)
      # 設定内容: レプリカオブジェクトに適用するストレージクラスを指定します。
      # 設定可能な値:
      #   - "STANDARD": S3 Standard（デフォルト）
      #   - "REDUCED_REDUNDANCY": S3 低冗長化ストレージ（非推奨）
      #   - "STANDARD_IA": S3 Standard-IA
      #   - "ONEZONE_IA": S3 One Zone-IA
      #   - "INTELLIGENT_TIERING": S3 Intelligent-Tiering
      #   - "GLACIER": S3 Glacier Flexible Retrieval
      #   - "DEEP_ARCHIVE": S3 Glacier Deep Archive
      #   - "GLACIER_IR": S3 Glacier Instant Retrieval
      # 省略時: ソースオブジェクトと同じストレージクラスを使用
      storage_class = null

      #---------------------------------------------------------
      # アクセスコントロール変換設定
      #---------------------------------------------------------

      # access_control_translation (Optional)
      # 設定内容: レプリカオブジェクトの所有者をレプリケーション先バケットの
      #           所有者に変更する場合に指定します。クロスアカウントレプリケーションで
      #           必要になります（accountと合わせて使用）。
      # 省略時: オブジェクト所有者の変換なし
      access_control_translation {
        # owner (Required)
        # 設定内容: レプリカオブジェクトの所有者を指定します。
        # 設定可能な値: "Destination"（宛先バケットの所有者に変更）
        owner = "Destination"
      }

      #---------------------------------------------------------
      # レプリカ暗号化設定
      #---------------------------------------------------------

      # encryption_configuration (Optional)
      # 設定内容: SSE-KMSで暗号化されたオブジェクトをレプリケートする際の
      #           暗号化設定を指定します。
      # 省略時: ソースと同じ暗号化設定を使用
      encryption_configuration {
        # replica_kms_key_id (Required)
        # 設定内容: レプリカオブジェクトの暗号化に使用するKMSキーのIDまたはARNを指定します。
        # 設定可能な値: KMSキーID、KMSキーARN、またはKMSエイリアスARN
        replica_kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"
      }

      #---------------------------------------------------------
      # レプリケーションメトリクス設定
      #---------------------------------------------------------

      # metrics (Optional)
      # 設定内容: レプリケーションメトリクスとS3イベント通知を有効化する設定です。
      #           レプリケーション進捗のモニタリングが必要な場合に指定します。
      # 省略時: レプリケーションメトリクスを使用しない
      metrics {
        # status (Required)
        # 設定内容: レプリケーションメトリクスを有効にするかどうかを指定します。
        # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
        status = "Enabled"

        # event_threshold (Optional)
        # 設定内容: レプリケーションが完了しなかった場合にイベント通知を
        #           送信するまでの時間閾値を指定します。
        # 省略時: イベント通知の閾値を設定しない
        event_threshold {
          # minutes (Required)
          # 設定内容: イベント通知を送信するまでの時間を分単位で指定します。
          # 設定可能な値: 15（現時点で15分のみサポート）
          minutes = 15
        }
      }

      #---------------------------------------------------------
      # レプリケーション時間制御設定
      #---------------------------------------------------------

      # replication_time (Optional)
      # 設定内容: S3レプリケーション時間制御（RTC）を有効化する設定です。
      #           対象オブジェクトの99.99%が15分以内にレプリケートされることを保証します。
      # 省略時: レプリケーション時間制御を使用しない
      replication_time {
        # status (Required)
        # 設定内容: レプリケーション時間制御を有効にするかどうかを指定します。
        # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
        status = "Enabled"

        # time (Required)
        # 設定内容: レプリケーション時間の目標値を定義する設定ブロックです。
        time {
          # minutes (Required)
          # 設定内容: レプリケーション時間の目標値を分単位で指定します。
          # 設定可能な値: 15（現時点で15分のみサポート）
          minutes = 15
        }
      }
    }

    #-----------------------------------------------------------
    # 削除マーカーレプリケーション設定
    #-----------------------------------------------------------

    # delete_marker_replication (Optional)
    # 設定内容: 削除マーカーをレプリケーション先にレプリケートするかどうかを指定します。
    #           バージョニング有効バケットで削除されたオブジェクトの削除マーカーを
    #           宛先バケットにも反映させる場合に使用します。
    # 省略時: 削除マーカーはレプリケートされません
    delete_marker_replication {
      # status (Required)
      # 設定内容: 削除マーカーレプリケーションを有効にするかどうかを指定します。
      # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
      status = "Enabled"
    }

    #-----------------------------------------------------------
    # 既存オブジェクトレプリケーション設定
    #-----------------------------------------------------------

    # existing_object_replication (Optional)
    # 設定内容: レプリケーション設定を有効にする前にバケットに存在していた
    #           オブジェクトをレプリケートするかどうかを指定します。
    #           このオプションを使用するにはAWSサポートへの連絡が必要な場合があります。
    # 省略時: 既存オブジェクトはレプリケートされません
    existing_object_replication {
      # status (Required)
      # 設定内容: 既存オブジェクトのレプリケーションを有効にするかどうかを指定します。
      # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
      status = "Enabled"
    }

    #-----------------------------------------------------------
    # ソース選択基準設定
    #-----------------------------------------------------------

    # source_selection_criteria (Optional)
    # 設定内容: レプリケートするオブジェクトを選択する追加基準を指定します。
    # 省略時: 追加の選択基準なし
    source_selection_criteria {

      # sse_kms_encrypted_objects (Optional)
      # 設定内容: SSE-KMSで暗号化されたオブジェクトのレプリケーションを
      #           有効または無効にするための設定ブロックです。
      # 省略時: SSE-KMSオブジェクトのレプリケーション設定なし
      sse_kms_encrypted_objects {
        # status (Required)
        # 設定内容: SSE-KMSで暗号化されたオブジェクトのレプリケーションを
        #           有効にするかどうかを指定します。
        # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
        status = "Enabled"
      }

      # replica_modifications (Optional)
      # 設定内容: レプリカオブジェクトへの変更（メタデータ変更など）を
      #           他のレプリケーション先にレプリケートするかどうかを指定します。
      #           双方向レプリケーション設定時に使用します。
      # 省略時: レプリカへの変更はレプリケートされません
      replica_modifications {
        # status (Required)
        # 設定内容: レプリカの変更レプリケーションを有効にするかどうかを指定します。
        # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
        status = "Enabled"
      }
    }
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: ソースバケット名（bucketの値と同一）
#
#---------------------------------------------------------------
