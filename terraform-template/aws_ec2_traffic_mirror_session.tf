################################################################################
# EC2 Traffic Mirror Session
# AWS Provider Version: 6.28.0
# Generated: 2026-02-15
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_traffic_mirror_session
# NOTE: このテンプレートには全ての利用可能なパラメータが含まれています
################################################################################
# 概要:
#   EC2トラフィックミラーリングセッションを作成・管理します。
#   ネットワークインターフェースからトラフィックをキャプチャし、
#   指定されたミラーターゲットに送信します。
#
# 主な用途:
#   - ネットワークトラフィックの監視と分析
#   - セキュリティ監視とコンプライアンス
#   - トラブルシューティングとパフォーマンス分析
#   - IDS/IPS（侵入検知/防御システム）との統合
#
# 制限事項:
#   - セッション番号は1-32766の範囲内で一意である必要があります
#   - パケット長は指定しない場合、全パケットがキャプチャされます
#   - VXLAN IDは指定しない場合、自動的に割り当てられます
#   - 同一のネットワークインターフェースに複数のセッションを設定可能です
################################################################################

#-----------------------------------------------------------------------
# トラフィックミラーリングセッション設定
#-----------------------------------------------------------------------
resource "aws_ec2_traffic_mirror_session" "this" {
  #-----------------------------------------------------------------------
  # 必須パラメータ
  #-----------------------------------------------------------------------

  # 設定内容: ミラーリング対象のネットワークインターフェースID
  # 設定可能な値: 有効なENI ID（例: eni-1234567890abcdef0）
  network_interface_id = "eni-1234567890abcdef0"

  # 設定内容: セッション番号（ミラーリングセッションの優先順位を決定）
  # 設定可能な値: 1-32766の整数（同一ソースで一意である必要あり）
  session_number = 1

  # 設定内容: 使用するトラフィックミラーフィルターのID
  # 設定可能な値: 有効なトラフィックミラーフィルターID
  traffic_mirror_filter_id = "tmf-1234567890abcdef0"

  # 設定内容: トラフィックの送信先となるミラーターゲットのID
  # 設定可能な値: ネットワークロードバランサーまたはネットワークインターフェースのID
  traffic_mirror_target_id = "tmt-1234567890abcdef0"

  #-----------------------------------------------------------------------
  # パケットキャプチャ設定
  #-----------------------------------------------------------------------

  # 設定内容: キャプチャするパケットの最大長（バイト）
  # 設定可能な値: 1以上の整数
  # 省略時: 全パケット長がキャプチャされます
  packet_length = 1500

  # 設定内容: VXLAN（Virtual eXtensible LAN）ネットワーク識別子
  # 設定可能な値: 1-16777215の整数
  # 省略時: 自動的にVXLAN IDが割り当てられます
  virtual_network_id = 12345

  #-----------------------------------------------------------------------
  # メタデータ設定
  #-----------------------------------------------------------------------

  # 設定内容: トラフィックミラーセッションの説明
  # 設定可能な値: 任意の文字列
  description = "Production VPC traffic monitoring session"

  # 設定内容: リソースのタグ
  # 設定可能な値: キーと値のペアのマップ
  tags = {
    Name        = "prod-traffic-mirror-session"
    Environment = "production"
    Purpose     = "security-monitoring"
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンが使用されます
  region = "ap-northeast-1"
}

################################################################################
# Attributes Reference（参照可能な属性）
################################################################################
# arn               - トラフィックミラーセッションのARN
# id                - トラフィックミラーセッションID
# owner_id          - AWSアカウントID
# tags_all          - デフォルトタグを含む全てのタグ
#
# output "traffic_mirror_session_id" {
#   value = aws_ec2_traffic_mirror_session.this.id
# }
