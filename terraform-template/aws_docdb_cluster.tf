#-----------------------------------------------------------------------
# Terraform AWS DocumentDB Cluster リソーステンプレート
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Resource Type: aws_docdb_cluster
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/docdb_cluster
# Generated: 2026-02-14
#
# NOTE: このテンプレートは実際の使用前に必ず内容を確認・調整してください
#-----------------------------------------------------------------------
# 【概要】
# Amazon DocumentDB (MongoDB互換) クラスターを作成・管理します。
# DocumentDBは完全マネージド型のドキュメントデータベースサービスで、
# MongoDBワークロードに対応し、自動バックアップ、高可用性、
# ストレージ暗号化などのエンタープライズ機能を提供します。
#
# 【主な機能】
# - MongoDBワークロード対応の完全マネージド型ドキュメントデータベース
# - 最大15個のリードレプリカによる高可用性構成
# - 自動バックアップとポイントインタイムリカバリ (1-35日間)
# - AWS KMSによるストレージ暗号化 (AES-256)
# - CloudWatch Logsへの監査ログ・プロファイラログ出力
# - VPC内での安全なネットワーク分離
# - グローバルクラスター対応によるクロスリージョンレプリケーション
#
# 【使用上の注意】
# - クラスター作成後の暗号化設定変更は不可
# - バックアップ保持期間は1-35日の範囲で設定
# - エンジンはdocdbを指定 (MongoDB互換)
# - プロダクション環境ではdeletion_protection有効化を推奨
# - ストレージ暗号化の有効化を強く推奨 (コンプライアンス要件)
#
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_docdb_cluster" "example" {
  # クラスター識別子
  # 設定内容: DocumentDBクラスターの一意な識別子 (小文字英数字とハイフンのみ)
  # 設定可能な値: 1-63文字の小文字英数字またはハイフン、先頭は英字、末尾はハイフンNG
  # 省略時: cluster_identifier_prefixが使用されるか、自動生成される
  cluster_identifier = "docdb-cluster-example"

  # クラスター識別子プレフィックス
  # 設定内容: Terraformによる一意な識別子生成時のプレフィックス
  # 設定可能な値: 小文字英数字とハイフン
  # 省略時: cluster_identifierが優先され、両方未指定時は完全自動生成
  cluster_identifier_prefix = null

  # クラスターメンバー
  # 設定内容: クラスターに属するインスタンスのリスト (手動指定も可能)
  # 設定可能な値: インスタンス識別子のセット
  # 省略時: 自動的にクラスターのインスタンスが設定される
  cluster_members = null

  #-----------------------------------------------------------------------
  # エンジン設定
  #-----------------------------------------------------------------------

  # データベースエンジン
  # 設定内容: DocumentDBエンジンの指定
  # 設定可能な値: docdb (MongoDB互換)
  # 省略時: docdb (デフォルト値)
  engine = "docdb"

  # エンジンバージョン
  # 設定内容: DocumentDBエンジンのバージョン
  # 設定可能な値: 3.6.0, 4.0.0, 5.0.0など (利用可能なバージョンはリージョンにより異なる)
  # 省略時: 最新のデフォルトバージョンが使用される
  engine_version = "5.0.0"

  # メジャーバージョンアップグレード許可
  # 設定内容: メンテナンスウィンドウ中のメジャーバージョンアップグレード許可
  # 設定可能な値: true (許可), false (不許可)
  # 省略時: false
  allow_major_version_upgrade = false

  # 即座に変更を適用
  # 設定内容: 設定変更を即座に適用するか、次回メンテナンスウィンドウで適用するか
  # 設定可能な値: true (即座に適用), false (次回メンテナンスウィンドウで適用)
  # 省略時: false
  apply_immediately = false

  #-----------------------------------------------------------------------
  # 認証設定
  #-----------------------------------------------------------------------

  # マスターユーザー名
  # 設定内容: クラスターのマスターユーザー名
  # 設定可能な値: 1-63文字の英数字、先頭は英字
  # 省略時: エラー (新規作成時は必須)
  master_username = "docdbadmin"

  # マスターパスワード
  # 設定内容: マスターユーザーのパスワード
  # 設定可能な値: 8文字以上、英数字と特定の記号
  # 省略時: manage_master_user_passwordがtrueの場合はSecrets Managerで自動生成
  master_password = "ExamplePassword123!"

  # マスターパスワード自動管理
  # 設定内容: AWS Secrets Managerによるパスワード自動生成・管理
  # 設定可能な値: true (自動管理), false (手動管理)
  # 省略時: false
  manage_master_user_password = false

  # マスターパスワード (書き込み専用)
  # 設定内容: API経由でのみ設定可能な書き込み専用パスワード
  # 設定可能な値: 8文字以上の文字列
  # 省略時: master_passwordが使用される
  master_password_wo = null

  # マスターパスワードバージョン (書き込み専用)
  # 設定内容: master_password_woのバージョン管理用属性
  # 設定可能な値: 数値
  # 省略時: null
  master_password_wo_version = null

  #-----------------------------------------------------------------------
  # ネットワーク設定
  #-----------------------------------------------------------------------

  # アベイラビリティーゾーン
  # 設定内容: クラスターインスタンスを配置するAZ (プライマリインスタンスのAZを優先指定)
  # 設定可能な値: リージョン内の有効なAZ名のリスト
  # 省略時: AWSが自動的にAZを選択
  availability_zones = ["ap-northeast-1a", "ap-northeast-1c", "ap-northeast-1d"]

  # DBサブネットグループ名
  # 設定内容: クラスターインスタンスを配置するサブネットグループ
  # 設定可能な値: 既存のDBサブネットグループ名
  # 省略時: デフォルトVPCのデフォルトサブネットグループ
  db_subnet_group_name = "docdb-subnet-group"

  # VPCセキュリティグループID
  # 設定内容: クラスターに関連付けるセキュリティグループ
  # 設定可能な値: VPCセキュリティグループIDのリスト
  # 省略時: デフォルトVPCセキュリティグループ
  vpc_security_group_ids = ["sg-0123456789abcdef0"]

  # ネットワークタイプ
  # 設定内容: クラスターのネットワークプロトコル
  # 設定可能な値: IPV4 (IPv4のみ), DUAL (IPv4とIPv6)
  # 省略時: IPV4
  network_type = "IPV4"

  # ポート番号
  # 設定内容: DocumentDBクラスターの接続ポート
  # 設定可能な値: 1150-65535の整数
  # 省略時: 27017 (MongoDBデフォルトポート)
  port = 27017

  #-----------------------------------------------------------------------
  # バックアップ設定
  #-----------------------------------------------------------------------

  # バックアップ保持期間
  # 設定内容: 自動バックアップの保持日数 (ポイントインタイムリカバリに使用)
  # 設定可能な値: 1-35日
  # 省略時: 1日
  backup_retention_period = 7

  # 優先バックアップウィンドウ
  # 設定内容: 自動バックアップを実行する時間帯 (UTC)
  # 設定可能な値: hh24:mi-hh24:mi形式 (最低30分間)
  # 省略時: AWSが自動的に8時間のウィンドウを選択
  preferred_backup_window = "17:00-18:00"

  # 最終スナップショット識別子
  # 設定内容: クラスター削除時に作成される最終スナップショットの識別子
  # 設定可能な値: 1-255文字の英数字とハイフン
  # 省略時: skip_final_snapshotがfalseの場合はエラー
  final_snapshot_identifier = "docdb-cluster-final-snapshot"

  # 最終スナップショットスキップ
  # 設定内容: クラスター削除時に最終スナップショットを作成しない
  # 設定可能な値: true (スキップ), false (作成)
  # 省略時: false
  skip_final_snapshot = false

  #-----------------------------------------------------------------------
  # ストレージ設定
  #-----------------------------------------------------------------------

  # ストレージ暗号化
  # 設定内容: ストレージの保存時暗号化 (AES-256)
  # 設定可能な値: true (暗号化), false (非暗号化)
  # 省略時: false
  storage_encrypted = true

  # KMSキーID
  # 設定内容: ストレージ暗号化に使用するKMSキー
  # 設定可能な値: KMSキーID、ARN、エイリアス (対称暗号化キーのみ)
  # 省略時: AWS管理キー (aws/rds) が使用される
  kms_key_id = "arn:aws:kms:ap-northeast-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  # ストレージタイプ
  # 設定内容: クラスターのストレージタイプ
  # 設定可能な値: standard (標準), iopt1 (I/O最適化)
  # 省略時: standard
  storage_type = "standard"

  #-----------------------------------------------------------------------
  # メンテナンス設定
  #-----------------------------------------------------------------------

  # 優先メンテナンスウィンドウ
  # 設定内容: システムメンテナンスを実行する時間帯 (UTC)
  # 設定可能な値: ddd:hh24:mi-ddd:hh24:mi形式 (最低30分間、バックアップウィンドウと重複不可)
  # 省略時: AWSが自動的に8時間のウィンドウを選択
  preferred_maintenance_window = "sun:19:00-sun:20:00"

  #-----------------------------------------------------------------------
  # CloudWatch Logs設定
  #-----------------------------------------------------------------------

  # CloudWatch Logsエクスポート
  # 設定内容: CloudWatch Logsにエクスポートするログタイプ
  # 設定可能な値: audit (監査ログ), profiler (プロファイラログ)
  # 省略時: ログエクスポートなし
  enabled_cloudwatch_logs_exports = ["audit", "profiler"]

  #-----------------------------------------------------------------------
  # 高度な設定
  #-----------------------------------------------------------------------

  # DBクラスターパラメータグループ名
  # 設定内容: クラスターに適用するパラメータグループ
  # 設定可能な値: 既存のクラスターパラメータグループ名
  # 省略時: デフォルトのクラスターパラメータグループ (default.docdb5.0など)
  db_cluster_parameter_group_name = "custom-docdb-params"

  # グローバルクラスター識別子
  # 設定内容: このクラスターを参加させるグローバルクラスターの識別子
  # 設定可能な値: 既存のグローバルクラスター識別子
  # 省略時: グローバルクラスターに参加しない
  global_cluster_identifier = null

  # リージョン
  # 設定内容: クラスターが配置されるリージョン
  # 設定可能な値: AWSリージョン名 (例: ap-northeast-1)
  # 省略時: プロバイダー設定のリージョンが使用される
  region = null

  # スナップショット識別子 (リストア用)
  # 設定内容: クラスター作成時にリストアするスナップショットの識別子
  # 設定可能な値: 既存のスナップショット識別子
  # 省略時: 新規クラスターとして作成
  snapshot_identifier = null

  # 削除保護
  # 設定内容: 誤削除防止のための削除保護
  # 設定可能な値: true (保護有効), false (保護無効)
  # 省略時: false
  deletion_protection = true

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # タグ
  # 設定内容: クラスターに付与するタグ
  # 設定可能な値: キー・バリューペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "docdb-cluster-example"
    Environment = "production"
    ManagedBy   = "Terraform"
  }

  #-----------------------------------------------------------------------
  # Serverless V2スケーリング設定
  #-----------------------------------------------------------------------

  # serverless_v2_scaling_configuration {
  #   # 最小容量
  #   # 設定内容: Serverless V2インスタンスの最小ACU (Amazon Compute Unit)
  #   # 設定可能な値: 0.5-128の範囲
  #   # 省略時: エラー (ブロック使用時は必須)
  #   min_capacity = 0.5
  #
  #   # 最大容量
  #   # 設定内容: Serverless V2インスタンスの最大ACU
  #   # 設定可能な値: 0.5-128の範囲 (min_capacity以上)
  #   # 省略時: エラー (ブロック使用時は必須)
  #   max_capacity = 4.0
  # }

  #-----------------------------------------------------------------------
  # ポイントインタイムリストア設定
  #-----------------------------------------------------------------------

  # restore_to_point_in_time {
  #   # リストア元クラスター識別子
  #   # 設定内容: リストア元となるソースクラスターの識別子
  #   # 設定可能な値: 既存のクラスター識別子
  #   # 省略時: エラー (ブロック使用時は必須)
  #   source_cluster_identifier = "source-docdb-cluster"
  #
  #   # リストアタイプ
  #   # 設定内容: リストアの種類
  #   # 設定可能な値: full-copy (完全コピー), copy-on-write (コピーオンライト)
  #   # 省略時: full-copy
  #   restore_type = "full-copy"
  #
  #   # リストア時刻
  #   # 設定内容: リストアする特定の時刻 (UTC)
  #   # 設定可能な値: RFC3339形式のタイムスタンプ (例: 2026-02-14T10:00:00Z)
  #   # 省略時: use_latest_restorable_timeがtrueの場合は最新時刻が使用される
  #   restore_to_time = "2026-02-14T10:00:00Z"
  #
  #   # 最新リストア可能時刻を使用
  #   # 設定内容: 最新のリストア可能時刻を使用
  #   # 設定可能な値: true (最新時刻), false (restore_to_time使用)
  #   # 省略時: false
  #   use_latest_restorable_time = false
  # }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 作成タイムアウト
  #   # 設定内容: クラスター作成時の最大待機時間
  #   # 設定可能な値: 時間文字列 (例: 120m, 2h)
  #   # 省略時: 120m
  #   create = "120m"
  #
  #   # 更新タイムアウト
  #   # 設定内容: クラスター更新時の最大待機時間
  #   # 設定可能な値: 時間文字列 (例: 120m, 2h)
  #   # 省略時: 120m
  #   update = "120m"
  #
  #   # 削除タイムアウト
  #   # 設定内容: クラスター削除時の最大待機時間
  #   # 設定可能な値: 時間文字列 (例: 120m, 2h)
  #   # 省略時: 120m
  #   delete = "120m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-----------------------------------------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# - arn
#   クラスターのARN
#
# - cluster_resource_id
#   AWSが割り当てるクラスターの一意なリソースID
#
# - cluster_members
#   クラスターに属するインスタンスのリスト
#
# - endpoint
#   クラスターのライターエンドポイント
#
# - reader_endpoint
#   クラスターのリーダーエンドポイント
#
# - hosted_zone_id
#   Route 53ホストゾーンID
#
# - master_user_secret
#   Secrets Manager管理のマスターユーザー認証情報
#-----------------------------------------------------------------------
