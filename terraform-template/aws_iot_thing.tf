resource "aws_iot_thing" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: IoT モノの名前を指定します。
  # 設定可能な値: 1〜128文字の文字列。使用可能な文字: [a-zA-Z0-9:_-]+
  # 注意: 名前はアカウントおよびリージョン内で一意である必要があります。
  #       作成後に名前を変更することはできません（リソースの再作成が必要）。
  name = "example-thing"

  #-------------------------------------------------------------
  # 属性設定
  #-------------------------------------------------------------

  # attributes (Optional)
  # 設定内容: モノに割り当てるカスタム属性のマップを指定します。
  # 設定可能な値: キーと値の文字列ペアのマップ。最大 3 つの属性を定義可能。
  #               キーは最大 128 文字、値は最大 800 文字。
  # 省略時: 属性なし
  # 注意: 属性はデバイスのメタデータとして利用でき、
  #       AWS IoT フリートインデックスサービスで検索可能です。
  attributes = {
    Environment = "production"
    Location    = "Tokyo"
  }

  #-------------------------------------------------------------
  # モノタイプ設定
  #-------------------------------------------------------------

  # thing_type_name (Optional)
  # 設定内容: このモノに割り当てるモノタイプの名前を指定します。
  # 設定可能な値: 既存の aws_iot_thing_type リソースの名前
  # 省略時: モノタイプなし
  # 注意: モノタイプを使用することで、同じカテゴリのデバイスに
  #       共通の属性定義を適用できます。
  #       モノタイプを変更するにはリソースの再作成が必要な場合があります。
  thing_type_name = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理する AWS リージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

