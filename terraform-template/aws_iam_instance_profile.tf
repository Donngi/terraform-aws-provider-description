#
#---------------------------------------------------------------

resource "aws_iam_instance_profile" "example" {
  #-------------------------------------------------------------
  # 名前設定
  #-------------------------------------------------------------

  # name (Optional, Forces new resource)
  # 設定内容: インスタンスプロファイルの名前を指定します。
  # 設定可能な値: 大文字・小文字の英数字および特殊文字 `_`, `+`, `=`, `,`, `.`, `@`, `-` を含む文字列。
  #              スペースは使用不可。
  # 省略時: Terraformがランダムな一意の名前を生成します。
  # 注意: name_prefix と排他的（どちらか一方のみ指定可能）。
  #       path や role の値が異なっていても、既存のインスタンスプロファイルと同じ name を
  #       指定すると EntityAlreadyExists エラーが発生します。
  name = "my-instance-profile"

  # name_prefix (Optional, Forces new resource)
  # 設定内容: インスタンスプロファイル名のプレフィックスを指定します。
  #           Terraformが後ろにランダムな一意のサフィックスを付加して名前を生成します。
  # 設定可能な値: 文字列
  # 注意: name と排他的（どちらか一方のみ指定可能）。
  name_prefix = null

  #-------------------------------------------------------------
  # パス設定
  #-------------------------------------------------------------

  # path (Optional)
  # 設定内容: インスタンスプロファイルのパスを指定します。
  #           IAMリソースを論理的にグループ化するために使用します。
  # 設定可能な値: 先頭と末尾がスラッシュ（/）で始まる文字列、またはスラッシュ（/）単体。
  #              ASCII文字（! \u0021 〜 DEL \u007F）を含められます。
  # 省略時: "/" (ルートパス)
  # 参考: https://docs.aws.amazon.com/IAM/latest/UserGuide/Using_Identifiers.html
  path = "/"

  #-------------------------------------------------------------
  # ロール設定
  #-------------------------------------------------------------

  # role (Optional)
  # 設定内容: インスタンスプロファイルに関連付けるIAMロールの名前を指定します。
  # 設定可能な値: 既存のIAMロール名（ARNではなく名前を指定）
  # 省略時: ロールが関連付けられません。
  # 注意: 1つのインスタンスプロファイルに関連付けられるロールは1つのみです。
  role = "my-iam-role-name"

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "my-instance-profile"
    Environment = "production"
  }
}

