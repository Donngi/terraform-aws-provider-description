#---------------------------------------------------------------
# AWS Location Service Tracker
#---------------------------------------------------------------
#
# Amazon Location Service のトラッカーリソースをプロビジョニングします。
# トラッカーはデバイスの位置情報を保存・管理するサービスであり、
# IoTデバイスや移動するアセットの位置追跡に使用されます。
# 位置データはフィルタリングポリシーに基づいて効率的に保存されます。
#
# AWS公式ドキュメント:
#   - Amazon Location Service トラッカー: https://docs.aws.amazon.com/location/latest/developerguide/geofence-tracker-concepts.html
#   - デバイス位置の追跡: https://docs.aws.amazon.com/location/latest/developerguide/tracking.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/location_tracker
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_location_tracker" "example" {
  #-------------------------------------------------------------
  # トラッカー基本設定
  #-------------------------------------------------------------

  # tracker_name (Required)
  # 設定内容: トラッカーの名前を指定します。
  # 設定可能な値: 1〜100文字の英数字、ハイフン、アンダースコア、ピリオドを含む文字列
  # 省略時: 省略不可
  tracker_name = "example-tracker"

  # description (Optional)
  # 設定内容: トラッカーの説明文を指定します。
  # 設定可能な値: 最大1000文字の文字列
  # 省略時: 説明なしで作成されます。
  description = "Example location tracker for device tracking"

  #-------------------------------------------------------------
  # 位置情報フィルタリング設定
  #-------------------------------------------------------------

  # position_filtering (Optional)
  # 設定内容: デバイス位置情報の更新をフィルタリングする方法を指定します。
  # 設定可能な値:
  #   - "TimeBased"         : 時間ベースのフィルタリング（30秒未満の更新を無視）
  #   - "DistanceBased"     : 距離ベースのフィルタリング（30m未満の移動を無視）
  #   - "AccuracyBased"     : 精度ベースのフィルタリング（位置精度を考慮してフィルタリング）
  # 省略時: "TimeBased" が使用されます。
  position_filtering = "TimeBased"

  #-------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------

  # kms_key_id (Optional)
  # 設定内容: 位置データの暗号化に使用するKMSキーのIDまたはARNを指定します。
  # 設定可能な値: KMSキーID、キーARN、エイリアス名、またはエイリアスARN
  # 省略時: Amazon Location Serviceが管理するキーで暗号化されます。
  # 注意: カスタマー管理キーを使用する場合、キーポリシーでAmazon Location Serviceへのアクセスを許可する必要があります。
  kms_key_id = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしで作成されます。
  # 注意: プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-tracker"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: トラッカーの名前（tracker_name と同じ値）
# - tracker_arn: トラッカーのARN
# - create_time: トラッカーが作成された日時（RFC3339形式）
# - update_time: トラッカーが最後に更新された日時（RFC3339形式）
# - tags_all: プロバイダーの default_tags 設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#---------------------------------------------------------------
