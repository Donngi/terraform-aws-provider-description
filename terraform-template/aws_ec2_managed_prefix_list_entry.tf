#---------------------------------------
# Terraform AWS リソーステンプレート
#---------------------------------------
# リソース: aws_ec2_managed_prefix_list_entry
# 用途: EC2マネージドプレフィックスリストのエントリを管理
#
# 機能:
# - マネージドプレフィックスリストへのCIDRエントリの追加
# - エントリごとの説明文の設定
# - 複数エントリによるプレフィックスリストの構成管理
#
# ユースケース:
# - セキュリティグループルールで使用するIPアドレス範囲の集中管理
# - 複数のリージョンやアカウント間でのIP範囲の共有
# - 頻繁に変更されるIPアドレスリストの一元管理
#
# 注意事項:
# - 1つのプレフィックスリストに追加できるエントリ数には上限がある
# - CIDRブロックの形式は正しいIPv4またはIPv6形式である必要がある
# - エントリの追加・削除はプレフィックスリストのバージョン管理に影響する
#
# Generated: 2026-02-15
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_managed_prefix_list_entry
# Terraform AWS Provider Version: 6.28.0
#
# NOTE:
# このテンプレートはサンプル実装です。
# 実際の環境に合わせて値を調整してください。
#---------------------------------------

#---------------------------------------
# Terraform 設定
#---------------------------------------
terraform {
  required_version = ">= 1.9"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "6.28.0"
    }
  }
}

#---------------------------------------
# Provider 設定
#---------------------------------------
provider "aws" {
  region = "ap-northeast-1" # 東京リージョン

  default_tags {
    tags = {
      Environment = "production"
      ManagedBy   = "terraform"
    }
  }
}

#---------------------------------------
# マネージドプレフィックスリストエントリ
#---------------------------------------
resource "aws_ec2_managed_prefix_list_entry" "example" {
  #---------------------------------------
  # 必須パラメータ
  #---------------------------------------

  # 設定内容: プレフィックスリストに追加するCIDRブロック
  # 設定可能な値: 有効なIPv4またはIPv6のCIDR形式（例: 10.0.0.0/16, 2001:db8::/32）
  cidr = "10.0.1.0/24"

  # 設定内容: エントリが所属するプレフィックスリストのID
  # 設定可能な値: pl-で始まるマネージドプレフィックスリストのID
  prefix_list_id = "pl-0123456789abcdef0"

  #---------------------------------------
  # エントリ情報設定
  #---------------------------------------

  # 設定内容: このエントリの説明文
  # 設定可能な値: 任意の文字列（エントリの用途や関連するサービスを記述）
  # 省略時: 説明なし
  description = "本番環境アプリケーションサーバー用サブネット"

  #---------------------------------------
  # リージョン設定
  #---------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョン識別子（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # region = "ap-northeast-1"
}

#---------------------------------------
# Outputs
#---------------------------------------

# 設定内容: プレフィックスリストエントリのID
output "prefix_list_entry_id" {
  description = "マネージドプレフィックスリストエントリのID"
  value       = aws_ec2_managed_prefix_list_entry.example.id
}

# 設定内容: 設定されたCIDRブロック
output "prefix_list_entry_cidr" {
  description = "プレフィックスリストエントリのCIDRブロック"
  value       = aws_ec2_managed_prefix_list_entry.example.cidr
}

# 設定内容: 所属するプレフィックスリストID
output "prefix_list_id" {
  description = "エントリが所属するプレフィックスリストのID"
  value       = aws_ec2_managed_prefix_list_entry.example.prefix_list_id
}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# このリソースでは以下の属性が参照可能:
#
# - id: プレフィックスリストエントリの一意な識別子
# - cidr: プレフィックスリストに追加されたCIDRブロック
# - description: エントリに設定された説明文
# - prefix_list_id: エントリが所属するプレフィックスリストのID
# - region: リソースが管理されているAWSリージョン
#---------------------------------------
