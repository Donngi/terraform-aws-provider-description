#-----------------------------------------------------------------------
# AWS Storage Gateway File System Association
#
# Storage GatewayとAmazon FSxファイルシステムを関連付けるリソース。
# FSx for Windows File ServerをStorage Gatewayに接続し、
# オンプレミスのアプリケーションからAWS上のファイルシステムに
# シームレスにアクセスできるようにする。
#
# Provider Version: 6.28.0
# Generated: 2026-02-19
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/storagegateway_file_system_association
#
# NOTE: このリソースはFSx for Windows File ServerとStorage Gatewayの
#       両方が事前に設定されていることを前提とする。
#       パスワードはAWS Secrets Managerなどで安全に管理することを推奨する。
#-----------------------------------------------------------------------

resource "aws_storagegateway_file_system_association" "example" {

  #-----------------------------------------------------------------------
  # 基本設定（必須）
  #-----------------------------------------------------------------------

  # 設定内容: 関連付けるStorage GatewayのARN
  # 設定可能な値: Storage GatewayリソースのARN文字列
  gateway_arn = aws_storagegateway_gateway.example.arn

  # 設定内容: 関連付けるAmazon FSxファイルシステムのARN
  # 設定可能な値: FSx for Windows File ServerのARN文字列
  location_arn = aws_fsx_windows_file_system.example.arn

  # 設定内容: FSxファイルシステムへのアクセスに使用するユーザー名
  # 設定可能な値: Active DirectoryのユーザーアカウントのSAMアカウント名
  # 省略時: 設定なし（必須）
  username = "Admin"

  # 設定内容: FSxファイルシステムへのアクセスに使用するパスワード（機密情報）
  # 設定可能な値: Active Directoryのユーザーパスワード文字列
  # 省略時: 設定なし（必須）
  password = var.fsx_password

  #-----------------------------------------------------------------------
  # 監査・ログ設定
  #-----------------------------------------------------------------------

  # 設定内容: ファイルアクセス監査ログの送信先ARN
  # 設定可能な値: CloudWatch LogsグループのARN、または空文字列（無効化）
  # 省略時: 監査ログなし
  audit_destination_arn = aws_cloudwatch_log_group.example.arn

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: "us-east-1", "ap-northeast-1" などAWSリージョン識別子
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  #-----------------------------------------------------------------------
  # キャッシュ設定
  #-----------------------------------------------------------------------

  cache_attributes {
    # 設定内容: キャッシュの古いデータを更新するまでのタイムアウト秒数
    # 設定可能な値: 0～2592000（秒）、0の場合は即時更新
    # 省略時: デフォルト値（Storage Gatewayのデフォルト動作に従う）
    cache_stale_timeout_in_seconds = 300
  }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグのマップ
  # 設定可能な値: キーと値の文字列マップ
  # 省略時: タグなし
  tags = {
    Name = "example-fsx-association"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 設定内容: リソース作成のタイムアウト時間
    # 設定可能な値: "30m", "1h" などの時間文字列
    # 省略時: プロバイダーのデフォルト値
    create = "30m"

    # 設定内容: リソース更新のタイムアウト時間
    # 設定可能な値: "30m", "1h" などの時間文字列
    # 省略時: プロバイダーのデフォルト値
    update = "30m"

    # 設定内容: リソース削除のタイムアウト時間
    # 設定可能な値: "30m", "1h" などの時間文字列
    # 省略時: プロバイダーのデフォルト値
    delete = "30m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#
# id         - ファイルシステム関連付けのARN（arnと同値）
# arn        - ファイルシステム関連付けのAmazon Resource Name (ARN)
# tags_all   - プロバイダーのdefault_tags設定を含む全タグのマップ
#-----------------------------------------------------------------------
