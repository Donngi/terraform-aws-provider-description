resource "aws_m2_deployment" "example" {
  #-------------------------------------------------------------
  # 必須設定 - アプリケーションと環境
  #-------------------------------------------------------------

  # application_id (Required, Forces new resource)
  # 設定内容: デプロイ対象のMainframe Modernizationアプリケーションの
  #           IDを指定します。
  # 設定可能な値: アプリケーションの一意識別子（26文字の英数字）
  # 取得方法: aws_m2_application リソースの id 属性から取得
  # 注意点: 変更すると新しいリソースが作成されます
  application_id = aws_m2_application.example.id

  # environment_id (Required, Forces new resource)
  # 設定内容: アプリケーションをデプロイする実行環境のIDを指定します。
  # 設定可能な値: 環境の一意識別子（26文字の英数字）
  # 取得方法: aws_m2_environment リソースの environment_id 属性から取得
  # 関連機能: M2環境
  #   環境は、コンピューティング、ストレージ、ネットワークなどの
  #   インフラストラクチャリソースを管理します。
  #   - https://docs.aws.amazon.com/m2/latest/userguide/applications-m2-runtime-env.html
  # 注意点: 変更すると新しいリソースが作成されます
  environment_id = aws_m2_environment.example.environment_id

  # application_version (Required, Forces new resource)
  # 設定内容: デプロイするアプリケーションのバージョン番号を指定します。
  # 設定可能な値: 正の整数（1以上）
  # 関連機能: アプリケーションバージョン管理
  #   アプリケーションは複数のバージョンを持つことができ、
  #   各バージョンは異なる設定やコードを含めることができます。
  #   新しいバージョンを作成すると、既存のデプロイメントに
  #   影響を与えることなく、段階的な更新が可能になります。
  # 注意点: 変更すると新しいリソースが作成されます
  application_version = 1

  # start (Required, Forces new resource)
  # 設定内容: デプロイ後にアプリケーションを自動的に開始するかどうかを
  #           指定します。
  # 設定可能な値:
  #   - true: デプロイ完了後、自動的にアプリケーションを開始
  #   - false: デプロイのみ実行し、手動で開始が必要
  # 推奨設定:
  #   - 本番環境: false（デプロイ確認後に手動で開始）
  #   - 開発/テスト環境: true（自動化による効率化）
  # 関連機能: アプリケーションライフサイクル
  #   startをtrueに設定すると、デプロイ後すぐにリクエストを
  #   受け付ける準備が整います。
  # 注意点: 変更すると新しいリソースが作成されます
  start = true

  #-------------------------------------------------------------
  # オプション設定
  #-------------------------------------------------------------

  # force_stop (Optional, Forces new resource)
  # 設定内容: 削除時にアプリケーションを強制停止するかどうかを指定します。
  # 設定可能な値:
  #   - true: 実行中のアプリケーションを強制的に停止してから削除
  #   - false: 実行中の場合、削除前に手動での停止が必要
  # 省略時: false（デフォルト）
  # 推奨設定:
  #   - 本番環境: false（グレースフルシャットダウンを手動で実施）
  #   - 開発/テスト環境: true（迅速なクリーンアップ）
  # 関連機能: リソースクリーンアップ
  #   force_stopをtrueに設定すると、Terraformによる
  #   インフラストラクチャの破棄が自動化されます。
  # 注意点: 変更すると新しいリソースが作成されます
  force_stop = false

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意点: AWS Mainframe Modernizationは一部のリージョンでのみ利用可能です。
  #         利用可能なリージョンについては以下を参照してください。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/m2.html
  region = null

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts ブロック (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  # デプロイメントの作成、更新、削除にかかる時間を設定できます。
  # 大規模なアプリケーションや複雑な環境では、
  # デフォルトのタイムアウトでは不足する場合があります。
  timeouts {
    # create (Optional)
    # 設定内容: デプロイメント作成のタイムアウト時間を指定します。
    # 設定可能な値: 期間を表す文字列（例: "30s", "5m", "2h"）
    # 省略時: プロバイダーのデフォルト値
    # 推奨設定: アプリケーションのサイズと複雑さに応じて調整
    #   - 小規模: "30m"（30分）
    #   - 中規模: "1h"（1時間）
    #   - 大規模: "2h"（2時間）
    create = "1h"

    # update (Optional)
    # 設定内容: デプロイメント更新のタイムアウト時間を指定します。
    # 設定可能な値: 期間を表す文字列（例: "30s", "5m", "2h"）
    # 省略時: プロバイダーのデフォルト値
    # 注意点: 更新操作には新しいバージョンのデプロイと
    #         古いバージョンの停止が含まれる場合があります。
    update = "1h"

    # delete (Optional)
    # 設定内容: デプロイメント削除のタイムアウト時間を指定します。
    # 設定可能な値: 期間を表す文字列（例: "30s", "5m", "2h"）
    # 省略時: プロバイダーのデフォルト値
    # 注意点: force_stopがfalseの場合、実行中のアプリケーションは
    #         事前に停止する必要があります。
    delete = "30m"
  }
}

