#-----------------------------------------------------------------------
# AWS CodeBuild ソース認証情報リソース
#-----------------------------------------------------------------------
# AWS CodeBuild プロジェクトがソースコードリポジトリにアクセスするための
# 認証情報を管理します。GitHub、GitHub Enterprise、GitLab、GitLab Self Managed、
# Bitbucket などのソースプロバイダーに対する認証トークンを保存します。
#
# Provider Version: 6.28.0
# Generated: 2026-02-12
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/codebuild_source_credential
#
# NOTE:
#   - 認証トークンは機密情報のため、変数やSecrets Managerから取得してください
#   - 同じserver_typeに対する認証情報は1つのAWSアカウントに1つのみ設定可能です
#   - Bitbucketの場合はApp PasswordまたはPersonal Access Tokenが必要です
#-----------------------------------------------------------------------

resource "aws_codebuild_source_credential" "example" {

  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  #-----------------------------------------------------------------------
  # auth_type - 認証タイプ（必須）
  #-----------------------------------------------------------------------
  # 設定内容:
  #   - 認証情報で使用する認証タイプを指定します
  # 設定可能な値:
  #   - OAUTH: OAuth認証
  #   - BASIC_AUTH: 基本認証（ユーザー名とパスワード）
  #   - PERSONAL_ACCESS_TOKEN: 個人アクセストークン
  #   - CODECONNECTIONS: AWS CodeConnections接続ARNを使用
  #   - SECRETS_MANAGER: AWS Secrets Managerシークレット使用
  #-----------------------------------------------------------------------
  auth_type = "PERSONAL_ACCESS_TOKEN"

  #-----------------------------------------------------------------------
  # server_type - ソースサーバータイプ（必須）
  #-----------------------------------------------------------------------
  # 設定内容:
  #   - ソースプロバイダーのタイプを指定します
  # 設定可能な値:
  #   - GITHUB: GitHub
  #   - GITHUB_ENTERPRISE: GitHub Enterprise Server
  #   - GITLAB: GitLab.com
  #   - GITLAB_SELF_MANAGED: GitLab Self Managed
  #   - BITBUCKET: Bitbucket Cloud
  #-----------------------------------------------------------------------
  server_type = "GITHUB"

  #-----------------------------------------------------------------------
  # token - 認証トークン（必須）
  #-----------------------------------------------------------------------
  # 設定内容:
  #   - ソースプロバイダーへの認証に使用するトークンを指定します
  #   - この値は機密情報として扱われ、Terraform Stateに暗号化されて保存されます
  # 推奨設定:
  #   - 本番環境ではvariables、AWS Secrets Manager、または環境変数から取得してください
  #   - GitHubの場合: repo、repo:status、admin:repo_hookスコープが必要
  #   - Bitbucketの場合: repository:read、pullrequest:read、webhookスコープが必要
  #   - auth_type=CODECONNECTIONS または SECRETS_MANAGER の場合は接続ARNまたはシークレットARNを指定
  #-----------------------------------------------------------------------
  token = "your-access-token-here" # 実際の運用では変数または Secrets Manager から取得してください

  #-----------------------------------------------------------------------
  # オプション設定
  #-----------------------------------------------------------------------

  #-----------------------------------------------------------------------
  # user_name - ユーザー名（オプション）
  #-----------------------------------------------------------------------
  # 設定内容:
  #   - BASIC_AUTH認証タイプで使用するユーザー名を指定します
  # 省略時:
  #   - 設定されません（BASIC_AUTH以外では不要）
  #-----------------------------------------------------------------------
  user_name = null # "github-username"

  #-----------------------------------------------------------------------
  # region - リージョン（オプション）
  #-----------------------------------------------------------------------
  # 設定内容:
  #   - このリソースを管理するAWSリージョンを指定します
  # 省略時:
  #   - プロバイダー設定のリージョンが使用されます
  #-----------------------------------------------------------------------
  region = null # "us-east-1"

}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソース作成後に参照可能な属性:
#
# - arn - 認証情報のAmazon Resource Name (ARN)
# - id  - 認証情報の一意の識別子（認証トークンのARN）
#-----------------------------------------------------------------------
