resource "aws_memorydb_multi_region_cluster" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # multi_region_cluster_name_suffix (Required)
  # 設定内容: マルチリージョンクラスター名のサフィックスを指定します。
  #           実際のクラスター名は "virxk-<suffix>" の形式で自動生成されます。
  # 設定可能な値: 英小文字・数字・ハイフンから成る文字列
  multi_region_cluster_name_suffix = "example-cluster"

  # node_type (Required)
  # 設定内容: クラスターで使用するノードタイプ（インスタンスタイプ）を指定します。
  # 設定可能な値: "db.r6g.large", "db.r6g.xlarge", "db.r7g.large" 等のMemoryDB対応ノードタイプ
  node_type = "db.r6g.large"

  # description (Optional)
  # 設定内容: マルチリージョンクラスターの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  description = "Example MemoryDB multi-region cluster"

  # engine (Optional)
  # 設定内容: クラスターで使用するキャッシュエンジンの種別を指定します。
  # 設定可能な値: "redis" / "valkey"
  # 省略時: プロバイダーのデフォルト値を使用（computedにより自動設定）
  engine = "redis"

  # engine_version (Optional)
  # 設定内容: クラスターで使用するエンジンのバージョンを指定します。
  # 設定可能な値: エンジンに対応するバージョン文字列（例: "7.1", "7.2"）
  # 省略時: AWSが推奨するデフォルトバージョンを使用（computedにより自動設定）
  engine_version = "7.1"

  #-------------------------------------------------------------
  # クラスター構成設定
  #-------------------------------------------------------------

  # num_shards (Optional)
  # 設定内容: マルチリージョンクラスターのシャード数を指定します。
  # 設定可能な値: 1以上の整数
  # 省略時: AWSが決定するデフォルト値を使用（computedにより自動設定）
  num_shards = 1

  # multi_region_parameter_group_name (Optional)
  # 設定内容: クラスターに適用するマルチリージョンパラメーターグループ名を指定します。
  # 設定可能な値: 既存のMemoryDBマルチリージョンパラメーターグループ名
  # 省略時: AWSが決定するデフォルトパラメーターグループを使用（computedにより自動設定）
  multi_region_parameter_group_name = null

  # tls_enabled (Optional)
  # 設定内容: クラスター内の全ノード間通信にTLS暗号化を有効化するかどうかを指定します。
  # 設定可能な値: true / false
  # 省略時: AWSが決定するデフォルト値を使用（computedにより自動設定）
  tls_enabled = true

  #-------------------------------------------------------------
  # 更新設定
  #-------------------------------------------------------------

  # update_strategy (Optional)
  # 設定内容: クラスターの更新戦略を指定します。
  # 設定可能な値:
  #   - "coordinated": 全メンバークラスターを協調して一括更新
  #   - "uncoordinated": 各メンバークラスターを個別に更新
  # 省略時: デフォルト更新戦略を使用
  update_strategy = "coordinated"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに付与するタグのマップを指定します。
  # 設定可能な値: キーと値がともに文字列のマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-multi-region-cluster"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソース作成の最大待機時間を指定します。
    # 設定可能な値: "30s", "5m", "2h" などの時間文字列（s=秒, m=分, h=時間）
    # 省略時: プロバイダーのデフォルトタイムアウトを使用
    create = "60m"

    # update (Optional)
    # 設定内容: リソース更新の最大待機時間を指定します。
    # 設定可能な値: "30s", "5m", "2h" などの時間文字列（s=秒, m=分, h=時間）
    # 省略時: プロバイダーのデフォルトタイムアウトを使用
    update = "120m"

    # delete (Optional)
    # 設定内容: リソース削除の最大待機時間を指定します。
    # 設定可能な値: "30s", "5m", "2h" などの時間文字列（s=秒, m=分, h=時間）
    # 省略時: プロバイダーのデフォルトタイムアウトを使用
    delete = "60m"
  }
}

