#---------------------------------------------------------------
# AWS S3 Bucket Versioning
#---------------------------------------------------------------
#
# Amazon S3バケットのバージョニング設定をプロビジョニングするリソースです。
# バージョニングを有効にすることで、同一バケット内にオブジェクトの複数バージョンを
# 保持でき、意図しない削除や上書きからデータを保護できます。
#
# AWS公式ドキュメント:
#   - S3バージョニングの仕組み: https://docs.aws.amazon.com/AmazonS3/latest/userguide/versioning-workflows.html
#   - バージョニングの有効化: https://docs.aws.amazon.com/AmazonS3/latest/userguide/manage-versioning-examples.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/s3_bucket_versioning
#
# Provider Version: 6.36.0
# Generated: 2026-03-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_s3_bucket_versioning" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # bucket (Required, Forces new resource)
  # 設定内容: バージョニング設定を適用するS3バケット名を指定します。
  # 設定可能な値: 既存のS3バケット名または aws_s3_bucket リソースのID
  bucket = "example-bucket"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # バケット所有者設定
  #-------------------------------------------------------------

  # expected_bucket_owner (Optional, Forces new resource, 非推奨)
  # 設定内容: バケットの期待される所有者のAWSアカウントIDを指定します。
  # 設定可能な値: 有効な12桁のAWSアカウントID
  # 省略時: バケット所有者の検証を行いません
  # 注意: このパラメータは非推奨（Deprecated）です
  expected_bucket_owner = null

  #-------------------------------------------------------------
  # MFA認証設定
  #-------------------------------------------------------------

  # mfa (Optional)
  # 設定内容: MFA削除が有効な場合に使用する認証デバイスの情報を指定します。
  # 設定可能な値: 認証デバイスのシリアル番号とデバイスに表示されるワンタイムパスワードを
  #               スペースで連結した文字列（例: "arn:aws:iam::123456789012:mfa/user 123456"）
  # 省略時: versioning_configuration の mfa_delete が無効の場合は不要
  # 注意: mfa_delete を "Enabled" に設定する場合は必須
  mfa = null

  #-------------------------------------------------------------
  # バージョニング設定
  #-------------------------------------------------------------

  # versioning_configuration (Required)
  # 設定内容: バージョニングのパラメーターを定義する設定ブロックです。
  # 関連機能: S3バージョニング
  #   同一バケット内に複数バージョンのオブジェクトを保持する機能。
  #   誤削除や意図しない上書きからデータを保護できます。
  #   - https://docs.aws.amazon.com/AmazonS3/latest/userguide/Versioning.html
  versioning_configuration {

    # status (Required)
    # 設定内容: バケットのバージョニング状態を指定します。
    # 設定可能な値:
    #   - "Enabled": バージョニングを有効化。バケット内のすべてのオブジェクトに一意のバージョンIDが付与される
    #   - "Suspended": バージョニングを一時停止。新しいオブジェクトにはバージョンIDが付与されない。既存バージョンは保持
    #   - "Disabled": バージョニングが未設定（一度も有効化されていない）バケットに対応。インポート時や未バージョン化バケット作成時のみ使用
    # 注意: 一度 "Enabled" にすると "Disabled" には戻せません。"Suspended" への変更は可能です。
    # 注意: バージョニングを初めて有効化した場合、AWS はバージョニング有効化後15分間は
    #       PUT/DELETE 操作を行わないことを推奨しています。
    status = "Enabled"

    # mfa_delete (Optional)
    # 設定内容: バージョニング設定でMFA削除を有効にするかどうかを指定します。
    # 設定可能な値:
    #   - "Enabled": MFA削除を有効化。オブジェクトバージョンの削除またはバージョニング状態の変更に
    #                MFA認証が必要になります
    #   - "Disabled": MFA削除を無効化
    # 省略時: "Disabled"（MFA削除は無効）
    # 注意: "Enabled" に設定する場合は、トップレベルの mfa 引数も指定が必要です
    mfa_delete = "Disabled"
  }
}

