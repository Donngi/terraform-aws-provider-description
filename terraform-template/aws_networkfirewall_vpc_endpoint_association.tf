#######################################################################
# Network Firewall VPC Endpoint Association
#######################################################################
# AWS Network Firewallのファイアウォールエンドポイントを管理するリソース。
# aws_networkfirewall_firewallリソースで既にファイアウォールを利用している
# アベイラビリティゾーンに、新しいファイアウォールエンドポイントを追加する際に使用。
#
# 主な用途:
# - 既存ファイアウォールへの追加AZエンドポイントの設定
# - VPCトラフィックのファイアウォール経由ルーティング
# - マルチAZ構成でのネットワークセキュリティ強化
#
# 参考: https://docs.aws.amazon.com/network-firewall/latest/developerguide/vpc-endpoint-associations.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/networkfirewall_vpc_endpoint_association
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_networkfirewall_vpc_endpoint_association" "example" {
  #-----------------------------------------------------------------------
  # ファイアウォール設定
  #-----------------------------------------------------------------------

  # ファイアウォールのARN（必須）
  # 設定内容: エンドポイントを追加するファイアウォールのARN
  # 注意: 指定するファイアウォールはすでに同一VPC内で使用されている必要がある
  firewall_arn = aws_networkfirewall_firewall.example.arn

  # VPC ID（必須）
  # 設定内容: ファイアウォールエンドポイントを配置するVPCのID
  vpc_id = aws_vpc.example.id

  # リソースの説明
  # 設定内容: VPCエンドポイントアソシエーションの説明文
  # 省略時: なし
  description = null

  #-----------------------------------------------------------------------
  # サブネット設定
  #-----------------------------------------------------------------------

  # サブネットマッピング（必須、複数指定可）
  # 設定内容: ファイアウォールエンドポイントを配置するサブネットの設定
  subnet_mapping {
    # サブネットID（必須）
    # 設定内容: エンドポイントを配置するサブネットの一意識別子
    subnet_id = aws_subnet.example.id

    # IPアドレスタイプ
    # 設定内容: サブネットのIPアドレスタイプ
    # 設定可能な値:
    #   - "IPV4": IPv4のみ
    #   - "DUALSTACK": IPv4とIPv6の両方
    # 省略時: プロバイダーが自動設定
    # ip_address_type = "IPV4"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 作成タイムアウト
    # 設定内容: リソース作成時の最大待機時間
    # 設定可能な値: "30s"、"5m"、"2h" などの期間文字列
    # 省略時: プロバイダーデフォルト
    # create = "30m"

    # 削除タイムアウト
    # 設定内容: リソース削除時の最大待機時間
    # 設定可能な値: "30s"、"5m"、"2h" などの期間文字列
    # 省略時: プロバイダーデフォルト
    # delete = "30m"
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = null

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # リソースタグ
  # 設定内容: VPCエンドポイントアソシエーションに付与するタグ（キー・バリューペア）
  # 用途: リソース管理、コスト配分、アクセス制御
  # 注意: プロバイダーのdefault_tagsと重複するキーは上書きされる
  tags = {
    Name        = "example-endpoint-association"
    Environment = "production"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - vpc_endpoint_association_id
#   VPCエンドポイントアソシエーションの一意識別子
#
# - vpc_endpoint_association_arn
#   VPCエンドポイントアソシエーションのARN
#
# - vpc_endpoint_association_status
#   アソシエーションの現在のステータス情報
#   - association_sync_state: サブネットごとの同期状態
#     - attachment.endpoint_id: VPCエンドポイントの識別子
#     - attachment.subnet_id: サブネットの一意識別子
#     - availability_zone: サブネットが属するAZ
#
# - tags_all
#   リソースに割り当てられたすべてのタグ
#   （プロバイダーのdefault_tagsから継承されたタグを含む）
#-----------------------------------------------------------------------
