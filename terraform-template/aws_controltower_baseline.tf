#---------------------------------------------------------------
# AWS Control Tower ベースライン
#---------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/controltower_baseline
# NOTE: 必須パラメータは実際の環境に合わせて設定してください
#---------------------------------------------------------------

# 【AWS Control Towerとは】
# AWS Control Towerは、マルチアカウントAWS環境のセットアップと
# ガバナンス管理を自動化するサービスです。
# ベースラインは組織単位(OU)またはアカウントに適用される
# セキュリティ・コンプライアンスの基準設定です。

# 【ベースラインの種類】
# - AWSControlTowerBaseline: 標準ベースライン（ガードレール、ログアーカイブ等）
# - LandingZoneConfiguration: ランディングゾーン設定
# - IdentityCenterBaseline: Identity Center統合設定

# 【主な用途】
# - 新規OUへのガバナンスポリシー適用
# - 既存アカウントへのセキュリティベースライン展開
# - 組織全体の統一されたコンプライアンス設定
# - ログ集約とセキュリティアカウント構成

#---------------------------------------------------------------
# 基本設定
#---------------------------------------------------------------

resource "aws_controltower_baseline" "example" {
  # ベースライン識別子
  # 設定内容: 適用するベースラインのARNまたは識別子
  # 設定可能な値: AWS提供のベースライン識別子（arn:aws:controltower:リージョン::baseline/ベースライン名）
  # 例: arn:aws:controltower:us-east-1::baseline/AWSControlTowerBaseline
  baseline_identifier = "arn:aws:controltower:us-east-1::baseline/AWSControlTowerBaseline"

  # ベースラインバージョン
  # 設定内容: 適用するベースラインのバージョン
  # 設定可能な値: セマンティックバージョニング形式（例: 1.0, 2.1, 3.0）
  # 補足: 最新バージョンの使用を推奨、バージョン変更時は影響範囲を確認
  baseline_version = "1.0"

  # ターゲット識別子
  # 設定内容: ベースラインを適用する対象のARN
  # 設定可能な値: OU ARN（arn:aws:organizations::アカウントID:ou/o-組織ID/ou-OUID）
  #              またはアカウントARN（arn:aws:organizations::アカウントID:account/o-組織ID/アカウントID）
  # 補足: OU指定時は配下の全アカウントに適用される
  target_identifier = "arn:aws:organizations::123456789012:ou/o-abc123/ou-xyz123"

  #---------------------------------------------------------------
  # パラメータ設定（ベースライン固有）
  #---------------------------------------------------------------

  # ベースライン固有のパラメータ
  # 設定内容: ベースラインの動作をカスタマイズするキー・バリューペア
  # 省略時: ベースラインのデフォルト設定が適用される
  parameters {
    # パラメータキー
    # 設定内容: ベースラインが受け付けるパラメータ名
    # 設定可能な値: ベースラインドキュメントに記載されたパラメータ名
    # 例: LogArchiveAccountId, AuditAccountId, LogRetentionDays等
    key = "LogArchiveAccountId"

    # パラメータ値
    # 設定内容: パラメータに対する設定値
    # 設定可能な値: パラメータのデータ型に応じた値（文字列形式）
    # 補足: アカウントIDやARN、数値などを文字列として指定
    value = "123456789012"
  }

  parameters {
    key   = "AuditAccountId"
    value = "123456789013"
  }

  #---------------------------------------------------------------
  # リージョン設定
  #---------------------------------------------------------------

  # 管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（us-east-1, ap-northeast-1等）
  # 省略時: プロバイダー設定のリージョンが使用される
  # 補足: Control Towerは特定のリージョンでのみ利用可能
  region = "us-east-1"

  #---------------------------------------------------------------
  # タグ設定
  #---------------------------------------------------------------

  # リソースタグ
  # 設定内容: ベースラインに付与するタグのマップ
  # 設定可能な値: キー・バリュー形式のマップ（最大50タグ）
  # 省略時: タグなし
  # 用途: コスト配分、リソース管理、コンプライアンス追跡
  tags = {
    Environment = "production"
    ManagedBy   = "terraform"
    Purpose     = "governance-baseline"
  }

  #---------------------------------------------------------------
  # タイムアウト設定
  #---------------------------------------------------------------

  # タイムアウト
  # 設定内容: ベースライン操作の最大待機時間
  # 省略時: デフォルトタイムアウト（create/update: 60分、delete: 30分）
  # 補足: 大規模OUへの適用は時間がかかる場合があるため調整推奨
  timeouts {
    # 作成タイムアウト
    # 設定内容: ベースライン適用完了までの最大待機時間
    # 設定可能な値: 時間文字列（例: "30m", "1h", "90m"）
    # create = "90m"

    # 更新タイムアウト
    # 設定内容: ベースライン更新完了までの最大待機時間
    # 設定可能な値: 時間文字列（例: "30m", "1h", "90m"）
    # update = "90m"

    # 削除タイムアウト
    # 設定内容: ベースライン削除完了までの最大待機時間
    # 設定可能な値: 時間文字列（例: "30m", "1h", "60m"）
    # delete = "60m"
  }
}

#---------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------------------------------

# arn - ベースラインリソースのARN
# 用途: 他リソースからの参照、IAMポリシー条件等
# 例: arn:aws:controltower:us-east-1:123456789012:baseline/baseline-abc123

# operation_identifier - ベースライン操作の一意識別子
# 用途: 操作の追跡、ログ分析、トラブルシューティング
# 形式: UUID形式の文字列

# tags_all - デフォルトタグとリソースタグを統合したマップ
# 用途: プロバイダーレベルのタグを含む完全なタグセット参照

#---------------------------------------------------------------
# 出力例
#---------------------------------------------------------------

