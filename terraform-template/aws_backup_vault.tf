#---------------------------------------------------------------
# AWS Backup Vault
#---------------------------------------------------------------
#
# AWS Backupのバックアップボールトをプロビジョニングするリソースです。
# バックアップボールトは、バックアップを保存・整理するためのコンテナです。
# ボールト作成時にAWS KMS暗号化キーを指定し、一部のバックアップを暗号化します。
#
# AWS公式ドキュメント:
#   - AWS Backupとは: https://docs.aws.amazon.com/aws-backup/latest/devguide/whatisbackup.html
#   - バックアップボールト: https://docs.aws.amazon.com/aws-backup/latest/devguide/vaults.html
#   - バックアップの暗号化: https://docs.aws.amazon.com/aws-backup/latest/devguide/encryption.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/backup_vault
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_backup_vault" "example" {
  #-------------------------------------------------------------
  # 名前設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: バックアップボールトの名前を指定します。
  # 設定可能な値: 2〜50文字の英数字、ハイフン、アンダースコア
  # 注意: AWSリージョン内で一意である必要があります。
  name = "example-backup-vault"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------

  # kms_key_arn (Optional)
  # 設定内容: バックアップを保護するためのサーバーサイド暗号化キーを指定します。
  # 設定可能な値: 有効なKMSキーARN
  # 省略時: AWS管理のKMSキー（aws/backup）が使用されます。
  # 関連機能: AWS Backup 暗号化
  #   バックアップボールトに保存されるバックアップはKMSキーで暗号化されます。
  #   一部のリソースタイプ（S3、DynamoDB with Advanced Backup、EFS、VMware VM等）は
  #   ボールトのKMSキーで独立した暗号化が可能です。その他のリソースタイプは
  #   ソースリソースの暗号化設定を継承します。
  #   - https://docs.aws.amazon.com/aws-backup/latest/devguide/encryption.html
  kms_key_arn = "arn:aws:kms:ap-northeast-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #-------------------------------------------------------------
  # 削除設定
  #-------------------------------------------------------------

  # force_destroy (Optional)
  # 設定内容: ボールト削除時に保存されているすべてのリカバリポイントを削除するかを指定します。
  # 設定可能な値:
  #   - true: ボールト削除時にすべてのリカバリポイントを削除
  #   - false (デフォルト): リカバリポイントが残っている場合、ボールト削除はエラーになる
  # 注意: 本番環境では false を推奨。trueにすると、terraform destroy時に
  #       すべてのバックアップが削除されます。
  force_destroy = false

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-backup-vault"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {
    # delete (Optional)
    # 設定内容: ボールト削除操作のタイムアウト時間
    # 設定可能な値: 時間を表す文字列（例: "10m", "1h"）
    # 省略時: デフォルトのタイムアウト値が使用されます
    # 注意: force_destroy = true の場合、リカバリポイントの削除に
    #       時間がかかる可能性があるため、適切な値を設定してください。
    delete = "10m"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: ボールトの名前
#
# - arn: バックアップボールトのAmazon Resource Name (ARN)
#
# - recovery_points: ボールトに保存されているリカバリポイントの数
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
