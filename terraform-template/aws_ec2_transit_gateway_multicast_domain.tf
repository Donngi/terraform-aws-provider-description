#-----------------------------------------------------------------------
# AWS EC2 Transit Gateway Multicast Domain
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Resource Type: aws_ec2_transit_gateway_multicast_domain
# Generated: 2026-02-15
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_transit_gateway_multicast_domain
#
# 用途: Transit Gatewayでマルチキャストトラフィックを処理するマルチキャストドメインを作成
#
# マルチキャストドメインは、マルチキャストネットワークをセグメント化し、
# 特定のサブネットをマルチキャストグループに関連付けることができます。
# IGMPv2プロトコルまたは静的ソース設定をサポートします。
#
# NOTE: Transit Gatewayがavailable状態である必要があります
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# マルチキャストドメイン
#-----------------------------------------------------------------------
resource "aws_ec2_transit_gateway_multicast_domain" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------
  # 設定内容: このマルチキャストドメインを作成するTransit GatewayのID
  # 設定可能な値: Transit GatewayのID（tgw-xxxxxxxxxxxxxxxxx形式）
  transit_gateway_id = "tgw-0123456789abcdef0"

  #-----------------------------------------------------------------------
  # マルチキャストプロトコル設定
  #-----------------------------------------------------------------------
  # 設定内容: IGMPv2プロトコルのサポートを有効化するかどうか
  # 設定可能な値: enable, disable
  # 省略時: enable
  # 補足: enableにすると、グループメンバーがIGMP JOINおよびLEAVEメッセージを使用して
  #       マルチキャストグループに参加・離脱できます
  igmpv2_support = "enable"

  # 設定内容: 静的マルチキャストソースのサポートを有効化するかどうか
  # 設定可能な値: enable, disable
  # 省略時: disable
  # 補足: enableにすると、マルチキャストソースを手動で追加する必要があります
  static_sources_support = "disable"

  #-----------------------------------------------------------------------
  # 共有設定
  #-----------------------------------------------------------------------
  # 設定内容: クロスアカウントのサブネット関連付けを自動的に受け入れるかどうか
  # 設定可能な値: enable, disable
  # 省略時: enable
  auto_accept_shared_associations = "enable"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（us-east-1, ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョン
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  tags = {
    Name        = "example-multicast-domain"
    Environment = "production"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------
  timeouts {
    # 設定内容: マルチキャストドメインの作成タイムアウト時間
    # 設定可能な値: 時間文字列（例: "10m", "1h"）
    # 省略時: 10m
    create = "10m"

    # 設定内容: マルチキャストドメインの削除タイムアウト時間
    # 設定可能な値: 時間文字列（例: "10m", "1h"）
    # 省略時: 10m
    delete = "10m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# arn - マルチキャストドメインのARN
# id - マルチキャストドメインのID
# owner_id - マルチキャストドメインを所有するAWSアカウントID
# region - マルチキャストドメインが作成されたリージョン
# tags_all - リソースに割り当てられたすべてのタグ
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 補足事項
#-----------------------------------------------------------------------
# IGMPv2とStatic Sources設定の組み合わせ:
# - IGMPドメイン: igmpv2_support = "enable", static_sources_support = "disable"
# - 静的ソースドメイン: igmpv2_support = "disable", static_sources_support = "enable"
#
# マルチキャストドメイン作成後は、サブネットをドメインに関連付け、
# マルチキャストグループにメンバーとソースを登録する必要があります。
#-----------------------------------------------------------------------
