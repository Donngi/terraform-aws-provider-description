#---------------------------------------------------------------
# AWS Athena Named Query
#---------------------------------------------------------------
#
# Amazon Athenaの名前付きクエリ（保存済みクエリ）をプロビジョニングするリソースです。
# 名前付きクエリは、頻繁に使用するSQLクエリを保存し、後で再利用できるようにする機能です。
# ワークグループ内で管理され、クエリエディタから簡単にアクセスできます。
#
# AWS公式ドキュメント:
#   - Athena保存済みクエリ: https://docs.aws.amazon.com/athena/latest/ug/saved-queries.html
#   - クエリに名前を付けて保存: https://docs.aws.amazon.com/athena/latest/ug/saved-queries-name.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/athena_named_query
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_athena_named_query" "example" {
  #-------------------------------------------------------------
  # 基本設定（必須）
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: 名前付きクエリの名前を指定します。
  # 設定可能な値: 最大128文字の文字列
  # 注意: クエリエディタの「保存済みクエリ」タブに表示される名前です。
  name = "example-query"

  # database (Required)
  # 設定内容: クエリが属するデータベース名を指定します。
  # 設定可能な値: Athenaで作成済みのデータベース名
  # 注意: クエリの実行時にこのデータベースがデフォルトのコンテキストとして使用されます。
  #       データベースは後から変更できません。
  database = "my_database"

  # query (Required)
  # 設定内容: クエリのSQL文を指定します。
  # 設定可能な値: 最大262144文字のSQL文
  # 注意: すべてのクエリステートメントを含むテキストです。
  query = "SELECT * FROM my_table LIMIT 10;"

  #-------------------------------------------------------------
  # オプション設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: クエリの簡単な説明を指定します。
  # 設定可能な値: 最大1024文字の文字列
  # 省略時: 説明なし
  # 用途: クエリの目的や使用方法を記録するのに便利です。
  description = "サンプルテーブルから10件のレコードを取得するクエリ"

  # workgroup (Optional)
  # 設定内容: クエリが属するワークグループを指定します。
  # 設定可能な値: Athenaで作成済みのワークグループ名
  # 省略時: "primary"（デフォルトワークグループ）
  # 関連機能: Athenaワークグループ
  #   ワークグループは、クエリの実行設定（結果の保存先、暗号化設定など）を
  #   グループ単位で管理する機能です。クエリのコスト管理やアクセス制御にも使用されます。
  #   - https://docs.aws.amazon.com/athena/latest/ug/workgroups.html
  # 注意: ワークグループは後から変更できません。
  workgroup = "primary"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

