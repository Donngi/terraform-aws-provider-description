################################################################################
# AWS FinSpace Kx Volume
################################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# FinSpace Kx環境内のストレージボリュームを管理するリソース。
# NAS_1タイプのネットワーク接続ストレージをサポートし、
# Kxクラスタからアクセス可能な共有ストレージを提供します。
#
# 主な用途:
# - FinSpace Kx環境用の共有ストレージ作成
# - 金融データ分析用の高性能ストレージ提供
# - クラスタ間でのデータ共有基盤構築
#
# 制約事項:
# - 現在はNAS_1ボリュームタイプのみサポート
# - SINGLE AZモードのみ利用可能
# - ボリューム作成後の一部設定変更は再作成が必要
#
# NOTE: 本テンプレートは実装例として提供されています。
# 実際の利用時には環境に応じて適切な値を設定してください。
#
# 参考: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/finspace_kx_volume

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_finspace_kx_volume" "example" {
  # 設定内容: ボリュームの一意な名前
  # 設定可能な値: 1-63文字の英数字、ハイフン
  name = "my-tf-kx-volume"

  # 設定内容: ボリュームを作成するKx環境のID
  # 設定可能な値: aws_finspace_kx_environment.*.id
  environment_id = "kx-environment-id"

  # 設定内容: ボリュームタイプの指定
  # 設定可能な値: NAS_1（現在サポートされている唯一のタイプ）
  type = "NAS_1"

  #-----------------------------------------------------------------------
  # アベイラビリティゾーン設定
  #-----------------------------------------------------------------------

  # 設定内容: ボリュームを配置するAZのモード
  # 設定可能な値: SINGLE（現在サポートされている唯一のモード）
  az_mode = "SINGLE"

  # 設定内容: ボリュームを配置するAZのID
  # 設定可能な値: ["use1-az2"]等のAZ識別子リスト
  availability_zones = ["use1-az2"]

  #-----------------------------------------------------------------------
  # ボリューム詳細設定
  #-----------------------------------------------------------------------

  # 設定内容: ボリュームの説明
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  description = "Volume for financial data analysis"

  #-----------------------------------------------------------------------
  # NAS設定
  #-----------------------------------------------------------------------

  # NAS_1タイプボリュームの設定
  # typeがNAS_1の場合は必須
  nas1_configuration {
    # 設定内容: ネットワーク接続ストレージのサイズ
    # 設定可能な値: 1200以上の整数（GB単位）
    size = 1200

    # 設定内容: ネットワーク接続ストレージのタイプ
    # 設定可能な値: SSD_250, SSD_1000, HDD_12
    type = "SSD_250"
  }

  #-----------------------------------------------------------------------
  # リソース管理設定
  #-----------------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: us-east-1, us-west-2等のリージョンコード
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: ボリュームに付与するタグ（最大50個）
  # 設定可能な値: キーと値のマップ
  # 省略時: タグなし
  tags = {
    Name        = "my-kx-volume"
    Environment = "production"
    Project     = "financial-analytics"
  }
}

#-----------------------------------------------------------------------
# タイムアウト設定
#-----------------------------------------------------------------------

# ボリューム作成・更新・削除時のタイムアウト設定
# 大容量ボリュームの場合は適宜調整が必要
# timeouts {
#   create = "30m"
#   update = "30m"
#   delete = "30m"
# }

################################################################################
# Attributes Reference
################################################################################
# このリソースから参照可能な属性:
#
# - id: ボリュームの一意な識別子
# - arn: ボリュームのARN
# - status: ボリュームのステータス（CREATING, ACTIVE, UPDATING等）
# - status_reason: 失敗時のエラーメッセージ
# - created_timestamp: ボリューム作成時刻（エポックミリ秒）
# - last_modified_timestamp: 最終更新時刻（エポック秒）
# - attached_clusters: アタッチされているクラスタのリスト
#   - cluster_name: クラスタ名
#   - cluster_type: クラスタタイプ
#   - cluster_status: クラスタステータス
# - tags_all: プロバイダー設定のdefault_tagsとマージされた全タグ
