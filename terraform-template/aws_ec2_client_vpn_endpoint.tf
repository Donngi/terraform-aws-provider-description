#---------------------------------------------------------------
# AWS EC2 Client VPN Endpoint
#---------------------------------------------------------------
#
# EC2 Client VPN エンドポイントをプロビジョニングします。
# AWS Client VPN は、AWS リソースや社内ネットワークへの安全なアクセスを
# 提供するマネージド型クライアントベースの VPN サービスです。
#
# AWS公式ドキュメント:
#   - AWS Client VPN: https://docs.aws.amazon.com/vpn/latest/clientvpn-admin/what-is.html
#   - Client VPN Endpoints: https://docs.aws.amazon.com/vpn/latest/clientvpn-admin/cvpn-working-endpoints.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_client_vpn_endpoint
#
# Provider Version: 6.28.0
# Generated: 2026-01-26
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_ec2_client_vpn_endpoint" "example" {
  #---------------------------------------------------------------
  # 必須パラメータ
  #---------------------------------------------------------------

  # サーバー証明書のARN (必須)
  # Client VPN エンドポイントがクライアントとのTLS接続を確立するために使用する
  # ACM (AWS Certificate Manager) のサーバー証明書ARNを指定します。
  server_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012"

  #---------------------------------------------------------------
  # 任意パラメータ - ネットワーク設定
  #---------------------------------------------------------------

  # クライアントCIDRブロック (任意)
  # VPN クライアントに割り当てるIPアドレス範囲を指定します。
  # /12 以上 /22 以下のサイズで、VPC CIDRと重複しない範囲を指定する必要があります。
  client_cidr_block = "10.0.0.0/16"

  # VPC ID (任意)
  # Client VPN エンドポイントを関連付けるVPCのIDを指定します。
  vpc_id = null

  # セキュリティグループID (任意)
  # Client VPN エンドポイントに適用するセキュリティグループのIDリストを指定します。
  security_group_ids = []

  # DNSサーバー (任意)
  # クライアントが使用するDNSサーバーのIPアドレスリストを指定します。
  # 最大2つまで指定可能です。
  dns_servers = []

  # エンドポイントIPアドレスタイプ (任意)
  # Client VPN エンドポイントのIPアドレスタイプを指定します。
  # 有効な値: "ipv4" (デフォルト), "ipv6", "dualstack"
  endpoint_ip_address_type = null

  # トラフィックIPアドレスタイプ (任意)
  # VPN トラフィックに使用するIPアドレスタイプを指定します。
  # 有効な値: "ipv4" (デフォルト), "ipv6", "dualstack"
  traffic_ip_address_type = null

  #---------------------------------------------------------------
  # 任意パラメータ - VPN設定
  #---------------------------------------------------------------

  # トランスポートプロトコル (任意)
  # VPN接続に使用するトランスポートプロトコルを指定します。
  # 有効な値: "udp" (デフォルト), "tcp"
  transport_protocol = "udp"

  # VPNポート (任意)
  # Client VPN エンドポイントがリッスンするポート番号を指定します。
  # デフォルト: UDPの場合は1194、TCPの場合は443
  vpn_port = null

  # スプリットトンネル (任意)
  # スプリットトンネルを有効にするかどうかを指定します。
  # true: VPN経由でルーティングされないトラフィックはローカルネットワーク経由
  # false: すべてのトラフィックがVPN経由でルーティング
  split_tunnel = false

  #---------------------------------------------------------------
  # 任意パラメータ - セッション設定
  #---------------------------------------------------------------

  # セッションタイムアウト時間 (任意)
  # VPNセッションの最大継続時間を時間単位で指定します。
  # 有効な値: 8, 10, 12, 24 (デフォルト)
  session_timeout_hours = 24

  # セッションタイムアウト時の切断 (任意)
  # セッションタイムアウト時にクライアントを切断するかどうかを指定します。
  disconnect_on_session_timeout = false

  #---------------------------------------------------------------
  # 任意パラメータ - セルフサービスポータル
  #---------------------------------------------------------------

  # セルフサービスポータル (任意)
  # セルフサービスポータルを有効にするかどうかを指定します。
  # 有効な値: "enabled" (デフォルト), "disabled"
  self_service_portal = "enabled"

  #---------------------------------------------------------------
  # 任意パラメータ - その他
  #---------------------------------------------------------------

  # 説明 (任意)
  # Client VPN エンドポイントの説明文を指定します。
  description = "Example Client VPN Endpoint"

  # リージョン (任意)
  # エンドポイントを作成するAWSリージョンを指定します。
  region = null

  # ID (任意)
  # リソースのID。通常は自動生成されますが、インポート時に使用できます。
  id = null

  # タグ (任意)
  # リソースに付与するタグのマップを指定します。
  tags = {
    Name        = "example-client-vpn-endpoint"
    Environment = "production"
  }

  # タグ（全て） (任意)
  # デフォルトタグを含むすべてのタグ。
  tags_all = null

  #---------------------------------------------------------------
  # 認証オプション (必須ブロック)
  #---------------------------------------------------------------
  # Client VPN の認証方法を設定します。
  # 最小1つ、最大2つまで指定可能です。

  authentication_options {
    # 認証タイプ (必須)
    # 有効な値: "certificate-authentication", "directory-service-authentication", "federated-authentication"
    type = "certificate-authentication"

    # ルート証明書チェーンARN (任意)
    # 証明書ベース認証の場合に使用します。
    root_certificate_chain_arn = "arn:aws:acm:us-east-1:123456789012:certificate/87654321-4321-4321-4321-210987654321"

    # Active Directory ID (任意)
    # ディレクトリサービス認証の場合に使用します。
    active_directory_id = null

    # SAML プロバイダーARN (任意)
    # フェデレーション認証の場合に使用します。
    saml_provider_arn = null

    # セルフサービスSAMLプロバイダーARN (任意)
    self_service_saml_provider_arn = null
  }

  #---------------------------------------------------------------
  # 接続ログオプション (必須ブロック)
  #---------------------------------------------------------------
  # Client VPN の接続ログ設定を構成します。

  connection_log_options {
    # 有効化 (必須)
    enabled = true

    # CloudWatch ロググループ (任意)
    cloudwatch_log_group = "/aws/clientvpn/example"

    # CloudWatch ログストリーム (任意・計算値)
    cloudwatch_log_stream = null
  }

  #---------------------------------------------------------------
  # クライアント接続オプション (任意ブロック)
  #---------------------------------------------------------------
  # Lambda関数を使用したカスタム接続ハンドラーを設定します。

  client_connect_options {
    # 有効化 (任意・計算値)
    enabled = false

    # Lambda関数ARN (任意・計算値)
    lambda_function_arn = null
  }

  #---------------------------------------------------------------
  # クライアントログインバナーオプション (任意ブロック)
  #---------------------------------------------------------------
  # VPN接続時にクライアントに表示するバナーテキストを設定します。

  client_login_banner_options {
    # 有効化 (任意・計算値)
    enabled = false

    # バナーテキスト (任意・計算値)
    banner_text = null
  }

  #---------------------------------------------------------------
  # クライアントルート強制オプション (任意ブロック)
  #---------------------------------------------------------------

  client_route_enforcement_options {
    # 強制 (任意・計算値)
    enforced = false
  }
}

#---------------------------------------------------------------
# Attributes Reference
#---------------------------------------------------------------
# このリソースは以下の属性を出力します（computed値）:
#
# - arn: Client VPN エンドポイントのARN
# - dns_name: Client VPN エンドポイントのDNS名
# - self_service_portal_url: セルフサービスポータルのURL
#---------------------------------------------------------------
