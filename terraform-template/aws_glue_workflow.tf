resource "aws_glue_workflow" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: ワークフローに割り当てる名前を指定します。
  # 設定可能な値: 1文字以上の文字列
  name = "example-glue-workflow"

  # description (Optional)
  # 設定内容: ワークフローの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  description = "ETLパイプラインのワークフロー"

  #-------------------------------------------------------------
  # 実行制御設定
  #-------------------------------------------------------------

  # max_concurrent_runs (Optional)
  # 設定内容: コンポーネントジョブの同時実行数の上限を指定します。
  #           この設定はワークフロー内のすべてのジョブに適用されます。
  # 設定可能な値: 正の整数
  # 省略時: 同時実行数に制限を設けません（無制限）
  max_concurrent_runs = 1

  #-------------------------------------------------------------
  # ランタイムプロパティ設定
  #-------------------------------------------------------------

  # default_run_properties (Optional)
  # 設定内容: ワークフローに関連するすべてのジョブに渡されるデフォルトの
  #           実行プロパティのマップを指定します。
  # 設定可能な値: 文字列キーと文字列値のマップ
  # 省略時: デフォルトのランタイムプロパティなし
  # 参考: https://docs.aws.amazon.com/glue/latest/dg/workflows_overview.html
  default_run_properties = {
    "ENVIRONMENT" = "production"
    "LOG_LEVEL"   = "INFO"
  }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 注意: プロバイダーのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-glue-workflow"
    Environment = "production"
    ManagedBy   = "terraform"
  }
}

