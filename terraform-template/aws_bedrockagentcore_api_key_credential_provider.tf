#----------------------------------------------------------------------
# AWS Bedrock Agent Core - APIキー認証情報プロバイダー
#----------------------------------------------------------------------
# Bedrock Agentで使用するAPIキー認証情報プロバイダーを作成・管理します
# APIキーを安全に保存し、エージェントが外部サービスへのアクセスに使用できます
#
# 主な用途:
# - エージェントからサードパーティAPIへの認証情報管理
# - APIキーのセキュアな保存と参照
# - Secrets Managerとの統合
#
# 公式ドキュメント:
# https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/bedrockagentcore_api_key_credential_provider
#----------------------------------------------------------------------

#----------------------------------------------------------------------
# 基本設定
#----------------------------------------------------------------------

resource "aws_bedrockagentcore_api_key_credential_provider" "example" {
  # 認証情報プロバイダー名
  # 設定内容: 認証情報プロバイダーを識別する一意の名前
  # 制約事項: Bedrock Agent内で一意である必要があります
  name = "example-api-key-provider"

  #----------------------------------------------------------------------
  # APIキー管理
  #----------------------------------------------------------------------

  # APIキー（読み取り可能）
  # 設定内容: プロバイダーに関連付けるAPIキー
  # 注意事項: センシティブな情報のため、Terraform stateで暗号化されます
  # セキュリティ: 本番環境ではvariablesやSecrets Managerから取得することを推奨
  # api_key = var.api_key

  # APIキー（書き込み専用）
  # 設定内容: Terraformで管理するAPIキー（書き込み専用）
  # 注意事項: 設定後は読み取り不可、更新のみ可能
  # api_key_woとapi_keyは排他的な関係です
  # api_key_wo = var.api_key_wo

  # APIキー（書き込み専用）バージョン
  # 設定内容: api_key_woのバージョン番号
  # 用途: APIキーのローテーション管理に使用
  # api_key_wo_version = 1

  #----------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------

  # リージョン指定
  # 設定内容: リソースを作成するAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用されます
  # region = "us-east-1"

  #----------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------

  # タグは未サポートのため設定できません
}

#----------------------------------------------------------------------
# Attributes Reference
#----------------------------------------------------------------------
# 以下の属性が参照可能です:
#
# credential_provider_arn
#   - 認証情報プロバイダーのARN
#   - 形式: arn:aws:bedrock:region:account-id:credential-provider/provider-id
#
# api_key_secret_arn
#   - APIキーが保存されているSecrets ManagerのARN情報
#   - 構造: [{ secret_arn = "arn:aws:secretsmanager:..." }]
#   - 注意: APIキーは自動的にSecrets Managerに保存されます
#
# region
#   - リソースが作成されたリージョン
#----------------------------------------------------------------------
