resource "aws_fms_resource_set" "example" {

  #-----------------------------------------------
  # リソースセット設定（必須）
  #-----------------------------------------------
  resource_set {
    # 設定内容: リソースセットの名前
    # 設定可能な値: 1文字以上の文字列
    # 省略時: なし（必須）
    # 補足: 作成後は変更不可。英数字とハイフンを推奨
    name = "example-resource-set"

    # 設定内容: リソースセットに関連付け可能なリソースタイプのリスト
    # 設定可能な値: AWS::NetworkFirewall::Firewall など
    # 省略時: なし（必須）
    # 補足: 現在はNetwork Firewallのみサポート。複数指定可能
    resource_type_list = ["AWS::NetworkFirewall::Firewall"]

    # 設定内容: リソースセットの説明
    # 設定可能な値: 0〜1024文字の文字列
    # 省略時: 説明なし
    # 補足: リソースセットの用途や管理範囲を明記
    description = "Resource set for Network Firewall management"

    # 設定内容: リソースセットのステータス
    # 設定可能な値: ACTIVE（管理可能）、OUT_OF_ADMIN_SCOPE（参照のみ）
    # 省略時: 自動設定
    # 補足: 管理者リージョンスコープ内外を示す。通常は指定不要
    # resource_set_status = "ACTIVE"

    # 設定内容: リソースセットの最終更新日時
    # 設定可能な値: RFC3339形式のタイムスタンプ
    # 省略時: 自動設定
    # 補足: 読み取り専用属性。通常は指定不要
    # last_update_time = "2024-01-01T00:00:00Z"

    # 設定内容: 更新トークン
    # 設定可能な値: トークン文字列
    # 省略時: 自動生成
    # 補足: 楽観的ロック制御用。通常は指定不要
    # update_token = ""
  }

  #-----------------------------------------------
  # リージョン設定
