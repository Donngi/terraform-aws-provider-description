  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: ap-northeast-1, us-east-1 など
  # 省略時: プロバイダー設定のリージョン
  # 補足: クロスリージョン管理時に指定。通常は省略可
  region = "ap-northeast-1"

  #-----------------------------------------------
  # タグ設定
  #-----------------------------------------------
  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のマップ（最大50個）
  # 省略時: タグなし
  # 補足: コスト配分タグやリソース管理用タグを設定
  tags = {
    Name        = "example-resource-set"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------
  # タイムアウト設定
