#-----------------------------------------------------------------------
# AWS ネットワークインターフェースのアタッチメント (aws_network_interface_attachment)
#-----------------------------------------------------------------------
#
# 既存のEC2インスタンスに既存のElastic Network Interface (ENI) をアタッチするリソースです。
# インスタンスと ENI はそれぞれ事前に作成されている必要があります。
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/network_interface_attachment
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# NOTE:
#   - aws_instance リソースの network_interface ブロックでの設定とは異なり、
#     このリソースは後から動的にENIをアタッチするために使用します
#   - device_index は各インスタンスで一意である必要があります（0 はプライマリENI用）
#   - ネットワークカード対応インスタンスタイプでは network_card_index も指定可能です
#-----------------------------------------------------------------------

resource "aws_network_interface_attachment" "example" {
  #-----------------------------------------------------------------------
  # インスタンス設定
  #-----------------------------------------------------------------------

  # 設定内容: ENIをアタッチする対象のEC2インスタンスID
  # 設定可能な値: EC2インスタンスID（例: i-xxxxxxxxxxxxxxxxx）
  # 省略時: 必須項目のため省略不可
  instance_id = "i-xxxxxxxxxxxxxxxxx"

  #-----------------------------------------------------------------------
  # ネットワークインターフェース設定
  #-----------------------------------------------------------------------

  # 設定内容: アタッチするElastic Network Interface (ENI) のID
  # 設定可能な値: ENI ID（例: eni-xxxxxxxxxxxxxxxxx）
  # 省略時: 必須項目のため省略不可
  network_interface_id = "eni-xxxxxxxxxxxxxxxxx"

  # 設定内容: ENIをアタッチするデバイスインデックス番号
  # 設定可能な値: 0以上の整数（0はプライマリENI、1以降がセカンダリENI）
  # 省略時: 必須項目のため省略不可
  device_index = 1

  # 設定内容: ENIをアタッチするネットワークカードのインデックス番号
  # 設定可能な値: 0以上の整数（複数ネットワークカード対応インスタンスタイプでのみ有効）
  # 省略時: AWSがデフォルト値を自動設定
  network_card_index = null

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョン識別子（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = null
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
#
# attachment_id         - アタッチメントのID
# instance_id           - アタッチ先EC2インスタンスのID
# network_interface_id  - アタッチしたENIのID
# device_index          - デバイスインデックス番号
# network_card_index    - ネットワークカードのインデックス番号
# status                - アタッチメントのステータス（attached など）
# id                    - リソースのID（attachment_id と同値）
# region                - リソースが管理されるAWSリージョン
#-----------------------------------------------------------------------
