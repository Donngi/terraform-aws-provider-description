# aws_cloudformation_stack
# CloudFormationスタックを作成・管理するリソース
# CloudFormationテンプレートを使用してAWSリソースを宣言的にプロビジョニングできます
resource "aws_cloudformation_stack" "example" {

  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # name
  # 設定内容: スタック名
  # 設定可能な値: 一意のスタック名（リージョン内で一意である必要があります）
  name = "example-stack"

  #-----------------------------------------------------------------------
  # テンプレート設定
  #-----------------------------------------------------------------------

  # template_body
  # 設定内容: テンプレート本体の文字列
  # 設定可能な値: CloudFormationテンプレートのJSON/YAML文字列（最大51,200バイト）
  # 省略時: template_urlと排他的に使用
  template_body = jsonencode({
    Resources = {
      MyBucket = {
        Type = "AWS::S3::Bucket"
      }
    }
  })

  # template_url
  # 設定内容: テンプレートファイルのS3 URL
  # 設定可能な値: テンプレートが保存されているS3オブジェクトのURL（最大460,800バイト）
  # 省略時: template_bodyと排他的に使用
  template_url = "https://s3.amazonaws.com/bucket/template.json"

  #-----------------------------------------------------------------------
  # パラメータ設定
  #-----------------------------------------------------------------------

  # parameters
  # 設定内容: スタックパラメータのキー・バリューマップ
  # 設定可能な値: テンプレートで定義されたパラメータ名と値のマップ
  # 省略時: テンプレートのデフォルト値が使用されます
  parameters = {
    VPCCidr      = "10.0.0.0/16"
    InstanceType = "t3.micro"
  }

  #-----------------------------------------------------------------------
  # 権限・機能設定
  #-----------------------------------------------------------------------

  # capabilities
  # 設定内容: スタックに必要な機能のリスト
  # 設定可能な値: CAPABILITY_IAM（IAMリソースを作成）、CAPABILITY_NAMED_IAM（カスタム名のIAMリソース）、CAPABILITY_AUTO_EXPAND（マクロを含むテンプレート）
  # 省略時: 特別な機能は有効化されません
  capabilities = ["CAPABILITY_IAM"]

  # iam_role_arn
  # 設定内容: CloudFormationが使用するIAMロールのARN
  # 設定可能な値: 有効なIAMロールのARN
  # 省略時: 以前関連付けられたロール、またはユーザー資格情報から生成された一時セッションが使用されます
  iam_role_arn = "arn:aws:iam::123456789012:role/CloudFormationRole"

  #-----------------------------------------------------------------------
  # 失敗時の動作設定
  #-----------------------------------------------------------------------

  # disable_rollback
  # 設定内容: スタック作成失敗時のロールバック無効化
  # 設定可能な値: true（ロールバックしない）、false（ロールバックする）
  # 省略時: false（ロールバックが有効）
  # 注意: on_failureと排他的に使用
  disable_rollback = false

  # on_failure
  # 設定内容: スタック作成失敗時のアクション
  # 設定可能な値: DO_NOTHING（何もしない）、ROLLBACK（ロールバック）、DELETE（削除）
  # 省略時: デフォルトの動作（ロールバック）
  # 注意: disable_rollbackと排他的に使用
  on_failure = "ROLLBACK"

  #-----------------------------------------------------------------------
  # ポリシー設定
  #-----------------------------------------------------------------------

  # policy_body
  # 設定内容: スタックポリシーのJSON文字列
  # 設定可能な値: スタックポリシードキュメントのJSON文字列
  # 省略時: policy_urlと排他的に使用
  policy_body = jsonencode({
    Statement = [{
      Effect    = "Allow"
      Principal = "*"
      Action    = "Update:*"
      Resource  = "*"
    }]
  })

  # policy_url
  # 設定内容: スタックポリシーファイルのURL
  # 設定可能な値: スタックポリシーが保存されているS3オブジェクトのURL
  # 省略時: policy_bodyと排他的に使用
  policy_url = "https://s3.amazonaws.com/bucket/policy.json"

  #-----------------------------------------------------------------------
  # 通知・タイムアウト設定
  #-----------------------------------------------------------------------

  # notification_arns
  # 設定内容: スタック関連イベントを発行するSNSトピックARNのリスト
  # 設定可能な値: 有効なSNSトピックARNのセット
  # 省略時: 通知は送信されません
  notification_arns = [
    "arn:aws:sns:us-east-1:123456789012:stack-notifications"
  ]

  # timeout_in_minutes
  # 設定内容: スタックステータスがCREATE_FAILEDになるまでの時間
  # 設定可能な値: 正の整数（分単位）
  # 省略時: タイムアウトなし
  timeout_in_minutes = 30

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # region
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（us-east-1、ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンが使用されます
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # tags
  # 設定内容: スタックに関連付けるタグ
  # 設定可能な値: キー・バリューペアのマップ
  # 省略時: タグなし（プロバイダーのdefault_tagsは適用されます）
  tags = {
    Environment = "production"
    Project     = "example"
  }
}

#-----------------------------------------------------------------------
# タイムアウト設定
#-----------------------------------------------------------------------

# timeouts
# 設定内容: リソース操作のタイムアウト時間
# 省略時: デフォルトのタイムアウト値が使用されます
# timeouts {
#   create = "30m"  # 作成操作のタイムアウト（デフォルト: 30分）
#   update = "30m"  # 更新操作のタイムアウト（デフォルト: 30分）
#   delete = "30m"  # 削除操作のタイムアウト（デフォルト: 30分）
# }

################################################################################
# Attributes Reference
################################################################################

# id - スタックの一意の識別子
# outputs - スタックからの出力値のマップ
# tags_all - リソースに割り当てられたすべてのタグ（プロバイダーのdefault_tagsを含む）
