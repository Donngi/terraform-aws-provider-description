#       実際の使用時は、必要な属性のみコメントを外して使用してください。
#-----------------------------------------------------------------------
# AWS CloudFormationスタックを管理するリソース。
# CloudFormationテンプレートを使用してAWSリソースのプロビジョニングと管理を行います。
# ドキュメント: https://docs.aws.amazon.com/cloudformation/
#
# 主な機能:
# - CloudFormationテンプレートを使用したインフラストラクチャのデプロイ
# - スタックパラメータによる動的な設定値の注入
# - IAMリソース作成のためのCapability設定
# - スタック更新時のロールバック制御
# - SNS通知による変更イベントの追跡
#
# 注意事項:
# - template_bodyとtemplate_urlは排他的な設定（どちらか一方のみ指定）
# - policy_bodyとpolicy_urlは排他的な設定（どちらか一方のみ指定）
# - disable_rollbackとon_failureは競合する設定（同時指定不可）
# - IAMリソースを含むテンプレートではcapabilitiesの明示的な指定が必要
# - スタック作成後のパラメータ変更は更新操作となり、リソースの再作成を伴う場合がある
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------
resource "aws_cloudformation_stack" "example" {
  #-----------------------------------------------------------------------
  # スタック識別情報
  #-----------------------------------------------------------------------
  # 設定内容: スタック名
  # 設定可能な値: 1〜128文字の英数字とハイフン
  # 備考: スタックの一意な識別子として使用される
  name = "example-stack"

  #-----------------------------------------------------------------------
  # テンプレート設定（template_body / template_url のいずれか一方を指定）
  #-----------------------------------------------------------------------
  # 設定内容: CloudFormationテンプレート本体（JSON/YAML形式）
  # 設定可能な値: 最大51,200バイトのテンプレート文字列
  # 備考: template_urlとの同時指定は不可
  template_body = jsonencode({
    Parameters = {
      VPCCidr = {
        Type        = "String"
        Default     = "10.0.0.0/16"
        Description = "VPC CIDR block"
      }
    }
    Resources = {
      ExampleVPC = {
        Type = "AWS::EC2::VPC"
        Properties = {
          CidrBlock = { Ref = "VPCCidr" }
        }
      }
    }
  })

  # 設定内容: テンプレートファイルのS3 URL
  # 設定可能な値: 最大460,800バイトのテンプレートを参照するHTTPS URL
  # 備考: template_bodyとの同時指定は不可
  template_url = "https://s3.amazonaws.com/bucket-name/template.json"

  #-----------------------------------------------------------------------
  # パラメータ設定
  #-----------------------------------------------------------------------
  # 設定内容: テンプレートパラメータのキーと値のマップ
  # 設定可能な値: テンプレートで定義されたパラメータ名と対応する値
  # 省略時: テンプレートで定義されたデフォルト値が使用される
  parameters = {
    VPCCidr = "10.0.0.0/16"
  }

  #-----------------------------------------------------------------------
  # 権限設定
  #-----------------------------------------------------------------------
  # 設定内容: CloudFormationがスタック操作時に使用するIAMロールのARN
  # 設定可能な値: IAMロールARN（arn:aws:iam::account-id:role/role-name形式）
  # 省略時: スタック実行ユーザーの認証情報から生成された一時セッションを使用
  iam_role_arn = "arn:aws:iam::123456789012:role/CloudFormationRole"

  # 設定内容: スタックがIAMリソースを作成する際に必要なCapabilityのリスト
  # 設定可能な値: CAPABILITY_IAM / CAPABILITY_NAMED_IAM / CAPABILITY_AUTO_EXPAND
  # 省略時: Capabilityなしで実行（IAMリソース作成は失敗）
  # 備考:
  #   - CAPABILITY_IAM: カスタムIAMリソース（ロール、ポリシー等）の作成を許可
  #   - CAPABILITY_NAMED_IAM: カスタム名を持つIAMリソースの作成を許可
  #   - CAPABILITY_AUTO_EXPAND: マクロやネストされたスタックの展開を許可
  capabilities = ["CAPABILITY_IAM", "CAPABILITY_NAMED_IAM"]

  #-----------------------------------------------------------------------
  # 失敗時の動作制御
  #-----------------------------------------------------------------------
  # 設定内容: スタック作成失敗時のロールバック無効化フラグ
  # 設定可能な値: true（無効化）/ false（有効化）
  # 省略時: false（ロールバック有効）
  # 備考: on_failureと同時指定不可、デバッグ時に有用
  disable_rollback = false

  # 設定内容: スタック作成失敗時のアクション
  # 設定可能な値: DO_NOTHING / ROLLBACK / DELETE
  # 省略時: ROLLBACK
  # 備考:
  #   - DO_NOTHING: 失敗状態のまま保持（デバッグ用）
  #   - ROLLBACK: 作成済みリソースをロールバック
  #   - DELETE: スタック全体を削除
  #   - disable_rollbackと同時指定不可
  on_failure = "ROLLBACK"

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------
  # 設定内容: スタック作成のタイムアウト時間（分単位）
  # 設定可能な値: 1以上の整数（分）
  # 省略時: タイムアウトなし
  # 備考: 指定時間を超過するとCREATE_FAILEDステータスになる
  timeout_in_minutes = 30

  #-----------------------------------------------------------------------
  # 通知設定
  #-----------------------------------------------------------------------
  # 設定内容: スタック関連イベントを通知するSNSトピックARNのリスト
  # 設定可能な値: SNSトピックARNのセット
  # 省略時: 通知なし
  # 備考: スタック作成、更新、削除イベントが通知される
  notification_arns = [
    "arn:aws:sns:us-east-1:123456789012:cloudformation-notifications"
  ]

  #-----------------------------------------------------------------------
  # スタックポリシー設定（policy_body / policy_url のいずれか一方を指定）
  #-----------------------------------------------------------------------
  # 設定内容: スタックポリシーのJSON定義
  # 設定可能な値: IAMポリシー形式のJSON文字列
  # 省略時: ポリシーなし
  # 備考:
  #   - policy_urlとの同時指定不可
  #   - スタック内リソースの更新・削除保護を定義
  policy_body = jsonencode({
    Statement = [{
      Effect    = "Allow"
      Principal = "*"
      Action    = "Update:*"
      Resource  = "*"
    }]
  })

  # 設定内容: スタックポリシーファイルのURL
  # 設定可能な値: S3バケット上のポリシーファイルのHTTPS URL
  # 省略時: ポリシーなし
  # 備考: policy_bodyとの同時指定不可
  policy_url = "https://s3.amazonaws.com/bucket-name/stack-policy.json"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（us-east-1、ap-northeast-1等）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # 設定内容: スタックに付与するタグのマップ
  # 設定可能な値: キーと値の文字列ペア
  # 省略時: タグなし
  # 備考: プロバイダーのdefault_tagsと統合される
  tags = {
    Environment = "production"
    Project     = "infrastructure"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------
  timeouts {
    # 設定内容: スタック作成のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 30m、1h）
    # 省略時: 30m
    create = "30m"

    # 設定内容: スタック更新のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 30m、1h）
    # 省略時: 30m
    update = "30m"

    # 設定内容: スタック削除のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 30m、1h）
    # 省略時: 30m
    delete = "30m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   スタックの一意な識別子
#   形式: スタック名
#
# - outputs
#   スタックのOutputセクションで定義された出力値のマップ
#   形式: キー（Output名）と値（Output値）のマップ
#   用途: 他のTerraformリソースやモジュールへの値の受け渡し
#
# - tags_all
#   リソースに割り当てられた全タグのマップ
#   プロバイダーのdefault_tags設定ブロックから継承されたタグを含む
#-----------------------------------------------------------------------
