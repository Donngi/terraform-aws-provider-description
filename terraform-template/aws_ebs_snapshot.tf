#---------------------------------------------------------------
# AWS EBS Snapshot
#---------------------------------------------------------------
#
# Amazon EBS (Elastic Block Store) ボリュームのスナップショットを作成するリソースです。
# スナップショットはEBSボリュームのポイントインタイムコピーで、増分バックアップとして
# 機能します（前回のスナップショット以降に変更されたブロックのみを保存）。
#
# スナップショットは新しいEBSボリュームの作成、別リージョンへのコピー、
# AMIの作成などに使用できます。
#
# AWS公式ドキュメント:
#   - EBSスナップショット: https://docs.aws.amazon.com/ebs/latest/userguide/ebs-snapshots.html
#   - スナップショットの作成: https://docs.aws.amazon.com/ebs/latest/userguide/ebs-creating-snapshot.html
#   - スナップショットアーカイブ: https://docs.aws.amazon.com/ebs/latest/userguide/snapshot-archive.html
#   - Outpost上のローカルスナップショット: https://docs.aws.amazon.com/ebs/latest/userguide/snapshots-outposts.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ebs_snapshot
#
# Provider Version: 6.28.0
# Generated: 2026-01-23
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_ebs_snapshot" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # volume_id (Required, Forces new resource)
  # 設定内容: スナップショットを作成するEBSボリュームのIDを指定します。
  # 設定可能な値: 有効なEBSボリュームID（例: vol-xxxxxxxx）
  # 関連機能: スナップショット作成
  #   スナップショットは非同期で作成され、ボリュームサイズや変更されたブロック数に
  #   応じて完了までの時間が変わります。
  volume_id = "vol-xxxxxxxx"

  # description (Optional)
  # 設定内容: スナップショットの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 用途: スナップショットの目的や内容を識別するための説明文
  description = "Snapshot of my EBS volume"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # ストレージティア設定
  #-------------------------------------------------------------

  # storage_tier (Optional)
  # 設定内容: スナップショットのストレージティアを指定します。
  # 設定可能な値:
  #   - "standard" (デフォルト): 標準ティア。即座にアクセス可能
  #   - "archive": アーカイブティア。90日以上の長期保存で最大75%コスト削減
  # 関連機能: EBSスナップショットアーカイブ
  #   アーカイブティアはアクセス頻度の低いスナップショット向けの低コストストレージ。
  #   アーカイブされたスナップショットを使用するには、まず標準ティアに復元する必要があります。
  #   復元には最大72時間かかる場合があります。
  #   - https://docs.aws.amazon.com/ebs/latest/userguide/snapshot-archive.html
  # 注意:
  #   - アーカイブの最小保存期間は90日
  #   - 90日未満で削除または復元すると追加料金が発生
  #   - アーカイブ時にフルスナップショットに変換される
  storage_tier = "standard"

  #-------------------------------------------------------------
  # アーカイブ復元設定
  #-------------------------------------------------------------

  # permanent_restore (Optional)
  # 設定内容: アーカイブされたスナップショットを永続的に復元するかを指定します。
  # 設定可能な値:
  #   - true: スナップショットを永続的に標準ティアに復元
  #   - false (デフォルト): 永続復元しない
  # 関連機能: アーカイブスナップショットの復元
  #   アーカイブされたスナップショットは一時的または永続的に復元できます。
  #   永続復元では、スナップショットは標準ティアに完全に移動されます。
  # 注意: storage_tierが"archive"のスナップショットに対してのみ有効
  permanent_restore = null

  # temporary_restore_days (Optional)
  # 設定内容: アーカイブされたスナップショットを一時的に復元する日数を指定します。
  # 設定可能な値: 正の整数（日数）
  # 関連機能: 一時復元
  #   指定した日数の間、スナップショットを標準ティアで利用可能にします。
  #   期間終了後、スナップショットは自動的にアーカイブティアに戻ります。
  # 注意:
  #   - 一時復元専用の設定（permanent_restoreがfalseの場合）
  #   - 復元には最大72時間かかる場合がある
  temporary_restore_days = null

  #-------------------------------------------------------------
  # Outpost設定
  #-------------------------------------------------------------

  # outpost_arn (Optional, Forces new resource)
  # 設定内容: ローカルスナップショットを作成するOutpostのARNを指定します。
  # 設定可能な値: 有効なOutpost ARN（例: arn:aws:outposts:us-east-1:123456789012:outpost/op-xxxxxxxx）
  # 関連機能: Outpost上のローカルスナップショット
  #   AWS Outpost上でスナップショットをローカルに保存できます。
  #   データレジデンシー要件がある場合や、リージョンへのデータ転送を
  #   最小限に抑えたい場合に有用です。
  #   - https://docs.aws.amazon.com/ebs/latest/userguide/snapshots-outposts.html
  # 注意:
  #   - S3 on Outpostsがプロビジョニングされている必要がある
  #   - ローカルスナップショットは暗号化が必須
  #   - Fast Snapshot RestoreやEBS direct APIsはサポートされない
  #   - ローカルスナップショットはリージョンにコピーできない
  outpost_arn = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "my-ebs-snapshot"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: スナップショット作成のタイムアウト時間を指定します。
    # 設定可能な値: 時間を表す文字列（例: "10m", "1h"）
    # デフォルト: 10m
    # 注意: 大容量ボリュームや変更ブロックが多い場合は長めに設定
    create = "10m"

    # delete (Optional)
    # 設定内容: スナップショット削除のタイムアウト時間を指定します。
    # 設定可能な値: 時間を表す文字列（例: "10m", "1h"）
    # デフォルト: 10m
    delete = "10m"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: EBSスナップショットのAmazon Resource Name (ARN)
#
# - id: スナップショットID（例: snap-59fcb34e）
#
# - owner_id: EBSスナップショット所有者のAWSアカウントID
#
# - owner_alias: スナップショット所有者のAmazon管理リスト値
#                （amazon, aws-marketplace, microsoft）
#
# - encrypted: スナップショットが暗号化されているかどうか
#
# - volume_size: ボリュームのサイズ（GiB単位）
#
# - kms_key_id: 暗号化に使用されるKMSキーのARN
#
# - data_encryption_key_id: スナップショットのデータ暗号化キー識別子
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#---------------------------------------------------------------
