#######################################################################
# Amazon Managed Grafana ワークスペース API キー
#######################################################################
# Amazon Managed Grafana ワークスペースに対してAPIキーを作成するリソース。
# APIキーはHTTPリクエストのBearerトークンとして使用し、
# Grafana HTTPエンドポイントへのプログラム的なアクセスを提供する。
#
# 主な用途:
# - Grafana APIへの自動化アクセスの提供
# - CI/CDパイプラインからのダッシュボード管理
# - 外部ツールとのGrafana連携
#
# 注意: APIキーはTerraform stateに機密情報として保存される。
#       APIキーの有効期限（seconds_to_live）を超えると自動削除される。
#
# 参考: https://docs.aws.amazon.com/grafana/latest/userguide/API_CreateWorkspaceApiKey.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/grafana_workspace_api_key
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_grafana_workspace_api_key" "example" {
  #-----------------------------------------------------------------------
  # APIキーの基本設定
  #-----------------------------------------------------------------------

  # APIキーの名前
  # 設定内容: ワークスペース内でAPIキーを識別するための一意の名前
  # 省略時: 必須のため省略不可
  key_name = "example-api-key"

  # APIキーに付与するロール
  # 設定内容: APIキーが持つGrafana上のアクセス権限レベル
  # 設定可能な値:
  #   - VIEWER: ダッシュボードの閲覧のみ
  #   - EDITOR: ダッシュボードの編集が可能
  #   - ADMIN: ワークスペースの管理が可能
  # 省略時: 必須のため省略不可
  key_role = "VIEWER"

  # APIキーの有効期限（秒）
  # 設定内容: キーが有効な期間を秒単位で指定
  # 設定可能な値: 1 〜 2592000（30日）の整数
  # 注意: 有効期限を過ぎると自動的にキーは削除される
  # 省略時: 必須のため省略不可
  seconds_to_live = 3600

  # 対象のGrafanaワークスペースID
  # 設定内容: APIキーを作成するGrafanaワークスペースのID
  # 省略時: 必須のため省略不可
  workspace_id = aws_grafana_workspace.example.id

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   APIキーのID（workspace_id と key_name の組み合わせ）
#
# - key
#   JSONフォーマットのAPIキートークン（機密情報）
#   HTTPリクエストのBearerトークンとして使用する
#-----------------------------------------------------------------------
