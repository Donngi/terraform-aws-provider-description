#----------------------------------------------------------------------
# Amazon CloudWatch Evidently プロジェクトを管理するリソース
#
# CloudWatch Evidently は A/B テストや機能フラグを管理するサービスで、
# 本リソースはその基盤となるプロジェクトを作成します。
# プロジェクト内で実験（Experiment）、起動（Launch）、機能（Feature）などを
# 管理することができます。
#
# 主な用途:
# - A/B テスト用プロジェクトの作成
# - 機能フラグ管理基盤の構築
# - 評価イベントのログ保存設定（CloudWatch Logs または S3）
#
# 注意事項:
# - 評価イベントは指定した保存先に記録され、それ以外は自動削除されます
# - CloudWatch Logs と S3 のいずれか一方のみ指定可能です
#----------------------------------------------------------------------

#----------------------------------------------------------------------
# 基本設定
#----------------------------------------------------------------------

resource "aws_evidently_project" "example" {
  # プロジェクト名（必須）
  # 設定内容: Evidently プロジェクトを識別する名前
  # 制約事項: 一意である必要があります
  name = "example-evidently-project"

  # プロジェクトの説明（オプション）
  # 設定内容: プロジェクトの目的や用途を説明するテキスト
  # 省略時: 説明なしでプロジェクトが作成されます
  description = "A/Bテスト用のEvidentlyプロジェクト"

  #----------------------------------------------------------------------
  # データ配信設定（評価イベントの保存先）
  #----------------------------------------------------------------------

  # 評価イベントの保存設定（オプション）
  # 設定内容: Evidently が評価イベントを長期保存する場所を定義
  # 省略時: イベントは指標生成後に自動削除されます
  # 注意: cloudwatch_logs と s3_destination は同時に指定できません
  data_delivery {

    # CloudWatch Logs への配信設定（オプション）
    # 設定内容: 評価イベントを CloudWatch Logs に保存する設定
    # 注意: s3_destination と同時指定不可
    cloudwatch_logs {
      # ロググループ名（オプション）
      # 設定内容: 評価イベントを保存する CloudWatch Logs のロググループ名
      # 制約事項: 事前にロググループが作成されている必要があります
      log_group = "example-log-group-name"
    }

    # S3 バケットへの配信設定（オプション）
    # 設定内容: 評価イベントを S3 バケットに保存する設定
    # 注意: cloudwatch_logs と同時指定不可
    s3_destination {
      # バケット名（オプション）
      # 設定内容: 評価イベントを保存する S3 バケット名
      # 制約事項: 事前にバケットが作成され、適切な権限が設定されている必要があります
      bucket = "example-bucket-name"

      # バケットプレフィックス（オプション）
      # 設定内容: S3 バケット内でイベントを保存するプレフィックス（フォルダパス）
      # 省略時: バケットのルートディレクトリに保存されます
      prefix = "evidently-events/"
    }
  }

  #----------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------

  # デプロイ先リージョン（オプション）
  # 設定内容: このリソースを管理する AWS リージョン
  # 省略時: プロバイダー設定のリージョンが使用されます
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = "ap-northeast-1"

  #----------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------

  # リソースタグ（オプション）
  # 設定内容: プロジェクトに付与するタグのキーバリューペア
  # 用途: コスト配分、リソース管理、アクセス制御などに使用
  # 注意: プロバイダーの default_tags と統合されます
  tags = {
    Environment = "production"
    Project     = "ab-testing"
    ManagedBy   = "terraform"
  }

  #----------------------------------------------------------------------
  # タイムアウト設定
  #----------------------------------------------------------------------

  timeouts {
    # 作成時のタイムアウト（オプション）
    # 設定内容: プロジェクト作成操作の最大待機時間
    # 省略時: デフォルトのタイムアウト値が使用されます
    create = "2m"

    # 更新時のタイムアウト（オプション）
    # 設定内容: プロジェクト更新操作の最大待機時間
    # 省略時: デフォルトのタイムアウト値が使用されます
    update = "2m"

    # 削除時のタイムアウト（オプション）
    # 設定内容: プロジェクト削除操作の最大待機時間
    # 省略時: デフォルトのタイムアウト値が使用されます
    delete = "2m"
  }
}

#----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#----------------------------------------------------------------------
# このリソースの作成後、以下の属性を参照できます:
#
# - arn: プロジェクトの ARN
# - id: プロジェクトの ID（ARN と同じ値）
# - status: プロジェクトの現在の状態（AVAILABLE または UPDATING）
# - created_time: プロジェクトの作成日時（ISO8601 形式）
# - last_updated_time: プロジェクトの最終更新日時（ISO8601 形式）
# - active_experiment_count: 実行中の実験数
# - active_launch_count: 実行中の起動数
# - experiment_count: プロジェクト内の総実験数（削除済みを除く）
# - feature_count: プロジェクト内の機能数
# - launch_count: プロジェクト内の総起動数（削除済みを除く）
# - tags_all: 全てのタグ（プロバイダーの default_tags を含む）
#----------------------------------------------------------------------
