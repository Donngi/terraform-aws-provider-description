#---------------------------------------------------------------
# AWS IAM Account Password Policy
#---------------------------------------------------------------
#
# AWSアカウントのIAMパスワードポリシーを管理するリソースです。
# アカウント内のIAMユーザーが設定するパスワードに対する要件
# （最小長、文字種の要件、有効期限等）を定義します。
# アカウントごとに1つのポリシーのみ設定可能です。
#
# AWS公式ドキュメント:
#   - IAMアカウントパスワードポリシー: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_passwords_account-policy.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/iam_account_password_policy
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iam_account_password_policy" "example" {
  #-------------------------------------------------------------
  # パスワード長設定
  #-------------------------------------------------------------

  # minimum_password_length (Optional)
  # 設定内容: IAMユーザーパスワードに要求する最小文字数を指定します。
  # 設定可能な値: 6〜128の整数
  # 省略時: AWSのデフォルト値（8文字）が適用されます。
  minimum_password_length = 8

  #-------------------------------------------------------------
  # 文字種要件設定
  #-------------------------------------------------------------

  # require_lowercase_characters (Optional)
  # 設定内容: パスワードに小文字（a〜z）を含めることを要求するかを指定します。
  # 設定可能な値:
  #   - true: 小文字を必須とする
  #   - false: 小文字を必須としない
  # 省略時: AWSのデフォルト値が適用されます。
  require_lowercase_characters = true

  # require_uppercase_characters (Optional)
  # 設定内容: パスワードに大文字（A〜Z）を含めることを要求するかを指定します。
  # 設定可能な値:
  #   - true: 大文字を必須とする
  #   - false: 大文字を必須としない
  # 省略時: AWSのデフォルト値が適用されます。
  require_uppercase_characters = true

  # require_numbers (Optional)
  # 設定内容: パスワードに数字（0〜9）を含めることを要求するかを指定します。
  # 設定可能な値:
  #   - true: 数字を必須とする
  #   - false: 数字を必須としない
  # 省略時: AWSのデフォルト値が適用されます。
  require_numbers = true

  # require_symbols (Optional)
  # 設定内容: パスワードに記号を含めることを要求するかを指定します。
  # 設定可能な値:
  #   - true: 記号を必須とする（! @ # $ % ^ & * ( ) _ + - = [ ] { } | ' 等）
  #   - false: 記号を必須としない
  # 省略時: AWSのデフォルト値が適用されます。
  require_symbols = true

  #-------------------------------------------------------------
  # パスワード有効期限設定
  #-------------------------------------------------------------

  # max_password_age (Optional)
  # 設定内容: IAMユーザーパスワードの有効日数を指定します。
  # 設定可能な値: 1〜1095の整数（日数）
  # 省略時: 0（パスワードの有効期限なし）が適用されます。
  # 注意: 0を指定した場合、expire_passwords属性はfalseになります。
  #       1以上を指定した場合、expire_passwords属性はtrueになります。
  max_password_age = 90

  # hard_expiry (Optional)
  # 設定内容: パスワード有効期限切れ後に管理者のリセットを必須とするかを指定します。
  # 設定可能な値:
  #   - true: 有効期限切れ後はユーザー自身でパスワード変更不可（管理者リセット必須）
  #   - false: 有効期限切れ後もユーザー自身でパスワード変更可能
  # 省略時: AWSのデフォルト値（false）が適用されます。
  hard_expiry = false

  #-------------------------------------------------------------
  # パスワード再利用設定
  #-------------------------------------------------------------

  # password_reuse_prevention (Optional)
  # 設定内容: ユーザーが再利用を禁止される過去のパスワード数を指定します。
  # 設定可能な値: 1〜24の整数（記憶するパスワード数）
  # 省略時: パスワードの再利用制限なし。
  # 注意: 値を一度設定した後に削除する場合は、0または明示的に属性を削除する必要があります。
  password_reuse_prevention = 24

  #-------------------------------------------------------------
  # ユーザー権限設定
  #-------------------------------------------------------------

  # allow_users_to_change_password (Optional)
  # 設定内容: IAMユーザーが自分自身のパスワードを変更できるかを指定します。
  # 設定可能な値:
  #   - true: ユーザー自身によるパスワード変更を許可
  #   - false: ユーザー自身によるパスワード変更を禁止（管理者のみ変更可能）
  # 省略時: false（ユーザーはパスワードを変更できない）が適用されます。
  allow_users_to_change_password = true
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - expire_passwords: アカウントのパスワードが有効期限切れになるかを示します。
#                     max_password_ageに0より大きい値が設定されている場合はtrue、
#                     0または未設定の場合はfalseを返します。
#---------------------------------------------------------------
