#-------------------------------------------------------
# DynamoDB Table Item
#-------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# DynamoDBテーブルにアイテム（レコード）を作成・管理するリソース
#
# ユースケース:
# - DynamoDBテーブルに初期データやマスターデータを登録
# - テーブル内のアイテムを宣言的に管理
# - インフラコードで静的なデータを管理
#
# NOTE: このリソースは大量のデータ管理には適していない（スケールを考慮した設計ではない）
#       定期的なバックアップの実施が推奨される
#
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/dynamodb_table_item

#-------------------------------------------------------
# 基本設定
#-------------------------------------------------------

resource "aws_dynamodb_table_item" "example" {
  # 設定内容: アイテムを格納するDynamoDBテーブルの名前またはARN
  # 省略時: 省略不可
  table_name = aws_dynamodb_table.example.name

  # 設定内容: テーブルのハッシュキー名（アイテムの検索と識別に使用）
  # 省略時: 省略不可
  hash_key = aws_dynamodb_table.example.hash_key

  # 設定内容: テーブルのレンジキー名（アイテムの検索と識別に使用、テーブルでレンジキーが定義されている場合は必須）
  # 省略時: レンジキーが定義されていない場合は不要
  range_key = aws_dynamodb_table.example.range_key

  #-------------------------------------------------------
  # アイテムデータ
  #-------------------------------------------------------

  # 設定内容: DynamoDBアイテムのJSON表現（属性名と値のペアを含む）
  # 省略時: 省略不可
  # 注意事項:
  # - プライマリキー属性（ハッシュキー/レンジキー）は必須
  # - 属性名は内部的に文字以外が削除されるため、"your-name-here"と"yournamehere"は衝突する
  # - JSON形式でDynamoDBのデータ型を指定（S=文字列, N=数値, B=バイナリ等）
  item = jsonencode({
    exampleHashKey = { S = "something" }
    attribute1     = { N = "11111" }
    attribute2     = { N = "22222" }
    attribute3     = { S = "value" }
  })

  #-------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"
}

#-------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-------------------------------------------------------
# このリソースでは以下の属性が参照可能:
#
# - id          : リソース識別子（"table_name:hash_key:range_key"の形式）
# - hash_key    : ハッシュキー名
# - range_key   : レンジキー名（設定されている場合）
# - table_name  : テーブル名
# - item        : アイテムのJSON表現
# - region      : リソースが管理されているリージョン
