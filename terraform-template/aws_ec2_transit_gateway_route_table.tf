#-----------------------------------------------------------------------------------------------------------------------
# AWS EC2 Transit Gateway Route Table
#-----------------------------------------------------------------------------------------------------------------------
# 用途: Transit Gatewayのルーティングテーブルを管理
# 概要: Transit Gatewayに関連付けられたVPCやVPN接続間のルーティングを制御するルートテーブルを作成・管理します
#
# 補足:
# - Transit Gatewayのアタッチメントとルートの関連付け・伝播を制御
# - デフォルトルートテーブルとカスタムルートテーブルを区別可能
# - ルートテーブルは複数のアタッチメントに関連付け可能
# - aws_ec2_transit_gateway_routeリソースと組み合わせて静的ルートを定義
# - aws_ec2_transit_gateway_route_table_associationで関連付けを設定
# - aws_ec2_transit_gateway_route_table_propagationで経路伝播を設定
# - 複数のルートテーブルを使用してトラフィックを分離可能
#
# Provider Version: 6.28.0
# Generated: 2026-02-16
# NOTE: このテンプレートは実際の環境に合わせて値を調整してください
#
# 公式ドキュメント: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_transit_gateway_route_table
#-----------------------------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------------------------
# リソース定義
#-----------------------------------------------------------------------------------------------------------------------
resource "aws_ec2_transit_gateway_route_table" "example" {
  #-----------------------------------------------------------------------------------------------------------------------
  # 必須パラメータ
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: Transit GatewayのID
  # 省略時: エラー（必須）
  transit_gateway_id = "tgw-0123456789abcdef0"

  #-----------------------------------------------------------------------------------------------------------------------
  # 配置設定
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: リソースに付与するタグ（キー=値のマップ）
  # 省略時: タグなし（provider default_tagsは適用される）
  tags = {
    Name        = "example-tgw-route-table"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  # 設定内容: すべてのタグ（ユーザー指定とプロバイダーdefault_tagsの統合）
  # 省略時: tagsの値とdefault_tagsをマージした値を自動設定
  # tags_all = {}
}

#-----------------------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------------------------------------------------------
# arn                              : Transit Gateway Route TableのARN
# default_association_route_table  : このルートテーブルがTransit Gatewayのデフォルト関連付けテーブルかどうか
# default_propagation_route_table  : このルートテーブルがTransit Gatewayのデフォルト伝播テーブルかどうか
# id                               : Transit Gateway Route TableのID（識別子）
# tags_all                         : 全タグのマップ（ユーザー指定タグとプロバイダーdefault_tagsの統合）
