#---------------------------------------
# AWS FinSpace Kx Cluster
#---------------------------------------
# AWS FinSpace環境内で動作するKxクラスターを管理するリソースです。
# HDB（履歴データベース）、RDB（リアルタイムデータベース）、GATEWAY、GP（汎用）、Tickerplantなど、
# 様々なクラスタータイプをサポートし、金融データの分析や処理に最適化されています。
#
# 主な用途:
# - 金融データの履歴分析用HDBクラスターの構築
# - リアルタイムデータ処理用RDBクラスターの構築
# - データアクセス用GATEWAYクラスターの構築
# - 開発・検証用GPクラスターの構築
# - データフィード処理用Tickerplantクラスターの構築
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/finspace_kx_cluster
#
# NOTE: このテンプレートには全てのプロパティが含まれていますが、
# 実際の使用時には必要なプロパティのみを選択してください。

#---------------------------------------
# 基本設定
#---------------------------------------

resource "aws_finspace_kx_cluster" "example" {
  # クラスター名
  # 設定内容: クラスターの一意の識別名
  # 設定可能な値: 英数字、ハイフン、アンダースコアを含む文字列
  # 制約: 環境内で一意である必要があります
  name = "my-kx-cluster"

  # 環境ID
  # 設定内容: クラスターを作成するFinSpace KX環境の一意識別子
  # 設定可能な値: 有効なFinSpace KX環境のID
  environment_id = "kx-env-12345678"

  # クラスタータイプ
  # 設定内容: KDBデータベースのタイプ
  # 設定可能な値:
  #   - HDB: Historical Database（読み取り専用の履歴データベース）
  #   - RDB: Realtime Database（リアルタイムデータベース、savedown機能付き）
  #   - GATEWAY: ゲートウェイクラスター（プロセス間データアクセス用）
  #   - GP: General Purpose（汎用クラスター、開発用）
  #   - Tickerplant: ティッカープラントクラスター（データフィード処理用）
  type = "HDB"

  # リリースラベル
  # 設定内容: 実行するFinSpace Managed kdbのバージョン
  # 設定可能な値: サポートされているバージョン番号（例: "1.0"）
  release_label = "1.0"

  # アベイラビリティゾーンモード
  # 設定内容: クラスターに割り当てるアベイラビリティゾーンの数
  # 設定可能な値:
  #   - SINGLE: 1つのAZを割り当て
  #   - MULTI: すべてのAZを割り当て
  az_mode = "SINGLE"

  #---------------------------------------
  # キャパシティ設定
  #---------------------------------------

  # キャパシティ構成
  # 設定内容: クラスターのメタデータ（CPU、メモリ、インスタンス数）を定義
  capacity_configuration {
    # ノードタイプ
    # 設定内容: クラスターインスタンスのハードウェアスペック
    # 設定可能な値:
    #   - kx.s.large: 12 GiB メモリ、2 vCPU
    #   - kx.s.xlarge: 27 GiB メモリ、4 vCPU
    #   - kx.s.2xlarge: 54 GiB メモリ、8 vCPU
    #   - kx.s.4xlarge: 108 GiB メモリ、16 vCPU
    #   - kx.s.8xlarge: 216 GiB メモリ、32 vCPU
    #   - kx.s.16xlarge: 432 GiB メモリ、64 vCPU
    #   - kx.s.32xlarge: 864 GiB メモリ、128 vCPU
    node_type = "kx.s.2xlarge"

    # ノード数
    # 設定内容: クラスター内で実行するインスタンスの数
    # 設定可能な値: 1～5
    # 注意: GPタイプの場合は1で固定
    node_count = 2
  }

  #---------------------------------------
  # ネットワーク設定
  #---------------------------------------

  # VPC設定
  # 設定内容: クラスターのPrivateLinkエンドポイントが配置されるネットワーク構成
  vpc_configuration {
    # VPC ID
    # 設定内容: VPCエンドポイントの識別子
    # 設定可能な値: 有効なVPC ID
    vpc_id = "vpc-12345678"

    # サブネットID
    # 設定内容: クラスターが配置されるサブネット
    # 設定可能な値: 有効なサブネットIDのセット
    subnet_ids = ["subnet-12345678"]

    # セキュリティグループID
    # 設定内容: VPCエンドポイントENIに適用されるセキュリティグループ
    # 設定可能な値: 有効なセキュリティグループIDのセット
    security_group_ids = ["sg-12345678"]

    # IPアドレスタイプ
    # 設定内容: クラスターネットワーク構成のIPアドレスバージョン
    # 設定可能な値: IP_V4（IPv4アドレス）
    ip_address_type = "IP_V4"
  }

  #---------------------------------------
  # オプション設定
  #---------------------------------------

  # アベイラビリティゾーンID
  # 設定内容: リクエストするリージョンのアベイラビリティゾーン識別子
  # 設定可能な値: 有効なAZ ID（例: "use1-az2"）
  # 省略時: null
  # 注意: az_modeがSINGLEの場合は必須
  availability_zone_id = "use1-az2"

  # 説明
  # 設定内容: クラスターの説明文
  # 設定可能な値: 任意の文字列
  # 省略時: null
  description = "HDB cluster for historical data analysis"

  # 実行ロール
  # 設定内容: クラスターが他のクラスターにアクセスする際に使用するIAMロール
  # 設定可能な値: 有効なIAMロールARN
  # 省略時: null
  execution_role = "arn:aws:iam::123456789012:role/FinSpaceKxClusterRole"

  # 初期化スクリプト
  # 設定内容: クラスター起動時に実行されるQプログラムのパス
  # 設定可能な値: zipファイル内の相対パス（ファイル名を含む、例: "somedir/init.q"）
  # 省略時: null
  initialization_script = "scripts/init.q"

  # コマンドライン引数
  # 設定内容: クラスター内で利用可能にするキーバリューペアのリスト
  # 設定可能な値: 文字列のマップ
  # 省略時: null
  command_line_arguments = {
    "arg1" = "value1"
    "arg2" = "value2"
  }

  # リージョン
  # 設定内容: リソースが管理されるAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: "us-east-1"）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #---------------------------------------
  # データベース設定
  #---------------------------------------

  # データベース
  # 設定内容: クエリ可能なKXデータベースの定義
  # 省略時: null
  # database {
  #   # データベース名
  #   # 設定内容: KXデータベースの名前
  #   # 設定可能な値: 既存のKXデータベース名
  #   database_name = "my-kx-database"
  #
  #   # チェンジセットID
  #   # 設定内容: クラスターに関連付けられたチェンジセットの一意識別子
  #   # 設定可能な値: 有効なチェンジセットID
  #   # 省略時: null
  #   # changeset_id = "changeset-12345678"
  #
  #   # データビュー名
  #   # 設定内容: ディスク上の履歴データキャッシュに使用するデータビュー名
  #   # 設定可能な値: 有効なデータビュー名
  #   # 省略時: null
  #   # 注意: クラスター作成後は変更不可、ignore_changesの使用を推奨
  #   # dataview_name = "my-dataview"
  #
  #   # キャッシュ構成
  #   # 設定内容: クラスターにマウントされたKXデータベースからの読み取りパフォーマンスを向上させるディスクキャッシュ設定
  #   # 省略時: null
  #   # cache_configurations {
  #   #   # キャッシュタイプ
  #   #   # 設定内容: ディスクキャッシュのタイプ
  #   #   # 設定可能な値: キャッシュタイプの識別子
  #   #   cache_type = "CACHE_1000"
  #   #
  #   #   # データベースパス
  #   #   # 設定内容: キャッシュするデータベース内のパス
  #   #   # 設定可能な値: パス文字列のセット
  #   #   # 省略時: null
  #   #   # db_paths = ["/path1", "/path2"]
  #   # }
  # }

  #---------------------------------------
  # ストレージ設定
  #---------------------------------------

  # キャッシュストレージ構成
  # 設定内容: クラスターに関連付けられた読み取り専用キャッシュストレージの構成
  # 省略時: null
  # 注意: FSx Lustreとして保存され、S3ストアから読み取ります
  # cache_storage_configurations {
  #   # タイプ
  #   # 設定内容: キャッシュストレージのタイプ
  #   # 設定可能な値:
  #   #   - CACHE_1000: 1000 MB/sのディスクアクセススループット
  #   #   - CACHE_250: 250 MB/sのディスクアクセススループット
  #   #   - CACHE_12: 12 MB/sのディスクアクセススループット
  #   type = "CACHE_1000"
  #
  #   # サイズ
  #   # 設定内容: キャッシュのサイズ（ギガバイト単位）
  #   # 設定可能な値: 正の整数
  #   # 注意: データ量によってはタイムアウト設定の調整が必要
  #   size = 1200
  # }

  # セーブダウンストレージ構成
  # 設定内容: セーブダウンプロセス中のデータ一時保存用の書き込み可能ストレージ
  # 省略時: null
  # 注意: typeがRDBの場合は必須、クラスター再起動時にデータは失われます
  # savedown_storage_configuration {
  #   # タイプ
  #   # 設定内容: 書き込み可能ストレージスペースのタイプ
  #   # 設定可能な値: SDS01（3000 IOPSのio2 EBSボリュームタイプ）
  #   # 省略時: null
  #   # type = "SDS01"
  #
  #   # サイズ
  #   # 設定内容: 一時ストレージのサイズ（ギガバイト単位）
  #   # 設定可能な値: 10～16000
  #   # 省略時: null
  #   # size = 100
  #
  #   # ボリューム名
  #   # 設定内容: クラスターの書き込み可能セーブダウンストレージとして使用するkdbボリュームの名前
  #   # 設定可能な値: 既存のkdbボリューム名
  #   # 省略時: null
  #   # volume_name = "my-volume"
  # }

  #---------------------------------------
  # コード設定
  #---------------------------------------

  # コード
  # 設定内容: データ分析時にクラスター内で使用するカスタムコードの詳細
  # 省略時: null
  # code {
  #   # S3バケット
  #   # 設定内容: コードが格納されているS3バケットの一意名
  #   # 設定可能な値: 有効なS3バケット名
  #   s3_bucket = "my-code-bucket"
  #
  #   # S3キー
  #   # 設定内容: クラスター起動時にロードされるzipファイルへのフルS3パス（バケット名を除く）
  #   # 設定可能な値: S3オブジェクトキー（zipファイル）
  #   s3_key = "code/cluster-code.zip"
  #
  #   # S3オブジェクトバージョン
  #   # 設定内容: S3オブジェクトのバージョン
  #   # 設定可能な値: 有効なS3オブジェクトバージョンID
  #   # 省略時: null
  #   # s3_object_version = "version-id-123"
  # }

  #---------------------------------------
  # スケーリング設定
  #---------------------------------------

  # オートスケーリング構成
  # 設定内容: FinSpaceがクラスター内のノードをスケールイン/スケールアウトする際の基準となる設定
  # 省略時: null
  # auto_scaling_configuration {
  #   # オートスケーリングメトリクス
  #   # 設定内容: クラスターがスケールイン/スケールアウトを判断するために追跡するメトリクス
  #   # 設定可能な値: CPU_UTILIZATION_PERCENTAGE（クラスター全体の平均CPU使用率）
  #   auto_scaling_metric = "CPU_UTILIZATION_PERCENTAGE"
  #
  #   # 最小ノード数
  #   # 設定内容: スケールする最小ノード数
  #   # 設定可能な値: 1以上、max_node_count未満
  #   # 注意: 複数AZの場合は最低3必要
  #   min_node_count = 1
  #
  #   # 最大ノード数
  #   # 設定内容: スケールする最大ノード数
  #   # 設定可能な値: 5以下
  #   max_node_count = 5
  #
  #   # メトリクスターゲット
  #   # 設定内容: auto_scaling_metricの目標値
  #   # 設定可能な値: 0～100（パーセント）
  #   # 注意: この値を下回るとスケールイン、上回るとスケールアウト
  #   metric_target = 70
  #
  #   # スケールインクールダウン秒数
  #   # 設定内容: スケールインイベント後、次のスケーリングイベントを開始するまでの待機時間
  #   # 設定可能な値: 秒数（正の整数）
  #   scale_in_cooldown_seconds = 300
  #
  #   # スケールアウトクールダウン秒数
  #   # 設定内容: スケールアウトイベント後、次のスケーリングイベントを開始するまでの待機時間
  #   # 設定可能な値: 秒数（正の整数）
  #   scale_out_cooldown_seconds = 60
  # }

  # スケーリンググループ構成
  # 設定内容: スケーリンググループの構成詳細を保存する構造
  # 省略時: null
  # scaling_group_configuration {
  #   # スケーリンググループ名
  #   # 設定内容: kdbスケーリンググループの一意識別子
  #   # 設定可能な値: 英数字、ハイフン、アンダースコアを含む文字列
  #   scaling_group_name = "my-scaling-group"
  #
  #   # メモリ予約
  #   # 設定内容: kdbクラスターがスケーリンググループに正常に配置されるために必要な最小メモリ量
  #   # 設定可能な値: メモリサイズ（MB単位）
  #   memory_reservation = 1000
  #
  #   # ノード数
  #   # 設定内容: kdbクラスターノードの数
  #   # 設定可能な値: 正の整数
  #   node_count = 2
  #
  #   # CPU
  #   # 設定内容: スケーリンググループホスト上のこのkdbクラスターの各ノードに予約するvCPU数
  #   # 設定可能な値: 正の整数
  #   # 省略時: null
  #   # cpu = 4
  #
  #   # メモリ制限
  #   # 設定内容: kdbクラスターが使用できるメモリ量のハードリミット（オプション）
  #   # 設定可能な値: メモリサイズ（MB単位）
  #   # 省略時: null
  #   # memory_limit = 2000
  # }

  #---------------------------------------
  # Tickerplant設定
  #---------------------------------------

  # Tickerplantログ構成
  # 設定内容: Tickerplantログを保存する構成
  # 省略時: null
  # 注意: クラスタータイプがTickerplantの場合に使用、グローバル変数.aws.tp_log_pathで位置を参照可能
  # tickerplant_log_configuration {
  #   # Tickerplantログボリューム
  #   # 設定内容: クラスターにマウントされるボリュームのリスト
  #   # 設定可能な値: ボリューム名の文字列セット
  #   tickerplant_log_volumes = ["volume1", "volume2"]
  # }

  #---------------------------------------
  # タグ設定
  #---------------------------------------

  # タグ
  # 設定内容: リソースに割り当てるキーバリューペアのタグ
  # 設定可能な値: キーと値の文字列マップ
  # 省略時: null
  # 注意: プロバイダーのdefault_tagsと重複するキーは上書きされます
  tags = {
    Environment = "Production"
    Project     = "FinanceAnalytics"
  }

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  # タイムアウト
  # 設定内容: リソース操作のタイムアウト設定
  # 省略時: デフォルトタイムアウト（作成/更新: 4時間、削除: 1時間）
  # 注意: キャッシュデータ量によっては最大18時間まで延長が必要
  # timeouts {
  #   # 作成タイムアウト
  #   # 設定内容: クラスター作成操作のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "4h", "18h"）
  #   # 省略時: 4時間
  #   # create = "18h"
  #
  #   # 更新タイムアウト
  #   # 設定内容: クラスター更新操作のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "4h", "18h"）
  #   # 省略時: 4時間
  #   # update = "18h"
  #
  #   # 削除タイムアウト
  #   # 設定内容: クラスター削除操作のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "1h", "2h"）
  #   # 省略時: 1時間
  #   # delete = "1h"
  # }
}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: KXクラスターのAmazon Resource Name (ARN)
# - id: 環境IDとクラスター名を結合したコンマ区切りの文字列
# - created_timestamp: クラスターがFinSpaceで作成されたタイムスタンプ（エポック秒）
# - last_modified_timestamp: クラスターがFinSpaceで最後に更新されたタイムスタンプ（エポック秒）
# - status: クラスターのステータス
# - status_reason: クラスターのステータス理由
# - tags_all: プロバイダーのdefault_tagsから継承されたタグを含む、リソースに割り当てられたタグのマップ
#
# 参照例:
# - ARN参照: aws_finspace_kx_cluster.example.arn
# - ID参照: aws_finspace_kx_cluster.example.id
# - 作成日時参照: aws_finspace_kx_cluster.example.created_timestamp
