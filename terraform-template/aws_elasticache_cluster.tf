#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Resource: aws_elasticache_cluster
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/elasticache_cluster
#
# NOTE: このテンプレートはAWS Provider v6.28.0のスキーマから自動生成されています。
#       実際の利用時は必要な属性のみを使用してください。
#-----------------------------------------------------------------------
# 概要:
# ElastiCacheクラスターを管理するリソース。
# Memcachedクラスター、単一ノードRedisインスタンス、またはRedisレプリケーション
# グループのリードレプリカを作成・管理します。
#
# ユースケース:
# - インメモリキャッシュによるアプリケーション高速化
# - セッションストアの実装
# - データベース負荷の軽減
# - リアルタイムランキングやカウンター機能
#
# 制限事項:
# - cluster_id, engine, port, availability_zoneの変更はリソース再作成が必要
# - replication_group_idを指定する場合、一部の属性は指定不可
# - Memcachedはnum_cache_nodesが1-40、Redisは1のみ
# - メンテナンスウィンドウ中の変更はダウンタイムが発生する可能性あり
#
# 依存関係:
# - aws_elasticache_subnet_group (VPC利用時)
# - aws_elasticache_parameter_group
# - aws_security_group (VPC利用時)
# - aws_sns_topic (通知設定時)
# - aws_cloudwatch_log_group (ログ配信時)
# - aws_kinesis_firehose_delivery_stream (ログ配信時)
#
# 注意事項:
# - apply_immediately=falseの場合、変更は次回メンテナンスウィンドウで適用
# - スナップショット取得には十分なメモリが必要
# - 暗号化設定は作成後の変更不可
# - Outpost利用時は制限事項が多い（M5/R5のみ、single-outpostのみ）
#
#-----------------------------------------------------------------------

resource "aws_elasticache_cluster" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # 設定内容: クラスター識別子（小文字に変換される）
  # 設定可能な値: 1-50文字の英数字とハイフン
  # 省略時: 指定必須
  cluster_id = "my-cluster"

  # 設定内容: キャッシュエンジンタイプ
  # 設定可能な値: memcached, redis, valkey
  # 省略時: replication_group_id指定時は自動設定、それ以外は指定必須
  engine = "redis"

  # 設定内容: キャッシュノードのインスタンスタイプ
  # 設定可能な値: cache.t2.micro, cache.m4.large等
  # 省略時: replication_group_id指定時は自動設定、それ以外は指定必須
  node_type = "cache.t3.micro"

  # 設定内容: クラスター内のキャッシュノード数
  # 設定可能な値: Redisは1、Memcachedは1-40
  # 省略時: replication_group_id指定時は自動設定、それ以外は指定必須
  num_cache_nodes = 1

  # 設定内容: 関連付けるパラメータグループ名
  # 設定可能な値: 既存のパラメータグループ名
  # 省略時: replication_group_id指定時は自動設定、それ以外はdefaultグループ使用
  parameter_group_name = "default.redis7"

  #-----------------------------------------------------------------------
  # エンジン設定
  #-----------------------------------------------------------------------

  # 設定内容: キャッシュエンジンのバージョン
  # 設定可能な値: エンジン別の利用可能バージョン（例: Redis 7.2, Memcached 1.6.12）
  # 省略時: 最新バージョン使用
  engine_version = "7.2"

  # 設定内容: マイナーバージョンの自動アップグレード有効化
  # 設定可能な値: true, false
  # 省略時: Redisでバージョン6以降の場合true
  auto_minor_version_upgrade = "true"

  #-----------------------------------------------------------------------
  # ネットワーク設定
  #-----------------------------------------------------------------------

  # 設定内容: キャッシュノードが受け付けるポート番号
  # 設定可能な値: 1-65535（Memcachedデフォルト11211、Redisデフォルト6379）
  # 省略時: エンジン別デフォルトポート使用
  port = 6379

  # 設定内容: サブネットグループ名（VPC利用時）
  # 設定可能な値: 既存のサブネットグループ名
  # 省略時: デフォルトサブネットグループ使用
  subnet_group_name = "my-subnet-group"

  # 設定内容: セキュリティグループID（VPC利用時）
  # 設定可能な値: VPCセキュリティグループIDのリスト
  # 省略時: デフォルトVPCセキュリティグループ使用
  security_group_ids = ["sg-12345678"]

  # 設定内容: アベイラビリティゾーン
  # 設定可能な値: ap-northeast-1a, us-east-1b等のAZ名
  # 省略時: システムが自動選択
  availability_zone = "ap-northeast-1a"

  # 設定内容: MemcachedノードのマルチAZ配置モード
  # 設定可能な値: single-az, cross-az
  # 省略時: single-az（cross-azの場合num_cache_nodesは2以上必要）
  az_mode = "single-az"

  # 設定内容: Memcachedで各ノードを配置するAZリスト
  # 設定可能な値: AZ名のリスト（num_cache_nodesと同数必要）
  # 省略時: システムが自動選択
  preferred_availability_zones = ["ap-northeast-1a", "ap-northeast-1c"]

  # 設定内容: IPバージョンタイプ
  # 設定可能な値: ipv4, ipv6, dual_stack
  # 省略時: ipv4
  network_type = "ipv4"

  # 設定内容: ディスカバリープロトコルでアドバタイズするIPバージョン
  # 設定可能な値: ipv4, ipv6
  # 省略時: ipv4
  ip_discovery = "ipv4"

  #-----------------------------------------------------------------------
  # セキュリティ設定
  #-----------------------------------------------------------------------

  # 設定内容: 転送中暗号化の有効化
  # 設定可能な値: true, false
  # 省略時: false
  transit_encryption_enabled = true

  #-----------------------------------------------------------------------
  # スナップショット・バックアップ設定
  #-----------------------------------------------------------------------

  # 設定内容: 自動スナップショット保持期間（日数、Redis専用）
  # 設定可能な値: 0-35（0は無効化）
  # 省略時: 0（無効）
  snapshot_retention_limit = 5

  # 設定内容: 自動スナップショット取得時間帯（UTC、Redis専用）
  # 設定可能な値: hh24:mi-hh24:mi形式（例: 05:00-09:00）
  # 省略時: システムが自動選択
  snapshot_window = "05:00-09:00"

  # 設定内容: 復元元となるRedis RDBスナップショットのARN（Redis専用）
  # 設定可能な値: S3に保存されたRDBファイルのARN（1要素のリスト）
  # 省略時: 新規クラスター作成
  snapshot_arns = ["arn:aws:s3:::my-bucket/snapshot.rdb"]

  # 設定内容: 復元元スナップショット名（Redis専用）
  # 設定可能な値: 既存のスナップショット名
  # 省略時: 新規クラスター作成
  snapshot_name = "my-snapshot"

  # 設定内容: 削除時の最終スナップショット名（Redis専用）
  # 設定可能な値: スナップショット識別子
  # 省略時: 最終スナップショット未作成
  final_snapshot_identifier = "final-snapshot"

  #-----------------------------------------------------------------------
  # メンテナンス・通知設定
  #-----------------------------------------------------------------------

  # 設定内容: メンテナンス時間帯（UTC）
  # 設定可能な値: ddd:hh24:mi-ddd:hh24:mi形式（最低60分、例: sun:05:00-sun:09:00）
  # 省略時: システムが自動選択
  maintenance_window = "sun:05:00-sun:09:00"

  # 設定内容: データベース変更の即座適用
  # 設定可能な値: true, false
  # 省略時: false（次回メンテナンスウィンドウで適用）
  apply_immediately = false

  # 設定内容: ElastiCache通知送信先SNSトピックARN
  # 設定可能な値: SNSトピックARN
  # 省略時: 通知なし
  notification_topic_arn = "arn:aws:sns:ap-northeast-1:123456789012:my-topic"

  #-----------------------------------------------------------------------
  # レプリケーション設定
  #-----------------------------------------------------------------------

  # 設定内容: 所属先レプリケーショングループID
  # 設定可能な値: 既存のレプリケーショングループID
  # 省略時: スタンドアロンプライマリとして作成
  replication_group_id = "my-replication-group"

  #-----------------------------------------------------------------------
  # Outpost設定
  #-----------------------------------------------------------------------

  # 設定内容: Outpost配置モード
  # 設定可能な値: single-outpost, cross-outpost（現在single-outpostのみサポート）
  # 省略時: Outpost未使用
  outpost_mode = "single-outpost"

  # 設定内容: クラスター配置先OutpostのARN
  # 設定可能な値: Outpost ARN
  # 省略時: outpost_mode指定時は必須
  preferred_outpost_arn = "arn:aws:outposts:ap-northeast-1:123456789012:outpost/op-1234567890abcdef0"

  #-----------------------------------------------------------------------
  # ログ配信設定
  #-----------------------------------------------------------------------

  # 設定内容: Redisログの配信設定（Redis専用、最大2つ）
  # 設定可能な値: slow-logまたはengine-logを各1つずつ設定可能
  # 省略時: ログ配信なし
  log_delivery_configuration {
    # 設定内容: CloudWatch LogsグループまたはKinesis Firehose配信ストリーム名
    # 設定可能な値: リソース名
    # 省略時: 指定必須
    destination = "my-log-group"

    # 設定内容: 配信先タイプ
    # 設定可能な値: cloudwatch-logs, kinesis-firehose
    # 省略時: 指定必須
    destination_type = "cloudwatch-logs"

    # 設定内容: ログフォーマット
    # 設定可能な値: json, text
    # 省略時: 指定必須
    log_format = "json"

    # 設定内容: ログタイプ
    # 設定可能な値: slow-log, engine-log（各タイプ最大1つ）
    # 省略時: 指定必須
    log_type = "slow-log"
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースが管理されるリージョン
  # 設定可能な値: ap-northeast-1, us-east-1等のリージョンコード
  # 省略時: プロバイダー設定のリージョン使用
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに割り当てるタグ
  # 設定可能な値: キーと値のマップ
  # 省略時: タグなし
  tags = {
    Environment = "production"
    Application = "web"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 設定内容: リソース作成のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 40m, 1h）
    # 省略時: デフォルトタイムアウト使用
    create = "40m"

    # 設定内容: リソース更新のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 80m, 1h）
    # 省略時: デフォルトタイムアウト使用
    update = "80m"

    # 設定内容: リソース削除のタイムアウト時間
    # 設定可能な値: 時間文字列（例: 40m, 1h）
    # 省略時: デフォルトタイムアウト使用
    delete = "40m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# - id: クラスター識別子（cluster_idと同値）
# - arn: クラスターのARN
# - engine_version_actual: 実際に使用されているエンジンバージョン
# - cache_nodes: ノード情報リスト（id, address, port, availability_zone, outpost_arn）
# - cluster_address: Memcached専用。ポート番号を含まないDNS名
# - configuration_endpoint: Memcached専用。ホスト検出用エンドポイント
# - tags_all: プロバイダーdefault_tagsを含む全タグのマップ
#-----------------------------------------------------------------------
