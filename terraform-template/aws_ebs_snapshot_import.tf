#-------------------------------------------------------------------------------------------------------
# Resource Type: aws_ebs_snapshot_import
# Provider: hashicorp/aws
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ebs_snapshot_import
# Generated: 2025-01-15
# NOTE: このテンプレートはAWS Provider 6.28.0のスキーマから生成されています
#-------------------------------------------------------------------------------------------------------
# 用途・機能:
#   外部ストレージ（S3バケット）に保存されたディスクイメージをAmazon EBSスナップショットとして
#   インポートするためのリソース。オンプレミスやクラウド環境からのマイグレーション、
#   バックアップデータの取り込み、ディザスタリカバリ用途に使用される。
#
# 主な機能:
#   - S3に保存されたVMDK/VHD/RAWディスクイメージのインポート
#   - インポート時の暗号化設定（KMS暗号化対応）
#   - ストレージ階層の選択（標準/アーカイブ）
#   - スナップショット復元の一時的/永続的設定
#   - クライアントメタデータ（アップロード情報）の記録
#
# 関連リソース:
#   - aws_ebs_snapshot: 標準のEBSスナップショット作成
#   - aws_ebs_volume: インポート後のボリューム作成
#   - aws_s3_bucket: ソースイメージの保存先
#   - aws_kms_key: スナップショット暗号化用KMSキー
#   - aws_iam_role: インポート処理用のIAMロール
#
# 注意事項:
#   - インポート可能な形式: VMDK, VHD, RAW
#   - S3バケットとIAMロールには適切な権限が必要
#   - インポート処理には時間がかかる場合がある（タイムアウト設定推奨）
#   - 暗号化済みスナップショットのインポートには対応するKMSキー権限が必要
#   - 一時復元の場合は temporary_restore_days の指定が必要
#   - リージョン間でのインポートには region パラメータを使用
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# リソース定義
#-------------------------------------------------------------------------------------------------------
resource "aws_ebs_snapshot_import" "example" {
  #-------------------------------------------------------------------------------------------------------
  # ディスクコンテナ設定（必須）
  #-------------------------------------------------------------------------------------------------------
  disk_container {
    # 設定内容: ディスクイメージのフォーマット
    # 設定可能な値: VMDK, VHD, RAW
    format = "VMDK"

    # 設定内容: ディスクコンテナの説明
    # 省略時: 説明なし
    # description = "Imported disk image from on-premises environment"

    # 設定内容: インポートするディスクイメージのURL
    # 省略時: user_bucket ブロックで指定したS3オブジェクトを使用
    # url = "https://s3.amazonaws.com/my-bucket/my-image.vmdk"

    #-------------------------------------------------------------------------------------------------------
    # S3バケット情報（disk_container内、url未指定時に必須）
    #-------------------------------------------------------------------------------------------------------
    user_bucket {
      # 設定内容: ディスクイメージが保存されているS3バケット名
      s3_bucket = "my-snapshot-import-bucket"

      # 設定内容: S3バケット内のディスクイメージのオブジェクトキー
      s3_key = "disk-images/my-server-disk.vmdk"
    }
  }

  #-------------------------------------------------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: インポート時にスナップショットを暗号化するかどうか
  # 省略時: false（暗号化なし）
  encrypted = true

  # 設定内容: スナップショット暗号化に使用するKMSキーのID/ARN/エイリアス
  # 省略時: AWSマネージドキー（aws/ebs）を使用
  # 備考: encrypted = true の場合に有効
  kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #-------------------------------------------------------------------------------------------------------
  # メタデータ設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: スナップショットの説明
  # 省略時: 空の説明
  description = "Snapshot imported from on-premises VMware environment"

  #-------------------------------------------------------------------------------------------------------
  # ストレージとリストア設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: スナップショットのストレージ階層
  # 設定可能な値: standard, archive
  # 省略時: standard
  storage_tier = "archive"

  # 設定内容: アーカイブから一時復元する期間（日数）
  # 備考: storage_tier が archive の場合に使用
  temporary_restore_days = 7

  # 設定内容: アーカイブから永続的に復元するかどうか
  # 省略時: false（一時復元）
  permanent_restore = true

  #-------------------------------------------------------------------------------------------------------
  # IAMロール設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: インポート処理で使用するIAMロール名
  # 省略時: AWSが自動的に適切なロールを使用
  # 備考: S3バケットへのアクセス権限が必要
  role_name = "ebs-snapshot-import-role"

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: スナップショットを作成するリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-west-2"

  #-------------------------------------------------------------------------------------------------------
  # クライアントデータ設定
  #-------------------------------------------------------------------------------------------------------
  client_data {
    # 設定内容: クライアント側のコメント/メモ
    # 省略時: コメントなし
    # comment = "Migration from VMware vSphere cluster A"

    # 設定内容: アップロード開始時刻（RFC3339形式）
    # 省略時: AWSが自動設定
    # upload_start = "2025-01-15T10:00:00Z"

    # 設定内容: アップロード終了時刻（RFC3339形式）
    # 省略時: AWSが自動設定
    # upload_end = "2025-01-15T12:30:00Z"

    # 設定内容: アップロードされたデータのサイズ（バイト）
    # 省略時: AWSが自動計算
    # upload_size = 10737418240
  }

  #-------------------------------------------------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------------------------------------------------
  tags = {
    Name        = "imported-snapshot"
    Environment = "production"
    Source      = "on-premises-vmware"
    ImportDate  = "2025-01-15"
  }

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------
  timeouts {
    # 設定内容: インポート処理の作成タイムアウト
    # 省略時: 60m
    create = "120m"

    # 設定内容: インポート処理の削除タイムアウト
    # 省略時: 10m
    delete = "20m"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースでは以下の属性を参照できます:
#
# - id: スナップショットID（例: snap-0123456789abcdef0）
# - arn: スナップショットのARN
# - data_encryption_key_id: データ暗号化キーID（暗号化時）
# - outpost_arn: Outposts上のスナップショットの場合のARN
# - owner_alias: スナップショット所有者のエイリアス（Amazon管理の場合）
# - owner_id: スナップショット所有者のAWSアカウントID
# - volume_id: 元のボリュームID（ある場合）
# - volume_size: スナップショットのサイズ（GiB）
# - tags_all: デフォルトタグを含むすべてのタグ
#
# 参照例:
# output "snapshot_id" {
#   value = aws_ebs_snapshot_import.example.id
# }
# output "snapshot_size" {
#   value = aws_ebs_snapshot_import.example.volume_size
# }
#-------------------------------------------------------------------------------------------------------
