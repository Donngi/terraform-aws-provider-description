#-------------------------------------------------------------------------------------------------------
# EMR Containers Virtual Cluster
#-------------------------------------------------------------------------------------------------------
# Resource: aws_emrcontainers_virtual_cluster
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/emrcontainers_virtual_cluster
#
# 用途: EKSクラスター上でEMRワークロードを実行するための仮想クラスターを構成
#
# EMR on EKS（EMR Containers）は、Amazon EKSクラスター上でApache Sparkなどの
# EMRワークロードを実行するためのサービスです。仮想クラスターは、EKSクラスターの
# 特定のKubernetes名前空間をEMRワークロード実行環境として定義します。
#
# 主な機能:
# - EKS上でのSparkジョブ実行環境の構築
# - コンテナベースの分散データ処理基盤の構築
# - 既存のKubernetesインフラを活用したEMRワークロードの実行
#
# NOTE:
# - 事前にEKSクラスターと名前空間が作成されている必要があります
# - 仮想クラスターの削除時、実行中のジョブは自動的に停止されます
# - タグは作成後も変更可能ですが、nameは変更できません（再作成が必要）
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# 基本設定
#-------------------------------------------------------------------------------------------------------

resource "aws_emrcontainers_virtual_cluster" "example" {
  # 設定内容: 仮想クラスターの名前
  # 制約事項: 変更する場合はリソースの再作成が必要
  # 命名規則: 英数字、ハイフン、アンダースコアが使用可能
  name = "my-emr-virtual-cluster"

  #-------------------------------------------------------------------------------------------------------
  # コンテナプロバイダー設定
  #-------------------------------------------------------------------------------------------------------

  container_provider {
    # 設定内容: コンテナプロバイダーのタイプ
    # 設定可能な値: EKS（現在はEKSのみサポート）
    # 補足: 将来的に他のKubernetesプラットフォームがサポートされる可能性があります
    type = "EKS"

    # 設定内容: コンテナプロバイダーの識別子（EKSクラスター名）
    # 参照方法: 既存のEKSクラスターのnameまたはidを指定
    # 例: aws_eks_cluster.example.name
    id = "my-eks-cluster"

    info {
      eks_info {
        # 設定内容: EMRジョブを実行するKubernetes名前空間
        # 省略時: defaultが使用されます
        # 補足: 名前空間は事前にEKSクラスター上に作成されている必要があります
        # ベストプラクティス: EMR専用の名前空間を作成することを推奨
        namespace = "emr-jobs"
      }
    }
  }

  #-------------------------------------------------------------------------------------------------------
  # リソース管理
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 用途: コスト管理、リソース検索、アクセス制御などに使用
  # 補足: provider default_tagsと併用可能
  tags = {
    Name        = "my-emr-virtual-cluster"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定（オプション）
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用されます
  # 補足: マルチリージョン構成で明示的にリージョンを指定する場合に使用
  region = null

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------

  timeouts {
    # 設定内容: 仮想クラスター削除時のタイムアウト時間
    # 省略時: 90m（90分）
    # 補足: 実行中のジョブがある場合、削除に時間がかかることがあります
    delete = "90m"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースの作成後に参照可能な主要な属性:
#
# arn          - 仮想クラスターのARN
#              - 形式: arn:aws:emr-containers:region:account-id:virtual-cluster/cluster-id
#              - 用途: IAMポリシーでのリソース指定、他のリソースからの参照
#
# id           - 仮想クラスターのID
#              - 用途: EMRジョブ実行時の仮想クラスター指定、リソース参照
#
# tags_all     - 全てのタグ（default_tagsとマージ済み）
#              - プロバイダーレベルのdefault_tagsと明示的に指定したtagsの統合結果
#-------------------------------------------------------------------------------------------------------
