#-----------------------------------------------------------------------
# AWS EFS File System Policy
#-----------------------------------------------------------------------
# Amazon Elastic File System (EFS) のファイルシステムに IAM リソースベースポリシーを
# アタッチするためのリソース。このポリシーにより、NFS クライアントのアクセス制御を
# 細かく設定できます。
#
# ユースケース:
# - 特定の IAM ロール/ユーザーに対してファイルシステムへのアクセスを制限
# - 読み取り専用アクセスや書き込みアクセスの個別制御
# - 暗号化転送(TLS)の強制
# - 特定の IP アドレスやVPCからのアクセスのみを許可
# - アクセスポイント経由のアクセスのみを許可
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/efs_file_system_policy
# NOTE: このファイルは EFS ファイルシステムポリシーのテンプレートです。
#       実際の環境に合わせて適宜カスタマイズしてください。
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_efs_file_system_policy" "example" {
  # 設定内容: ポリシーをアタッチする EFS ファイルシステムの ID
  # 設定可能な値: 有効な EFS ファイルシステム ID (例: fs-12345678)
  file_system_id = "fs-12345678"

  # 設定内容: JSON 形式の IAM ポリシードキュメント
  # 設定可能な値: 有効な IAM ポリシー JSON 文字列（最大20,000文字）
  # 備考: aws_iam_policy_document データソースの使用を推奨
  # 参考: https://docs.aws.amazon.com/efs/latest/ug/access-control-overview.html
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "ExampleStatement"
        Effect = "Allow"
        Principal = {
          AWS = "*"
        }
        Action = [
          "elasticfilesystem:ClientMount",
          "elasticfilesystem:ClientWrite"
        ]
        Resource = "*"
        Condition = {
          Bool = {
            "aws:SecureTransport" = "true"
          }
        }
      }
    ]
  })

  #-----------------------------------------------------------------------
  # セーフティチェック設定
  #-----------------------------------------------------------------------

  # 設定内容: ポリシーロックアウト安全チェックをバイパスするかどうか
  # 設定可能な値: true (バイパスする) / false (チェックを実施)
  # 省略時: false
  # 備考: ポリシー設定者自身がロックアウトされる可能性がある場合に警告を抑制
  #       意図的に自分自身をロックアウトする場合のみ true を設定
  bypass_policy_lockout_safety_check = false

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: このリソースを管理する AWS リージョン
  # 設定可能な値: 有効な AWS リージョン名 (例: us-east-1, ap-northeast-1)
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: ファイルシステムの ID (例: fs-12345678)
#
# 参照例: aws_efs_file_system_policy.example.id
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 補足情報
#-----------------------------------------------------------------------
# インポート:
#   terraform import aws_efs_file_system_policy.example fs-12345678
#
# 注意事項:
# - ファイルシステムのライフサイクルステートが "available" の時のみ設定可能
# - ポリシーは 1 つのファイルシステムにつき 1 つのみ設定可能
# - ポリシー変更時は既存のポリシーが上書きされる
#-----------------------------------------------------------------------
