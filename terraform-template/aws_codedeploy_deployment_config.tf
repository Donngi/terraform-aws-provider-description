###################################################################################
# Terraform Template: aws_codedeploy_deployment_config
###################################################################################
# 用途: CodeDeployデプロイ設定の管理
#
# このリソースは以下の機能を提供します:
# - カスタムデプロイ設定の定義
# - 最小ヘルシーホスト数の制御
# - トラフィックルーティング戦略の設定
# - ゾーン別デプロイ設定の管理
#
# 主な用途:
# - EC2/オンプレミスサーバーのデプロイ設定
# - Lambda関数のトラフィックシフト設定
# - ECSサービスのデプロイ設定
# - マルチAZ環境でのゾーン別制御
#
# ドキュメント: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/codedeploy_deployment_config
#
# Provider Version: 6.28.0
# Generated: 2026-02-13
# NOTE: このテンプレートは実運用前に要件に応じたカスタマイズが必要です
###################################################################################

resource "aws_codedeploy_deployment_config" "example" {

  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # 設定内容: デプロイ設定の名前
  # 必須: はい
  # 備考: デプロイグループで参照される一意の識別子
  deployment_config_name = "example-deployment-config"

  # 設定内容: コンピュートプラットフォームのタイプ
  # 設定可能な値: Server / Lambda / ECS
  # 省略時: Server
  # 備考: プラットフォームにより設定可能な項目が異なります
  compute_platform = "Server"

  #-----------------------------------------------------------------------
  # EC2/オンプレミスサーバー向け設定
  #-----------------------------------------------------------------------

  # minimum_healthy_hosts - 最小ヘルシーホスト数の設定
  # 用途: デプロイ中に稼働を維持する最小インスタンス数の定義
  # 備考: compute_platform が Server の場合に必須
  minimum_healthy_hosts {
    # 設定内容: ヘルシーホスト数の指定方法
    # 設定可能な値: HOST_COUNT (絶対値) / FLEET_PERCENT (パーセント)
    # 備考: FLEET_PERCENT は小数点以下を切り上げて計算されます
    type = "HOST_COUNT"

    # 設定内容: 最小ヘルシーホスト数
    # 備考: type が HOST_COUNT の場合は台数、FLEET_PERCENT の場合はパーセンテージ
    value = 2
  }

  #-----------------------------------------------------------------------
  # Lambda/ECS向けトラフィック制御
  #-----------------------------------------------------------------------

  # traffic_routing_config - トラフィックルーティング設定
  # 用途: Lambda/ECSデプロイ時のトラフィックシフト戦略の定義
  # 備考: compute_platform が Lambda または ECS の場合に使用
  # traffic_routing_config {
  #   # 設定内容: トラフィックルーティングのタイプ
  #   # 設定可能な値: TimeBasedCanary (カナリア) / TimeBasedLinear (リニア) / AllAtOnce (一括)
  #   # 備考: タイプにより使用できる子ブロックが異なります
  #   type = "TimeBasedLinear"
  #
  #   # time_based_canary - カナリアデプロイ設定
  #   # 用途: 2段階でトラフィックをシフト
  #   # 備考: type が TimeBasedCanary の場合に使用
  #   # time_based_canary {
  #   #   # 設定内容: 1回目と2回目のシフト間隔（分）
  #   #   interval = 10
  #   #
  #   #   # 設定内容: 1回目のシフトで移行するトラフィックの割合
  #   #   percentage = 10
  #   # }
  #
  #   # time_based_linear - リニアデプロイ設定
  #   # 用途: 等間隔で段階的にトラフィックをシフト
  #   # 備考: type が TimeBasedLinear の場合に使用
  #   time_based_linear {
  #     # 設定内容: 各シフト間の間隔（分）
  #     interval = 10
  #
  #     # 設定内容: 各シフトで移行するトラフィックの割合
  #     percentage = 10
  #   }
  # }

  #-----------------------------------------------------------------------
  # ゾーン別デプロイ設定
  #-----------------------------------------------------------------------

  # zonal_config - アベイラビリティゾーン別設定
  # 用途: マルチAZ環境での段階的デプロイ制御
  # 備考: AZ間でのデプロイ順序と待機時間を制御
  # zonal_config {
  #   # 設定内容: 1つ目のAZへのデプロイ後の監視時間（秒）
  #   # 省略時: monitor_duration_in_seconds の値を使用
  #   # 備考: この時間経過後に次のAZへのデプロイを開始
  #   first_zone_monitor_duration_in_seconds = 300
  #
  #   # 設定内容: 各AZへのデプロイ後の監視時間（秒）
  #   # 省略時: 0（即座に次のAZへデプロイ開始）
  #   monitor_duration_in_seconds = 300
  #
  #   # minimum_healthy_hosts_per_zone - AZ単位の最小ヘルシーホスト設定
  #   # 用途: 各AZで維持する最小ヘルシーインスタンス数の定義
  #   # 省略時: 0パーセント
  #   minimum_healthy_hosts_per_zone {
  #     # 設定内容: ヘルシーホスト数の指定方法
  #     # 設定可能な値: HOST_COUNT (絶対値) / FLEET_PERCENT (パーセント)
  #     type = "FLEET_PERCENT"
  #
  #     # 設定内容: AZ単位の最小ヘルシーホスト数
  #     # 備考: type が HOST_COUNT の場合は台数、FLEET_PERCENT の場合はパーセンテージ
  #     value = 50
  #   }
  # }

  #-----------------------------------------------------------------------
  # リージョン設定（オプション）
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  # 備考: 特定のリージョンで管理する必要がある場合に指定
  region = "us-east-1"

}

###################################################################################
# Attributes Reference (参照可能な属性)
###################################################################################
