#   デプロイ設定の名前
#
# - arn
#   デプロイ設定のARN
#
# - deployment_config_id
#   AWSが割り当てたデプロイ設定ID
#
# 参照例:
#   aws_codedeploy_deployment_config.example.id
#   aws_codedeploy_deployment_config.example.arn
#   aws_codedeploy_deployment_config.example.deployment_config_id
