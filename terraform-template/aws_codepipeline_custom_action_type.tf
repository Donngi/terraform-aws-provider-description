#---------------------------------------
# aws_codepipeline_custom_action_type
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/codepipeline_custom_action_type
#
# NOTE:
# CodePipelineのカスタムアクションタイプを定義するリソース
# カスタムビルド、デプロイ、テスト等の独自処理をパイプラインに組み込める
# ジョブワーカーと連携してカスタムロジックを実行可能
#
# 主な用途:
# - カスタムビルド・デプロイ・テストアクションの作成
# - 外部ツールやサービスとの統合
# - 独自のCI/CDワークフローの実装
#
# 制約事項:
# - 設定プロパティは最大10個まで
# - アーティファクト数は0〜5の範囲で設定
# - カテゴリは6種類（Source/Build/Deploy/Test/Invoke/Approval）から選択

#---------------------------------------
# リソース定義
#---------------------------------------

resource "aws_codepipeline_custom_action_type" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # 設定内容: カスタムアクションのカテゴリ
  # 設定可能な値: Source / Build / Deploy / Test / Invoke / Approval
  # カテゴリによってパイプライン内での実行タイミングが決まる
  category = "Build"

  # 設定内容: カスタムアクションのプロバイダー名
  # 一意の識別子として使用され、パイプライン定義で参照される
  # 組織名やサービス名を含めることを推奨
  provider_name = "MyCustomProvider"

  # 設定内容: カスタムアクションのバージョン識別子
  # アクションの更新時には新しいバージョンを作成して互換性を管理
  # 通常は整数値（"1", "2", "3"等）を使用
  version = "1"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # カスタムアクションは指定リージョンでのみ利用可能
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-----------------------------------------------------------------------
  # アーティファクト設定
  #-----------------------------------------------------------------------

  # 設定内容: 入力アーティファクトの詳細設定
  # パイプラインから受け取る成果物の数を制限
  # 前段階のアクションから渡されるファイルの数を定義
  input_artifact_details {
    # 設定内容: 入力アーティファクトの最大数
    # 設定可能な値: 0〜5
    # この数を超える入力は受け付けない
    maximum_count = 5

    # 設定内容: 入力アーティファクトの最小数
    # 設定可能な値: 0〜5
    # この数未満の入力では実行されない
    minimum_count = 0
  }

  # 設定内容: 出力アーティファクトの詳細設定
  # アクション実行後に次の段階へ渡す成果物の数を制限
  # ビルド結果やテストレポート等を出力
  output_artifact_details {
    # 設定内容: 出力アーティファクトの最大数
    # 設定可能な値: 0〜5
    # この数を超える出力は許可されない
    maximum_count = 5

    # 設定内容: 出力アーティファクトの最小数
    # 設定可能な値: 0〜5
    # 承認アクション等では0を設定
    minimum_count = 0
  }

  #-----------------------------------------------------------------------
  # 設定プロパティ
  #-----------------------------------------------------------------------

  # 設定内容: カスタムアクションの設定プロパティ定義
  # ユーザーがパイプライン定義時に指定可能なパラメータを定義
  # 最大10個まで設定可能
  # configuration_property {
  #   # 設定内容: プロパティがキーとして機能するか
  #   # trueに設定するとPollForJobsでフィルタリングに使用可能
  #   key = false
  #
  #   # 設定内容: 設定プロパティの名前
  #   # パイプライン定義でこの名前を使用してパラメータを指定
  #   name = "ProjectName"
  #
  #   # 設定内容: 設定プロパティが必須かどうか
  #   # trueの場合、パイプライン定義時に必ず指定が必要
  #   required = true
  #
  #   # 設定内容: 設定値が機密情報かどうか
  #   # trueに設定するとCodePipelineコンソールで値がマスキングされる
  #   secret = false
  #
  #   # 設定内容: プロパティの説明文
  #   # 省略可能、ユーザーへのヘルプテキストとして表示
  #   # description = "ビルド対象のプロジェクト名を指定"
  #
  #   # 設定内容: プロパティがクエリ可能かどうか
  #   # 省略時: false
  #   # trueに設定するとPollForJobsでこのプロパティを使用可能
  #   # queryable = false
  #
  #   # 設定内容: プロパティのデータ型
  #   # 省略可能、入力値の検証に使用
  #   # type = "String"
  # }

  #-----------------------------------------------------------------------
  # 外部システム連携設定
  #-----------------------------------------------------------------------

  # 設定内容: 外部システムとの連携URLテンプレート設定
  # CodePipelineコンソールから外部システムへのリンクを提供
  # settings {
  #   # 設定内容: エンティティURLテンプレート
  #   # 省略可能、外部システムのリソース詳細ページへのディープリンク
  #   # テンプレート変数を使用して動的にURLを生成可能
  #   # entity_url_template = "https://example.com/entity/{Config:ProjectName}"
  #
  #   # 設定内容: 実行URLテンプレート
  #   # 省略可能、外部システムのトップページへのリンク
  #   # アクション実行時のコンテキスト情報を含められる
  #   # execution_url_template = "https://example.com/execution/{ExternalExecutionId}"
  #
  #   # 設定内容: リビジョンURLテンプレート
  #   # 省略可能、設定変更ページへのリンク
  #   # ユーザーがアクション設定を更新する際に使用
  #   # revision_url_template = "https://example.com/revision/{Config:ProjectName}"
  #
  #   # 設定内容: サードパーティ設定URL
  #   # 省略可能、外部サービスのサインアップページURL
  #   # 初回設定時にユーザーを誘導するために使用
  #   # third_party_configuration_url = "https://example.com/signup"
  # }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 省略時: タグなし
  # カスタムアクションの分類や管理に使用
  # プロバイダーのdefault_tagsと統合される
  tags = {
    Environment = "Production"
    Team        = "DevOps"
    ManagedBy   = "Terraform"
  }
}

#######################################################################
# Attributes Reference
#######################################################################
# 以下の属性がエクスポートされ、他のリソースから参照可能:
#
# arn - カスタムアクションのARN
# id - category:provider:versionの形式の複合ID（例: Build:MyCustomProvider:1）
# owner - アクションの作成者（通常は"Custom"）
# tags_all - プロバイダーのdefault_tagsを含む全てのタグ
