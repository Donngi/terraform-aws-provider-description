#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Resource Type: aws_m2_environment
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/m2_environment
# Generated: 2026-02-17
#-----------------------------------------------------------------------
# AWS Mainframe Modernization (M2) ランタイム環境を管理します。
# レガシーメインフレームアプリケーションをAWS上で実行するための
# マネージドランタイム環境を提供します。
#
# 主な機能:
# - メインフレームアプリケーション実行環境の管理
# - エンジンタイプ（Blu Age / Micro Focus）の選択
# - 高可用性設定（マルチノード構成）
# - EFSまたはFSxストレージの接続
# - メンテナンスウィンドウの設定
# - KMSによるデータ暗号化
#
# NOTE:
# - engine_type は環境作成後に変更できません
# - instance_type はエンジンタイプに応じた対応タイプを選択してください
# - high_availability_config を設定すると複数ノードが起動されます
# - storage_configuration の efs と fsx はどちらか一方のみ指定可能です
# - publicly_accessible = true の場合は適切なセキュリティグループ設定が必要です
#-----------------------------------------------------------------------

resource "aws_m2_environment" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # 環境名
  # 設定内容: ランタイム環境の一意な名前
  # 設定可能な値: 1〜60文字の英数字、ダッシュ、アンダースコア
  name = "example-m2-env"

  # エンジンタイプ
  # 設定内容: メインフレームアプリケーションの実行エンジン
  # 設定可能な値: bluage（Blu Age）/ microfocus（Micro Focus COBOL）
  # 注意: 作成後に変更できません
  engine_type = "microfocus"

  # インスタンスタイプ
  # 設定内容: 環境に使用するEC2インスタンスタイプ
  # 設定可能な値: M2サービスで対応しているインスタンスタイプ（例: M2.m5.large）
  # 注意: エンジンタイプに応じたインスタンスタイプを選択してください
  instance_type = "M2.m5.large"

  #-----------------------------------------------------------------------
  # バージョン設定
  #-----------------------------------------------------------------------

  # エンジンバージョン
  # 設定内容: 使用するエンジンのバージョン
  # 設定可能な値: 利用可能なエンジンバージョン文字列
  # 省略時: 最新の利用可能なバージョン
  engine_version = null

  #-----------------------------------------------------------------------
  # 説明設定
  #-----------------------------------------------------------------------

  # 環境の説明
  # 設定内容: ランタイム環境の説明テキスト
  # 設定可能な値: 任意の文字列（最大500文字）
  # 省略時: 説明なし
  description = "Example M2 mainframe modernization environment"

  #-----------------------------------------------------------------------
  # ネットワーク設定
  #-----------------------------------------------------------------------

  # サブネットID
  # 設定内容: 環境を配置するVPCサブネットのIDセット
  # 設定可能な値: サブネットIDのセット
  # 省略時: デフォルトサブネット
  # 注意: 高可用性構成の場合は複数のAZにまたがるサブネットを指定してください
  subnet_ids = [
    "subnet-12345678",
    "subnet-87654321",
  ]

  # セキュリティグループID
  # 設定内容: 環境に関連付けるセキュリティグループのIDセット
  # 設定可能な値: セキュリティグループIDのセット
  # 省略時: デフォルトセキュリティグループ
  security_group_ids = [
    "sg-12345678",
  ]

  # パブリックアクセス
  # 設定内容: 環境をインターネットからアクセス可能にするか
  # 設定可能な値: true / false
  # 省略時: false
  publicly_accessible = false

  #-----------------------------------------------------------------------
  # 高可用性設定
  #-----------------------------------------------------------------------

  # 高可用性設定
  # 設定内容: マルチノード構成による高可用性設定
  # high_availability_config {
  #   # 希望キャパシティ（必須）
  #   # 設定内容: 実行するノード数
  #   # 設定可能な値: 2以上の整数（高可用性には2以上が必要）
  #   desired_capacity = 2
  # }

  #-----------------------------------------------------------------------
  # ストレージ設定
  #-----------------------------------------------------------------------

  # ストレージ設定
  # 設定内容: 環境に接続するストレージの設定（EFS または FSx）
  # storage_configuration {
  #   # EFSストレージ設定（efsとfsxはどちらか一方のみ指定可能）
  #   efs {
  #     # ファイルシステムID（必須）
  #     # 設定内容: 接続するEFSファイルシステムのID
  #     # 設定可能な値: 有効なEFSファイルシステムID
  #     file_system_id = "fs-12345678"
  #
  #     # マウントポイント（必須）
  #     # 設定内容: EFSファイルシステムのマウントポイントパス
  #     # 設定可能な値: 有効なUnixパス（例: /m2/mount/efs）
  #     mount_point = "/m2/mount/efs"
  #   }
  #
  #   # FSxストレージ設定（efsとfsxはどちらか一方のみ指定可能）
  #   fsx {
  #     # ファイルシステムID（必須）
  #     # 設定内容: 接続するFSxファイルシステムのID
  #     # 設定可能な値: 有効なFSxファイルシステムID
  #     file_system_id = "fs-12345678"
  #
  #     # マウントポイント（必須）
  #     # 設定内容: FSxファイルシステムのマウントポイントパス
  #     # 設定可能な値: 有効なUnixパス（例: /m2/mount/fsx）
  #     mount_point = "/m2/mount/fsx"
  #   }
  # }

  #-----------------------------------------------------------------------
  # セキュリティ設定
  #-----------------------------------------------------------------------

  # KMSキーID
  # 設定内容: 環境データの暗号化に使用するKMSキーのARNまたはID
  # 設定可能な値: KMSキーのARN、キーID、またはエイリアスARN
  # 省略時: AWSマネージドキーを使用
  # 注意: 作成後に変更できません
  kms_key_id = null

  #-----------------------------------------------------------------------
  # メンテナンス設定
  #-----------------------------------------------------------------------

  # 優先メンテナンスウィンドウ
  # 設定内容: 自動メンテナンスを実行する優先時間帯
  # 設定可能な値: ddd:hh24:mi-ddd:hh24:mi 形式（例: sun:05:00-sun:06:00）
  # 省略時: AWSが自動的に割り当て
  preferred_maintenance_window = null

  # メンテナンスウィンドウ中に変更を適用するか
  # 設定内容: メンテナンスウィンドウ中に変更を適用するか
  # 設定可能な値: true / false
  # 省略時: false
  apply_changes_during_maintenance_window = false

  # 強制更新
  # 設定内容: 更新を強制するか
  # 設定可能な値: true / false
  # 省略時: false
  # 注意: 実行中のアプリケーションが影響を受ける可能性があります
  force_update = false

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リージョン（オプション）
  # 設定内容: リソースが管理されるAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-west-2、ap-northeast-1）
  # 省略時: プロバイダー設定のリージョン
  region = null

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # タグ
  # 設定内容: リソースに付与するタグのキーと値のマップ
  # 設定可能な値: 任意のキーと値のペア
  tags = {
    Name        = "example-m2-env"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # タイムアウト
  # 設定内容: リソース操作のタイムアウト時間
  # timeouts {
  #   # 作成タイムアウト
  #   # 設定内容: 環境作成のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m"、"1h"）
  #   create = "30m"
  #
  #   # 更新タイムアウト
  #   # 設定内容: 環境更新のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m"、"1h"）
  #   update = "30m"
  #
  #   # 削除タイムアウト
  #   # 設定内容: 環境削除のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m"、"1h"）
  #   delete = "30m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースが作成された後、以下の属性を参照できます:
#
# - arn: 環境のARN
# - environment_id: 環境のID
# - id: 環境のID（environment_idと同値）
# - load_balancer_arn: 環境に関連付けられたロードバランサーのARN
# - tags_all: プロバイダーのdefault_tagsを含む全てのタグ
#-----------------------------------------------------------------------
