#----------------------------------------------------------------------
# AWS Dedicated Host
#----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# NOTE: instance_family または instance_type のいずれか一方の指定が必須です。
#       両方を同時に指定することはできません。
#
# Amazon EC2 Dedicated Host を割り当てます。
# Dedicated Host は、EC2インスタンスを実行するための専用物理サーバーです。
# 既存のサーバーバウンドソフトウェアライセンスを使用でき、コンプライアンス要件を満たすことができます。
#
# 主な用途:
#   - ライセンス要件: ソケット/コア/物理サーバーにバインドされたライセンスを使用
#   - コンプライアンス: 専用物理サーバーの使用が必要な規制要件への対応
#   - 可視性と制御: インスタンス配置の完全な可視性と制御
#   - コスト最適化: オンデマンドまたはReservationでコストを最適化
#
# 関連リソース:
#   - aws_instance: Dedicated Host上で起動するインスタンス
#   - aws_ec2_host_reservation: Dedicated Hostの予約購入
#
# Terraformドキュメント: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_host
# AWSドキュメント: https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/dedicated-hosts-overview.html
#----------------------------------------------------------------------

resource "aws_ec2_host" "example" {
  #----------------------------------------------------------------------
  # 必須設定
  #----------------------------------------------------------------------

  # 設定内容: Dedicated Hostを配置するアベイラビリティゾーン
  # 設定可能な値: us-east-1a, ap-northeast-1a など
  # 注意事項: インスタンスを起動する際は同じAZを指定する必要があります
  availability_zone = "ap-northeast-1a"

  #----------------------------------------------------------------------
  # インスタンスタイプ設定（instance_family または instance_type のいずれかが必須）
  #----------------------------------------------------------------------

  # 設定内容: Dedicated Hostがサポートするインスタンスファミリー
  # 設定可能な値: m5, c5, r5, t3, g4dn など
  # 用途: 同じファミリー内の複数のインスタンスサイズをサポート（例: m5.large, m5.xlarge, m5.2xlarge）
  # 注意事項: instance_type と同時に指定することはできません
  instance_family = "m5"

  # 設定内容: Dedicated Hostがサポートする特定のインスタンスタイプ
  # 設定可能な値: m5.large, c5.xlarge など
  # 用途: 単一のインスタンスタイプのみをサポート
  # 注意事項: instance_family と同時に指定することはできません
  instance_type = "m5.large"

  #----------------------------------------------------------------------
  # 配置とリカバリ設定
  #----------------------------------------------------------------------

  # 設定内容: インスタンスの自動配置を有効にするかどうか
  # 設定可能な値: on（有効）、off（無効）
  # 省略時: off
  # 用途: ターゲットホストを指定しないインスタンス起動を受け入れるかどうか
  # 推奨設定: マルチテナント的に使用する場合は "on"、特定インスタンス専用の場合は "off"
  auto_placement = "on"

  # 設定内容: ホストリカバリを有効にするかどうか
  # 設定可能な値: on（有効）、off（無効）
  # 省略時: off
  # 用途: ハードウェア障害発生時に新しいホストへ自動的にインスタンスをリカバリ
  # 推奨設定: 本番環境では "on" を推奨
  host_recovery = "on"

  #----------------------------------------------------------------------
  # AWS Outposts設定
  #----------------------------------------------------------------------

  # 設定内容: AWS Outpost上のアセットIDを指定
  # 用途: Outpost上の特定のハードウェアアセットをターゲットにする場合に使用
  # 注意事項: outpost_arn と併せて使用します
  asset_id = "asset-1234567890abcdef0"

  # 設定内容: Dedicated HostをデプロイするAWS OutpostのARN
  # 用途: オンプレミスやエッジロケーションでDedicated Hostを使用する場合
  # 注意事項: Outposts環境でのみ使用可能
  outpost_arn = "arn:aws:outposts:ap-northeast-1:123456789012:outpost/op-1234567890abcdef0"

  #----------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意事項: 通常は省略し、プロバイダー設定に従うことを推奨
  region = "ap-northeast-1"

  #----------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 用途: リソースの識別、コスト配分、自動化などに使用
  tags = {
    Name        = "example-dedicated-host"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #----------------------------------------------------------------------
  # タイムアウト設定
  #----------------------------------------------------------------------

  timeouts {
    # 設定内容: ホスト作成のタイムアウト時間
    # 省略時: 10m
    create = "10m"

    # 設定内容: ホスト更新のタイムアウト時間
    # 省略時: 10m
    update = "10m"

    # 設定内容: ホスト削除のタイムアウト時間
    # 省略時: 20m
    delete = "20m"
  }
}

#----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#----------------------------------------------------------------------
# このリソースから参照できる属性値:
#
# arn           - Dedicated HostのARN
# id            - Dedicated HostのID（ホストID: h-xxxxxxxxxxxxxxxxx形式）
# owner_id      - Dedicated Hostを所有するAWSアカウントID
# region        - Dedicated Hostが配置されているリージョン
# tags_all      - デフォルトタグを含むすべてのタグ
# asset_id      - Outpost上のアセットID（指定した場合）
#
# 参照例:
#   arn        = aws_ec2_host.example.arn
#   host_id    = aws_ec2_host.example.id
#   owner_id   = aws_ec2_host.example.owner_id
