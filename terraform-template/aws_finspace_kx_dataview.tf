#---------------------------------------
# aws_finspace_kx_dataview
#---------------------------------------
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/finspace_kx_dataview
# Generated: 2026-02-17
#
# Amazon FinSpace Kx Dataviewを管理するリソース
#
# 概要:
# - kdbデータベースのスナップショットを作成し、kdbクラスターにマウント可能な形式で提供
# - 階層化ストレージとプリウォームキャッシュを備えたデータビューを構成
# - スケーリンググループ上で実行されるクラスターでのみ利用可能（専用クラスターでは非サポート）
# - 自動更新型または静的なデータビューを選択可能
#
# 主な機能:
# - データベースのスナップショット管理
# - 高速アクセス用のディスク配置最適化
# - セグメント単位でのボリューム割り当て
# - 読み取り専用または書き込み可能モードの選択
# - 自動更新によるデータ同期
#
# 制約事項:
# - 書き込み可能なデータビューは部分的な作成が不可（データベース全体のパスが必要）
# - 書き込み可能データビューでは自動更新が無効化必須
# - 書き込み可能データビューには専用ボリュームが必要
# - 一度書き込み可能として作成したデータビューは読み取り専用に変更不可
# - 異なるボリューム上のパスは重複不可
#
# NOTE:
# - Amazon FinSpaceは2026年10月7日にサポート終了予定
# - タイムアウト設定はキャッシュタイプとボリュームサイズに応じて最大24時間まで延長が必要な場合あり

resource "aws_finspace_kx_dataview" "example" {
  #-------
  # 基本設定
  #-------
  # 設定内容: データビューの一意な識別子
  # 設定可能な値: 任意の文字列
  name = "my-kx-dataview"

  # 設定内容: KX環境の一意な識別子
  # 設定可能な値: 既存のFinSpace KX環境ID
  environment_id = "example-environment-id"

  # 設定内容: データビューを作成するデータベースの名前
  # 設定可能な値: 既存のKXデータベース名
  database_name = "example-database"

  #-------
  # 可用性設定
  #-------
  # 設定内容: クラスターに割り当てる可用性ゾーンの数
  # 設定可能な値:
  #   - SINGLE: クラスターごとに1つの可用性ゾーンを割り当て
  #   - MULTI: クラスターごとにすべての可用性ゾーンを割り当て
  az_mode = "SINGLE"

  # 設定内容: 可用性ゾーンの識別子
  # 設定可能な値: AWSの可用性ゾーンID（例: use1-az2）
  # 省略時: 指定なし
  # 注意: ボリュームをアタッチする場合、ボリュームはデータビューと同じ可用性ゾーンに存在する必要あり
  availability_zone_id = "use1-az2"

  #-------
  # データ更新設定
  #-------
  # 設定内容: 新しいチェンジセット取り込み時に、将来の追加と修正をデータビューに自動適用するかどうか
  # 設定可能な値: true（自動更新有効）、false（手動更新）
  # 省略時: false
  # 注意: read_writeがtrueの場合は、auto_updateをfalseに設定する必要あり
  auto_update = true

  # 設定内容: データ取り込みに使用するデータベースのチェンジセットの一意な識別子
  # 設定可能な値: 既存のチェンジセットID
  # 省略時: 指定なし
  changeset_id = "example-changeset-id"

  #-------
  # アクセスモード設定
  #-------
  # 設定内容: データベースメンテナンスのためにデータビューを書き込み可能にするかどうか
  # 設定可能な値: true（書き込み可能）、false（読み取り専用）
  # 省略時: false
  # 制約事項:
  #   - 部分的な書き込み可能データビューは作成不可（データベース全体のパスが必要）
  #   - 書き込み可能データビューでは更新不可（auto_updateをfalseに設定必須）
  #   - 書き込み可能データビューには一意なボリュームが必要
  #   - 一度書き込み可能として作成すると読み取り専用に変更不可
  read_write = false

  #-------
  # セグメント設定
  #-------
  # 設定内容: 選択した各ボリュームに配置するデータのデータベースパスを含む設定
  # 省略時: デフォルトのS3/オブジェクトストアセグメント経由でクラスターからアクセス可能
  # 注意: 各セグメントはボリュームごとに一意なデータベースパスを持つ必要あり
  segment_configurations {
    # 設定内容: 各ボリュームに配置するデータのデータベースパス
    # 設定可能な値: データベースパスのリスト（例: ["/*"], ["/2023/*"], ["/2023/01/*"]）
    # 注意: 各セグメントはボリュームごとに一意なデータベースパスを持つ必要あり
    db_paths = ["/*"]

    # 設定内容: データビューにアタッチするボリュームの名前
    # 設定可能な値: 既存のKXボリューム名
    # 注意: このボリュームはアタッチ先のデータビューと同じ可用性ゾーンに存在する必要あり
    volume_name = "example-volume"

    # 設定内容: データベースファイルまたはカラムへのアクセス時にオンデマンドキャッシングを有効化するかどうか
    # 設定可能な値: true（オンデマンドキャッシング有効）、false（すべてキャッシュ）
    # 省略時: false
    # 説明:
    #   - true: データビューは必要に応じてファイルシステム上のファイルを最小限ロード
    #   - false: すべてをキャッシュ
    on_demand = false
  }

  #-------
  # 説明・メタデータ
  #-------
  # 設定内容: データビューの説明
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  description = "Terraform managed Kx Dataview"

  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 注意: プロバイダーのdefault_tagsと結合される
  tags = {
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-------
  # リージョン設定
  #-------
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: us-east-1）
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"

  #-------
  # タイムアウト設定
  #-------
  # 設定内容: リソース操作のタイムアウト時間
  # 注意: キャッシュタイプとKXボリュームのサイズに応じて、作成/更新のタイムアウトを最大24時間、削除のタイムアウトを最大12時間まで延長する必要がある場合あり
  # timeouts {
  #   create = "24h"
  #   update = "24h"
  #   delete = "12h"
  # }
}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# arn                     - KXデータビューのARN
# created_timestamp       - データビューがFinSpaceで作成されたタイムスタンプ（エポックミリ秒）
# id                      - 環境ID、データベース名、データビュー名をカンマ区切りで結合した文字列
# last_modified_timestamp - データビューがFinSpaceで最後に更新されたタイムスタンプ（エポックミリ秒）
# status                  - データビューのステータス
# tags_all                - プロバイダーのdefault_tagsを含むすべてのタグのマップ
