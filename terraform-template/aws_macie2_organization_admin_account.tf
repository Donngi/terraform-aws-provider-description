#######################################################################
# Macie2 組織委任管理者アカウント
#######################################################################
# AWS Organizations の主アカウントから特定のメンバーアカウントを
# Amazon Macie の委任管理者として指定するリソース。
# 委任管理者アカウントは組織全体のMacie設定・メンバー管理を担当する。
#
# 主な用途:
# - Organizations 全体のAmazon Macie管理を専用アカウントへ委任
# - セキュリティ専用アカウントへのMacie管理権限の集約
# - マルチアカウント構成でのAmazon Macie一元管理
#
# 前提条件:
# - このリソースを使用するAWSアカウントがOrganizationsの主アカウントであること
# - Organizations で macie.amazonaws.com のサービスアクセスが有効化されていること
# - 指定アカウントに aws_macie2_account が作成されていること
#
# 参考: https://docs.aws.amazon.com/macie/latest/user/accounts-orgs-delegate.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/macie2_organization_admin_account
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_macie2_organization_admin_account" "example" {
  #-----------------------------------------------------------------------
  # 委任管理者アカウントの設定
  #-----------------------------------------------------------------------

  # Macie委任管理者として指定するAWSアカウントID
  # 設定内容: 組織内のAmazon Macie管理を委任するメンバーアカウントの12桁のID
  # 設定可能な値: 有効なAWSアカウントID（例: "123456789012"）
  # 注意: このリソースを適用するアカウントはOrganizationsの主アカウントである必要がある
  # 注意: 指定アカウントに事前にMacieアカウントが有効化されていること
  admin_account_id = "123456789012"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   委任管理者として指定されたAWSアカウントID（admin_account_idと同一）
#-----------------------------------------------------------------------
