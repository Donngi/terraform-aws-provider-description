#---------------------------------------
# Resource: aws_codecatalyst_source_repository
#---------------------------------------
# AWS CodeCatalyst プロジェクト内のソースリポジトリを作成・管理
# CodeCatalyst は AWS のソフトウェア開発サービスで、
# プロジェクト管理、コードリポジトリ、CI/CD などを統合提供します。
#
# Generated: 2026-02-12
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/codecatalyst_source_repository
#
# NOTE: このテンプレートは CodeCatalyst サービスのソースリポジトリを定義します。
#       使用前に CodeCatalyst スペースとプロジェクトが作成されている必要があります。
#---------------------------------------

resource "aws_codecatalyst_source_repository" "example" {
  #---------------------------------------
  # 基本設定
  #---------------------------------------

  #---------------------------------------
  # リポジトリ名
  #---------------------------------------
  # 設定内容: CodeCatalyst プロジェクト内で一意のソースリポジトリ名
  # 設定可能な値: 任意の文字列（プロジェクト内で一意である必要がある）
  # 省略時: 設定必須
  #---------------------------------------
  name = "example-repository"

  #---------------------------------------
  # プロジェクト名
  #---------------------------------------
  # 設定内容: リポジトリを作成する CodeCatalyst プロジェクトの名前
  # 設定可能な値: 既存の CodeCatalyst プロジェクト名
  # 省略時: 設定必須
  #---------------------------------------
  project_name = "example-project"

  #---------------------------------------
  # スペース名
  #---------------------------------------
  # 設定内容: プロジェクトが属する CodeCatalyst スペースの名前
  # 設定可能な値: 既存の CodeCatalyst スペース名
  # 省略時: 設定必須
  #---------------------------------------
  space_name = "example-space"

  #---------------------------------------
  # リポジトリの説明
  #---------------------------------------
  # 設定内容: ソースリポジトリの説明文
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  #---------------------------------------
  description = "CodeCatalyst source repository for example application"

  #---------------------------------------
  # リージョン
  #---------------------------------------
  # 設定内容: リソースを管理するリージョン
  # 設定可能な値: AWS リージョン名（例: us-west-2）
  # 省略時: プロバイダー設定のリージョンを使用
  #---------------------------------------
  region = "us-west-2"

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------
  # 設定内容: リソース操作のタイムアウト時間
  # 設定可能な値: 時間文字列（例: "5m", "1h"）
  # 省略時: デフォルトのタイムアウト値を使用
  #---------------------------------------
  timeouts {
    # create = "10m"  # 作成時のタイムアウト
    # update = "10m"  # 更新時のタイムアウト
    # delete = "10m"  # 削除時のタイムアウト
  }
}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# id - リソースの一意識別子（space_name:project_name:name の形式）
