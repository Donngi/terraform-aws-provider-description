#----------------------------------------------------------------------
# Amazon FSx File Cache
#----------------------------------------------------------------------
# Amazon FSx File Cacheは、オンプレミスやマルチクラウド環境のファイルデータに
# 高速アクセスを提供するキャッシュリソースです。S3やNFSv3データリポジトリと
# 連携し、Lustreファイルシステムベースの高性能キャッシュレイヤーを提供します。
#
# 主な用途:
# - オンプレミスファイルサーバーへの高速アクセス
# - マルチクラウドデータの統合アクセスポイント
# - S3データの高速キャッシュレイヤー
# - NFSv3データリポジトリの性能向上
#
# 公式ドキュメント:
# https://docs.aws.amazon.com/fsx/latest/FileCacheGuide/what-is.html
# Terraform公式ドキュメント:
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/fsx_file_cache
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# NOTE: このテンプレートは、Amazon FSx File Cacheの全設定項目を網羅したリファレンスです。
# 実際の使用時は、要件に応じて必要な項目のみを有効化してください。
#----------------------------------------------------------------------

resource "aws_fsx_file_cache" "example" {
  #----------------------------------------------------------------------
  # 基本設定
  #----------------------------------------------------------------------

  # 設定内容: ファイルキャッシュのタイプ
  # 設定可能な値: LUSTRE（現在サポートされている唯一の値）
  # 例: Lustreベースの高性能キャッシュを作成
  file_cache_type = "LUSTRE"

  # 設定内容: キャッシュタイプのバージョン
  # 設定可能な値: 2.12（現在サポートされている唯一の値）
  # 例: 最新のLustreキャッシュバージョンを指定
  file_cache_type_version = "2.12"

  # 設定内容: キャッシュのストレージ容量（GiB単位）
  # 設定可能な値:
  #   - 1200 GiB（最小サイズ）
  #   - 2400 GiB
  #   - 2400 GiB単位で増加（4800, 7200, 9600...）
  # 例: 初期構成では1200 GiB、大規模データセットでは2400 GiB以上
  storage_capacity = 1200

  # 設定内容: キャッシュがアクセス可能なサブネットIDのリスト
  # 設定可能な値: 1つのサブネットIDのみ指定可能
  # 例: プライベートサブネット内に配置してセキュアなアクセスを提供
  subnet_ids = ["subnet-12345678"]

  #----------------------------------------------------------------------
  # ネットワーク設定
  #----------------------------------------------------------------------

  # 設定内容: すべてのネットワークインターフェースに適用するセキュリティグループIDのリスト
  # 設定可能な値: 既存のセキュリティグループID
  # 省略時: VPCのデフォルトセキュリティグループが使用される
  # 例: NFSポート2049やLustreポート988, 1021-1023へのアクセスを制御
  security_group_ids = ["sg-12345678"]

  #----------------------------------------------------------------------
  # データリポジトリ連携
  #----------------------------------------------------------------------

  # 設定内容: データリポジトリアソシエーション（DRA）の設定
  # 設定可能な値: 最大8つのDRA設定
  # 制約事項:
  #   - すべてのDRAは同じタイプ（全てS3または全てNFS）である必要がある
  #   - NFSの場合はNFSv3プロトコルをサポートするファイルシステムのみ
  #   - DRAの自動インポート/エクスポートはサポートされない
  # 例: オンプレミスNFSサーバーまたはS3バケットをキャッシュにリンク
  data_repository_association {
    # 設定内容: キャッシュ上のマウントパス
    # 設定可能な値: /ns1/, /ns1/subdir/ などの形式（先頭スラッシュ必須）
    # 制約事項:
    #   - 2つのDRAで重複するキャッシュパスは設定不可
    #   - ルートパス（/）はNFS DRAかつdata_repository_subdirectoriesが
    #     指定されている場合のみ設定可能（この場合1つのDRAのみ作成可能）
    #   - S3 DRAではルートパス（/）は設定不可
    file_cache_path = "/ns1"

    # 設定内容: S3またはNFSデータリポジトリへのパス
    # 設定可能な値:
    #   - S3: s3://bucket-name/prefix/
    #   - NFS: nfs://filer.domain.com
    # 例: オンプレミスNFSサーバーのドメイン名を指定
    data_repository_path = "nfs://filer.domain.com"

    # 設定内容: NFSエクスポートパスのリスト
    # 設定可能な値: /exportpath1 形式のパス（最大500個）
    # 制約事項:
    #   - data_repository_pathにNFSファイルシステムのドメイン名を指定する必要がある
    #   - S3データリポジトリではサポートされない
    # 例: 特定のNFSエクスポートディレクトリのみをキャッシュ対象とする
    # data_repository_subdirectories = ["test", "test2"]

    # 設定内容: NFSデータリポジトリの接続設定
    nfs {
      # 設定内容: NFSプロトコルのバージョン
      # 設定可能な値: NFS3（NFSv3プロトコル、現在サポートされている唯一の値）
      version = "NFS3"

      # 設定内容: NFSファイルシステムのドメイン名解決に使用するDNSサーバーのIPアドレス
      # 設定可能な値: 最大2つのIPアドレス
      # 例:
      #   - VPC内のDNSフォワーダー/リゾルバーのIPアドレス
      #   - オンプレミスDNSサーバーのIPアドレス
      # dns_ips = ["192.168.0.1", "192.168.0.2"]
    }

    # 設定内容: DRAに適用するタグ
    # 省略時: キャッシュのタグは自動的にコピーされない
    # tags = {
    #   Environment = "production"
    #   Purpose     = "nfs-cache"
    # }
  }

  # 設定内容: キャッシュのタグをデータリポジトリアソシエーションにコピーするかどうか
  # 設定可能な値: true / false
  # 省略時: false
  # 例: 統一的なタグ管理のためtrueを設定
  copy_tags_to_data_repository_associations = false

  #----------------------------------------------------------------------
  # Lustre設定
  #----------------------------------------------------------------------

  # 設定内容: Lustreファイルキャッシュの詳細設定
  # 必須条件: file_cache_typeがLUSTREの場合は必須
  lustre_configuration {
    # 設定内容: キャッシュのデプロイメントタイプ
    # 設定可能な値: CACHE_1（現在サポートされている唯一の値）
    deployment_type = "CACHE_1"

    # 設定内容: Lustre MDT（Metadata Target）ストレージボリュームの設定
    # 必須設定: 少なくとも1つ、最大8つまで設定可能
    metadata_configuration {
      # 設定内容: MDTストレージの容量（GiB単位）
      # 設定可能な値: 2400 GiB（現在サポートされている唯一の値）
      # 例: メタデータの保存とファイルシステム管理に使用
      storage_capacity = 2400
    }

    # 設定内容: 1 TiBのキャッシュストレージ容量あたりの読み書きスループット（MB/s/TiB）
    # 設定可能な値: 1000（現在サポートされている唯一の値）
    # 例: 1200 GiBキャッシュの場合、約1000 MB/sのスループットを提供
    per_unit_storage_throughput = 1000

    # 設定内容: 週次メンテナンスウィンドウの開始時刻
    # 設定可能な値: D:HH:MM 形式
    #   - D: 曜日（1=月曜日、7=日曜日）
    #   - HH: 時（00-23）
    #   - MM: 分（00-59）
    # 省略時: AWSが自動的にメンテナンス時刻を選択
    # 例: 業務時間外にメンテナンスをスケジュール
    # weekly_maintenance_start_time = "2:05:00"
  }

  #----------------------------------------------------------------------
  # 暗号化設定
  #----------------------------------------------------------------------

  # 設定内容: データ暗号化に使用するAWS KMSキーのID
  # 設定可能な値: KMSキーのARNまたはキーID
  # 省略時: アカウントのAmazon FSx管理のKMSキーが使用される
  # 例: カスタムKMSキーで暗号化制御を強化
  kms_key_id = "arn:aws:kms:us-west-2:111122223333:key/1234abcd-12ab-34cd-56ef-1234567890ab"

  #----------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------

  # 設定内容: リソースが管理されるAWSリージョン
  # 省略時: プロバイダー設定で指定されたリージョンが使用される
  # 例: マルチリージョン構成で明示的にリージョンを指定
  region = "us-west-2"

  #----------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------

  # 設定内容: ファイルキャッシュに適用するタグ
  # 例: リソース管理、コスト配分、環境識別に使用
  tags = {
    Name        = "production-file-cache"
    Environment = "production"
    Team        = "platform"
    CostCenter  = "engineering"
  }

  #----------------------------------------------------------------------
  # タイムアウト設定
  #----------------------------------------------------------------------

  # 設定内容: 各操作のタイムアウト時間
  # timeouts {
  #   create = "30m"
  #   update = "30m"
  #   delete = "30m"
  # }
}

#----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#----------------------------------------------------------------------
# このリソースの作成後、以下の属性を参照できます:
#
# arn - ファイルキャッシュのAmazon Resource Name（ARN）
#   例: arn:aws:fsx:us-west-2:123456789012:file-cache/fc-0123456789abcdef0
#
# data_repository_association_ids - キャッシュに関連付けられたDRAのIDリスト
#   例: ["dra-0123456789abcdef0", "dra-abcdef0123456789"]
#
# dns_name - キャッシュのDNS名
#   例: fc-0123456789abcdef0.fsx.us-west-2.amazonaws.com
#
# file_cache_id - システムが生成したキャッシュの一意のID
#   例: fc-0123456789abcdef0
#
# id - キャッシュのID（file_cache_idと同じ）
#
# network_interface_ids - ネットワークインターフェースIDのリスト
#   例: ["eni-0123456789abcdef0"]
#
# vpc_id - Virtual Private Cloud（VPC）のID
#   例: vpc-0123456789abcdef0
#----------------------------------------------------------------------
