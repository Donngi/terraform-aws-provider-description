  tags = {
    Name        = "my-snapshot"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: スナップショット作成操作のタイムアウト時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "60m", "2h"）
    # 省略時: プロバイダーのデフォルトタイムアウトを使用
    create = "120m"

    # delete (Optional)
    # 設定内容: スナップショット削除操作のタイムアウト時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "60m", "2h"）
