#---------------------------------------------------------------
# MemoryDB スナップショット
#---------------------------------------------------------------
#
# MemoryDBクラスターの手動スナップショットをプロビジョニングします。
# スナップショットはクラスターの特定時点のバックアップであり、
# クラスターの再作成やデータのリストアに使用できます。
# 全てのスナップショットはAmazon S3に保存され、耐久性が確保されます。
#
# AWS公式ドキュメント:
#   - スナップショットと復元: https://docs.aws.amazon.com/memorydb/latest/devguide/snapshots.html
#   - 手動スナップショットの作成: https://docs.aws.amazon.com/memorydb/latest/devguide/snapshots-manual.html
#   - 保管時の暗号化: https://docs.aws.amazon.com/memorydb/latest/devguide/at-rest-encryption.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/memorydb_snapshot
#
# Provider Version: 6.28.0
# Generated: 2026-01-31
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_memorydb_snapshot" "example" {
  #---------------------------------------------------------------
  # 基本設定
  #---------------------------------------------------------------

  # cluster_name (Required, Forces new resource)
  # 設定内容: スナップショットを作成するMemoryDBクラスターの名前を指定します。
  # 設定可能な値: 既存のMemoryDBクラスター名
  # 注意: この値を変更すると新しいリソースが作成されます。
  #       スナップショット作成中は、クラスターに対する他のAPI/CLI操作は実行できません。
  #       24時間以内にクラスターあたり最大20個の手動スナップショットを作成できます。
  # 参考: https://docs.aws.amazon.com/memorydb/latest/devguide/snapshots-constraints.html
  cluster_name = "example-cluster"

  #---------------------------------------------------------------
  # 名前設定
  #---------------------------------------------------------------

  # name (Optional, Forces new resource)
  # 設定内容: スナップショットの名前を指定します。
  # 設定可能な値: 文字列
  # 省略時: Terraformがランダムで一意な名前を自動生成します。
  # 注意: name_prefixと排他的（どちらか一方のみ指定可能）
  #       この値を変更すると新しいリソースが作成されます。
  name = "my-snapshot"

  # name_prefix (Optional, Forces new resource)
  # 設定内容: スナップショット名のプレフィックスを指定します。
  # 設定可能な値: 文字列。Terraformが後ろにランダムなサフィックスを追加します。
  # 注意: nameと排他的（どちらか一方のみ指定可能）
  #       この値を変更すると新しいリソースが作成されます。
  # name_prefix = null

  #---------------------------------------------------------------
  # リージョン設定
  #---------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  # region = null

  #---------------------------------------------------------------
  # 暗号化設定
  #---------------------------------------------------------------

  # kms_key_arn (Optional, Forces new resource)
  # 設定内容: スナップショットの暗号化に使用するKMSキーのARNを指定します。
  # 設定可能な値: 有効なKMSキーARN
  # 省略時: デフォルトのサービス管理キーが使用されます。
  # 関連機能: MemoryDB 保管時の暗号化
  #   MemoryDBはS3に保存されるスナップショットの暗号化をサポートしています。
  #   デフォルト（サービス管理）暗号化と、AWS KMSのカスタマー管理キーの両方に対応しています。
  #   - https://docs.aws.amazon.com/memorydb/latest/devguide/at-rest-encryption.html
  # 注意: カスタマー管理キーを使用する場合は、事前にAWS KMSでキーを作成する必要があります。
  #       この値を変更すると新しいリソースが作成されます。
  # kms_key_arn = null

  #---------------------------------------------------------------
  # タグ設定
  #---------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、ここで指定した値で上書きされます。
  tags = {
    Name        = "example-snapshot"
    Environment = "production"
  }

  #---------------------------------------------------------------
  # タイムアウト設定
  #---------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: スナップショット作成のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "20m", "1h"）
    # 省略時: デフォルトは20分です。
    # 注意: 大きなクラスターの場合、より長い時間を設定することを推奨します。
    # create = "20m"

    # delete (Optional)
    # 設定内容: スナップショット削除のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "20m", "1h"）
    # 省略時: デフォルトは20分です。
    # delete = "20m"
  }
}

#---------------------------------------------------------------
# Attributes Reference（読み取り専用属性）
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: スナップショットの名前（nameと同じ値）
#
# - arn: スナップショットのAmazon Resource Name (ARN)
#        形式: arn:aws:memorydb:region:account-id:snapshot/snapshot-name
#
# - cluster_configuration: スナップショット作成元のクラスター設定情報（リスト型）
#                          以下のサブ属性を含みます:
#   - description: クラスターの説明
#   - engine: クラスターノードで実行されるエンジン
#   - engine_version: エンジンのバージョン番号
#   - maintenance_window: メンテナンスウィンドウ（週次）
#   - name: クラスターの名前
#   - node_type: ノードのコンピュート・メモリ容量
#   - num_shards: クラスター内のシャード数
#   - parameter_group_name: 関連付けられたパラメータグループ名
#   - port: クラスターが接続を受け付けるポート番号
#   - snapshot_retention_limit: 自動スナップショットの保持日数
#   - snapshot_window: 日次スナップショットを開始する時間帯（UTC）
#   - subnet_group_name: クラスターが使用するサブネットグループ名
#   - topic_arn: クラスター通知を送信するSNSトピックのARN
#   - vpc_id: クラスターが存在するVPCのID
#
# - source: スナップショットの作成元を示す文字列
#           - "manual": 手動で作成されたスナップショット
#           - "automated": 自動バックアップからのスナップショット
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#---------------------------------------------------------------
