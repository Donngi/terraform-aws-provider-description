#######################################################################
# Lambda Function Recursion Config
#######################################################################
# Lambda関数の再帰ループ検出と自動停止を設定するリソース。
# Lambda関数が自身を再帰的に呼び出し続けるループを検知した場合に、
# 自動的に関数の実行を停止してコストの無限増大を防ぐことができる。
#
# 主な用途:
# - Lambda関数の再帰ループによる意図しないコスト増大の防止
# - SQSやSNSを介した間接的な再帰呼び出しの検出と停止
# - 本番環境でのLambda関数安全運用
#
# 参考: https://docs.aws.amazon.com/lambda/latest/dg/invocation-recursion.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/lambda_function_recursion_config
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_lambda_function_recursion_config" "example" {
  #-----------------------------------------------------------------------
  # 関数の識別設定
  #-----------------------------------------------------------------------

  # 再帰ループ検出を設定するLambda関数の名前
  # 設定内容: 対象Lambda関数の名前またはARN
  # 設定可能な値: 関数名（例: "my-function"）またはARN
  function_name = aws_lambda_function.example.function_name

  #-----------------------------------------------------------------------
  # 再帰ループ検出の設定
  #-----------------------------------------------------------------------

  # 再帰ループ検出時の動作設定
  # 設定内容: 再帰ループを検出した際にLambdaが実行を停止するかどうかを制御する
  # 設定可能な値:
  #   - Allow: 再帰ループを検出しても実行を継続する（検出のみ）
  #   - Terminate: 再帰ループを検出したら自動的に実行を停止する（推奨）
  # 省略時: なし（必須項目）
  recursive_loop = "Terminate"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   Lambda関数の名前（function_nameと同値）
#-----------------------------------------------------------------------
