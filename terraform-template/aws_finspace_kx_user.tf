#--------------------------------------------------------------

#---------------------------------------------------------------
# 基本設定
#---------------------------------------------------------------

resource "aws_finspace_kx_user" "example" {
  #---------------------------------------------------------------
  # 必須パラメータ
  #---------------------------------------------------------------

  # 設定内容: ユーザーの一意識別子
  # 設定可能な値: 1文字以上の文字列
  name = "my-kx-user"

  # 設定内容: FinSpace Kx環境のID
  # 設定可能な値: 既存のFinSpace Kx環境ID
  environment_id = "kx-environment-id"

  # 設定内容: ユーザーに関連付けるIAMロールのARN
  # 設定可能な値: 有効なIAMロールARN
  iam_role = "arn:aws:iam::123456789012:role/example-role"

  #---------------------------------------------------------------
  # リージョン設定
  #---------------------------------------------------------------

  # 設定内容: このリソースを管理するリージョン
  # 設定可能な値: 有効なAWSリージョン名（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #---------------------------------------------------------------
  # タグ設定
  #---------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-kx-user"
    Environment = "production"
    ManagedBy   = "terraform"
  }
}

