resource "aws_datazone_project" "example" {
  #-------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------

  # domain_identifier (Required)
  # 設定内容: プロジェクトが属するDataZoneドメインの識別子を指定します。
  # 設定可能な値: `^dzd[-_][a-zA-Z0-9_-]{1,36}$` の正規表現に一致する文字列
  # 注意: リソース作成後の変更はできません（Forces new resource）
  # 関連機能: DataZoneドメインはアセット、ユーザー、プロジェクトを組織化するエンティティです。
  #   複数のAWSアカウントからデータソースをまとめるために使用できます。
  domain_identifier = aws_datazone_domain.example.id

  # name (Required)
  # 設定内容: プロジェクトの名前を指定します。
  # 設定可能な値: `^[\w -]+$` の正規表現に一致し、最大64文字の文字列
  # 注意: プロジェクト名はユーザーがDataZoneポータルで識別するために使用されます
