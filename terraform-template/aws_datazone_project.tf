  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソースの作成・削除操作に対するタイムアウトを指定します。
  timeouts {
    # create (Optional)
    # 設定内容: プロジェクト作成のタイムアウト時間を指定します。
    # 設定可能な値: 時間の長さを表す文字列（例: "30s", "2h45m"）
    # 有効な時間単位: "s"（秒）, "m"（分）, "h"（時）
    # 省略時: デフォルトのタイムアウトが適用されます
    create = "10m"

    # delete (Optional)
    # 設定内容: プロジェクト削除のタイムアウト時間を指定します。
    # 設定可能な値: 時間の長さを表す文字列（例: "30s", "2h45m"）
    # 有効な時間単位: "s"（秒）, "m"（分）, "h"（時）
    # 省略時: デフォルトのタイムアウトが適用されます
    # 注意: 削除操作のタイムアウトは、destroy操作前に変更が
    #   ステートに保存された場合にのみ適用されます。
    delete = "10m"
  }
}

