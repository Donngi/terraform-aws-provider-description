  #   チームメンバーがプロジェクトの内容を理解しやすくなります。
  description = "Example DataZone project for data collaboration"

  # glossary_terms (Optional)
  # 設定内容: プロジェクトで使用できるビジネス用語集の用語IDリストを指定します。
  # 設定可能な値: `[a-zA-Z0-9_-]{1,36}$` の正規表現に一致する用語IDの配列
  # 制約: リストは空にできず、20個以下の値を含める必要があります
  # 省略時: ビジネス用語集は関連付けられません
  # 関連機能: ビジネス用語集はデータに関連付けられるビジネス用語のコレクションです。
  #   用語はアセットやカラムに関連付けることができ、組織全体で一貫した用語を使用できます。
  #   - https://docs.aws.amazon.com/datazone/latest/userguide/create-maintain-term.html
  glossary_terms = null

  # skip_deletion_check (Optional)
  # 設定内容: プロジェクト内のすべての子エンティティを削除するフラグを指定します。
  # 設定可能な値: true または false
  # 省略時: false（子エンティティがある場合は削除がブロックされる）
  # 注意: trueに設定すると、プロジェクト削除時にプロジェクト内の
