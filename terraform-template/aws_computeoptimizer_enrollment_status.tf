/*
AWS Compute Optimizer 登録ステータス設定

Provider Version: 6.28.0
Generated: 2026-02-13
Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/computeoptimizer_enrollment_status

Compute Optimizer はマシンラーニングを使用して、EC2インスタンス、Auto Scaling グループ、
EBSボリューム、Lambdaファンクションなどの AWS リソースの最適な設定を分析し推奨します。
このリソースではアカウントのCompute Optimizer サービスへの登録ステータスを管理します。

NOTE:
・登録を有効化すると、Compute Optimizerが過去14日間のリソース使用状況を分析開始
・組織の管理アカウントの場合、メンバーアカウントの一括登録も可能
・登録解除するとリソース推奨情報の取得が停止される
・分析結果が表示されるまで12時間以上かかる場合がある

【主な用途】
・コスト最適化のための推奨事項取得
・パフォーマンス改善の提案受領
・組織全体でのリソース最適化管理

【関連リソース】
・aws_ce_cost_category - コスト管理カテゴリ設定
・aws_budgets_budget - コスト予算設定
*/

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_computeoptimizer_enrollment_status" "example" {
  # 設定内容: Compute Optimizer サービスへの登録ステータス
  # 設定可能な値:
  #   - Active   : サービスを有効化しリソース分析を実行
  #   - Inactive : サービスを無効化し分析を停止
  # 注意: ステータス変更には数分かかる場合がある
  status = "Active"

  #-----------------------------------------------------------------------
  # 組織設定
  #-----------------------------------------------------------------------

  # 設定内容: 組織メンバーアカウントを一括登録するかどうか
  # 設定可能な値: true（一括登録する）、false（管理アカウントのみ登録）
  # 省略時: false
  # 注意: この設定は組織の管理アカウントでのみ有効
  include_member_accounts = false

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: Compute Optimizer は複数リージョンで個別に登録が必要
  region = null

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 設定内容: リソース作成時のタイムアウト時間
  #   # 省略時: 10m
  #   # create = "10m"

  #   # 設定内容: リソース更新時のタイムアウト時間
  #   # 省略時: 10m
  #   # update = "10m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------

# このリソースでは以下の属性が参照可能です:
#
# ■ id
#   リソースの一意識別子（AWSアカウントID:リージョン形式）
#
# ■ number_of_member_accounts_opted_in
#   組織メンバーアカウントのうち、Compute Optimizer に登録されているアカウント数
#   組織の管理アカウントでのみ利用可能
#
# ■ status
#   現在の登録ステータス（Active または Inactive）
#
# ■ include_member_accounts
#   メンバーアカウント一括登録の設定値
#
# ■ region
#   リソースが管理されているリージョン
