#---------------------------------------------------------------
# AWS Rekognition Collection
#---------------------------------------------------------------
#
# Amazon Rekognitionで顔データを格納・管理するためのコレクションリソースです。
# コレクションは顔のベクトル情報を保存し、顔検索や顔認証などの用途に使用されます。
# 実際の画像は保存されず、顔の数学的表現のみが格納されます。
#
# AWS公式ドキュメント:
#   - Rekognition Collectionの管理: https://docs.aws.amazon.com/rekognition/latest/dg/managing-face-collections.html
#   - Collectionでの顔検索: https://docs.aws.amazon.com/rekognition/latest/dg/collections.html
#   - 顔のインデックス化: https://docs.aws.amazon.com/rekognition/latest/dg/add-faces-to-collection-procedure.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/rekognition_collection
#
# Provider Version: 6.28.0
# Generated: 2025-02-03
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_rekognition_collection" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # collection_id (Required)
  # 設定内容: コレクションの名前を指定します。
  # 設定可能な値: 1～255文字の英数字、アンダースコア、ピリオド、ダッシュ
  # 注意: 同一リージョン内でユニークである必要があります
  # 用途: 顔ベクトルの保存先として使用されるコレクションの識別子
  collection_id = "my-collection"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: コレクションは特定のリージョンに作成され、リージョン間で共有されません
  #       また、各コレクションは作成時点の最新の顔検出モデルバージョンに関連付けられます
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 注意: プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  # 用途: リソースの整理、コスト配分、アクセス制御などに使用
  tags = {
    Name        = "my-collection"
    Environment = "production"
    Purpose     = "face-recognition"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: RekognitionコレクションのAmazon Resource Name (ARN)
#
# - face_model_version: コレクションが初期化された際の顔モデルバージョン
#   各コレクションは作成時の最新モデルに関連付けられます。
#   モデルバージョンは後から変更できません。
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#
#---------------------------------------------------------------
# 使用例とベストプラクティス
#---------------------------------------------------------------
#
# 1. 顔のインデックス化:
#    コレクション作成後、IndexFaces APIを使用して画像から顔を検出し、
#    コレクションに顔ベクトルを追加します。
#
# 2. 顔検索:
#    - SearchFacesByImage: 入力画像の顔をコレクション内の顔と照合
#    - SearchFaces: 既知の顔IDを使用してコレクション内の類似顔を検索
#    - SearchUsers: ユーザーベクトルを使用して顔を検索（精度向上）
#
# 3. ユーザー管理:
#    同一人物の複数の顔ベクトルを1つのユーザーベクトルに関連付けることで、
#    検索精度を向上させることができます。
#
# 4. セキュリティ考慮事項:
#    - コレクションには顔の数学的表現のみが保存され、実際の画像は保存されません
#    - IAMポリシーを使用してコレクションへのアクセスを制御してください
#    - 機密性の高い用途では、適切な暗号化とアクセスログを設定してください
#
# 5. コスト最適化:
#    - 不要なコレクションは削除してストレージコストを削減
#    - 検索頻度が低い顔は定期的に見直しを行う
#
# 6. リージョン選択:
#    - レイテンシーを最小化するため、アプリケーションに近いリージョンを選択
#    - コンプライアンス要件（データレジデンシーなど）を考慮
#
#---------------------------------------------------------------
