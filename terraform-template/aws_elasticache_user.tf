#-----------------------------------------------------------------------
# ElastiCache User
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/elasticache_user
#
# 用途: ElastiCacheクラスター（Redis/Valkey）のユーザーアカウントを作成・管理
# ドキュメント: https://docs.aws.amazon.com/AmazonElastiCache/latest/red-ug/Clusters.RBAC.html
# 前提条件:
#   - ElastiCacheクラスターが存在すること
#   - Redis 6.0以降またはValkeyエンジンが必要
#   - RBACが有効化されていること
#
# NOTE: パスワードはTerraformのステートファイルに平文で保存されます。
#       IAM認証を使用する場合は認証モード設定が必須です。
#       ユーザーごとに最大2つのパスワードを設定可能です。
#-----------------------------------------------------------------------

resource "aws_elasticache_user" "example" {

  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # 設定内容: ユーザーID（一意の識別子）
  # 設定可能な値: 英数字、ハイフン、アンダースコアを含む文字列
  # 注意事項: 作成後の変更不可（再作成が必要）
  user_id = "example-user-id"

  # 設定内容: ユーザー名（実際のログインに使用される名前）
  # 設定可能な値: 英数字、ハイフン、アンダースコアを含む文字列
  # 注意事項: 作成後の変更不可（再作成が必要）
  user_name = "example-username"

  # 設定内容: キャッシュエンジンの種類
  # 設定可能な値: "redis", "valkey"（大文字小文字を区別しない）
  # 注意事項: Redis 6.0以降またはValkeyエンジンでのみ使用可能
  engine = "redis"

  # 設定内容: アクセス権限文字列（ユーザーの操作権限を定義）
  # 設定可能な値: Redis ACL構文に準拠した文字列
  #   - on/off: ユーザーの有効/無効
  #   - ~pattern: アクセス可能なキーパターン
  #   - +@category/-@category: コマンドカテゴリの許可/拒否
  #   - +command/-command: 個別コマンドの許可/拒否
  # 参考: https://docs.aws.amazon.com/AmazonElastiCache/latest/red-ug/Clusters.RBAC.html#Access-string
  # 例: "on ~* +@all" - すべてのキーとコマンドへのフルアクセス
  # 例: "on ~app::* -@all +@read" - app::プレフィックスのキーへの読み取り専用アクセス
  access_string = "on ~* +@all"

  #-----------------------------------------------------------------------
  # 認証設定
  #-----------------------------------------------------------------------

  # 設定内容: パスワード認証を使用しない設定
  # 設定可能な値: true, false
  # 省略時: false
  # 注意事項: trueの場合、passwordsとauthentication_modeは使用不可
  no_password_required = null

  # 設定内容: ユーザーのパスワード（最大2つ）
  # 設定可能な値: 文字列のセット（各パスワードは16-128文字）
  # 注意事項:
  #   - センシティブ情報として扱われる
  #   - ステートファイルに平文で保存される
  #   - authentication_modeと併用不可
  passwords = null

  #-----------------------------------------------------------------------
  # 認証モード設定（authentication_modeブロック）
  #-----------------------------------------------------------------------
  # 用途: IAM認証またはパスワード認証のモードを指定
  # 注意事項:
  #   - 最大1つのブロックのみ指定可能
  #   - passwordsとの併用不可
  #-----------------------------------------------------------------------

  # authentication_mode {
  #   # 設定内容: 認証タイプ
  #   # 設定可能な値: "password", "no-password-required", "iam"
  #   # 注意事項:
  #   #   - "iam": IAM認証を使用（passwordsは不要）
  #   #   - "password": パスワード認証を使用（passwordsが必須）
  #   #   - "no-password-required": 認証不要（非推奨）
  #   type = "password"
  #
  #   # 設定内容: 認証用パスワード（typeが"password"の場合のみ）
  #   # 設定可能な値: 文字列のセット（各パスワードは16-128文字、最大2つ）
  #   # 省略時: typeが"password"の場合はエラー
  #   # 注意事項: センシティブ情報として扱われる
  #   passwords = ["password1", "password2"]
  # }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: ユーザーを作成するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: ユーザーに付与するタグ
  # 設定可能な値: キーと値の文字列マップ
  # 省略時: タグなし
  # 注意事項: コスト配分タグとして使用可能
  tags = {
    Name        = "example-user"
    Environment = "production"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定（timeoutsブロック）
  #-----------------------------------------------------------------------
  # 用途: リソース操作のタイムアウト時間をカスタマイズ
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 設定内容: ユーザー作成時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "5m", "1h"）
  #   # 省略時: デフォルトのタイムアウト値を使用
  #   create = "10m"
  #
  #   # 設定内容: ユーザー更新時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "5m", "1h"）
  #   # 省略時: デフォルトのタイムアウト値を使用
  #   update = "10m"
  #
  #   # 設定内容: ユーザー削除時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "5m", "1h"）
  #   # 省略時: デフォルトのタイムアウト値を使用
  #   delete = "10m"
  #
  #   # 設定内容: ユーザー情報読み取り時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "5m", "1h"）
  #   # 省略時: デフォルトのタイムアウト値を使用
  #   read = "10m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# arn          - 作成されたElastiCacheユーザーのARN
# id           - ユーザーID（user_idと同じ値）
# tags_all     - デフォルトタグを含むすべてのタグのマップ
#
# authentication_modeブロック内:
# password_count - 設定されているパスワードの数（計算値）
#-----------------------------------------------------------------------
