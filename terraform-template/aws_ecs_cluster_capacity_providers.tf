#-------------------------------------------------------------------------------------------------------
# ECSクラスター キャパシティプロバイダー設定
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# 用途: ECSクラスターに関連付けるキャパシティプロバイダーの管理
# 機能:
#   - クラスターレベルのキャパシティプロバイダー設定
#   - デフォルトのタスク配置戦略の定義
#   - FARGATEとFARGATE_SPOTのサポート
#   - カスタムキャパシティプロバイダーの関連付け
#
# 関連ドキュメント:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ecs_cluster_capacity_providers
#   - https://docs.aws.amazon.com/AmazonECS/latest/developerguide/cluster-capacity-providers.html
#
# NOTE: このテンプレートは学習・リファレンス用です。本番環境で使用する前に要件に応じて調整してください。
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# 基本設定
#-------------------------------------------------------------------------------------------------------

resource "aws_ecs_cluster_capacity_providers" "example" {

  #-------------------------------------------------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: ECSクラスター名
  # 設定可能な値: 既存のECSクラスター名
  # 注意事項:
  #   - 変更すると新規リソースが作成される
  #   - 1クラスターに1つのみ設定可能
  cluster_name = aws_ecs_cluster.example.name

  #-------------------------------------------------------------------------------------------------------
  # キャパシティプロバイダー設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: クラスターに関連付けるキャパシティプロバイダーのセット
  # 設定可能な値:
  #   - FARGATE: AWS Fargateキャパシティプロバイダー
  #   - FARGATE_SPOT: Fargate Spotキャパシティプロバイダー
  #   - カスタムキャパシティプロバイダー名
  # 省略時: キャパシティプロバイダーなし
  # 注意事項:
  #   - FARGATEとFARGATE_SPOTは事前定義済み
  #   - カスタムプロバイダーは別途aws_ecs_capacity_providerで作成
  capacity_providers = ["FARGATE", "FARGATE_SPOT"]

  #-------------------------------------------------------------------------------------------------------
  # デフォルト配置戦略
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: クラスターのデフォルトキャパシティプロバイダー戦略
  # 用途: サービスやタスクで戦略が指定されていない場合に使用
  # 省略時: デフォルト戦略なし
  default_capacity_provider_strategy {
    # 設定内容: キャパシティプロバイダー名
    # 設定可能な値: capacity_providersで指定したプロバイダー名
    capacity_provider = "FARGATE"

    # 設定内容: 最小タスク数
    # 設定可能な値: 0以上の整数
    # 省略時: 0
    # 注意事項:
    #   - 戦略内で1つのプロバイダーのみbaseを定義可能
    #   - この数のタスクは常に指定プロバイダーで実行
    base = 1

    # 設定内容: タスク配分の相対的な重み
    # 設定可能な値: 0以上の整数
    # 省略時: 0
    # 注意事項:
    #   - base数を満たした後の追加タスクに適用
    #   - 複数戦略間での比率として使用
    weight = 100
  }

  # 設定例: 複数戦略の組み合わせ
  # default_capacity_provider_strategy {
  #   capacity_provider = "FARGATE_SPOT"
  #   base              = 0
  #   weight            = 1
  # }

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: ap-northeast-1）
  # 省略時: プロバイダー設定のリージョン
  # 注意事項:
  #   - 通常はプロバイダー設定を使用
  #   - マルチリージョン構成でのみ明示的に指定
  region = "ap-northeast-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference
#-------------------------------------------------------------------------------------------------------
# - id: クラスター名と同じ値
