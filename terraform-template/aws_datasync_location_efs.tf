#######################################################
# AWS DataSync EFS Location
#######################################################
# Provider Version: 6.28.0
# Generated: 2026-02-14
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/datasync_location_efs
#
# NOTE:
# このテンプレートはAWS Provider 6.28.0のスキーマを基に生成されています。
# 実際の利用時は必須パラメータのみ設定し、オプションパラメータはコメントアウトを解除して使用してください。
#
# ユースケース:
#   - EFSファイルシステムとDataSync間のデータ転送元/転送先の設定
#   - オンプレミス・他クラウド・他AWSリージョンとのEFS連携
#   - 転送時のセキュリティ制御（暗号化・アクセス権限）の実装
#
# 主な機能:
#   - EFSアクセスポイント経由のパス制限付きアクセス
#   - 転送中暗号化（TLS 1.2）の有効化
#   - VPC内セキュリティグループによるネットワーク制御
#
# 関連リソース:
#   - aws_datasync_task: 実際のデータ転送タスクの定義
#   - aws_efs_file_system: 転送対象のEFSファイルシステム
#   - aws_efs_access_point: EFS上の特定ディレクトリへのアクセス制限
#   - aws_security_group: DataSyncエージェントのネットワークアクセス制御
#######################################################

resource "aws_datasync_location_efs" "example" {

  #-------------------------------------------------------
  # EFSファイルシステム設定（必須）
  #-------------------------------------------------------
  # 設定内容: 転送元または転送先となるEFSファイルシステムのARN
  # 形式: arn:aws:elasticfilesystem:region:account-id:file-system/fs-id
  efs_file_system_arn = "arn:aws:elasticfilesystem:us-east-1:123456789012:file-system/fs-0123456789abcdef0"

  #-------------------------------------------------------
  # ネットワーク設定（必須）
  #-------------------------------------------------------
  # 設定内容: DataSyncがEFSマウントターゲットにアクセスする際のVPC設定
  # 要件: EFSマウントターゲットと同じVPC内のサブネットを指定
  ec2_config {
    # 設定内容: DataSyncエージェント用サブネットのARN
    # 推奨: EFSマウントターゲットと同じアベイラビリティゾーンのサブネット
    subnet_arn = "arn:aws:ec2:us-east-1:123456789012:subnet/subnet-0123456789abcdef0"

    # 設定内容: DataSyncエージェントにアタッチするセキュリティグループのARNリスト
    # 必須ルール: EFSマウントターゲットへのNFS (TCP 2049) アウトバウンド許可
    security_group_arns = [
      "arn:aws:ec2:us-east-1:123456789012:security-group/sg-0123456789abcdef0"
    ]
  }

  #-------------------------------------------------------
  # アクセスポイント設定（オプション）
  #-------------------------------------------------------
  # 設定内容: EFSアクセスポイントのARN（特定ディレクトリへのアクセス制限時に使用）
  # 効果: アクセスポイントのパス配下のみアクセス可能となる
  # 省略時: EFSファイルシステムのルートディレクトリ全体にアクセス
  access_point_arn = "arn:aws:elasticfilesystem:us-east-1:123456789012:access-point/fsap-0123456789abcdef0"

  #-------------------------------------------------------
  # サブディレクトリ設定（オプション）
  #-------------------------------------------------------
  # 設定内容: 転送対象とするEFS上のディレクトリパス
  # 形式: /path/to/directory（絶対パス）
  # 省略時: EFSファイルシステムまたはアクセスポイントのルートディレクトリ
  # 注意: access_point_arn指定時はアクセスポイントのルート相対パス
  subdirectory = "/data/sync"

  #-------------------------------------------------------
  # 転送中暗号化設定（オプション）
  #-------------------------------------------------------
  # 設定内容: DataSyncとEFS間の通信暗号化の有効化
  # 設定可能な値:
  #   - TLS1_2: TLS 1.2による暗号化を有効化（推奨）
  #   - NONE: 暗号化無効（デフォルト）
  # 省略時: NONE（暗号化なし）
  # 推奨: TLS1_2（セキュリティ強化）
  in_transit_encryption = "TLS1_2"

  #-------------------------------------------------------
  # IAMロール設定（オプション）
  #-------------------------------------------------------
  # 設定内容: DataSyncがEFSアクセスポイント経由でアクセスする際に使用するIAMロールのARN
  # 必須条件: access_point_arn指定時に設定
  # 必要な権限: elasticfilesystem:ClientMount, elasticfilesystem:ClientWrite
  # 省略時: DataSyncサービスのデフォルトロールを使用
  file_system_access_role_arn = "arn:aws:iam::123456789012:role/DataSyncEFSAccessRole"

  #-------------------------------------------------------
  # リージョン設定（オプション）
  #-------------------------------------------------------
  # 設定内容: このロケーションを管理するAWSリージョン
  # 用途: クロスリージョン転送時にEFS側リージョンを明示的に指定
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"

  #-------------------------------------------------------
  # タグ設定（オプション）
  #-------------------------------------------------------
  # 設定内容: ロケーションに付与するタグ（Key-Valueペア）
  # 用途: コスト配分、リソース管理、アクセス制御
  tags = {
    Name        = "efs-sync-location"
    Environment = "production"
    Purpose     = "data-replication"
  }

}

#######################################################
# Attributes Reference（参照可能な属性）
#######################################################
# arn         : ロケーションのARN（他のDataSyncリソースで参照）
# uri         : ロケーションのURI（efs://file-system-id.efs.region.amazonaws.com/path/）
# id          : ロケーションID（DataSyncタスクでの参照用）
# tags_all    : デフォルトタグとリソース固有タグをマージした完全なタグマップ
#######################################################
