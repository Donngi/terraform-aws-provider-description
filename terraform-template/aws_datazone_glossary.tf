#-----------------------------------------------------------------------
# AWS DataZone Glossary
#
# Provider Version: 6.28.0
# Generated: 2026-02-14
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/datazone_glossary
#
# NOTE: 用語集リソース - DataZoneドメイン内でビジネス用語を定義・管理するための用語集
#-----------------------------------------------------------------------

/*
動作概要:
  Amazon DataZone内に用語集を作成し、データガバナンスとメタデータ管理を実現します。
  用語集は特定のプロジェクトに所有され、ドメイン内でビジネス用語の標準化を支援します。

関連サービス・機能:
  - Amazon DataZone Domain    : 用語集が属する親ドメイン
  - DataZone Project          : 用語集を所有するプロジェクト
  - DataZone Glossary Term    : 用語集内に定義される個別の用語
  - AWS Organizations         : クロスアカウント用語集共有時に使用
*/

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_datazone_glossary" "example" {
  # 用語集名
  # 設定内容: ドメイン内で用語集を識別するための名前
  # 制約事項: ドメイン内で一意である必要があります
  name = "business-glossary"

  # ドメインID
  # 設定内容: 用語集を作成するDataZoneドメインの識別子
  # 参照方法: aws_datazone_domain.example.id を使用
  domain_identifier = "dzd_example123456"

  # 所有プロジェクトID
  # 設定内容: 用語集を所有するDataZoneプロジェクトの識別子
  # 参照方法: aws_datazone_project.example.id を使用
  # 重要: プロジェクトは同一ドメイン内に存在する必要があります
  owning_project_identifier = "project-123456"

  #-----------------------------------------------------------------------
  # 用語集の詳細設定
  #-----------------------------------------------------------------------

  # 用語集の説明
  # 設定内容: 用語集の目的や対象範囲を説明するテキスト
  # 省略時: 説明なしで用語集が作成されます
  description = "企業全体で使用するビジネス用語の標準定義を管理する用語集"

  #-----------------------------------------------------------------------
  # ステータス設定
  #-----------------------------------------------------------------------

  # 用語集のステータス
  # 設定内容: 用語集の有効化状態を指定
  # 設定可能な値:
  #   - ENABLED  : 用語集が有効でユーザーが利用可能
  #   - DISABLED : 用語集が無効化されており利用不可
  # 省略時: ENABLED が設定されます
  # 注意: DISABLEDにすると既存の用語参照に影響する可能性があります
  status = "ENABLED"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソースリージョン
  # 設定内容: 用語集を管理するAWSリージョン
  # 省略時: プロバイダーのリージョン設定が使用されます
  # 注意: domain_identifierと同じリージョンである必要があります
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-----------------------------------------------------------------------

/*
リソース作成後に参照可能な属性:

  id
    説明: 用語集の一意識別子
    形式: "domain_id/glossary_id"
    用途: 他リソースからの参照やインポート操作

  region
    説明: 用語集が管理されているリージョン
    型: string
*/

#-----------------------------------------------------------------------
# 出力例
#-----------------------------------------------------------------------

output "glossary_id" {
  description = "DataZone用語集のID"
  value       = aws_datazone_glossary.example.id
}

output "glossary_name" {
  description = "用語集の名前"
  value       = aws_datazone_glossary.example.name
}
