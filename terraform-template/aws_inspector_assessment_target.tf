#######################################################################
# Amazon Inspector 評価ターゲット
#######################################################################
# Amazon Inspector Classic（Inspector v1）の評価ターゲットを定義する
# リソース。評価ターゲットは、セキュリティ評価の対象となるEC2
# インスタンスのグループを表す。
#
# 主な用途:
# - EC2インスタンスのセキュリティ脆弱性評価
# - コンプライアンス評価の対象グループ定義
# - CVEやセキュリティベストプラクティスの自動チェック
#
# 注意: Amazon Inspector Classic（v1）は新規利用が制限されており、
#       Amazon Inspector v2の使用が推奨されています。
#
# 参考: https://docs.aws.amazon.com/inspector/v1/userguide/inspector_targets.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/inspector_assessment_target
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_inspector_assessment_target" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # 評価ターゲットの名前
  # 設定内容: Amazon Inspector内で評価ターゲットを識別する名前
  # 設定可能な値: 最大140文字の文字列
  name = "example-assessment-target"

  #-----------------------------------------------------------------------
  # リソースグループの設定
  #-----------------------------------------------------------------------

  # 評価対象リソースグループのARN
  # 設定内容: 評価対象のEC2インスタンスを識別するタグベースのグループ
  # 用途: aws_inspector_resource_groupリソースで定義したグループを指定する
  # 省略時: AWSアカウント内のすべてのEC2インスタンスが対象となる
  resource_group_arn = aws_inspector_resource_group.example.arn

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: 評価ターゲットリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   評価ターゲットのID
#
# - arn
#   評価ターゲットのARN
#-----------------------------------------------------------------------
