#-------------------------------------------------------------------------------------------------------
# aws_ec2_serial_console_access
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-15
#
# NOTE: このテンプレートはaws_ec2_serial_console_accessリソースの全属性を網羅しています。
#       コメントアウトされている属性は必要に応じてコメントを外して使用してください。
#
# 用途: AWSアカウントレベルでEC2シリアルコンソールへのアクセスを有効化・無効化するリソース
#
# 主な機能:
# - アカウント全体でのシリアルコンソールアクセス設定の管理
# - リージョンごとのアクセス制御設定
# - トラブルシューティング機能の有効化制御
#
# 制限事項:
# - デフォルトではアカウントレベルでシリアルコンソールアクセスは無効
# - シリアルコンソールを使用するには、追加でIAMポリシーの設定が必要
# - Linuxインスタンスの場合、パスワードベースのユーザー設定が必要
#
# 関連リソース:
# - aws_iam_policy: シリアルコンソールアクセス用のIAMポリシー定義
# - aws_instance: シリアルコンソールでアクセスするEC2インスタンス
#
# 参考: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_serial_console_access
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# シリアルコンソールアクセス設定
#-------------------------------------------------------------------------------------------------------
resource "aws_ec2_serial_console_access" "example" {
  # 設定内容: アカウントレベルでEC2シリアルコンソールアクセスを有効化するかどうか
  # 設定可能な値:
  #   - true: シリアルコンソールアクセスを有効化
  #   - false: シリアルコンソールアクセスを無効化
  # 省略時: 現在の設定値を維持
  # 注意: アカウントレベルで有効化した後、IAMポリシーで個別ユーザーへのアクセス許可が必要
  enabled = true

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 任意のAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: リージョンごとに個別の設定が必要な場合に指定
  region = "us-east-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースでは以下の属性が参照可能:
#
# - id: リソースの一意識別子（リージョン名）
#
# - enabled: シリアルコンソールアクセスの有効化状態
#   - 値: true（有効）またはfalse（無効）
#
# - region: このリソースが管理されているAWSリージョン
#   - 形式: リージョンコード文字列（例: us-east-1）
#
#-------------------------------------------------------------------------------------------------------
# Import
#-------------------------------------------------------------------------------------------------------
# 既存のシリアルコンソールアクセス設定は以下の形式でインポート可能:
#
# terraform import aws_ec2_serial_console_access.example us-east-1
#
# インポート形式: リージョン名を指定
#-------------------------------------------------------------------------------------------------------
