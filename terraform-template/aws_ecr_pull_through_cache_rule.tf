#-----------------------------------------------------------------------
# リソース概要
#-----------------------------------------------------------------------
# Amazon ECR Pull Through Cache Rule
#
# 説明:
# アップストリームレジストリからのコンテナイメージをECRプライベートレジストリに
# キャッシュするためのプルスルーキャッシュルールを作成します。
# Docker Hub、GitHub Container Registry、Quay、Kubernetes、ECR Public、
# Azure Container Registry、GitLab Container Registryなどの外部レジストリや、
# 他のECRプライベートレジストリ(クロスアカウント/クロスリージョン)からの
# イメージプルを高速化し、アップストリームへの依存を軽減します。
#
# ユースケース:
# - パブリックレジストリからのイメージプルの高速化と安定性向上
# - アップストリームレジストリのレート制限やダウンタイムの影響を軽減
# - クロスアカウント/クロスリージョンでのECRイメージ共有
# - 組織全体での一元的なイメージキャッシュ管理
# - CI/CDパイプラインでのイメージプル時間の短縮
#
# 制約事項:
# - リージョンごとに個別にルールを作成する必要があります
# - AWS Lambdaではサポートされていません
# - 初回プル時にはインターネットアクセスが必要です
# - FIPS対応エンドポイントは初回プル時に使用できません
# - 特定のリージョンではサポートされていない場合があります
# - キャッシュされたイメージは少なくとも24時間に1回更新が試行されます
#
# 参考ドキュメント:
# - https://docs.aws.amazon.com/AmazonECR/latest/userguide/pull-through-cache.html
# - https://docs.aws.amazon.com/AmazonECR/latest/userguide/pull-through-cache-creating-rule.html
# - https://docs.aws.amazon.com/AmazonECR/latest/APIReference/API_CreatePullThroughCacheRule.html

#-----------------------------------------------------------------------
# Resource Definition
#-----------------------------------------------------------------------

resource "aws_ecr_pull_through_cache_rule" "example" {
  #-----------------------------------------------------------------------
  # 必須パラメータ
  #-----------------------------------------------------------------------

  # ECRリポジトリプレフィックス
  # 設定内容: アップストリームレジストリからキャッシュされたイメージに使用するECRリポジトリの名前空間プレフィックス
  # 設定可能な値: 英数字、ハイフン、アンダースコア、スラッシュ
  # 補足事項:
  # - キャッシュされたイメージは「プレフィックス/アップストリームリポジトリ名」の形式で作成されます
  # - 例: プレフィックスが "docker-hub" の場合、nginx イメージは "docker-hub/nginx" として保存されます
  # - アップストリームレジストリごとに一意のプレフィックスを使用することを推奨します
  # - 同じリージョン内で同じプレフィックスを持つルールは1つのみ作成可能です
  ecr_repository_prefix = "docker-hub"

  # アップストリームレジストリURL
  # 設定内容: キャッシュ元となるアップストリームコンテナレジストリのURL
  # 設定可能な値:
  # - public.ecr.aws (ECR Public)
  # - registry.k8s.io (Kubernetes Container Image Registry)
  # - quay.io (Quay)
  # - registry-1.docker.io (Docker Hub)
  # - ghcr.io (GitHub Container Registry)
  # - [name].azurecr.io (Azure Container Registry)
  # - registry.gitlab.com (GitLab Container Registry)
  # - [account_id].dkr.ecr.[region].amazonaws.com (ECR Private - クロスアカウント/クロスリージョン)
  # 補足事項:
  # - 認証が必要なレジストリ(Docker Hub、GitHub、Azure、GitLabなど)では credential_arn の指定が必須です
  # - ECR Privateからのクロスアカウントプルでは custom_role_arn の指定が必要です
  upstream_registry_url = "registry-1.docker.io"

  #-----------------------------------------------------------------------
  # 認証とアクセス制御
  #-----------------------------------------------------------------------

  # 認証情報ARN
  # 設定内容: アップストリームレジストリへの認証に使用するAWS Secrets ManagerシークレットのARN
  # 省略時: 認証なしでアクセス可能なレジストリ(ECR Public、Kubernetes、Quay)にのみ接続します
  # 補足事項:
  # - Docker Hub、GitHub、Azure、GitLab Container Registryでは必須です
  # - シークレット名は "ecr-pullthroughcache/" で始まる必要があります
  # - シークレットはルールと同じアカウント・リージョンに存在する必要があります
  # - Docker Hubの場合: メールアドレスとアクセストークンを含むシークレット
  # - GitHubの場合: ユーザー名とPersonal Access Token(PAT)を含むシークレット
  # - Azureの場合: ユーザー名とアクセストークンを含むシークレット
  # - GitLabの場合: ユーザー名とアクセストークン(Personal/Group/Project)を含むシークレット
  credential_arn = "arn:aws:secretsmanager:us-west-2:123456789012:secret:ecr-pullthroughcache/docker-hub-AbCdEf"

  # カスタムIAMロールARN
  # 設定内容: クロスアカウントのECR Privateレジストリへのアクセスに使用するIAMロールのARN
  # 省略時: デフォルトのサービスリンクロールが使用されます
  # 補足事項:
  # - 他のAWSアカウントのECR Privateレジストリからプルする場合に必須です
  # - ロールには ecr:GetAuthorizationToken、ecr:BatchCheckLayerAvailability、
  #   ecr:GetDownloadUrlForLayer、ecr:BatchGetImage などの権限が必要です
  # - アップストリームアカウントのECRリポジトリポリシーでプルを許可する必要があります
  custom_role_arn = "arn:aws:iam::123456789012:role/ECRPullThroughCacheRole"

  #-----------------------------------------------------------------------
  # アップストリーム設定
  #-----------------------------------------------------------------------

  # アップストリームリポジトリプレフィックス
  # 設定内容: アップストリームレジストリ内でプル対象とするリポジトリの名前空間プレフィックス
  # 省略時: アップストリームレジストリ内の全リポジトリからプル可能です
  # 補足事項:
  # - 特定の組織やプロジェクトのイメージのみをキャッシュしたい場合に使用します
  # - 例: "myorg/" を指定すると "myorg/*" パターンのリポジトリのみがプル対象になります
  # - ECR to ECRのプルスルーキャッシュでワイルドカードを使用したカスタマイズが可能です
  # - 空文字列を指定すると全リポジトリがプル対象になります
  upstream_repository_prefix = "library"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リージョン
  # 設定内容: このリソースが管理されるAWSリージョン
  # 省略時: プロバイダー設定で指定されたリージョンが使用されます
  # 補足事項:
  # - クロスリージョンのECR Privateレジストリからプルする場合に明示的に指定できます
  # - リージョンごとに個別にプルスルーキャッシュルールを作成する必要があります
  # - 一部のリージョンではプルスルーキャッシュ機能がサポートされていない場合があります
  region = "us-west-2"

  #-----------------------------------------------------------------------
  # 依存関係とライフサイクル
  #-----------------------------------------------------------------------

  # depends_on = []

  # lifecycle {
  #   prevent_destroy = true
  #   ignore_changes  = []
  # }

  #-----------------------------------------------------------------------
  # タグ
  #-----------------------------------------------------------------------
  # 注意: このリソースはタグをサポートしていません
}

