#-----------------------------------------------------------------------------------------------------------------------
# AWS CodeBuild Fleet
#-----------------------------------------------------------------------------------------------------------------------
# AWS CodeBuildの専用ビルドフリートリソース。
# 予約済みコンピューティング容量を使用してビルドジョブのパフォーマンスとスケーラビリティを最適化する。
#
# 主な機能:
# - 予約済みビルドキャパシティの管理により待機時間を削減
# - AutoScalingによる動的なキャパシティ調整
# - カスタムコンピューティング環境の構成
# - VPC内での安全なビルド実行
#
# Provider Version: 6.28.0
# Generated: 2026-02-12
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/codebuild_fleet
#
# NOTE: このテンプレートは学習・参考用です。本番環境で使用する前に必ず公式ドキュメントを確認してください。
#-----------------------------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------------------------
# フリート基本設定
#-----------------------------------------------------------------------------------------------------------------------
# フリートの識別とコアリソース設定

resource "aws_codebuild_fleet" "example" {
  # フリート名
  # 設定内容: CodeBuildフリートの一意の名前
  # 設定可能な値: 2〜128文字の英数字、ハイフン、アンダースコア
  # 省略時: 必須項目
  name = "my-codebuild-fleet"

  # ベースキャパシティ
  # 設定内容: フリートで常に利用可能な最小限のビルドインスタンス数
  # 設定可能な値: 1以上の整数
  # 省略時: 必須項目
  base_capacity = 2

  # コンピューティングタイプ
  # 設定内容: ビルド環境のコンピューティング性能レベル
  # 設定可能な値:
  #   BUILD_GENERAL1_SMALL  - 3 GB メモリ、2 vCPU
  #   BUILD_GENERAL1_MEDIUM - 7 GB メモリ、4 vCPU
  #   BUILD_GENERAL1_LARGE  - 15 GB メモリ、8 vCPU
  #   BUILD_GENERAL1_XLARGE - 70 GB メモリ、36 vCPU（Linuxのみ）
  #   BUILD_GENERAL1_2XLARGE - 145 GB メモリ、72 vCPU（Linuxのみ）
  # 省略時: 必須項目
  compute_type = "BUILD_GENERAL1_SMALL"

  # 環境タイプ
  # 設定内容: ビルド環境のプラットフォームタイプ
  # 設定可能な値:
  #   LINUX_CONTAINER         - Linuxコンテナ環境
  #   LINUX_GPU_CONTAINER     - GPU対応Linuxコンテナ
  #   WINDOWS_SERVER_2019_CONTAINER - Windows Server 2019コンテナ
  #   WINDOWS_SERVER_2022_CONTAINER - Windows Server 2022コンテナ
  #   ARM_CONTAINER          - ARM対応Linuxコンテナ
  #   MAC_ARM                - macOS ARM環境
  # 省略時: 必須項目
  environment_type = "LINUX_CONTAINER"

  #-----------------------------------------------------------------------------------------------------------------------
  # オプション設定
  #-----------------------------------------------------------------------------------------------------------------------

  # フリートサービスロール
  # 設定内容: フリートがAWSリソースにアクセスするためのIAMロールARN
  # 設定可能な値: 有効なIAMロールARN
  # 省略時: デフォルトのサービスロールを使用
  fleet_service_role = null

  # イメージID
  # 設定内容: ビルド環境で使用するDockerイメージまたはAMI
  # 設定可能な値:
  #   - AWS管理イメージ: aws/codebuild/standard:7.0 など
  #   - カスタムECRイメージ: <account-id>.dkr.ecr.<region>.amazonaws.com/<repo>:<tag>
  #   - Docker Hubイメージ: <image>:<tag>
  # 省略時: 環境タイプに応じたデフォルトイメージを使用
  image_id = null

  # オーバーフロー動作
  # 設定内容: キャパシティ不足時の動作設定
  # 設定可能な値:
  #   QUEUE           - ビルドをキューに入れて待機
  #   ON_DEMAND       - オンデマンドインスタンスで実行
  # 省略時: QUEUE
  overflow_behavior = null

  # リージョン
  # 設定内容: フリートを作成するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード (us-east-1, ap-northeast-1など)
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  # タグ
  # 設定内容: フリートに付与するリソースタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Environment = "production"
    Service     = "codebuild"
  }

  #-----------------------------------------------------------------------------------------------------------------------
  # コンピューティング構成 (オプション)
  #-----------------------------------------------------------------------------------------------------------------------
  # カスタムコンピューティングリソースの詳細設定

  # compute_configuration {
  #   # ディスク容量
  #   # 設定内容: ビルドインスタンスのディスク容量（GB）
  #   # 設定可能な値: 1〜3000（compute_typeによって上限が異なる）
  #   # 省略時: compute_typeのデフォルト値
  #   disk = 100
  #
  #   # インスタンスタイプ
  #   # 設定内容: 使用するEC2インスタンスタイプ（MAC_ARM環境のみ）
  #   # 設定可能な値: mac2.metal, mac2.metal.m1ultra など
  #   # 省略時: 環境に応じたデフォルト
  #   # instance_type = "mac2.metal"
  #
  #   # マシンタイプ
  #   # 設定内容: ビルドマシンのハードウェアタイプ
  #   # 設定可能な値:
  #   #   GENERAL     - 汎用マシン
  #   #   NVME        - NVMeストレージ搭載
  #   # 省略時: GENERAL
  #   # machine_type = "GENERAL"
  #
  #   # メモリ容量
  #   # 設定内容: ビルドインスタンスのメモリ容量（GB）
  #   # 設定可能な値: 1〜255（compute_typeによって上限が異なる）
  #   # 省略時: compute_typeのデフォルト値
  #   # memory = 8
  #
  #   # vCPU数
  #   # 設定内容: ビルドインスタンスの仮想CPU数
  #   # 設定可能な値: 1〜72（compute_typeによって上限が異なる）
  #   # 省略時: compute_typeのデフォルト値
  #   # vcpu = 4
  # }

  #-----------------------------------------------------------------------------------------------------------------------
  # スケーリング構成 (オプション)
  #-----------------------------------------------------------------------------------------------------------------------
  # フリートの自動スケーリング設定

  # scaling_configuration {
  #   # 最大キャパシティ
  #   # 設定内容: フリートがスケールアウト可能な最大インスタンス数
  #   # 設定可能な値: base_capacity以上の整数
  #   # 省略時: スケーリングなし（base_capacityで固定）
  #   max_capacity = 10
  #
  #   # スケーリングタイプ
  #   # 設定内容: スケーリングの動作モード
  #   # 設定可能な値:
  #   #   TARGET_TRACKING_SCALING - ターゲット追跡スケーリング
  #   # 省略時: TARGET_TRACKING_SCALING
  #   # scaling_type = "TARGET_TRACKING_SCALING"
  #
  #   # ターゲット追跡スケーリング設定
  #   target_tracking_scaling_configs {
  #     # メトリックタイプ
  #     # 設定内容: スケーリングの判断基準となるメトリック
  #     # 設定可能な値:
  #     #   FLEET_UTILIZATION_RATE - フリート使用率（推奨）
  #     # 省略時: 必須（target_tracking_scaling_configs使用時）
  #     metric_type = "FLEET_UTILIZATION_RATE"
  #
  #     # ターゲット値
  #     # 設定内容: 目標とするメトリック値（パーセンテージ）
  #     # 設定可能な値: 1.0〜100.0（FLEET_UTILIZATION_RATEの場合）
  #     # 省略時: 必須（target_tracking_scaling_configs使用時）
  #     target_value = 75.0
  #   }
  # }

  #-----------------------------------------------------------------------------------------------------------------------
  # VPC構成 (オプション)
  #-----------------------------------------------------------------------------------------------------------------------
  # VPC内でのビルド実行設定

  # vpc_config {
  #   # セキュリティグループID
  #   # 設定内容: ビルド環境に適用するセキュリティグループ
  #   # 設定可能な値: 有効なセキュリティグループIDのセット（最大5個）
  #   # 省略時: 必須（vpc_config使用時）
  #   security_group_ids = [
  #     aws_security_group.codebuild.id
  #   ]
  #
  #   # サブネット
  #   # 設定内容: ビルドインスタンスを配置するサブネット
  #   # 設定可能な値: 有効なサブネットIDのセット（最大16個）
  #   # 省略時: 必須（vpc_config使用時）
  #   subnets = [
  #     aws_subnet.private_a.id,
  #     aws_subnet.private_c.id
  #   ]
  #
  #   # VPC ID
  #   # 設定内容: ビルド環境を配置するVPC
  #   # 設定可能な値: 有効なVPC ID
  #   # 省略時: 必須（vpc_config使用時）
  #   vpc_id = aws_vpc.main.id
  # }
}

#-----------------------------------------------------------------------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-----------------------------------------------------------------------------------------------------------------------
# このリソースから参照可能な属性値

# arn           - フリートのARN
# created       - フリートの作成日時（RFC3339形式）
# id            - フリートの一意識別子
# last_modified - フリートの最終更新日時（RFC3339形式）
# status        - フリートのステータス情報
#   - context     - ステータスのコンテキスト情報
#   - message     - ステータスメッセージ
#   - status_code - ステータスコード（CREATING, ACTIVE, UPDATING, DELETING, CREATE_FAILED, UPDATE_FAILED）
# tags_all      - すべてのタグ（デフォルトタグを含む）
#
# scaling_configuration.desired_capacity - 現在の希望キャパシティ
#
# compute_configuration.disk           - 実際のディスク容量
# compute_configuration.instance_type  - 実際のインスタンスタイプ
# compute_configuration.machine_type   - 実際のマシンタイプ
# compute_configuration.memory         - 実際のメモリ容量
# compute_configuration.vcpu           - 実際のvCPU数
