#-----------------------------------------------------------------------
# API Gateway REST API Put
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/api_gateway_rest_api_put
# Generated: 2026-02-11
#
# NOTE: OpenAPI/Swagger仕様を使用してAPI Gateway REST APIを一括更新するリソース
# 既存のREST APIにOpenAPI定義を適用し、リソース・メソッド・統合設定を更新
#
# 主な用途:
# - OpenAPI/Swagger仕様ファイルによるAPI定義の一括適用
# - マルチステージ環境での段階的API更新
# - バージョン管理されたAPI定義の適用
#
# 注意事項:
# - OpenAPI定義ファイルの最大サイズは6MB
# - body内のinfo.titleフィールドはREST APIのname属性を更新する
# - 警告発生時のロールバック動作を制御可能
# - リデプロイトリガーを使用した変更検知が可能
#-----------------------------------------------------------------------

resource "aws_api_gateway_rest_api_put" "example" {
  #-----------------------------------------------------------------------
  # 必須設定
  #-----------------------------------------------------------------------

  # 設定内容: OpenAPI/Swagger仕様を含むPUTリクエストボディ
  # 設定可能な値: OpenAPI定義のJSON/YAML文字列（最大6MB）
  # 形式: jsonencode()関数またはfile()関数で読み込んだOpenAPI定義
  body = jsonencode({
    openapi = "3.0.1"
    info = {
      title   = "example"
      version = "1.0"
    }
    paths = {
      "/test" = {
        get = {
          x-amazon-apigateway-integration = {
            httpMethod           = "GET"
            payloadFormatVersion = "1.0"
            type                 = "HTTP_PROXY"
            uri                  = "https://example.com"
          }
        }
      }
    }
  })

  # 設定内容: 更新対象のREST API ID
  # 設定可能な値: 既存のAPI Gateway REST APIのID
  rest_api_id = "example"

  #-----------------------------------------------------------------------
  # インポート設定
  #-----------------------------------------------------------------------

  # 設定内容: 仕様インポート時のカスタマイズパラメータ
  # 設定可能な値:
  #   - ignore: "documentation" - DocumentationPartsを除外
  #   - basepath: "ignore" - ベースパスマッピングを無視
  #   - basepath: "prepend" - ベースパスを先頭に追加
  #   - basepath: "split" - ベースパスで分割
  # 省略時: パラメータなしでインポート実行
  parameters = {
    ignore = "documentation"
  }

  #-----------------------------------------------------------------------
  # エラー処理設定
  #-----------------------------------------------------------------------

  # 設定内容: 警告発生時にAPI更新をロールバックするかどうか
  # 設定可能な値: true（ロールバックする）、false（ロールバックしない）
  # 省略時: false
  fail_on_warnings = false

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # 再デプロイトリガー設定
  #-----------------------------------------------------------------------

  # 設定内容: 変更時に再デプロイをトリガーする任意のキー・値マップ
  # 設定可能な値: 任意の文字列マップ（ファイルハッシュなど）
  # 省略時: トリガーなし
  triggers = {
    redeployment = "example"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 設定内容: リソース作成時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30s", "10m", "1h"）
  #   # 省略時: デフォルトタイムアウト
  #   create = "10m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id - リソースID（rest_api_id）

#-----------------------------------------------------------------------
# Import
#-----------------------------------------------------------------------
# 既存のAPI Gateway REST API Putは以下の形式でインポートできます:
#
# terraform import aws_api_gateway_rest_api_put.example <rest_api_id>
#
# 例:
# terraform import aws_api_gateway_rest_api_put.example abc123def456
