#---------------------------------------
# AWS DataSync FSx for OpenZFS ファイルシステムロケーション
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# NOTE:
# DataSyncでのデータ転送元または転送先として使用するFSx for OpenZFSファイルシステムの
# ロケーションを定義します。
#
# 主な機能:
# - FSx for OpenZFSファイルシステムの接続設定
# - NFSプロトコル経由でのアクセス設定
# - セキュリティグループによるネットワーク制御
# - サブディレクトリの指定によるアクセス範囲の制限
#
# 注意事項:
# - FSx for OpenZFSファイルシステムは既に作成されている必要があります
# - セキュリティグループは、DataSyncとFSx間の通信を許可する必要があります
# - NFSプロトコルバージョンは、FSxでサポートされているものを指定してください
#
# 関連リソース:
# - aws_fsx_openzfs_file_system: FSx for OpenZFSファイルシステムの作成
# - aws_security_group: セキュリティグループの管理
# - aws_datasync_task: データ同期タスクの定義
#
# 参考資料:
# https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/datasync_location_fsx_openzfs_file_system
#---------------------------------------

resource "aws_datasync_location_fsx_openzfs_file_system" "example" {
  #---------------------------------------
  # FSx for OpenZFS設定
  #---------------------------------------
  # 設定内容: FSx for OpenZFSファイルシステムのARN
  # 形式: arn:aws:fsx:リージョン:アカウントID:file-system/fs-xxxxx
  # 注意: FSxファイルシステムは事前に作成しておく必要があります
  fsx_filesystem_arn = "arn:aws:fsx:ap-northeast-1:123456789012:file-system/fs-0123456789abcdef0"

  #---------------------------------------
  # ネットワーク設定
  #---------------------------------------
  # 設定内容: DataSyncタスクで使用するセキュリティグループのARNリスト
  # 形式: ["arn:aws:ec2:リージョン:アカウントID:security-group/sg-xxxxx"]
  # 注意: セキュリティグループは、NFS通信（ポート2049）を許可する必要があります
  security_group_arns = [
    "arn:aws:ec2:ap-northeast-1:123456789012:security-group/sg-0123456789abcdef0",
  ]

  #---------------------------------------
  # アクセスパス設定
  #---------------------------------------
  # 設定内容: FSxファイルシステム内のサブディレクトリパス
  # 形式: /パス/サブディレクトリ（先頭に/が必要）
  # 省略時: ファイルシステムのルートディレクトリ
  # 用途: データ転送の対象範囲を特定のディレクトリに限定
  subdirectory = "/data/transfer"

  #---------------------------------------
  # プロトコル設定
  #---------------------------------------
  protocol {
    #---------------------------------------
    # NFSプロトコル設定
    #---------------------------------------
    nfs {
      #---------------------------------------
      # NFSマウントオプション
      #---------------------------------------
      mount_options {
        # 設定内容: NFSプロトコルバージョン
        # 設定可能な値: "AUTOMATIC" | "NFS3" | "NFS4_0" | "NFS4_1"
        # 省略時: "AUTOMATIC"（FSxが対応する最新バージョンを自動選択）
        # 推奨: 通常はAUTOMATICで問題ありませんが、特定バージョンが必要な場合は明示的に指定
        version = "AUTOMATIC"
      }
    }
  }

  #---------------------------------------
  # リージョン設定（オプション）
  #---------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 用途: クロスリージョンでのリソース管理が必要な場合に指定
  region = "ap-northeast-1"

  #---------------------------------------
  # タグ設定
  #---------------------------------------
  # 設定内容: ロケーションに付与するタグ
  # 用途: リソース管理、コスト配分、検索の効率化
  tags = {
    Name        = "fsx-openzfs-location-example"
    Environment = "production"
    ManagedBy   = "terraform"
    Purpose     = "data-sync"
  }
}

#---------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------
# このリソースでは以下の属性を参照できます:
#
# arn               - ロケーションのARN
# creation_time     - ロケーションの作成日時（RFC3339形式）
# id                - ロケーションのID（ARNと同じ値）
# region            - リソースが管理されているリージョン
# tags_all          - デフォルトタグを含むすべてのタグ
# uri               - ロケーションのURI（nfs://ホスト名/パス形式）
#---------------------------------------
