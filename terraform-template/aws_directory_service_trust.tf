#-------------------------------------------------------------------------------------------------------
# AWS Directory Service トラスト関係
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/directory_service_trust
# Generated: 2026-02-14
#
# NOTE: 2つのActive Directoryディレクトリ間の信頼関係を管理するリソース
#
# ユースケース:
# - AWS Managed Microsoft AD同士のトラスト関係の確立
# - AWS Managed Microsoft ADとセルフマネージド型ADのトラスト関係の確立
# - マルチドメイン環境でのシングルサインオン（SSO）の実現
# - 既存オンプレミスADとAWS環境の統合
#
# 制約事項:
# - トラスト関係は両側で設定する必要がある（片側のみの場合は VerifyFailed 状態になる）
# - 同一ペア間で作成できるトラストは1つのみ
# - AWS Managed Microsoft ADディレクトリでのみ使用可能
# - トラストパスワードは最大128文字まで設定可能
# - 条件付きフォワーダーIPアドレスは1～4個まで設定可能
#
# 注意事項:
# - トラスト関係の作成後、双方向の設定が完了するまで状態が VerifyFailed になる
# - セルフマネージド型ADとの信頼関係では、DNSおよびネットワーク設定の事前準備が必要
# - trust_password はディレクトリのパスワードと一致させる必要はない
# - トラスト削除時の条件付きフォワーダーの扱いを delete_associated_conditional_forwarder で制御可能
#
#-------------------------------------------------------------------------------------------------------

resource "aws_directory_service_trust" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: このトラストが適用されるディレクトリのID
  # 省略時: 省略不可（必須）
  directory_id = "d-1234567890"

  # 設定内容: リモートディレクトリの完全修飾ドメイン名（FQDN）
  # 省略時: 省略不可（必須）
  remote_domain_name = "remote.example.com"

  # 設定内容: トラスト関係の方向
  # 設定可能な値:
  #   - "One-Way: Outgoing" : 一方向（発信）トラスト（このディレクトリからリモートへ）
  #   - "One-Way: Incoming" : 一方向（受信）トラスト（リモートからこのディレクトリへ）
  #   - "Two-Way"           : 双方向トラスト（相互認証が可能）
  # 省略時: 省略不可（必須）
  trust_direction = "Two-Way"

  # 設定内容: トラスト関係のパスワード
  # 設定可能な値: 大文字・小文字・数字・記号を含む最大128文字の文字列
  # 省略時: 省略不可（必須）
  # 注意: トラスト関係の両側で同じパスワードを使用する必要がある
  trust_password = "SecurePassword123!"

  #-------------------------------------------------------------------------------------------------------
  # トラストタイプとセキュリティ設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: トラスト関係のタイプ
  # 設定可能な値:
  #   - "Forest"   : フォレストトラスト（Active Directoryフォレスト間の包括的な信頼関係）
  #   - "External" : 外部トラスト（特定のドメイン間の信頼関係）
  # 省略時: "Forest"（フォレストトラスト）
  trust_type = "Forest"

  # 設定内容: 選択的認証の有効化
  # 設定可能な値:
  #   - "Enabled"  : 有効（明示的に許可されたリソースのみアクセス可能）
  #   - "Disabled" : 無効（トラストされたドメインの全ユーザーがアクセス可能）
  # 省略時: "Disabled"（無効）
  selective_auth = "Disabled"

  #-------------------------------------------------------------------------------------------------------
  # DNS設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: リモートディレクトリに関連付けられたDNSサーバーのIPv4アドレスセット
  # 設定可能な値: 1～4個のIPv4アドレス
  # 省略時: 条件付きフォワーダーを設定しない
  # 注意: リモートディレクトリの dns_ip_addresses 属性を参照することが推奨される
  conditional_forwarder_ip_addrs = [
    "10.0.1.10",
    "10.0.2.10"
  ]

  #-------------------------------------------------------------------------------------------------------
  # 削除設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: トラスト関係削除時に条件付きフォワーダーも削除するかどうか
  # 設定可能な値: true（削除する）、false（削除しない）
  # 省略時: false（削除しない）
  delete_associated_conditional_forwarder = false

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: このリソースが管理されるAWSリージョン
  # 省略時: プロバイダー設定で指定されたリージョン
  region = "us-east-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference
#-------------------------------------------------------------------------------------------------------
# このリソースでは以下の属性が参照可能:
#
# id                           - トラスト関係の識別子
# created_date_time            - トラスト関係が作成された日時
# last_updated_date_time       - トラスト関係が最後に更新された日時
# state_last_updated_date_time - trust_state が最後に更新された日時
# trust_state                  - トラスト関係の状態
#                                (Created/VerifyFailed/Verified/UpdateFailed/Updated/Deleted/Failed)
# trust_state_reason           - trust_state に設定された状態の理由
#-------------------------------------------------------------------------------------------------------
