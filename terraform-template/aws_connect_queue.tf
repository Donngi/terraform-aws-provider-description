#######################################################################
# AWS Connect Queue - Amazon Connectキュー設定
#######################################################################
# Amazon Connectインスタンス内のキューを定義し、着信コンタクトのルーティングやエージェント割り当てを管理します。
# 営業時間、最大同時コンタクト数、アウトバウンド発信設定などを構成できます。
#
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/connect_queue
#
# NOTE: このテンプレートは完全な設定例を提供しています。実際の利用時には必須パラメータのみ設定し、
# 不要なオプション項目は削除してください。

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_connect_queue" "example" {
  # 設定内容: Amazon ConnectインスタンスのID（必須）
  # 設定可能な値: 既存のConnectインスタンスID
  instance_id = "aaaaaaaa-bbbb-cccc-dddd-111111111111"

  # 設定内容: キューの名前（必須）
  # 設定可能な値: 1〜127文字の英数字、ハイフン、アンダースコア
  name = "CustomerSupportQueue"

  # 設定内容: キューの営業時間ID（必須）
  # 設定可能な値: 既存の営業時間設定のID
  hours_of_operation_id = "12345678-1234-1234-1234-123456789012"

  # 設定内容: キューの説明
  # 設定可能な値: 任意のテキスト（最大250文字）
  # 省略時: 説明なし
  description = "カスタマーサポート専用キュー"

  #-----------------------------------------------------------------------
  # キュー運用設定
  #-----------------------------------------------------------------------

  # 設定内容: キューで同時に処理できる最大コンタクト数
  # 設定可能な値: 0以上の整数
  # 省略時: 無制限
  max_contacts = 10

  # 設定内容: キューのステータス
  # 設定可能な値: ENABLED | DISABLED
  # 省略時: ENABLED
  status = "ENABLED"

  #-----------------------------------------------------------------------
  # クイック接続設定
  #-----------------------------------------------------------------------

  # 設定内容: キューに関連付けるクイック接続のIDセット
  # 設定可能な値: 既存のクイック接続IDのセット（最大50個）
  # 省略時: クイック接続なし
  quick_connect_ids = [
    "11111111-2222-3333-4444-555555555555",
    "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
  ]

  #-----------------------------------------------------------------------
  # アウトバウンド発信設定
  #-----------------------------------------------------------------------

  # 設定内容: アウトバウンドコール時の発信者情報設定
  # 省略時: デフォルトのインスタンス設定を使用
  outbound_caller_config {
    # 設定内容: アウトバウンド発信時に表示される発信者名
    # 設定可能な値: 任意のテキスト
    # 省略時: 発信者名なし
    outbound_caller_id_name = "カスタマーサポート"

    # 設定内容: アウトバウンド発信時に使用する電話番号のID
    # 設定可能な値: Connectインスタンスに登録済みの電話番号ID
    # 省略時: デフォルトの電話番号を使用
    outbound_caller_id_number_id = "12345678-abcd-1234-abcd-123456789012"

    # 設定内容: アウトバウンド発信時に実行するコンタクトフローのID
    # 設定可能な値: 既存のコンタクトフローID
    # 省略時: デフォルトのアウトバウンドフローを使用
    outbound_flow_id = "aaaaaaaa-1111-2222-3333-bbbbbbbbbbbb"
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（us-east-1, ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のマップ（最大50個）
  # 省略時: タグなし
  tags = {
    Name        = "CustomerSupportQueue"
    Environment = "Production"
    Department  = "CustomerService"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# - arn: キューのARN
# - queue_id: キューの一意なID
# - id: Terraform内部で使用されるリソースID（instance_id:queue_idの形式）
# - status: キューの現在のステータス
# - tags_all: デフォルトタグを含むすべてのタグのマップ
# - region: リソースが管理されているリージョン
#
# 参照例:
#   aws_connect_queue.example.arn
#   aws_connect_queue.example.queue_id
