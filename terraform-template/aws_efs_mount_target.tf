#-----------------------------------------------------------------------
# AWS EFS Mount Target (aws_efs_mount_target)
# Terraform Documentation: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/efs_mount_target
# Provider Version: 6.28.0
# Generated: 2026-02-17
#-----------------------------------------------------------------------
# NOTE: このテンプレートは実際の環境に合わせて値を調整してください。
#       コメントアウトされたパラメータは必要に応じて有効化できます。
#-----------------------------------------------------------------------
# EFSファイルシステムのマウントターゲットを管理します。
# マウントターゲットはVPC内の特定のサブネットにEFSファイルシステムを
# マウントするためのネットワークエンドポイントを提供します。
#-----------------------------------------------------------------------

resource "aws_efs_mount_target" "example" {
  #-----------------------------------------------------------------------
  # 必須設定
  #-----------------------------------------------------------------------
  # 設定内容: マウントターゲットを作成するEFSファイルシステムのID
  # 設定可能な値: EFSファイルシステムID（fs-xxxxxxxxxxxxxxxxx形式）
  file_system_id = "fs-12345678"

  # 設定内容: マウントターゲットを配置するサブネットのID
  # 設定可能な値: VPC内のサブネットID（subnet-xxxxxxxxxxxxxxxxx形式）
  # 注意事項: 各アベイラビリティゾーンにつき1つのマウントターゲットのみ作成可能
  subnet_id = "subnet-12345678"

  #-----------------------------------------------------------------------
  # ネットワーク設定
  #-----------------------------------------------------------------------
  # 設定内容: マウントターゲットに割り当てるプライベートIPアドレス
  # 設定可能な値: サブネットのCIDRブロック内の有効なIPv4アドレス
  # 省略時: サブネットから自動的に割り当てられます
  ip_address = null

  # 設定内容: マウントターゲットのIPアドレスタイプ
  # 設定可能な値: "IPv4" | "IPv6" | "IPv4AndIPv6"
  # 省略時: "IPv4"
  ip_address_type = null

  # 設定内容: マウントターゲットに割り当てるIPv6アドレス
  # 設定可能な値: サブネットのIPv6 CIDRブロック内の有効なアドレス
  # 省略時: ip_address_typeがIPv6を含む場合、自動的に割り当てられます
  # 前提条件: サブネットがIPv6 CIDRブロックを持っている必要があります
  ipv6_address = null

  # 設定内容: マウントターゲットに適用するセキュリティグループIDのリスト
  # 設定可能な値: セキュリティグループID（sg-xxxxxxxxxxxxxxxxx形式）のリスト
  # 省略時: VPCのデフォルトセキュリティグループが適用されます
  # 推奨設定: NFS（ポート2049）を許可するセキュリティグループを指定
  security_groups = null

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンが使用されます
  region = null

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------
  # timeouts {
  #   # 設定内容: マウントターゲット作成時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: 30m
  #   create = "30m"

  #   # 設定内容: マウントターゲット削除時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: 30m
  #   delete = "30m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-----------------------------------------------------------------------
# id                     - マウントターゲットのID
# availability_zone_id   - アベイラビリティゾーンの一意の識別子
# availability_zone_name - アベイラビリティゾーンの名前
# dns_name               - マウントターゲットのDNS名（IPv4用）
# mount_target_dns_name  - マウントターゲットのDNS名
# file_system_arn        - EFSファイルシステムのARN
# ip_address             - 割り当てられたIPv4アドレス
# ip_address_type        - IPアドレスタイプ
# ipv6_address           - 割り当てられたIPv6アドレス
# network_interface_id   - マウントターゲットに関連付けられたネットワークインターフェイスのID
# owner_id               - マウントターゲットを所有するAWSアカウントID
# region                 - リソースが管理されているリージョン
# security_groups        - 適用されているセキュリティグループIDのセット
