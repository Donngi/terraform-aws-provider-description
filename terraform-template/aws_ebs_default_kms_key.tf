#-------------------------------------------------------------------------------------------------------
# Resource: aws_ebs_default_kms_key
# Purpose: AWSアカウントのEBSボリューム暗号化に使用するデフォルトのKMSキーを管理する
#
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# Terraform Registry:
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ebs_default_kms_key
#
# AWS API Documentation:
# https://docs.aws.amazon.com/AWSEC2/latest/APIReference/API_ModifyEbsDefaultKmsKeyId.html
# https://docs.aws.amazon.com/AWSEC2/latest/APIReference/API_ResetEbsDefaultKmsKeyId.html
# https://docs.aws.amazon.com/AWSEC2/latest/APIReference/API_GetEbsDefaultKmsKeyId.html
#
# NOTE:
# - このリソースを作成してもデフォルトのEBS暗号化は有効にならない（aws_ebs_encryption_by_defaultリソースを使用する必要がある）
# - このリソースを削除すると、デフォルトCMKはアカウントのAWS管理デフォルトCMKにリセットされる
# - Amazon EBSは非対称KMSキーをサポートしていない（対称キーのみ使用可能）
#
# このリソースについて:
# - AWSアカウントがEBSボリューム暗号化に使用するデフォルトのカスタマーマスターキー(CMK)を管理する
# - デフォルトでは、AWSはEBSボリューム暗号化用にAWS管理のデフォルトCMKを各リージョンで作成する
# - このリソースを使用することで、AWS管理のCMKの代わりにカスタマー管理のCMKを指定できる
# - ボリューム作成時にCMKが指定されていない場合、このデフォルトCMKが使用される
#-------------------------------------------------------------------------------------------------------

resource "aws_ebs_default_kms_key" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 必須パラメータ
  #-------------------------------------------------------------------------------------------------------

  # KMSキーARN
  # 設定内容: EBSボリューム暗号化に使用するAWS KMSカスタマーマスターキー(CMK)のARN
  # 設定可能な値: 有効なKMSキーのARN（対称キーのみ）
  # 変更時の影響: リソースの再作成が発生する
  key_arn = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #-------------------------------------------------------------------------------------------------------
  # オプションパラメータ
  #-------------------------------------------------------------------------------------------------------

  # リージョン
  # 設定内容: このリソースが管理されるAWSリージョン
  # 設定可能な値: 有効なAWSリージョン名（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定で指定されたリージョンが使用される
  region = "us-east-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference
#-------------------------------------------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします（output値として参照可能）:
#
# - id - リソースのID（リージョン名）
# - key_arn - EBSボリューム暗号化に使用されるKMSキーのARN
# - region - リソースが管理されているAWSリージョン
#-------------------------------------------------------------------------------------------------------
