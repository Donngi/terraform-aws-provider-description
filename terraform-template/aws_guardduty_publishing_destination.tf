#######################################################################
# GuardDuty Publishing Destination
#######################################################################
# GuardDutyの検出結果をS3バケットなどの外部送信先へエクスポートする
# リソース。検出結果の長期保存、分析基盤への連携、コンプライアンス
# 対応などに利用する。
#
# 主な用途:
# - GuardDuty検出結果のS3への長期アーカイブ
# - SIEMや分析ツールへの検出結果連携
# - 複数アカウントの検出結果集約
# - コンプライアンス監査ログの保存
#
# 参考: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_exportfindings.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/guardduty_publishing_destination
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_guardduty_publishing_destination" "example" {
  #-----------------------------------------------------------------------
  # GuardDuty ディテクターの設定
  #-----------------------------------------------------------------------

  # 対象GuardDutyディテクターのID
  # 設定内容: 検出結果を送信するGuardDutyディテクターのID
  # 用途: どのディテクターの検出結果を送信するかを特定する
  detector_id = aws_guardduty_detector.example.id

  #-----------------------------------------------------------------------
  # 送信先の設定
  #-----------------------------------------------------------------------

  # 送信先のARN
  # 設定内容: 検出結果の送信先リソースのARN
  # 用途: S3バケットなどの送信先を指定する
  # 注意: S3バケットにはGuardDutyからの書き込みを許可するバケットポリシーが必要
  destination_arn = aws_s3_bucket.guardduty.arn

  # 送信先のタイプ
  # 設定内容: 検出結果の送信先となるサービスの種別
  # 設定可能な値:
  #   - S3: Amazon S3バケット
  # 省略時: S3
  destination_type = "S3"

  #-----------------------------------------------------------------------
  # 暗号化の設定
  #-----------------------------------------------------------------------

  # KMSキーのARN
  # 設定内容: 検出結果データの暗号化に使用するKMSキーのARN
  # 用途: 送信先に保存される検出結果の暗号化
  # 注意: KMSキーにはGuardDutyからの利用を許可するキーポリシーが必要
  kms_key_arn = aws_kms_key.guardduty.arn

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   送信先のID（ディテクターIDと送信先IDをコロン区切りで結合した値）
#-----------------------------------------------------------------------
