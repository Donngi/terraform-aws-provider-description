#-----------------------------------------------------------------------
# Amazon GuardDuty Publishing Destination (検出結果エクスポート先)
#-----------------------------------------------------------------------
#
# GuardDutyの検出結果をS3バケットなどの外部送信先へエクスポートするリソースです。
# 検出結果の長期保存、SIEM連携、コンプライアンス対応などに利用します。
# 既存のGuardDuty Detectorが必要です。
#
# 注意: S3バケットポリシーおよびKMSキーポリシーに適切な権限がないと
#       リソースの作成に失敗します。権限変更後の反映状況は
#       DescribePublishingDestination APIで確認できます。
#
# AWS公式ドキュメント:
#   - 検出結果のエクスポート: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_exportfindings.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/6.36.0/docs/resources/guardduty_publishing_destination
#
# Provider Version: 6.36.0
# Generated: 2026-03-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#-----------------------------------------------------------------------

resource "aws_guardduty_publishing_destination" "example" {
  #-----------------------------------------------------------------------
  # GuardDuty ディテクター設定
  #-----------------------------------------------------------------------

  # detector_id (Required)
  # 設定内容: 検出結果をエクスポートするGuardDutyディテクターのIDを指定します。
  # 設定可能な値: 有効なGuardDutyディテクターのID文字列
  detector_id = aws_guardduty_detector.example.id

  #-----------------------------------------------------------------------
  # エクスポート先設定
  #-----------------------------------------------------------------------

  # destination_arn (Required)
  # 設定内容: 検出結果のエクスポート先S3バケットのARNを指定します。
  # 設定可能な値: S3バケットのARN（プレフィックス付きも可）
  # 注意: バケットARNは必須。プレフィックスを省略した場合、
  #       AWSLogs/[Account-ID]/GuardDuty/[Region]/ が自動付与されます。
  #       S3バケットにはGuardDutyからのPutObjectおよびGetBucketLocationを
  #       許可するバケットポリシーが必要です。
  destination_arn = aws_s3_bucket.guardduty.arn

  # destination_type (Optional)
  # 設定内容: エクスポート先サービスの種別を指定します。
  # 設定可能な値:
  #   - "S3": Amazon S3バケット
  # 省略時: "S3"
  # destination_type = "S3"

  #-----------------------------------------------------------------------
  # 暗号化設定
  #-----------------------------------------------------------------------

  # kms_key_arn (Required)
  # 設定内容: 検出結果データの暗号化に使用するKMSキーのARNを指定します。
  # 設定可能な値: KMSキーのARN
  # 注意: GuardDutyはエクスポートされる検出結果の暗号化を必須としています。
  #       KMSキーにはGuardDutyサービスからのkms:GenerateDataKeyを
  #       許可するキーポリシーが必要です。
  kms_key_arn = aws_kms_key.guardduty.arn

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 注意: プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "guardduty-publishing-destination"
    Environment = "production"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: GuardDuty Publishing DestinationのARN
# - destination_id: エクスポート先のID
# - tags_all: プロバイダーの default_tags から継承されたタグを含む、
#             全タグのマップ
#-----------------------------------------------------------------------
