#---------------------------------------------------------------
# EC2インスタンスメタデータデフォルト設定
#---------------------------------------------------------------
#
# リージョンレベルでEC2インスタンスメタデータサービス（IMDS）のデフォルト設定を管理します。
# 新しく起動されるインスタンスに適用されるメタデータオプションのアカウントレベルのデフォルト値を設定できます。
# IMDSv2の強制、ホップ制限、エンドポイントの有効化、インスタンスタグへのアクセスなどを制御します。
#
# AWS公式ドキュメント:
#   - Configure instance metadata options for new instances: https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/configuring-IMDS-new-instances.html
#   - GetInstanceMetadataDefaults API: https://docs.aws.amazon.com/AWSEC2/latest/APIReference/API_GetInstanceMetadataDefaults.html
#   - ModifyInstanceMetadataDefaults API: https://docs.aws.amazon.com/AWSEC2/latest/APIReference/API_ModifyInstanceMetadataDefaults.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_instance_metadata_defaults
#
# Provider Version: 6.28.0
# Generated: 2026-01-31
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_ec2_instance_metadata_defaults" "example" {
  #---------------------------------------------------------------
  # メタデータサービスエンドポイント設定
  #---------------------------------------------------------------
  # メタデータサービスが利用可能かどうかを制御します。
  #
  # 設定可能な値:
  #   - "enabled"       : メタデータサービスを有効化（新規インスタンスでIMDSが利用可能）
  #   - "disabled"      : メタデータサービスを無効化（新規インスタンスでIMDSが利用不可）
  #   - "no-preference" : 設定なし（デフォルト動作）
  #
  # デフォルト: "no-preference"
  #
  # 注意事項:
  #   - この設定はアカウントレベルのデフォルト値であり、新規インスタンスに適用されます
  #   - 既存のインスタンスには影響しません
  #   - インスタンス起動時やAMI設定で個別にオーバーライド可能です
  #   - メタデータを完全に無効化する場合は "disabled" を指定します
  #
  http_endpoint = "enabled"

  #---------------------------------------------------------------
  # HTTPレスポンスホップ制限
  #---------------------------------------------------------------
  # インスタンスメタデータリクエストが通過できるネットワークホップ数の制限を設定します。
  # この値が大きいほど、メタデータリクエストがより遠くまで到達できます。
  #
  # 設定可能な値:
  #   - 1～64の整数 : 具体的なホップ数制限
  #   - -1         : 設定なし（no-preference）
  #
  # デフォルト: -1
  #
  # 推奨設定:
  #   - コンテナを実行する場合: 2以上
  #     （コンテナからホストのメタデータにアクセスするため追加のホップが必要）
  #   - 通常のEC2インスタンス: 1
  #     （メタデータへのアクセスを同一インスタンス内に制限）
  #
  # 注意事項:
  #   - セキュリティのため、必要最小限の値を設定することを推奨
  #   - IMDSv2を使用する場合、この設定でメタデータトークンの伝播範囲を制限できます
  #   - -1を指定すると、AMIの設定やその他のデフォルト値が適用されます
  #
  http_put_response_hop_limit = 1

  #---------------------------------------------------------------
  # IMDSv2セッショントークン要件
  #---------------------------------------------------------------
  # メタデータサービスがセッショントークンを要求するかどうかを設定します。
  # Instance Metadata Service Version 2 (IMDSv2) の使用を制御します。
  #
  # 設定可能な値:
  #   - "optional"      : IMDSv1とIMDSv2の両方を許可（デフォルト動作）
  #   - "required"      : IMDSv2のみを許可（セキュアな設定、推奨）
  #   - "no-preference" : 設定なし
  #
  # デフォルト: "no-preference"
  #
  # IMDSv2の利点:
  #   - SSRF（Server-Side Request Forgery）攻撃からの保護
  #   - セッションベースの認証によるセキュリティ強化
  #   - メタデータへのアクセスに明示的なトークン取得が必要
  #
  # 推奨設定:
  #   - 新規環境: "required" を推奨（IMDSv2を強制）
  #   - 既存環境の移行: まず "optional" で互換性を確認後、"required" に移行
  #
  # 注意事項:
  #   - "required" に設定する前に、既存のアプリケーションがIMDSv2に対応していることを確認
  #   - 古いSDKやツールはIMDSv2に対応していない可能性があります
  #   - この設定は新規インスタンスのみに適用され、既存インスタンスには影響しません
  #
  http_tokens = "required"

  #---------------------------------------------------------------
  # インスタンスメタデータタグアクセス
  #---------------------------------------------------------------
  # インスタンスメタデータサービスからインスタンスタグへのアクセスを制御します。
  #
  # 設定可能な値:
  #   - "enabled"       : インスタンスタグへのアクセスを有効化
  #   - "disabled"      : インスタンスタグへのアクセスを無効化（デフォルト動作）
  #   - "no-preference" : 設定なし
  #
  # デフォルト: "no-preference"（実質的には "disabled" と同じ動作）
  #
  # ユースケース:
  #   - インスタンス内のアプリケーションがタグ情報を必要とする場合
  #   - タグベースの動的な設定管理を行う場合
  #   - インスタンスの識別情報をメタデータから取得する場合
  #
  # 注意事項:
  #   - セキュリティ上の理由から、必要な場合のみ有効化してください
  #   - タグには機密情報を含めないように注意
  #   - IAMポリシーと組み合わせてアクセス制御を行うことを推奨
  #   - タグキーは特定の文字制限に準拠する必要があります
  #
  instance_metadata_tags = "disabled"

  #---------------------------------------------------------------
  # リージョン設定（オプション）
  #---------------------------------------------------------------
  # このリソースを管理するAWSリージョンを指定します。
  #
  # 設定値:
  #   - 任意のAWSリージョンコード（例: "us-east-1", "ap-northeast-1"）
  #
  # デフォルト: プロバイダー設定で指定されたリージョン
  #
  # 注意事項:
  #   - この設定はリージョンごとに個別に管理されます
  #   - 複数リージョンでデフォルト設定を行う場合は、リージョンごとにリソースを作成
  #   - 明示的に指定しない場合、プロバイダーの設定が使用されます
  #   - 詳細: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  #
  # region = "us-east-1"
}

