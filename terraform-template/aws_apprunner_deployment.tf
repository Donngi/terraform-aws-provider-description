#
# AWS App Runnerサービスへのデプロイメント操作を管理するリソースです。
# このリソースは、App Runnerサービスに対して新しいアプリケーションバージョンの
# 手動デプロイメントをトリガーするために使用されます。
#
# App Runnerは、コンテナ化されたWebアプリケーションやAPIサービスを
# インフラストラクチャの管理なしにデプロイできるフルマネージドサービスです。
# 自動デプロイメントと手動デプロイメントの2つの方法があり、
# このリソースは手動デプロイメントを実行する際に使用します。
#
# AWS公式ドキュメント:
#   - App Runner概要: https://docs.aws.amazon.com/apprunner/latest/dg/what-is-apprunner.html
#   - デプロイメント管理: https://docs.aws.amazon.com/apprunner/latest/dg/manage-deploy.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/apprunner_deployment
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_apprunner_deployment" "example" {
  #-------------------------------------------------------------
  # サービス設定
  #-------------------------------------------------------------

  # service_arn (Required)
  # 設定内容: デプロイメントを開始するApp RunnerサービスのARNを指定します。
  # 設定可能な値: 有効なApp RunnerサービスのARN
  # 関連機能: App Runnerサービス
  #   このリソースは指定されたサービスに対して手動デプロイメントを
  #   トリガーします。サービスが自動デプロイメントに設定されている場合でも、
  #   このリソースを使用して明示的にデプロイメントを実行できます。
  #   - https://docs.aws.amazon.com/apprunner/latest/dg/manage-deploy.html
  service_arn = "arn:aws:apprunner:ap-northeast-1:123456789012:service/my-service/1234567890123456789"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: リソース作成（デプロイメント完了）のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "5m", "2h45m" などの時間文字列
    #   有効な単位: "s" (秒), "m" (分), "h" (時間)
    # 省略時: デフォルトのタイムアウト値が使用されます
    # 注意: デプロイメント完了までの時間はアプリケーションのサイズや
    #       ビルド時間によって異なるため、適切な値を設定してください。
    create = "20m"
  }
}

