#---------------------------------------------------------------
# AWS Global Accelerator カスタムルーティング エンドポイントグループ
#---------------------------------------------------------------
#
# AWS Global Acceleratorのカスタムルーティングアクセラレーター用の
# エンドポイントグループをプロビジョニングするリソースです。
# カスタムルーティングエンドポイントグループは、リスナーに関連付けられ、
# トラフィックを転送するVPCサブネットのエンドポイントと、
# 使用するポート範囲およびプロトコルを定義します。
#
# AWS公式ドキュメント:
#   - Global Accelerator カスタムルーティング: https://docs.aws.amazon.com/global-accelerator/latest/dg/work-with-custom-routing-accelerators.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/globalaccelerator_custom_routing_endpoint_group
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_globalaccelerator_custom_routing_endpoint_group" "example" {
  #-------------------------------------------------------------
  # リスナー設定
  #-------------------------------------------------------------

  # listener_arn (Required)
  # 設定内容: このエンドポイントグループを関連付けるカスタムルーティングリスナーのARNを指定します。
  # 設定可能な値: aws_globalaccelerator_custom_routing_listener リソースのARN
  listener_arn = aws_globalaccelerator_custom_routing_listener.example.arn

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # endpoint_group_region (Optional)
  # 設定内容: エンドポイントグループを配置するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  endpoint_group_region = null

  #-------------------------------------------------------------
  # 転送先設定
  #-------------------------------------------------------------

  # destination_configuration (Required)
  # 設定内容: エンドポイントグループ内の全エンドポイントがクライアントトラフィックを
  #          受け付けるポート範囲とプロトコルを指定します。
  # 注意: 最低1つのdestination_configurationブロックが必須です。
  destination_configuration {
    # from_port (Required)
    # 設定内容: エンドポイントグループに関連付けられたポート範囲の開始ポートを指定します。
    # 設定可能な値: 1〜65535 の整数
    from_port = 80

    # to_port (Required)
    # 設定内容: エンドポイントグループに関連付けられたポート範囲の終了ポートを指定します。
    # 設定可能な値: 1〜65535 の整数（from_port 以上の値）
    to_port = 8080

    # protocols (Required)
    # 設定内容: カスタムルーティングアクセラレーターに関連付けられた
    #          エンドポイントグループが使用するプロトコルを指定します。
    # 設定可能な値: "TCP", "UDP" の1つ以上を含むセット
    protocols = ["TCP"]
  }

  #-------------------------------------------------------------
  # エンドポイント設定
  #-------------------------------------------------------------

  # endpoint_configuration (Optional)
  # 設定内容: エンドポイントオブジェクトのリストを指定します。
  #          カスタムルーティングアクセラレーターでは、VPCサブネットIDを指定します。
  endpoint_configuration {
    # endpoint_id (Optional)
    # 設定内容: エンドポイントのIDを指定します。
    #          カスタムルーティングアクセラレーターでは、VPCのサブネットIDを指定します。
    # 設定可能な値: VPCサブネットのID（例: subnet-xxxxxxxxxxxxxxxxx）
    endpoint_id = aws_subnet.example.id
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: リソース作成のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" などのGoの時間書式
    # 省略時: プロバイダーのデフォルトタイムアウトを使用
    create = null

    # delete (Optional)
    # 設定内容: リソース削除のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" などのGoの時間書式
    # 省略時: プロバイダーのデフォルトタイムアウトを使用
    delete = null
  }
}

