  #   IPAMプールにCIDRをプロビジョニングした後、このリソースで
  #   プール内の特定のCIDR範囲を割り当て（アロケーション）します。
  #   - https://docs.aws.amazon.com/vpc/latest/ipam/what-it-is-ipam.html
  ipam_pool_id = "ipam-pool-0123456789abcdef0"

  #---------------------------------------------------------------
  # CIDR割り当て設定
  #---------------------------------------------------------------

  # cidr (Optional, Computed)
  # 設定内容: 割り当てたいCIDRブロックを明示的に指定します。
  # 設定可能な値: 有効なIPv4またはIPv6 CIDRブロック（例: "10.0.0.0/24", "2001:db8::/64"）
  # 省略時: netmask_lengthが指定された場合は自動的に決定されます。
  # 注意: netmask_lengthと同時に指定できません。どちらか一方のみ使用してください。
  cidr = null

  # netmask_length (Optional, Computed)
  # 設定内容: 自動割り当てするCIDRのネットマスク長を指定します。
  # 設定可能な値: IPv4の場合は整数（例: 24、28）、IPv6の場合は整数（例: 64、128）
  # 省略時: cidrが明示指定された場合は不要です。
  # 注意: cidrと同時に指定できません。どちらか一方のみ使用してください。
  #       指定したネットマスク長で、プール内の次に利用可能なCIDRが自動的に割り当てられます。
  netmask_length = null

  # disallowed_cidrs (Optional)
  # 設定内容: 割り当て時に除外したいCIDRブロックのセットを指定します。
  # 設定可能な値: 除外するCIDRブロックの文字列セット（例: ["10.0.1.0/24", "10.0.2.0/24"]）
  # 省略時: 除外するCIDRなし（全プールCIDRが割り当て候補）
  # 用途: 特定のCIDR範囲を予約または除外して、自動割り当ての対象外にしたい場合に使用します。
  #       netmask_lengthと組み合わせることで、除外リスト外の範囲から自動割り当てができます。
  disallowed_cidrs = null

