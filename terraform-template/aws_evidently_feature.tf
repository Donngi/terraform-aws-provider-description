#---------------------------------------
# AWS CloudWatch Evidently Feature
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/evidently_feature
#
# NOTE: このリソースは非推奨となっています。
# 新規開発ではAWS AppConfig Feature Flagsの使用が推奨されています。
#
# CloudWatch Evidentlyのフィーチャーフラグを作成・管理します。
# A/Bテストや段階的なロールアウトを実施する際に使用します。
#
# ユースケース:
# - 新機能のA/Bテスト実施
# - フィーチャーフラグによる機能の段階的リリース
# - ユーザーセグメントごとの異なる機能バリエーション提供
# - 本番環境での安全な機能検証
#
# 制約事項:
# - フィーチャー名は1〜127文字
# - バリエーションは1〜5個まで設定可能
# - プロジェクトが事前に作成されている必要があります
#
# 関連リソース:
# - aws_evidently_project (必須の親リソース)
# - aws_evidently_launch (フィーチャーのロールアウト管理)
# - aws_evidently_experiment (A/Bテスト実験の実施)

resource "aws_evidently_feature" "example" {
  #---------------------------------------
  # 基本設定
  #---------------------------------------

  # 設定内容: フィーチャーの名前
  # 設定可能な値: 1〜127文字の文字列
  # 補足: プロジェクト内で一意である必要があります
  name = "example-feature"

  # 設定内容: フィーチャーを含むプロジェクト
  # 設定可能な値: プロジェクト名またはARN
  # 補足: 事前にaws_evidently_projectリソースを作成しておく必要があります
  project = "example-project"

  # 設定内容: フィーチャーの説明
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  description = "新機能のA/Bテスト用フィーチャーフラグ"

  #---------------------------------------
  # バリエーション設定
  #---------------------------------------
  # フィーチャーの異なるバリエーションを定義します。
  # 最小1個、最大5個まで設定可能です。

  variations {
    # 設定内容: バリエーション名
    # 設定可能な値: 1〜127文字の文字列
    # 補足: フィーチャー内で一意である必要があります
    name = "Variation1"

    # バリエーションの値を定義
    # bool_value、double_value、long_value、string_valueのいずれか1つを指定します
    value {
      # 設定内容: 文字列型の値
      # 設定可能な値: 0〜512文字の文字列
      # 補足: string_value、bool_value、double_value、long_valueのいずれか1つのみ指定
      string_value = "control"

      # 設定内容: 真偽値型の値
      # 設定可能な値: "true" または "false" (文字列として指定)
      # 補足: ブール値のバリエーションに使用
      # bool_value = "true"

      # 設定内容: 倍精度浮動小数点型の値
      # 設定可能な値: 任意の数値 (文字列として指定)
      # 補足: 小数を含む数値のバリエーションに使用
      # double_value = "1.5"

      # 設定内容: 長整数型の値
      # 設定可能な値: -9007199254740991 〜 9007199254740991
      # 補足: 整数値のバリエーションに使用
      # long_value = "100"
    }
  }

  # 追加のバリエーション例
  # variations {
  #   name = "Variation2"
  #   value {
  #     string_value = "treatment"
  #   }
  # }

  #---------------------------------------
  # デフォルトバリエーション設定
  #---------------------------------------

  # 設定内容: デフォルトで使用するバリエーション名
  # 設定可能な値: variationsブロックで定義したバリエーション名
  # 省略時: 最初に定義されたバリエーションが使用されます
  # 補足: ローンチや実験に割り当てられていないユーザーに提供されます
  default_variation = "Variation1"

  #---------------------------------------
  # エンティティオーバーライド設定
  #---------------------------------------

  # 設定内容: 特定ユーザーに常に提供するバリエーションの指定
  # 設定可能な値: ユーザー識別子とバリエーション名のマップ
  # 省略時: オーバーライドなし
  # 補足: キーはユーザーID、値はバリエーション名を指定します
  entity_overrides = {
    "user-123" = "Variation1"
    "user-456" = "Variation2"
  }

  #---------------------------------------
  # 評価戦略設定
  #---------------------------------------

  # 設定内容: フィーチャーの評価戦略
  # 設定可能な値:
  #   - ALL_RULES: ローンチや実験で指定されたトラフィック配分を有効化
  #   - DEFAULT_VARIATION: すべてのユーザーにデフォルトバリエーションを提供
  # 省略時: ALL_RULES
  # 補足: 実験やローンチを一時停止する際にDEFAULT_VARIATIONを使用します
  evaluation_strategy = "ALL_RULES"

  #---------------------------------------
  # リージョン設定
  #---------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード (例: us-east-1, ap-northeast-1)
  # 省略時: プロバイダー設定のリージョン
  # 補足: プロジェクトと同じリージョンを指定する必要があります
  region = "us-east-1"

  #---------------------------------------
  # タグ設定
  #---------------------------------------

  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 補足: プロバイダーのdefault_tagsと統合されます
  tags = {
    Environment = "production"
    Project     = "ab-testing"
    ManagedBy   = "terraform"
  }

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  # timeouts {
  #   # 設定内容: 作成時のタイムアウト時間
  #   # 設定可能な値: 時間文字列 (例: "10m", "1h")
  #   # 省略時: 2m
  #   # create = "2m"

  #   # 設定内容: 更新時のタイムアウト時間
  #   # 設定可能な値: 時間文字列 (例: "10m", "1h")
  #   # 省略時: 2m
  #   # update = "2m"

  #   # 設定内容: 削除時のタイムアウト時間
  #   # 設定可能な値: 時間文字列 (例: "10m", "1h")
  #   # 省略時: 2m
  #   # delete = "2m"
  # }
}

#---------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------
# このリソースの作成後に参照可能な属性:
#
# - arn: フィーチャーのARN
# - created_time: フィーチャーの作成日時
# - id: フィーチャー識別子 (形式: project_name:feature_name)
# - last_updated_time: 最終更新日時
# - status: フィーチャーの状態 (AVAILABLE, UPDATING)
# - tags_all: プロバイダーのdefault_tagsを含むすべてのタグ
# - value_type: バリエーションの値の型 (STRING, LONG, DOUBLE, BOOLEAN)
# - evaluation_rules: 評価ルールのリスト
#   - name: 実験またはローンチの名前
#   - type: ルールの種類 (aws.evidently.splits, aws.evidently.onlineab)
