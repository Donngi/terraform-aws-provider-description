#---------------------------------------------------------------
# S3 Bucket Object Lock Configuration
#---------------------------------------------------------------
#
# S3バケットのObject Lock設定を管理するリソース。
# Object Lockは、オブジェクトの削除や上書きを一定期間または無期限に防ぐ
# Write-Once-Read-Many (WORM) モデルを提供します。
# 規制要件への対応や、データ保護の追加レイヤーとして使用できます。
#
# 重要な前提条件:
# - S3バケットでバージョニングが有効化されている必要があります
# - 新規バケットまたは既存バケットの両方で使用可能です
# - S3 Directory Bucketsでは使用できません
# - Object Lockを有効化すると、バケットでの無効化やバージョニング停止はできません
#
# AWS公式ドキュメント:
#   - Using S3 Object Lock: https://docs.aws.amazon.com/AmazonS3/latest/userguide/object-lock.html
#   - Configuring S3 Object Lock: https://docs.aws.amazon.com/AmazonS3/latest/userguide/object-lock-configure.html
#   - ObjectLockConfiguration API: https://docs.aws.amazon.com/AmazonS3/latest/API/API_ObjectLockConfiguration.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/s3_bucket_object_lock_configuration
#
# Provider Version: 6.28.0
# Generated: 2026-02-03
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_s3_bucket_object_lock_configuration" "example" {
  #---------------------------------------------------------------
  # 必須パラメータ
  #---------------------------------------------------------------

  # バケット名 (必須)
  # Object Lock設定を適用するS3バケットの名前
  # 注意: この値の変更は新しいリソースの作成を強制します (Forces new resource)
  bucket = "example-bucket-name"

  #---------------------------------------------------------------
  # オプションパラメータ
  #---------------------------------------------------------------

  # 期待されるバケット所有者のアカウントID (オプション)
  # バケット所有者の検証に使用。指定したアカウントIDがバケット所有者と
  # 一致しない場合、APIリクエストは失敗します
  # 注意: この値の変更は新しいリソースの作成を強制します (Forces new resource)
  # expected_bucket_owner = "123456789012"

  # Object Lock有効化フラグ (オプション)
  # バケットでObject Lock設定が有効かどうかを示します
  # 有効な値: "Enabled"
  # デフォルト: "Enabled"
  # 注意: この値の変更は新しいリソースの作成を強制します (Forces new resource)
  # object_lock_enabled = "Enabled"

  # リージョン (オプション)
  # このリソースを管理するAWSリージョン
  # 指定しない場合、プロバイダー設定のリージョンが使用されます
  # この属性は computed であり、指定しない場合は自動的に設定されます
  # region = "us-east-1"

  # トークン (オプション、非推奨)
  # 注意: この引数は非推奨であり、Object Lock有効化には不要です
  # 既存バケットでObject Lockを有効化するには、まずバケットでバージョニングを
  # 有効化し、その後Object Lockを有効化してください
  # 詳細はaws_s3_bucket_versioningリソースを参照してください
  # この属性は sensitive であり、Terraformステート内で暗号化されます
  # token = "..."

  #---------------------------------------------------------------
  # ネストブロック: rule
  #---------------------------------------------------------------
  # Object Lockルールの設定 (オプション)
  # バケットに配置される新しいオブジェクトに適用される
  # デフォルトのObject Lock保持設定を指定します
  # 最大1つのruleブロックを指定可能
  #
  # rule {
  #   #---------------------------------------------------------------
  #   # ネストブロック: default_retention (ruleブロック内で必須)
  #   #---------------------------------------------------------------
  #   # デフォルト保持期間の設定
  #   # バケットに配置される新しいオブジェクトに適用される
  #   # デフォルトの保持設定を指定します
  #   # 1つのdefault_retentionブロックを指定する必要があります
  #   #
  #   default_retention {
  #     # 保持モード (必須)
  #     # 新しいオブジェクトに適用するデフォルトのObject Lock保持モード
  #     # 有効な値: "COMPLIANCE", "GOVERNANCE"
  #     #
  #     # COMPLIANCE モード:
  #     # - 保護されたオブジェクトバージョンは、AWSアカウントのルートユーザーを
  #     #   含むすべてのユーザーが上書きまたは削除できません
  #     # - 保持モードの変更や保持期間の短縮はできません
  #     # - 保持期間が経過する前にオブジェクトを削除する唯一の方法は、
  #     #   関連するAWSアカウントを削除することです
  #     #
  #     # GOVERNANCE モード:
  #     # - 特別な権限を持たないユーザーはオブジェクトの上書き、削除、
  #     #   ロック設定の変更ができません
  #     # - s3:BypassGovernanceRetention権限を持つユーザーは、
  #     #   保持設定の変更やオブジェクトの削除が可能です
  #     # - 保持期間設定のテストにも使用できます
  #     mode = "COMPLIANCE"
  #
  #     # 保持日数 (オプション、yearsが指定されていない場合は必須)
  #     # デフォルト保持期間として指定する日数
  #     # daysまたはyearsのいずれか一方を指定する必要があります
  #     # 両方を同時に指定することはできません
  #     days = 5
  #
  #     # 保持年数 (オプション、daysが指定されていない場合は必須)
  #     # デフォルト保持期間として指定する年数
  #     # daysまたはyearsのいずれか一方を指定する必要があります
  #     # 両方を同時に指定することはできません
  #     # years = 1
  #   }
  # }
}

