#---------------------------------------------------------------
# AWS VPC Security Group Ingress Rule
#---------------------------------------------------------------
#
# VPCセキュリティグループにインバウンドルールを1件追加するリソースです。
# 従来の aws_security_group_rule と異なり、1リソースで1ルール（1送信元）を
# 管理するため、Terraform による差分検知が正確になります。
# CIDRブロック、プレフィックスリスト、他セキュリティグループのいずれかを
# 送信元として指定します（いずれか1つを指定してください）。
#
# 注意: aws_security_group のインラインルール（ingress ブロック）や
#       aws_security_group_rule と組み合わせるとルールの競合が発生します。
#       これらを混在させずに使用してください。
#
# AWS公式ドキュメント:
#   - セキュリティグループルール: https://docs.aws.amazon.com/vpc/latest/userguide/security-group-rules.html
#   - セキュリティグループルールの追加: https://docs.aws.amazon.com/vpc/latest/userguide/working-with-security-group-rules.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/vpc_security_group_ingress_rule
#
# Provider Version: 6.28.0
# Generated: 2026-02-19
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_vpc_security_group_ingress_rule" "example" {
  #-------------------------------------------------------------
  # 対象セキュリティグループ設定
  #-------------------------------------------------------------

  # security_group_id (Required)
  # 設定内容: このインバウンドルールを追加するセキュリティグループのIDを指定します。
  # 設定可能な値: 有効なセキュリティグループID（例: "sg-12345678"）
  security_group_id = "sg-12345678"

  #-------------------------------------------------------------
  # プロトコル・ポート設定
  #-------------------------------------------------------------

  # ip_protocol (Required)
  # 設定内容: ルールに適用するIPプロトコルを指定します。
  # 設定可能な値:
  #   - "tcp": TCPプロトコル
  #   - "udp": UDPプロトコル
  #   - "icmp": ICMPプロトコル
  #   - "icmpv6": ICMPv6プロトコル
  #   - "-1": 全プロトコル（from_port, to_portは指定不要）
  #   - プロトコル番号（文字列形式）: IANAプロトコル番号（例: "6"=TCP, "17"=UDP）
  # 参考: https://www.iana.org/assignments/protocol-numbers/protocol-numbers.xhtml
  ip_protocol = "tcp"

  # from_port (Optional)
  # 設定内容: 許可するポート範囲の開始ポート番号を指定します。
  #           icmp/icmpv6の場合はICMPタイプ番号（-1で全タイプ）を指定します。
  # 設定可能な値: 0〜65535の整数。ip_protocol が "-1" の場合は指定不要
  # 省略時: ポート範囲の指定なし
  from_port = 443

  # to_port (Optional)
  # 設定内容: 許可するポート範囲の終了ポート番号を指定します。
  #           icmpの場合はICMPコード番号（-1で全コード）を指定します。
  # 設定可能な値: 0〜65535の整数。ip_protocol が "-1" の場合は指定不要
  # 省略時: ポート範囲の指定なし
  to_port = 443

  #-------------------------------------------------------------
  # 送信元設定（いずれか1つを指定）
  #-------------------------------------------------------------
  # 注意: cidr_ipv4, cidr_ipv6, prefix_list_id, referenced_security_group_id の
  #       うちいずれか1つのみを指定してください。複数同時指定はできません。

  # cidr_ipv4 (Optional)
  # 設定内容: 送信元として許可するIPv4 CIDRブロックを指定します。
  # 設定可能な値: 有効なIPv4 CIDRブロック（例: "0.0.0.0/0", "10.0.0.0/8"）
  # 省略時: IPv4 CIDRブロックによる送信元制限なし
  cidr_ipv4 = "0.0.0.0/0"

  # cidr_ipv6 (Optional)
  # 設定内容: 送信元として許可するIPv6 CIDRブロックを指定します。
  # 設定可能な値: 有効なIPv6 CIDRブロック（例: "::/0", "2001:db8::/32"）
  # 省略時: IPv6 CIDRブロックによる送信元制限なし
  cidr_ipv6 = null

  # prefix_list_id (Optional)
  # 設定内容: 送信元として使用するマネージドプレフィックスリストのIDを指定します。
  # 設定可能な値: 有効なプレフィックスリストID（例: "pl-12345678"）
  # 省略時: プレフィックスリストによる送信元制限なし
  prefix_list_id = null

  # referenced_security_group_id (Optional)
  # 設定内容: 送信元として許可する他のセキュリティグループのIDを指定します。
  #           同一VPC内または共有セキュリティグループのIDを指定します。
  # 設定可能な値: 有効なセキュリティグループID（例: "sg-98765432"）
  # 省略時: セキュリティグループ参照による送信元制限なし
  referenced_security_group_id = null

  #-------------------------------------------------------------
  # 説明設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: セキュリティグループルールの説明を指定します。
  # 設定可能な値: 255文字以内の文字列
  # 省略時: 説明なし
  description = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに付与するタグをキーと値のマップで指定します。
  # 設定可能な値: 文字列キーと文字列値のマップ（例: { Name = "example-rule" }）
  # 省略時: タグなし
  tags = {}

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: "ap-northeast-1", "us-east-1"）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: セキュリティグループルールのリソースID。
#
# - arn: セキュリティグループルールのARN。
#
# - security_group_rule_id: AWSが割り当てるセキュリティグループルールID。
#
# - tags_all: プロバイダーのdefault_tags設定を含む全タグのマップ。
#---------------------------------------------------------------
