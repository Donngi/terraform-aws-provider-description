#-----------------------------------------------------------------------
# AWS Elastic Transcoder プリセット
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/elastictranscoder_preset
# Generated: 2026-02-17
#
# Elastic Transcoderでメディアファイルを変換する際に使用する
# プリセット（エンコード設定）を定義します。
#
# 【重要な非推奨警告】
# このリソースは非推奨です。AWS Elemental MediaConvertへの移行を推奨します。
# AWSは2025年11月13日をもってAmazon Elastic Transcoderのサポートを終了します。
# https://aws.amazon.com/blogs/media/support-for-amazon-elastic-transcoder-ending-soon/
#
# NOTE: このリソースに変更を加えると新しいリソースが作成されます（Forces new resource）
#
# ユースケース:
# - ビデオ/オーディオのトランスコーディング設定
# - 複数の出力形式の標準化
# - サムネイル生成設定
# - ウォーターマーク設定の管理
#-----------------------------------------------------------------------

resource "aws_elastictranscoder_preset" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------
  # 設定内容: 出力ファイルのコンテナ形式
  # 設定可能な値: flac, flv, fmp4, gif, mp3, mp4, mpg, mxf, oga, ogg, ts, webm
  # 必須項目（新規リソース作成時に変更不可）
  container = "mp4"

  # 設定内容: プリセットの説明文（最大255文字）
  # 省略時: 説明なし
  description = "Sample Preset for video transcoding"

  # 設定内容: プリセットの名前（最大40文字）
  # 省略時: AWS側で自動生成
  name = "sample_preset"

  # 設定内容: プリセットのタイプ
  # 省略時: AWS側で自動判定
  type = "System"

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # オーディオ設定
  #-----------------------------------------------------------------------
  audio {
    # 設定内容: オーディオチャンネルとトラックの編成方法
    # 設定可能な値: SingleTrack（1トラック）など
    # 省略時: SingleTrack
    audio_packing_mode = "SingleTrack"

    # 設定内容: 出力ファイルのオーディオストリームのビットレート（キロビット/秒）
    # 設定可能な値: 64〜320の整数
    # 省略時: AWS側で自動設定
    bit_rate = "96"

    # 設定内容: 出力ファイルのオーディオチャンネル数
    # 設定可能な値: 1（モノラル）, 2（ステレオ）
    channels = "2"

    # 設定内容: 出力ファイルのオーディオコーデック
    # 設定可能な値: AAC, flac, mp2, mp3, pcm, vorbis
    codec = "AAC"

    # 設定内容: 出力ファイルのオーディオサンプルレート（ヘルツ）
    # 設定可能な値: auto, 22050, 32000, 44100, 48000, 96000
    sample_rate = "44100"
  }

  #-----------------------------------------------------------------------
  # オーディオコーデックオプション
  #-----------------------------------------------------------------------
  audio_codec_options {
    # 設定内容: AACコーデックのプロファイル（AAC使用時）
    # 設定可能な値: AAC-LC（低複雑度）, HE-AAC（高効率）など
    # 省略時: AWS側で自動設定
    profile = "AAC-LC"

    # 設定内容: サンプルのビット深度（FLAC/PCMのみ）
    # 設定可能な値: 16, 24
    # 省略時: AWS側で自動設定
    # bit_depth = "16"

    # 設定内容: PCMサンプルのビット順序（PCMのみ）
    # 設定可能な値: LittleEndian
    # 省略時: AWS側で自動設定
    # bit_order = "LittleEndian"

    # 設定内容: オーディオサンプルの符号表現（PCMのみ）
    # 設定可能な値: Signed（正負の値）
    # 省略時: AWS側で自動設定
    # signed = "Signed"
  }

  #-----------------------------------------------------------------------
  # ビデオ設定
  #-----------------------------------------------------------------------
  video {
    # 設定内容: 出力ファイルのビデオのアスペクト比
    # 設定可能な値: auto, 1:1, 4:3, 3:2, 16:9
    # 省略時: auto
    # aspect_ratio = "auto"

    # 設定内容: 出力ファイルのビデオストリームのビットレート（キロビット/秒）
    # 可変ビットレートまたは固定ビットレートを設定可能
    # 省略時: AWS側で自動設定
    bit_rate = "1600"

    # 設定内容: 出力ファイルのビデオコーデック
    # 設定可能な値: gif, H.264, mpeg2, vp8, vp9
    codec = "H.264"

    # 設定内容: 出力ファイルのメタデータに追加される表示アスペクト比
    # 設定可能な値: auto（正方形ピクセルを保証）, 1:1, 4:3, 3:2, 16:9
    # 省略時: auto
    display_aspect_ratio = "16:9"

    # 設定内容: Video:FixedGOPに固定値を使用するか（GIFコンテナには適用不可）
    # 設定可能な値: true（固定）, false（可変）
    # 省略時: false
    fixed_gop = "false"

    # 設定内容: 出力ファイルのフレームレート（フレーム/秒）
    # 設定可能な値: auto, 10, 15, 23.97, 24, 25, 29.97, 30, 50, 60
    frame_rate = "auto"

    # 設定内容: キーフレーム間の最大フレーム数（GIFコンテナには適用不可）
    # 省略時: AWS側で自動設定
    keyframes_max_dist = "240"

    # 設定内容: FrameRateにautoを指定した場合の最大フレームレート
    # 省略時: 30
    max_frame_rate = "60"

    # 設定内容: 出力ビデオの最大高さ（ピクセル）
    # 設定可能な値: auto（デフォルト1080）または96〜3072の偶数
    # 省略時: auto
    max_height = "auto"

    # 設定内容: 出力ビデオの最大幅（ピクセル）
    # 設定可能な値: auto（デフォルト1920）または128〜4096の偶数
    # 省略時: auto
    max_width = "auto"

    # 設定内容: 出力ビデオのパディングポリシー
    # 設定可能な値: Pad（黒帯を追加）, NoPad（パディングなし）
    # 省略時: NoPad
    padding_policy = "Pad"

    # 設定内容: 出力ファイルのビデオの幅と高さ（widthxheight形式）
    # 設定可能な値: auto, 幅x高さ（例: 1920x1080）
    # 省略時: auto
    # resolution = "auto"

    # 設定内容: 出力ビデオのスケーリング制御
    # 設定可能な値: Fit（比率維持）, Fill（埋める）, Stretch（引き伸ばす）, Keep（維持）, ShrinkToFit（縮小して収める）, ShrinkToFill（縮小して埋める）
    # 省略時: Fit
    sizing_policy = "Fit"
  }

  #-----------------------------------------------------------------------
  # ビデオコーデックオプション
  #-----------------------------------------------------------------------
  # 設定内容: ビデオコーデックの詳細設定（マップ形式）
  # H.264/VP8/VP9/MPEG2などのコーデック固有設定を指定
  video_codec_options = {
    # H.264プロファイル（baseline, main, highなど）
    Profile = "main"

    # H.264レベル（1, 1b, 1.1, 1.2, 1.3, 2, 2.1, 2.2, 3, 3.1, 3.2, 4, 4.1）
    Level = "2.2"

    # 参照フレームとして使用する最大フレーム数（0〜16）
    MaxReferenceFrames = "3"

    # インターレースモード（Progressive, TopFirst, BottomFirst, Autoなど）
    InterlacedMode = "Progressive"

    # 色空間変換（None, Bt709toBt601, Bt601toBt709, Auto）
    ColorSpaceConversionMode = "None"

    # 最大ビットレート（16〜62500キロビット/秒、またはauto）（オプション）
    # MaxBitRate = "auto"

    # バッファサイズ（MaxBitRateの10倍が推奨）（オプション）
    # BufferSize = "16000"

    # クロマサブサンプリング（yuv420p, yuv422p）
    # ChromaSubsampling = "yuv420p"

    # GIFのループ回数（GIFコーデック使用時）
    # LoopCount = "0"
  }

  #-----------------------------------------------------------------------
  # ビデオウォーターマーク設定
  #-----------------------------------------------------------------------
  video_watermarks {
    # 設定内容: ウォーターマークの一意識別子（最大40文字）
    # 最大4つのウォーターマークを設定可能
    id = "Terraform Test"

    # 設定内容: ウォーターマークの最大高さ
    # 設定可能な値: ピクセル数またはパーセンテージ（例: "20%"）
    max_height = "20%"

    # 設定内容: ウォーターマークの最大幅
    # 設定可能な値: ピクセル数またはパーセンテージ（例: "20%"）
    max_width = "20%"

    # 設定内容: ウォーターマークのスケーリング制御
    # 設定可能な値: Fit（比率維持）, Stretch（引き伸ばす）, ShrinkToFit（縮小して収める）
    sizing_policy = "ShrinkToFit"

    # 設定内容: ウォーターマークの水平位置（offsetが0の場合）
    # 設定可能な値: Left（左）, Right（右）, Center（中央）
    horizontal_align = "Right"

    # 設定内容: horizontal_alignからの水平オフセット
    # 設定可能な値: ピクセル数（例: "10px"）またはパーセンテージ
    horizontal_offset = "10px"

    # 設定内容: ウォーターマークの垂直位置（offsetが0の場合）
    # 設定可能な値: Top（上）, Bottom（下）, Center（中央）
    vertical_align = "Bottom"

    # 設定内容: vertical_alignからの垂直オフセット
    # 設定可能な値: ピクセル数（例: "10px"）またはパーセンテージ
    vertical_offset = "10px"

    # 設定内容: ウォーターマークの不透明度（0〜100）
    # 設定可能な値: 0（完全透明）〜100（完全不透明）
    opacity = "55.5"

    # 設定内容: オフセット値と最大幅/高さの解釈方法
    # 設定可能な値: Content（コンテンツに対して）, Frame（フレームに対して）
    target = "Content"
  }

  #-----------------------------------------------------------------------
  # サムネイル設定
  #-----------------------------------------------------------------------
  thumbnails {
    # 設定内容: サムネイルのアスペクト比
    # 設定可能な値: auto, 1:1, 4:3, 3:2, 16:9
    # aspect_ratio = "auto"

    # 設定内容: サムネイルのフォーマット
    # 設定可能な値: jpg, png
    format = "png"

    # 設定内容: サムネイル間のおおよその間隔（秒）
    # 整数を指定（実際の間隔は数秒変動する可能性あり）
    interval = "120"

    # 設定内容: サムネイルの最大高さ（ピクセル）
    # 設定可能な値: auto（デフォルト1080）または32〜3072の偶数
    max_height = "auto"

    # 設定内容: サムネイルの最大幅（ピクセル）
    # 設定可能な値: auto（デフォルト1920）または32〜4096の偶数
    max_width = "auto"

    # 設定内容: サムネイルのパディングポリシー
    # 設定可能な値: Pad（黒帯を追加してサイズを調整）, NoPad（パディングなし）
    padding_policy = "Pad"

    # 設定内容: サムネイルの幅と高さ（widthxheight形式）
    # 注意: max_width/max_height/sizing_policy/padding_policyとの併用不可
    # resolution = "auto"

    # 設定内容: サムネイルのスケーリング制御
    # 設定可能な値: Fit（比率維持）, Fill（埋める）, Stretch（引き伸ばす）, Keep（維持）, ShrinkToFit（縮小して収める）, ShrinkToFill（縮小して埋める）
    sizing_policy = "Fit"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# arn - プリセットのAmazon Resource Name（ARN）
# id - プリセットのID
# name - プリセットの名前
# type - プリセットのタイプ
