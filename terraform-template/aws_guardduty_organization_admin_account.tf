#######################################################################
# GuardDuty 組織委任管理者アカウント
#######################################################################
# AWS Organizations の主アカウントから特定のメンバーアカウントを
# GuardDuty の委任管理者として指定するリソース。
# 委任管理者アカウントは組織全体のGuardDuty設定・メンバー管理を担当する。
#
# 主な用途:
# - Organizations 全体のGuardDuty管理を専用アカウントへ委任
# - セキュリティ専用アカウントへの管理権限の集約
# - マルチアカウント構成でのGuardDuty一元管理
#
# 前提条件:
# - このリソースを使用するAWSアカウントがOrganizationsの主アカウントであること
# - Organizations で guardduty.amazonaws.com のサービスアクセスが有効化されていること
# - 指定アカウントに aws_guardduty_detector が作成されていること
#
# 参考: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_organizations.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/guardduty_organization_admin_account
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_guardduty_organization_admin_account" "example" {
  #-----------------------------------------------------------------------
  # 委任管理者アカウントの設定
  #-----------------------------------------------------------------------

  # GuardDuty委任管理者として指定するAWSアカウントID
  # 設定内容: 組織内のGuardDuty管理を委任するメンバーアカウントの12桁のID
  # 設定可能な値: 有効なAWSアカウントID（例: "123456789012"）
  # 注意: このリソースを適用するアカウントはOrganizationsの主アカウントである必要がある
  # 注意: 指定アカウントに事前にGuardDuty検出器が作成されていること
  admin_account_id = "123456789012"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   委任管理者として指定されたAWSアカウントID（admin_account_idと同一）
#-----------------------------------------------------------------------
