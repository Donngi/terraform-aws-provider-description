#---------------------------------------
# AWS ElastiCache Global Replication Group
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# NOTE: このテンプレートはAWSプロバイダースキーマから自動生成されたコメント付きリファレンスです
#
# 【用途】
#   複数リージョン間でレプリケーショングループを管理するグローバルデータストアを構成する
#   プライマリとセカンダリのレプリケーショングループ間でデータを自動的にレプリケーション
#
# 【主な機能】
#   - クロスリージョンレプリケーション
#   - 自動フェイルオーバー
#   - グローバルデータストアの集中管理
#   - エンジンバージョン統一管理
#
# 【注意事項】
#   - グローバルレプリケーショングループIDのサフィックスとプライマリレプリケーショングループIDは変更すると新規リソース作成
#   - エンジンバージョンはダウングレード不可（ダウングレードする場合は全メンバーの再作成が必要）
#   - メジャーバージョンアップグレード時はparameter_group_nameが必須
#   - 各メンバーレプリケーショングループに対してパラメータグループのコピーが自動作成される
#
# 【関連ドキュメント】
#   https://docs.aws.amazon.com/AmazonElastiCache/latest/red-ug/Redis-Global-Datastore.html
#   https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/elasticache_global_replication_group

#---------------------------------------
# 基本設定
#---------------------------------------

resource "aws_elasticache_global_replication_group" "example" {
  # 設定内容: グローバルデータストアIDのサフィックス（プレフィックスは自動生成される）
  # 制約事項: 変更すると新規リソースが作成される
  global_replication_group_id_suffix = "example"

  # 設定内容: 書き込みを受け付けセカンダリにレプリケーションを行うプライマリクラスタのID
  # 制約事項: 変更すると新規リソースが作成される
  primary_replication_group_id = "example-primary"

  # 設定内容: グローバルレプリケーショングループの説明
  # 省略時: 説明なし
  global_replication_group_description = "グローバルデータストアの説明"

  # 設定内容: このリソースが管理されるリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考URL: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = "us-east-1"

  #---------------------------------------
  # キャパシティ設定
  #---------------------------------------

  # 設定内容: インスタンスクラスの指定
  # 設定可能な値: cache.t3.micro, cache.m5.large, cache.r5.xlarge など
  # 省略時: プライマリレプリケーショングループのノードタイプを継承
  # 参考URL: https://docs.aws.amazon.com/AmazonElastiCache/latest/red-ug/CacheNodes.SupportedTypes.html
  cache_node_type = "cache.m5.large"

  # 設定内容: グローバルレプリケーショングループのノードグループ（シャード）数
  # 省略時: プライマリレプリケーショングループの設定を継承
  num_node_groups = 2

  #---------------------------------------
  # エンジン設定
  #---------------------------------------

  # 設定内容: キャッシュエンジン名
  # 設定可能な値: redis, valkey
  # 省略時: engine_versionが指定されている場合はredis、それ以外はプライマリから継承
  # 備考: エンジンを指定すると全メンバーレプリケーショングループがアップグレードされる
  engine = "redis"

  # 設定内容: エンジンバージョン
  # 設定可能な値:
  #   - バージョン7以降: メジャー.マイナーバージョンを指定（例: 7.2）
  #   - バージョン6: メジャー.マイナーまたはメジャー.x（例: 6.2, 6.x）
  # 省略時: プライマリレプリケーショングループのバージョンを継承
  # 制約事項: ダウングレード不可（グローバルレプリケーショングループと全メンバーの再作成が必要）
  # 備考:
  #   - バージョンを指定すると全メンバーレプリケーショングループがアップグレードされる
  #   - 実際に使用されるバージョンはengine_version_actual属性で参照可能
  engine_version = "7.2"

  # 設定内容: ElastiCacheパラメータグループ名
  # 省略時: デフォルトパラメータグループを使用
  # 制約事項: エンジンまたはメジャーエンジンバージョンアップグレード時に必須
  # 備考:
  #   - メジャーバージョンアップグレードなしで指定するとエラー
  #   - アップグレード完了後も設定が残っているが無視される
  #   - 各メンバーレプリケーショングループに対してコピーが作成される
  parameter_group_name = "default.redis7"

  #---------------------------------------
  # 可用性設定
  #---------------------------------------

  # 設定内容: 既存プライマリ障害時に読み取り専用レプリカを自動的に読み書きプライマリに昇格させるか
  # 設定可能な値: true, false
  # 省略時: プライマリレプリケーショングループの自動フェイルオーバー設定を継承
  automatic_failover_enabled = true

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  # timeouts {
  #   # 設定内容: 作成時のタイムアウト時間
  #   # 省略時: 60m
  #   # create = "60m"
  #
  #   # 設定内容: 更新時のタイムアウト時間
  #   # 省略時: 40m
  #   # update = "40m"
  #
  #   # 設定内容: 削除時のタイムアウト時間
  #   # 省略時: 20m
  #   # delete = "20m"
  # }
}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# このリソースからは以下の属性が参照可能:
#
# id                           - ElastiCacheグローバルレプリケーショングループのID
# arn                          - ElastiCacheグローバルレプリケーショングループのARN
# global_replication_group_id  - グローバルレプリケーショングループの完全なID
# engine_version_actual        - このグローバルレプリケーショングループのメンバーで実行中のキャッシュエンジンの完全バージョン番号
# at_rest_encryption_enabled   - 保存時の暗号化が有効かどうかを示すフラグ
# auth_token_enabled           - AuthToken（パスワード）が有効かどうかを示すフラグ
# cluster_enabled              - グローバルデータストアでクラスタモードが有効かどうかを示すフラグ
# transit_encryption_enabled   - 転送時の暗号化が有効かどうかを示すフラグ
# global_node_groups           - グローバルレプリケーショングループのノードグループ（シャード）セット
#                                global_node_group_id（グローバルノードグループのID）とslots（このノードグループのキースペース）を含む
