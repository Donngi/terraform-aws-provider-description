#------------------------------------------------------------------------------
# aws_vpc_dhcp_options
#
# VPC の DHCP オプションセットを管理するリソース。
# DNS サーバー、NTP サーバー、NetBIOS 設定などを VPC に適用できる。
#
# Provider Version: 6.28.0
# Generated: 2026-02-19
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/vpc_dhcp_options
#
# NOTE: このファイルはテンプレートです。実際の環境に合わせて値を変更してください。
#------------------------------------------------------------------------------

resource "aws_vpc_dhcp_options" "example" {

  #----------------------------------------------------------------------------
  # DNS 設定
  #----------------------------------------------------------------------------

  # 設定内容: VPC 内のインスタンスが使用する DNS ドメイン名
  # 設定可能な値: 任意のドメイン名文字列（例: "example.internal"）
  # 省略時: AWS 提供のデフォルトドメイン名が使用される
  domain_name = "example.internal"

  # 設定内容: VPC 内のインスタンスが使用する DNS サーバーの IP アドレスリスト
  # 設定可能な値: 最大4件の IP アドレス、"AmazonProvidedDNS" を指定して AWS DNS を利用可能
  # 省略時: デフォルトの DNS サーバー設定が使用される
  domain_name_servers = ["AmazonProvidedDNS"]

  #----------------------------------------------------------------------------
  # NTP 設定
  #----------------------------------------------------------------------------

  # 設定内容: VPC 内のインスタンスが使用する NTP サーバーの IP アドレスリスト
  # 設定可能な値: 最大4件の IP アドレス
  # 省略時: NTP サーバーは設定されない
  ntp_servers = ["169.254.169.123"]

  #----------------------------------------------------------------------------
  # NetBIOS 設定
  #----------------------------------------------------------------------------

  # 設定内容: NetBIOS ネームサーバーの IP アドレスリスト
  # 設定可能な値: 最大4件の IP アドレス
  # 省略時: NetBIOS ネームサーバーは設定されない
  netbios_name_servers = ["10.0.0.1"]

  # 設定内容: NetBIOS ノードタイプ
  # 設定可能な値: "1"（ブロードキャスト）, "2"（P ノード）, "4"（混在ノード）, "8"（ハイブリッド）
  # 省略時: NetBIOS ノードタイプは設定されない
  netbios_node_type = "2"

  #----------------------------------------------------------------------------
  # IPv6 設定
  #----------------------------------------------------------------------------

  # 設定内容: IPv6 アドレスの優先リース時間（秒単位）
  # 設定可能な値: 任意の秒数を表す文字列（例: "3600"）
  # 省略時: デフォルトのリース時間が使用される
  ipv6_address_preferred_lease_time = "3600"

  #----------------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------------

  # 設定内容: このリソースを管理するリージョン
  # 設定可能な値: 有効な AWS リージョンコード（例: "us-east-1"）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = "ap-northeast-1"

  #----------------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------------

  # 設定内容: リソースに付与するタグのマップ
  # 設定可能な値: キーと値が文字列のマップ
  # 省略時: タグは設定されない
  tags = {
    Name = "example-dhcp-options"
  }
}

#------------------------------------------------------------------------------
# Attributes Reference
#
# id          - DHCP オプションセットの ID
# arn         - DHCP オプションセットの ARN
# owner_id    - DHCP オプションセットを所有する AWS アカウント ID
# tags_all    - プロバイダーのデフォルトタグを含む全タグのマップ
#------------------------------------------------------------------------------
