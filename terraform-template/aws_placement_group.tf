  # 設定可能な値:
  #   - "rack" (デフォルト): ラック単位でインスタンスを分散配置。通常リージョンで使用。
  #   - "host"             : ホスト単位でインスタンスを分散配置。Outpostプレイスメントグループでのみ使用可能。
  # 省略時: "rack"
  # 注意: strategyが"spread"の場合のみ指定可能です。
  spread_level = null

  #-------------------------------------------------------------
