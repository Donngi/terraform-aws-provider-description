#---------------------------------------------------------------
# Amazon Lightsail インスタンス
#---------------------------------------------------------------
#
# Amazon LightsailのVPSインスタンスをプロビジョニングするTerraformリソースです。
# ブループリント（OS・アプリケーション）とバンドル（CPU・メモリ・ストレージ・転送量）を
# 指定することで、低コストで手軽にクラウドサーバーを作成できます。
# Webアプリケーション、ブログ、開発環境など小中規模のワークロードに適しています。
#
# 注意: Lightsailは限られたAWSリージョンでのみ利用可能です。
#   利用可能なリージョンについてはAWSの公式ページを確認してください。
#
# AWS公式ドキュメント:
#   - Lightsail インスタンス概要: https://docs.aws.amazon.com/lightsail/latest/userguide/understanding-instances-virtual-private-servers-in-amazon-lightsail.html
#   - ブループリット一覧: https://docs.aws.amazon.com/lightsail/latest/userguide/understanding-blueprints-in-amazon-lightsail.html
#   - バンドル一覧: https://aws.amazon.com/lightsail/pricing/
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/lightsail_instance
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_lightsail_instance" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: インスタンスの名前を指定します。
  # 設定可能な値: アルファベット文字で始まり、英数字・アンダースコア・ハイフン・ドットのみ使用可能な文字列
  name = "example-instance"

  # blueprint_id (Required)
  # 設定内容: インスタンスのブループリットIDを指定します。ブループリットはOSやアプリケーションのイメージを表します。
  # 設定可能な値: 例 "amazon_linux_2023", "ubuntu_22_04", "debian_12", "wordpress", "lamp" 等
  # 参考: 利用可能なブループリットIDはAWS CLIコマンド `aws lightsail get-blueprints` で確認できます。
  blueprint_id = "amazon_linux_2023"

  # bundle_id (Required)
  # 設定内容: インスタンスのバンドルIDを指定します。バンドルはCPU・メモリ・ストレージ・転送量のセットを表します。
  # 設定可能な値: 例 "nano_3_0", "micro_3_0", "small_3_0", "medium_3_0", "large_3_0", "xlarge_3_0", "2xlarge_3_0" 等
  # 参考: 利用可能なバンドルIDはAWS CLIコマンド `aws lightsail get-bundles` で確認できます。
  bundle_id = "nano_3_0"

  # availability_zone (Required)
  # 設定内容: インスタンスを作成するアベイラビリティゾーンを指定します。
  # 設定可能な値: 有効なAWSアベイラビリティゾーン（例: ap-northeast-1a, us-east-1a）
  # 注意: インスタンスに接続するLightsailリソース（ディスク等）は同じアベイラビリティゾーンに存在する必要があります。
  availability_zone = "ap-northeast-1a"

  #-------------------------------------------------------------
  # ネットワーク設定
  #-------------------------------------------------------------

  # ip_address_type (Optional)
  # 設定内容: インスタンスのIPアドレスタイプを指定します。
  # 設定可能な値:
  #   - "dualstack": IPv4とIPv6の両方を使用
  #   - "ipv4": IPv4のみ使用（デフォルト）
  #   - "ipv6": IPv6のみ使用
  # 省略時: "ipv4"
  ip_address_type = "ipv4"

  #-------------------------------------------------------------
  # SSH設定
  #-------------------------------------------------------------

  # key_pair_name (Optional)
  # 設定内容: インスタンスへのSSHアクセスに使用するキーペアの名前を指定します。
  # 設定可能な値: 既存のLightsailキーペア名の文字列
  # 省略時: Lightsailのデフォルトキーペアを使用します。
  # 参考: aws_lightsail_key_pair リソースで作成したキーペアを参照できます。
  key_pair_name = null

  #-------------------------------------------------------------
  # ユーザーデータ設定
  #-------------------------------------------------------------

  # user_data (Optional)
  # 設定内容: インスタンス起動時に実行するユーザーデータスクリプトを指定します。
  # 設定可能な値: シェルスクリプト等の文字列
  # 省略時: ユーザーデータなし
  # 注意: インスタンス初回起動時にのみ実行されます。変更後はインスタンスを再作成する必要があります。
  user_data = null

  #-------------------------------------------------------------
  # 自動スナップショット設定
  #-------------------------------------------------------------

  # add_on (Optional)
  # 設定内容: インスタンスに追加する自動スナップショット機能を設定します。
  # 注意: このブロックは最大1つまで指定できます。
  add_on {
    # type (Required)
    # 設定内容: 追加するアドオンのタイプを指定します。
    # 設定可能な値: "AutoSnapshot"
    type = "AutoSnapshot"

    # status (Required)
    # 設定内容: 自動スナップショットアドオンを有効または無効にするかを指定します。
    # 設定可能な値:
    #   - "Enabled": 自動スナップショットを有効化
    #   - "Disabled": 自動スナップショットを無効化
    status = "Enabled"

    # snapshot_time (Required)
    # 設定内容: 自動スナップショットを作成するUTC時刻を指定します。
    # 設定可能な値: "HH:00" 形式の文字列（例: "06:00", "17:00"）。1時間単位で指定します。
    snapshot_time = "06:00"
  }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ。キーのみのタグを作成するには空文字列を値として使用します。
  # 省略時: タグなし
  # 参考: プロバイダーのdefault_tags設定ブロックが存在する場合、一致するキーを持つタグはプロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-instance"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: インスタンスのAmazon Resource Name (ARN)
# - cpu_count: インスタンスのvCPU数
# - created_at: インスタンスが作成された日時
# - id: インスタンスの名前（nameと同じ値）
# - ipv6_addresses: インスタンスに割り当てられたIPv6アドレスのリスト
# - is_static_ip: インスタンスに静的IPアドレスがアタッチされているかどうか
# - private_ip_address: インスタンスのプライベートIPアドレス
# - public_ip_address: インスタンスのパブリックIPアドレス
# - ram_size: インスタンスのRAMサイズ（GB）
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
# - username: インスタンスへのSSHアクセスに使用するデフォルトのユーザー名
#---------------------------------------------------------------
