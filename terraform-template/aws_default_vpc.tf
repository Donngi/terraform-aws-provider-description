#-------------------------------------------------------------------------------------------------------
# リソース: aws_default_vpc
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# 説明:
#   各AWSアカウントのリージョンに自動的に作成されるデフォルトVPCを管理するためのリソースです。
#   このリソースはデフォルトVPCの削除や属性変更を行うことができますが、新規作成はできません。
#   デフォルトVPCが既に削除されている場合は、再作成ではなくエラーとなります。
#
# 用途:
#   - デフォルトVPCのDNS設定やIPv6設定を変更
#   - デフォルトVPCにタグを付与して管理
#   - デフォルトVPCを安全に削除（force_destroy使用時）
#   - ネットワークアドレス使用状況メトリクスの有効化
#
# 注意事項:
#   - このリソースはデフォルトVPCが存在しない場合は使用できません
#   - force_destroyをtrueに設定すると、Terraform破棄時にデフォルトVPCが削除されます
#   - デフォルトVPCのCIDRブロックやインスタンステナンシーは変更できません（読み取り専用）
#   - IPv6 CIDRブロックの割り当て・解除が可能です
#
# NOTE:
#   - デフォルトVPCは各リージョンごとに1つのみ存在します
#   - 削除されたデフォルトVPCはAWSコンソールまたはAWS CLIで再作成する必要があります
#   - このリソースで既存のデフォルトVPCを新規作成することはできません
#
# 参考ドキュメント:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/default_vpc
#   - https://docs.aws.amazon.com/vpc/latest/userguide/default-vpc.html
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# リソース定義
#-------------------------------------------------------------------------------------------------------
resource "aws_default_vpc" "example" {
  #-------------------------------------------------------------------------------------------------------
  # DNS設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: VPC内のインスタンスにDNSホスト名を割り当てるかどうか
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: VPCの既存設定が維持されます
  enable_dns_hostnames = true

  # 設定内容: VPC内でAmazon提供のDNSサーバーによる名前解決を有効にするかどうか
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: VPCの既存設定が維持されます（通常はtrue）
  enable_dns_support = true

  #-------------------------------------------------------------------------------------------------------
  # IPv6設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: AWSが自動的に生成するIPv6 CIDRブロックをVPCに割り当てるかどうか
  # 設定可能な値: true（割り当てる）、false（割り当てない）
  # 省略時: IPv6 CIDRブロックは割り当てられません
  assign_generated_ipv6_cidr_block = false

  # 設定内容: VPCに関連付けるIPv6 CIDRブロック
  # 設定可能な値: 有効なIPv6 CIDRブロック（/56）
  # 省略時: IPv6 CIDRブロックは設定されません
  ipv6_cidr_block = "2600:1f13:fe4:c800::/56"

  # 設定内容: IPv6 CIDRブロックが属するネットワークボーダーグループ
  # 設定可能な値: AWSリージョン名またはLocal Zone名
  # 省略時: リージョンのデフォルトネットワークボーダーグループが使用されます
  ipv6_cidr_block_network_border_group = "us-east-1"

  # 設定内容: IPv6アドレスをIPAMプールから割り当てる場合のIPAMプールID
  # 設定可能な値: IPAMプールのID（ipam-pool-xxxxxxxx形式）
  # 省略時: IPAMプールからの割り当ては行われません
  ipv6_ipam_pool_id = "ipam-pool-12345678"

  # 設定内容: IPAMプールから割り当てるIPv6 CIDRブロックのネットマスク長
  # 設定可能な値: 56（/56 CIDRブロック）
  # 省略時: デフォルトのネットマスク長が使用されます
  ipv6_netmask_length = 56

  #-------------------------------------------------------------------------------------------------------
  # モニタリング設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: VPCのネットワークアドレス使用状況メトリクスをCloudWatchに送信するかどうか
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: 既存の設定が維持されます
  enable_network_address_usage_metrics = false

  #-------------------------------------------------------------------------------------------------------
  # リソース管理設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: Terraform destroyまたはterraform apply実行時にデフォルトVPCを削除するかどうか
  # 設定可能な値: true（削除する）、false（削除しない）
  # 省略時: false（デフォルトVPCは削除されず、Terraformの管理から外れるのみ）
  force_destroy = false

  # 設定内容: リソースのAWSリージョン
  # 設定可能な値: AWSリージョンコード（us-east-1、ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンが使用されます
  region = "us-east-1"

  #-------------------------------------------------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: デフォルトVPCに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されません
  tags = {
    Name        = "default-vpc"
    Environment = "production"
    ManagedBy   = "Terraform"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースからは以下の属性を参照できます:
#
# - id: VPCのID
# - arn: VPCのARN（Amazon Resource Name）
# - cidr_block: VPCのIPv4 CIDRブロック（例: 172.31.0.0/16）
# - instance_tenancy: VPC内のインスタンスのテナンシー（default、dedicated、host）
# - ipv6_association_id: IPv6 CIDRブロックの関連付けID
# - ipv6_cidr_block: 関連付けられたIPv6 CIDRブロック
# - ipv6_cidr_block_network_border_group: IPv6 CIDRブロックのネットワークボーダーグループ
# - default_network_acl_id: デフォルトネットワークACLのID
# - default_security_group_id: デフォルトセキュリティグループのID
# - default_route_table_id: デフォルトルートテーブルのID
# - main_route_table_id: メインルートテーブルのID
# - dhcp_options_id: VPCに関連付けられたDHCPオプションセットのID
# - owner_id: VPCの所有者のAWSアカウントID
# - existing_default_vpc: デフォルトVPCが既に存在していたかどうか（true/false）
# - tags_all: リソースに割り当てられた全てのタグ（デフォルトタグを含む）
# - enable_network_address_usage_metrics: ネットワークアドレス使用状況メトリクスの有効状態
