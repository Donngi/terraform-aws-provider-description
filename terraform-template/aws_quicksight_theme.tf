#---------------------------------------------------------------
# Amazon QuickSight Theme
#---------------------------------------------------------------
#
# Amazon QuickSightのテーマをプロビジョニングするリソースです。
# テーマは、QuickSightダッシュボードやビジュアルの外観をカスタマイズするための
# カラーパレット、フォント、シートレイアウト等の表示設定を定義します。
#
# AWS公式ドキュメント:
#   - QuickSight テーマ: https://docs.aws.amazon.com/quicksight/latest/user/themes-in-quicksight.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/quicksight_theme
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_quicksight_theme" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # theme_id (Required, Forces new resource)
  # 設定内容: テーマの一意の識別子を指定します。
  # 設定可能な値: 英数字およびハイフン、アンダースコアを含む文字列
  # 注意: リソース作成後に変更するとリソースが再作成されます。
  theme_id = "example-theme"

  # name (Required)
  # 設定内容: テーマの表示名を指定します。
  # 設定可能な値: 1-2048文字の文字列
  name = "Example Theme"

  # base_theme_id (Required)
  # 設定内容: カスタムテーマが継承するベーステーマのIDを指定します。
  # 設定可能な値:
  #   - "MIDNIGHT": ダークテーマ
  #   - "SEASIDE": 明るい青系テーマ
  #   - "CLASSIC": クラシックなテーマ
  #   - その他QuickSight組み込みテーマID
  # 参考: 利用可能なテーマはListThemes APIまたはQuickSightコンソールで確認できます。
  base_theme_id = "MIDNIGHT"

  #-------------------------------------------------------------
  # アカウント・リージョン設定
  #-------------------------------------------------------------

  # aws_account_id (Optional, Forces new resource)
  # 設定内容: テーマを作成するAWSアカウントIDを指定します。
  # 設定可能な値: 12桁のAWSアカウントID
  # 省略時: Terraform AWSプロバイダーの設定から自動的に取得したアカウントIDを使用します。
  aws_account_id = null

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # バージョン設定
  #-------------------------------------------------------------

  # version_description (Optional)
  # 設定内容: 作成・更新中のテーマバージョンの説明を指定します。
  # 設定可能な値: 512文字以内の文字列
  # 省略時: バージョンの説明は設定されません。
  version_description = "Initial version"

  #-------------------------------------------------------------
  # テーマ構成設定
  #-------------------------------------------------------------

  configuration {
    #-----------------------------------------------------------
    # データカラーパレット設定
    #-----------------------------------------------------------

    # data_color_palette (Optional)
    # 設定内容: チャートデータの色に適用されるカラーパレットを指定します。
    # 省略時: ベーステーマのデータカラーパレットが使用されます。
    data_color_palette {
      # colors (Optional)
      # 設定内容: カラーパレットの16進数カラーコードのリストを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード、8〜20件
      # 省略時: ベーステーマのカラーリストが使用されます。
      colors = [
        "#FFFFFF",
        "#111111",
        "#222222",
        "#333333",
        "#444444",
        "#555555",
        "#666666",
        "#777777",
        "#888888",
        "#999999",
      ]

      # empty_fill_color (Optional)
      # 設定内容: データが存在しない箇所をハイライトする際に使用する16進数カラーコードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      empty_fill_color = "#FFFFFF"

      # min_max_gradient (Optional)
      # 設定内容: カラーグラデーションの最小値と最大値に対応する16進数カラーコードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコードのリスト、必ず2件指定
      # 省略時: ベーステーマのグラデーション設定が使用されます。
      min_max_gradient = [
        "#FFFFFF",
        "#111111",
      ]
    }

    #-----------------------------------------------------------
    # シート表示設定
    #-----------------------------------------------------------

    # sheet (Optional)
    # 設定内容: シートに関連する表示オプションを指定します。
    # 省略時: ベーステーマのシート設定が使用されます。
    sheet {
      # tile (Optional)
      # 設定内容: タイルの表示オプションを指定します。
      # 省略時: ベーステーマのタイル設定が使用されます。
      tile {
        # border (Optional)
        # 設定内容: ビジュアル周囲のボーダー設定を指定します。
        # 省略時: ベーステーマのボーダー設定が使用されます。
        border {
          # show (Optional)
          # 設定内容: ビジュアルのボーダーを表示するかどうかを指定します。
          # 設定可能な値:
          #   - true: ボーダーを表示する
          #   - false: ボーダーを非表示にする
          # 省略時: ベーステーマの設定が使用されます。
          show = true
        }
      }

      # tile_layout (Optional)
      # 設定内容: タイルのレイアウトオプションを指定します。
      # 省略時: ベーステーマのタイルレイアウト設定が使用されます。
      tile_layout {
        # gutter (Optional)
        # 設定内容: タイル間のガタースペース設定を指定します。
        # 省略時: ベーステーマのガター設定が使用されます。
        gutter {
          # show (Optional)
          # 設定内容: シートタイル間のガタースペースを表示するかどうかを指定します。
          # 設定可能な値:
          #   - true: ガタースペースを表示する
          #   - false: ガタースペースを非表示にする
          # 省略時: ベーステーマの設定が使用されます。
          show = true
        }

        # margin (Optional)
        # 設定内容: シート外側の余白設定を指定します。
        # 省略時: ベーステーマのマージン設定が使用されます。
        margin {
          # show (Optional)
          # 設定内容: シートの余白を表示するかどうかを指定します。
          # 設定可能な値:
          #   - true: シートマージンを表示する
          #   - false: シートマージンを非表示にする
          # 省略時: ベーステーマの設定が使用されます。
          show = true
        }
      }
    }

    #-----------------------------------------------------------
    # タイポグラフィ設定
    #-----------------------------------------------------------

    # typography (Optional)
    # 設定内容: テーマで使用するフォントファミリーのオプションを指定します。
    # 省略時: ベーステーマのタイポグラフィ設定が使用されます。
    typography {
      # font_families (Optional)
      # 設定内容: 使用するフォントファミリーのリストを指定します。最大5件まで指定可能です。
      # 省略時: ベーステーマのフォントファミリー設定が使用されます。
      font_families {
        # font_family (Optional)
        # 設定内容: フォントファミリー名を指定します。
        # 設定可能な値: 有効なフォントファミリー名の文字列（例: "Arial"）
        # 省略時: 設定されません。
        font_family = "Arial"
      }
    }

    #-----------------------------------------------------------
    # UIカラーパレット設定
    #-----------------------------------------------------------

    # ui_color_palette (Optional)
    # 設定内容: UIおよびチャートに適用される色（データ色を除く）を指定します。
    # 省略時: ベーステーマのUIカラーパレットが使用されます。
    ui_color_palette {
      # accent (Optional)
      # 設定内容: 選択状態やボタンに適用されるアクセントカラーの16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      accent = "#FF0000"

      # accent_foreground (Optional)
      # 設定内容: アクセントカラーの上に表示されるテキストや要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      accent_foreground = "#FFFFFF"

      # danger (Optional)
      # 設定内容: エラーメッセージに適用される色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      danger = "#FF0000"

      # danger_foreground (Optional)
      # 設定内容: エラーカラーの上に表示されるテキストや要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      danger_foreground = "#FFFFFF"

      # dimension (Optional)
      # 設定内容: ディメンションとして識別されるフィールド名に適用される色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      dimension = "#0000FF"

      # dimension_foreground (Optional)
      # 設定内容: ディメンションカラーの上に表示されるテキストや要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      dimension_foreground = "#FFFFFF"

      # measure (Optional)
      # 設定内容: メジャーとして識別されるフィールド名に適用される色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      measure = "#00FF00"

      # measure_foreground (Optional)
      # 設定内容: メジャーカラーの上に表示されるテキストや要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      measure_foreground = "#000000"

      # primary_background (Optional)
      # 設定内容: ビジュアルおよび高強調UIに適用される背景色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      primary_background = "#000000"

      # primary_foreground (Optional)
      # 設定内容: プライマリ背景領域上に表示されるテキストや前景要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      primary_foreground = "#FFFFFF"

      # secondary_background (Optional)
      # 設定内容: シート背景およびシートコントロールに適用される色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      secondary_background = "#111111"

      # secondary_foreground (Optional)
      # 設定内容: セカンダリ背景上に表示されるシートタイトル・コントロールテキスト・UIの色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      secondary_foreground = "#FFFFFF"

      # success (Optional)
      # 設定内容: 成功メッセージに適用される色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      success = "#00FF00"

      # success_foreground (Optional)
      # 設定内容: 成功カラーの上に表示されるテキストや要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      success_foreground = "#000000"

      # warning (Optional)
      # 設定内容: 警告および情報メッセージに適用される色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      warning = "#FFFF00"

      # warning_foreground (Optional)
      # 設定内容: 警告カラーの上に表示されるテキストや要素の色の16進数コードを指定します。
      # 設定可能な値: #RRGGBBフォーマットの16進数カラーコード
      # 省略時: ベーステーマの設定が使用されます。
      warning_foreground = "#000000"
    }
  }

  #-------------------------------------------------------------
  # 権限設定
  #-------------------------------------------------------------

  # permissions (Optional)
  # 設定内容: テーマに対するリソース権限のセットを指定します。最大64件まで指定可能です。
  # 省略時: 権限は設定されません。
  permissions {
    # actions (Required)
    # 設定内容: 付与または取り消すIAMアクションのリストを指定します。
    # 設定可能な値: QuickSightテーマに関連するIAMアクション文字列のセット
    # 参考: https://docs.aws.amazon.com/quicksight/latest/APIReference/API_ResourcePermission.html
    actions = [
      "quicksight:DescribeTheme",
      "quicksight:ListThemeVersions",
      "quicksight:UpdateThemePermissions",
      "quicksight:DescribeThemePermissions",
    ]

    # principal (Required)
    # 設定内容: 権限を付与するプリンシパルのARNを指定します。
    # 設定可能な値: IAMユーザー、グループ、またはQuickSightユーザーのARN
    # 参考: https://docs.aws.amazon.com/quicksight/latest/APIReference/API_ResourcePermission.html
    principal = "arn:aws:quicksight:ap-northeast-1:123456789012:user/default/example-user"
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されません。
  tags = {
    Name        = "example-theme"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソース作成時のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "5m", "1h" などの時間文字列
    # 省略時: デフォルトのタイムアウト時間が使用されます。
    create = "5m"

    # update (Optional)
    # 設定内容: リソース更新時のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "5m", "1h" などの時間文字列
    # 省略時: デフォルトのタイムアウト時間が使用されます。
    update = "5m"

    # delete (Optional)
    # 設定内容: リソース削除時のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "5m", "1h" などの時間文字列
    # 省略時: デフォルトのタイムアウト時間が使用されます。
    delete = "5m"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: テーマのAmazon Resource Name (ARN)
# - created_time: テーマが作成された日時
# - id: AWSアカウントIDとテーマIDをカンマ区切りで結合した文字列
# - last_updated_time: テーマが最後に更新された日時
# - status: テーマ作成のステータス
# - tags_all: プロバイダーのdefault_tags設定から継承されたタグを含む全タグのマップ
# - version_number: テーマバージョンのバージョン番号
#---------------------------------------------------------------
