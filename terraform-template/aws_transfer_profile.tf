#---------------------------------------------------------------
# AWS Transfer Family AS2 プロファイル
#---------------------------------------------------------------
#
# AWS Transfer Family の AS2 (Applicability Statement 2) プロファイルを
# プロビジョニングするリソースです。
# ローカルプロファイル（LOCAL）またはパートナープロファイル（PARTNER）を
# 作成して、AS2 プロトコルによるファイル転送を設定します。
#
# AWS公式ドキュメント:
#   - AWS Transfer Family AS2 概要: https://docs.aws.amazon.com/transfer/latest/userguide/as2-intro.html
#   - プロファイルの作成: https://docs.aws.amazon.com/transfer/latest/userguide/create-b2b-server.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/transfer_profile
#
# Provider Version: 6.28.0
# Generated: 2026-02-19
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_transfer_profile" "example" {
  #-------------------------------------------------------------
  # AS2 識別子設定
  #-------------------------------------------------------------

  # as2_id (Required)
  # 設定内容: RFC 4130 で定義された AS2 名を指定します。
  #   インバウンド転送では受信する AS2 メッセージの AS2 From ヘッダーに対応します。
  #   アウトバウンド転送では送信する AS2 メッセージの AS2 To ヘッダーに対応します。
  # 設定可能な値: スペースを含まない文字列
  as2_id = "example-as2-id"

  #-------------------------------------------------------------
  # プロファイル種別設定
  #-------------------------------------------------------------

  # profile_type (Required)
  # 設定内容: プロファイルのタイプを指定します。
  # 設定可能な値:
  #   - "LOCAL": ローカルプロファイル（自組織の AS2 プロファイル）
  #   - "PARTNER": パートナープロファイル（取引先の AS2 プロファイル）
  profile_type = "LOCAL"

  #-------------------------------------------------------------
  # 証明書設定
  #-------------------------------------------------------------

  # certificate_ids (Optional)
  # 設定内容: このプロファイルに関連付ける証明書 ID のリストを指定します。
  #   aws_transfer_certificate リソースでインポートした証明書の ID を使用します。
  # 設定可能な値: 証明書 ID の文字列セット
  # 省略時: 証明書なし
  certificate_ids = []

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-transfer-profile"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: プロファイルの一意識別子
# - arn: プロファイルの ARN
# - profile_id: AS2 プロファイルの一意識別子
# - tags_all: プロバイダーの default_tags 設定から継承されたタグを含む全タグマップ
#---------------------------------------------------------------
