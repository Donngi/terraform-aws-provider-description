#-------------------------------------------------------------------------------------------------------
# リソース: aws_elastic_beanstalk_environment
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# 説明:
#   AWS Elastic Beanstalkの環境を作成・管理するためのリソースです。
#   Elastic Beanstalkを使用すると、インフラストラクチャを意識することなくアプリケーションを
#   AWSクラウドにデプロイ・管理できます。環境とは、アプリケーションを実行するためのAWSリソース
#   （EC2インスタンス、ロードバランサー、Auto Scalingグループなど）のコレクションです。
#
# 用途:
#   - 開発、ステージング、本番などの環境の構築
#   - Webサーバー環境またはワーカー環境の作成
#   - アプリケーションバージョンのデプロイ
#   - 環境固有の設定オプションの管理
#   - 環境のスケーリングやリソース設定のカスタマイズ
#
# 注意事項:
#   - solution_stack_name、template_name、platform_arnのいずれかを指定する必要があります
#   - tierを省略した場合、デフォルトで「WebServer」が使用されます
#   - 環境の作成には数分かかることがあります（デフォルトタイムアウト: 20分）
#   - 環境の更新中はアプリケーションの可用性に影響が出る可能性があります
#   - cname_prefixを変更すると新しい環境が作成されます（破壊的変更）
#
# NOTE:
#   - 環境作成時、Elastic Beanstalkが自動的にEC2インスタンス、セキュリティグループ、
#     ロードバランサーなどのリソースを作成します
#   - settingブロックを使用して、環境の詳細な設定を行うことができます
#   - 環境の準備完了を待機するタイムアウト時間はwait_for_ready_timeoutで調整可能です
#
# 参考ドキュメント:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/elastic_beanstalk_environment
#   - https://docs.aws.amazon.com/elasticbeanstalk/latest/dg/environments.html
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# リソース定義
#-------------------------------------------------------------------------------------------------------
resource "aws_elastic_beanstalk_environment" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 環境の一意な名前（アプリケーションURL内で使用）
  # 設定可能な値: 4～40文字の英数字とハイフン（先頭と末尾は英数字）
  # 省略時: 必須項目のため省略不可
  name = "my-app-production"

  # 設定内容: デプロイするバージョンを含むElastic Beanstalkアプリケーションの名前
  # 設定可能な値: 既存のElastic Beanstalkアプリケーション名
  # 省略時: 必須項目のため省略不可
  application = "my-application"

  # 設定内容: 環境の簡単な説明
  # 設定可能な値: 最大200文字の文字列
  # 省略時: 説明は設定されません
  description = "Production environment for my application"

  #-------------------------------------------------------------------------------------------------------
  # 環境タイプ設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: Elastic Beanstalk環境のティア（層）
  # 設定可能な値: WebServer（Webアプリケーション）、Worker（バックグラウンド処理）
  # 省略時: WebServerが使用されます
  tier = "WebServer"

  #-------------------------------------------------------------------------------------------------------
  # プラットフォーム設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 環境のベースとなるソリューションスタック名
  # 設定可能な値: Amazon API documentationに記載されているスタック名
  # 省略時: platform_arnまたはtemplate_nameの指定が必要です
  solution_stack_name = "64bit Amazon Linux 2023 v4.0.0 running Python 3.11"

  # 設定内容: デプロイに使用するElastic BeanstalkプラットフォームのARN
  # 設定可能な値: 有効なElastic BeanstalkプラットフォームのARN
  # 省略時: solution_stack_nameまたはtemplate_nameの指定が必要です
  platform_arn = "arn:aws:elasticbeanstalk:us-east-1::platform/Python 3.11 running on 64bit Amazon Linux 2023/4.0.0"

  # 設定内容: デプロイに使用するElastic Beanstalk設定テンプレートの名前
  # 設定可能な値: 既存の設定テンプレート名
  # 省略時: solution_stack_nameまたはplatform_arnの指定が必要です
  template_name = "my-template"

  #-------------------------------------------------------------------------------------------------------
  # バージョン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: デプロイするElastic Beanstalkアプリケーションバージョンの名前
  # 設定可能な値: 既存のアプリケーションバージョン名
  # 省略時: 最新のアプリケーションバージョンが使用されます
  version_label = "v1.0.0"

  #-------------------------------------------------------------------------------------------------------
  # DNS設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 環境の完全修飾DNS名に使用するプレフィックス
  # 設定可能な値: 4～63文字の英数字とハイフン（先頭と末尾は英数字）
  # 省略時: 環境名から自動生成されます
  cname_prefix = "my-app-prod"

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（us-east-1、ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンが使用されます
  region = "us-east-1"

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 環境が準備完了状態になるまでの最大待機時間
  # 設定可能な値: Goのtime.ParseDuration形式（例: 20m、1h）
  # 省略時: 20mがデフォルトで使用されます
  wait_for_ready_timeout = "20m"

  # 設定内容: 変更が適用されたかをAWS APIで確認する間隔
  # 設定可能な値: 10s～180sの範囲でtime.ParseDuration形式
  # 省略時: 指数バックオフによる自動調整が行われます
  poll_interval = "30s"

  #-------------------------------------------------------------------------------------------------------
  # 環境設定オプション
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 環境の詳細設定を行うオプション
  # 設定可能な値: settingブロックのリスト
  # 省略時: デフォルト設定が使用されます
  setting {
    # 設定内容: オプション設定が属する名前空間
    # 設定可能な値: AWS定義の名前空間（aws:elasticbeanstalk:application:environmentなど）
    # 省略時: 必須項目のため省略不可
    namespace = "aws:elasticbeanstalk:application:environment"

    # 設定内容: 設定オプションの名前
    # 設定可能な値: 名前空間に応じた設定名
    # 省略時: 必須項目のため省略不可
    name = "ENVIRONMENT"

    # 設定内容: 設定オプションの値
    # 設定可能な値: 設定オプションに応じた値
    # 省略時: 必須項目のため省略不可
    value = "production"

    # 設定内容: 設定が適用されるリソース名（オプショナル）
    # 設定可能な値: Auto ScalingグループやELBなどのリソース名
    # 省略時: 設定はリソースに関連付けられません
    # resource = ""
  }

  setting {
    namespace = "aws:autoscaling:launchconfiguration"
    name      = "InstanceType"
    value     = "t3.small"
  }

  setting {
    namespace = "aws:autoscaling:asg"
    name      = "MinSize"
    value     = "2"
  }

  setting {
    namespace = "aws:autoscaling:asg"
    name      = "MaxSize"
    value     = "4"
  }

  #-------------------------------------------------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 環境に付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されません
  tags = {
    Name        = "my-app-production"
    Environment = "production"
    Application = "my-application"
    ManagedBy   = "Terraform"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースからは以下の属性を参照できます:
#
# - id: Elastic Beanstalk環境のID
# - arn: 環境のARN（Amazon Resource Name）
# - name: 環境の名前
# - description: 環境の説明
# - application: 環境が属するElastic Beanstalkアプリケーション名
# - tier: 環境のティア（WebServerまたはWorker）
# - cname: 環境の完全修飾DNS名
# - endpoint_url: 環境のロードバランサーのURL
# - version_label: 現在デプロイされているアプリケーションバージョン名
# - setting: 環境に設定されているオプション設定
# - all_settings: デフォルト設定とオーバーライド設定の組み合わせ（全オプション設定）
# - autoscaling_groups: 環境で使用されているAuto Scalingグループのリスト
# - instances: 環境で使用されているEC2インスタンスのリスト
# - launch_configurations: 環境で使用されている起動設定のリスト
# - load_balancers: 環境で使用されているElastic Load Balancerのリスト
# - queues: 環境で使用されているSQSキューのリスト
# - triggers: 環境で使用されているAuto Scalingトリガーのリスト
# - tags_all: リソースに割り当てられた全てのタグ（デフォルトタグを含む）
