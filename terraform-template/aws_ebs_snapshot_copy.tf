#---------------------------------------
# EBS スナップショットコピー (aws_ebs_snapshot_copy)
# Resource: aws_ebs_snapshot_copy
# Provider Version: 6.28.0
# Generated: 2026-02-14
# NOTE: 別リージョンのEBSスナップショットをコピーし、災害復旧対策やストレージ階層管理を実現
#---------------------------------------
# 用途:
#   - 別リージョンのEBSスナップショットをコピー
#   - 災害復旧対策のためのリージョン間バックアップ
#   - スナップショットの暗号化設定変更
#   - スナップショットのストレージ階層移動
#
# 主な機能:
#   - リージョン間スナップショットコピー
#   - コピー時の暗号化設定
#   - アーカイブストレージ階層への移動
#   - 一時的な復元設定
#
# 関連リソース:
#   - aws_ebs_snapshot (ソーススナップショット)
#   - aws_kms_key (暗号化キー)
#   - aws_ebs_volume (ボリューム)
#
# 公式ドキュメント:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ebs_snapshot_copy
#---------------------------------------

resource "aws_ebs_snapshot_copy" "example" {
  #---------------------------------------
  # コピー元設定（必須）
  #---------------------------------------
  # 設定内容: コピー元スナップショットのリージョン
  # 設定可能な値: AWS リージョンコード（us-east-1, ap-northeast-1 等）
  # 備考: コピー先リージョンはプロバイダー設定で指定
  source_region = "us-west-2"

  # 設定内容: コピー元スナップショットのID
  # 設定可能な値: snap- で始まるスナップショットID
  # 備考: コピー元リージョンに存在するスナップショット
  source_snapshot_id = "snap-0123456789abcdef0"

  #---------------------------------------
  # 暗号化設定（オプション）
  #---------------------------------------
  # 設定内容: コピー先スナップショットの暗号化有効化
  # 設定可能な値: true, false
  # 省略時: ソーススナップショットの暗号化設定を継承
  # 備考: true を指定すると暗号化されたスナップショットを作成
  encrypted = true

  # 設定内容: 暗号化に使用するKMSキーID
  # 設定可能な値: KMSキーID、ARN、エイリアス
  # 省略時: デフォルトのEBS暗号化キー
  # 備考: encrypted = true の場合のみ有効
  kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #---------------------------------------
  # スナップショット設定（オプション）
  #---------------------------------------
  # 設定内容: スナップショットの説明
  # 設定可能な値: 任意の文字列（最大255文字）
  # 省略時: ソーススナップショットの説明を継承
  description = "Disaster recovery copy of production snapshot"

  # 設定内容: スナップショットのストレージ階層
  # 設定可能な値: standard, archive
  # 省略時: standard
  # 備考: archive は低コストだが復元に時間がかかる
  storage_tier = "standard"

  # 設定内容: スナップショットコピー完了までの最大時間（分）
  # 設定可能な値: 正の整数
  # 省略時: 制限なし
  # 備考: 指定時間内に完了しない場合はエラー
  completion_duration_minutes = 60

  #---------------------------------------
  # アーカイブ復元設定（オプション）
  #---------------------------------------
  # 設定内容: アーカイブからの一時復元期間（日数）
  # 設定可能な値: 1 ～ 180
  # 省略時: 一時復元なし
  # 備考: storage_tier が archive の場合のみ有効
  temporary_restore_days = 7

  # 設定内容: アーカイブからの恒久的復元
  # 設定可能な値: true, false
  # 省略時: false
  # 備考: true の場合、スナップショットは standard 階層に恒久的に復元
  permanent_restore = false

  #---------------------------------------
  # リージョン設定（オプション）
  #---------------------------------------
  # 設定内容: スナップショットを管理するリージョン
  # 設定可能な値: AWS リージョンコード
  # 省略時: プロバイダー設定のリージョン
  # 備考: このリソースが管理されるリージョンを明示的に指定
  region = "us-east-1"

  #---------------------------------------
  # タグ設定（オプション）
  #---------------------------------------
  # 設定内容: スナップショットに付与するタグ
  # 設定可能な値: キーと値のマップ
  # 備考: コスト配分やリソース管理に使用
  tags = {
    Name        = "snapshot-copy-example"
    Environment = "production"
    Backup      = "disaster-recovery"
  }

  #---------------------------------------
  # タイムアウト設定（オプション）
  #---------------------------------------
  timeouts {
    # 設定内容: スナップショットコピー作成のタイムアウト時間
    # 設定可能な値: 時間文字列（例: "60m", "2h"）
    # 省略時: 10m
    create = "60m"

    # 設定内容: スナップショット削除のタイムアウト時間
    # 設定可能な値: 時間文字列（例: "10m", "30m"）
    # 省略時: 10m
    delete = "10m"
  }
}

#---------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------
# arn                     - スナップショットのARN
# id                      - スナップショットID（snap-xxxxxxxxx）
# owner_id                - スナップショットの所有者のAWSアカウントID
# owner_alias             - スナップショットの所有者のエイリアス（amazon等）
# volume_id               - 元のボリュームID
# volume_size             - ボリュームのサイズ（GB）
# data_encryption_key_id  - データ暗号化キーID
# outpost_arn             - Outpost ARN（Outpost上のスナップショットの場合）
# storage_tier            - 現在のストレージ階層
# tags_all                - デフォルトタグを含む全タグのマップ
# region                  - スナップショットが作成されたリージョン
