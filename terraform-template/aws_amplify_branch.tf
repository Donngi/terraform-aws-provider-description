#---------------------------------------------------------------
# AWS Amplify Branch
#---------------------------------------------------------------
#
# AWS Amplifyアプリケーションのブランチをプロビジョニングするリソースです。
# ブランチはAmplifyアプリケーション内の特定のGitブランチに対応し、
# 環境ごとの設定（本番、開発、ステージングなど）や
# 個別のビルド・デプロイ設定を管理します。
#
# AWS公式ドキュメント:
#   - Amplify概要: https://docs.aws.amazon.com/amplify/latest/userguide/welcome.html
#   - ブランチ設定: https://docs.aws.amazon.com/amplify/latest/userguide/branches.html
#   - Skew Protection: https://docs.aws.amazon.com/amplify/latest/userguide/skew-protection.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/amplify_branch
#
# Provider Version: 6.28.0
# Generated: 2026-01-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_amplify_branch" "example" {
  #-------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------

  # app_id (Required)
  # 設定内容: Amplifyアプリケーションの一意のIDを指定します。
  # 設定可能な値: 有効なAmplifyアプリケーションID
  app_id = aws_amplify_app.example.id

  # branch_name (Required)
  # 設定内容: ブランチの名前を指定します。
  # 設定可能な値: Gitリポジトリ内の有効なブランチ名
  branch_name = "main"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # ブランチ情報設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: ブランチの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 用途: ブランチの目的や用途を説明するために使用
  description = "Main production branch"

  # display_name (Optional)
  # 設定内容: ブランチの表示名を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: branch_nameがデフォルトのドメインプレフィックスとして使用されます
  # 用途: コンソールでの表示やデフォルトドメインプレフィックスに使用
  display_name = "main"

  #-------------------------------------------------------------
  # ステージ設定
  #-------------------------------------------------------------

  # stage (Optional)
  # 設定内容: ブランチの現在のステージを指定します。
  # 設定可能な値:
  #   - "PRODUCTION": 本番環境
  #   - "BETA": ベータ環境
  #   - "DEVELOPMENT": 開発環境
  #   - "EXPERIMENTAL": 実験環境
  #   - "PULL_REQUEST": プルリクエストプレビュー
  # 用途: 環境の種類を明示的に設定し、適切なビルド設定を適用
  stage = "PRODUCTION"

  #-------------------------------------------------------------
  # ビルド設定
  #-------------------------------------------------------------

  # enable_auto_build (Optional)
  # 設定内容: ブランチの自動ビルドを有効にするかを指定します。
  # 設定可能な値:
  #   - true: リポジトリへのプッシュ時に自動的にビルドを開始
  #   - false: 手動でビルドをトリガーする必要あり
  enable_auto_build = true

  # framework (Optional)
  # 設定内容: ブランチで使用するフレームワークを指定します。
  # 設定可能な値: フレームワーク名（例: "React", "Next.js", "Angular", "Vue"等）
  # 用途: ビルド設定の自動検出に使用
  framework = "Next.js"

  #-------------------------------------------------------------
  # 認証設定
  #-------------------------------------------------------------

  # enable_basic_auth (Optional)
  # 設定内容: ブランチの基本認証を有効にするかを指定します。
  # 設定可能な値:
  #   - true: 基本認証を有効化（パスワード保護）
  #   - false: 基本認証を無効化
  # 用途: 開発中やステージング環境のブランチをパスワード保護
  enable_basic_auth = false

  # basic_auth_credentials (Optional, Sensitive)
  # 設定内容: ブランチの基本認証資格情報を指定します。
  # 設定可能な値: Base64エンコードされた"username:password"形式の文字列
  # 注意: enable_basic_authがtrueの場合に必要
  # 例: base64encode("username:password")
  basic_auth_credentials = null

  #-------------------------------------------------------------
  # 通知設定
  #-------------------------------------------------------------

  # enable_notification (Optional)
  # 設定内容: ブランチの通知を有効にするかを指定します。
  # 設定可能な値:
  #   - true: ビルドステータス変更時にEventBridge経由で通知を有効化
  #   - false: 通知を無効化
  # 関連機能: Amazon EventBridge連携
  #   ビルドステータス（SUCCEED, FAILED, STARTED）の変更時に
  #   EventBridgeルールでSNS等へ通知可能
  enable_notification = false

  #-------------------------------------------------------------
  # プルリクエストプレビュー設定
  #-------------------------------------------------------------

  # enable_pull_request_preview (Optional)
  # 設定内容: このブランチへのプルリクエストプレビューを有効にするかを指定します。
  # 設定可能な値:
  #   - true: プルリクエストごとにプレビュー環境を自動作成
  #   - false: プルリクエストプレビューを無効化
  # 関連機能: Amplify Pull Request Previews
  #   プルリクエストが作成されると、自動的にプレビュー環境がデプロイされ、
  #   本番環境に影響を与えずに変更を確認可能
  enable_pull_request_preview = false

  # pull_request_environment_name (Optional)
  # 設定内容: プルリクエストのAmplify環境名を指定します。
  # 設定可能な値: 任意の文字列
  # 用途: プルリクエストプレビュー環境の識別名として使用
  pull_request_environment_name = null

  #-------------------------------------------------------------
  # パフォーマンス設定
  #-------------------------------------------------------------

  # enable_performance_mode (Optional)
  # 設定内容: ブランチのパフォーマンスモードを有効にするかを指定します。
  # 設定可能な値:
  #   - true: パフォーマンスモードを有効化（キャッシュ時間延長）
  #   - false: 標準モード
  # 関連機能: Amplify Performance Mode
  #   コンテンツのキャッシュ時間を延長し、パフォーマンスを向上させます。
  #   本番環境のような頻繁に変更されないブランチに推奨
  enable_performance_mode = false

  # enable_skew_protection (Optional)
  # 設定内容: デプロイメントスキュー保護を有効にするかを指定します。
  # 設定可能な値:
  #   - true: スキュー保護を有効化
  #   - false: スキュー保護を無効化
  # 関連機能: Amplify Skew Protection
  #   デプロイ中にクライアントとサーバー間のバージョン不整合を防止します。
  #   ユーザーセッションが常に同じデプロイバージョンのアセットを取得し、
  #   404エラーや機能の破損を防ぎます。
  #   - https://docs.aws.amazon.com/amplify/latest/userguide/skew-protection.html
  enable_skew_protection = false

  #-------------------------------------------------------------
  # TTL設定
  #-------------------------------------------------------------

  # ttl (Optional)
  # 設定内容: WebサイトのコンテンツTTL（Time To Live）を秒単位で指定します。
  # 設定可能な値: 秒数を表す文字列（例: "3600"）
  # 用途: ブラウザやCDNでのコンテンツキャッシュ期間を制御
  ttl = null

  #-------------------------------------------------------------
  # バックエンド環境設定
  #-------------------------------------------------------------

  # backend_environment_arn (Optional)
  # 設定内容: Amplifyアプリの一部であるバックエンド環境のARNを指定します。
  # 設定可能な値: 有効なAmplifyバックエンド環境ARN
  # 用途: ブランチを特定のバックエンド環境（Auth, API, Storage等）に関連付け
  backend_environment_arn = null

  #-------------------------------------------------------------
  # 環境変数設定
  #-------------------------------------------------------------

  # environment_variables (Optional)
  # 設定内容: ブランチの環境変数を指定します。
  # 設定可能な値: キーと値のマップ
  # 用途: ビルド時およびランタイムで使用する環境固有の設定値を定義
  # 注意: アプリレベルの環境変数を上書きまたは追加可能
  environment_variables = {
    ENVIRONMENT = "production"
  }

  #-------------------------------------------------------------
  # ID設定
  #-------------------------------------------------------------

  # id (Optional)
  # 設定内容: リソースの識別子を指定します。
  # 設定可能な値: 文字列
  # 省略時: Terraformが自動生成（通常は "{app_id}/{branch_name}" 形式）
  # 注意: 通常はユーザーが明示的に設定する必要はありません
  # id = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "main-branch"
    Environment = "production"
  }

  # tags_all (Optional)
  # 設定内容: プロバイダーのdefault_tagsとリソースのtagsをマージした全タグ
  # 注意: 通常は直接設定せず、tagsプロパティを使用します
  # tags_all = {}
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: ブランチのAmazon Resource Name (ARN)
#
# - associated_resources: このブランチにリンクされているカスタムリソースのリスト
#
# - custom_domains: ブランチのカスタムドメインのリスト
#
# - destination_branch: プルリクエストブランチの場合、宛先ブランチ
#
# - source_branch: プルリクエストブランチの場合、ソースブランチ
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#---------------------------------------------------------------
