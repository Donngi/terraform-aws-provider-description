#
#---------------------------------------------------------------

resource "aws_macie2_findings_filter" "example" {
  #-------------------------------------------------------------
  # フィルターアクション設定
  #-------------------------------------------------------------

  # action (Required)
  # 設定内容: フィルター条件に一致するファインディングに対して実行するアクションを指定します。
  # 設定可能な値:
  #   - "ARCHIVE": 条件に一致するファインディングを自動的にアーカイブ（抑制）します
  #   - "NOOP": 条件に一致するファインディングに対してアクションを実行しません（フィルタールール）
  action = "ARCHIVE"

  #-------------------------------------------------------------
  # 名前設定
  #-------------------------------------------------------------

  # name (Optional)
  # 設定内容: フィルターのカスタム名を指定します。
  # 設定可能な値: 3〜64文字の文字列
  # 省略時: Terraform がランダムな一意の名前を生成します。
  # 注意: name_prefix と排他的（どちらか一方のみ指定可能）
  name = "example-findings-filter"

  # name_prefix (Optional)
  # 設定内容: フィルター名のプレフィックスを指定します。Terraform が後ろにランダムなサフィックスを追加します。
  # 設定可能な値: 文字列
  # 注意: name と排他的（どちらか一方のみ指定可能）
  name_prefix = null

  #-------------------------------------------------------------
  # 説明設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: フィルターのカスタム説明文を指定します。
  # 設定可能な値: 最大512文字の文字列
  # 省略時: 説明なし
  description = "Example findings filter for archiving specific findings"

  #-------------------------------------------------------------
  # 表示順序設定
  #-------------------------------------------------------------

  # position (Optional)
  # 設定内容: Amazon Macie コンソールの保存済みフィルターリストでのフィルターの表示順序を指定します。
  # 設定可能な値: 正の整数。他のフィルターに対してこのフィルターが適用される相対的な順序も決定します。
  # 省略時: Macie が自動的に順序を割り当てます。
  position = 1

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-findings-filter"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # フィルター条件設定
  #-------------------------------------------------------------

  # finding_criteria (Required)
  # 設定内容: ファインディングをフィルタリングするための条件を定義するブロックです。
  # 参考: https://docs.aws.amazon.com/macie/latest/user/findings-filter-basics.html
  finding_criteria {

    # criterion (Optional)
    # 設定内容: フィルター結果を絞り込むためのプロパティ・演算子・値を指定する条件ブロックです。
    #           複数の criterion ブロックを指定した場合、Macie はANDロジックで条件を結合します。
    # 参考: https://docs.aws.amazon.com/macie/latest/user/findings-filter-fields.html
    criterion {

      # field (Required)
      # 設定内容: 評価対象のファインディング属性フィールド名を指定します。
      # 設定可能な値: Macie がサポートするファインディングフィールド名（例: region, severity.description, type 等）
      # 参考: https://docs.aws.amazon.com/macie/latest/user/findings-filter-fields.html
      field = "region"

      # eq (Optional)
      # 設定内容: フィールドの値が指定した値のいずれかに一致する条件を指定します（部分一致を含む）。
      # 設定可能な値: 文字列の集合。複数指定した場合は Macie が OR ロジックで結合します。
      # 省略時: この条件を使用しません。
      eq = ["ap-northeast-1"]

      # eq_exact_match (Optional)
      # 設定内容: フィールドの値が指定したすべての値と完全一致する条件を指定します。
      # 設定可能な値: 文字列の集合。複数指定した場合は Macie が AND ロジックで結合します。
      # 省略時: この条件を使用しません。
      eq_exact_match = null

      # neq (Optional)
      # 設定内容: フィールドの値が指定した値のいずれとも一致しない条件を指定します。
      # 設定可能な値: 文字列の集合。複数指定した場合は Macie が OR ロジックで結合します。
      # 省略時: この条件を使用しません。
      neq = null

      # gt (Optional)
      # 設定内容: フィールドの値が指定した値より大きい条件を指定します（数値・日時フィールド向け）。
      # 設定可能な値: 数値または日時を表す文字列
      # 省略時: この条件を使用しません。
      gt = null

      # gte (Optional)
      # 設定内容: フィールドの値が指定した値以上の条件を指定します（数値・日時フィールド向け）。
      # 設定可能な値: 数値または日時を表す文字列
      # 省略時: この条件を使用しません。
      gte = null

      # lt (Optional)
      # 設定内容: フィールドの値が指定した値より小さい条件を指定します（数値・日時フィールド向け）。
      # 設定可能な値: 数値または日時を表す文字列
      # 省略時: この条件を使用しません。
      lt = null

      # lte (Optional)
      # 設定内容: フィールドの値が指定した値以下の条件を指定します（数値・日時フィールド向け）。
      # 設定可能な値: 数値または日時を表す文字列
      # 省略時: この条件を使用しません。
      lte = null
    }
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を設定するブロックです。
  timeouts {

    # create (Optional)
    # 設定内容: リソース作成操作のタイムアウト時間を指定します。
    # 設定可能な値: "60s", "5m", "1h" などの時間フォーマット文字列
    # 省略時: デフォルトのタイムアウト時間を使用
    create = "5m"
  }
}

