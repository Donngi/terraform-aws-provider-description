#######################################################################################################
# Resource: aws_codecommit_approval_rule_template_association
# AWS Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/codecommit_approval_rule_template_association
# Generated: 2026-02-12
#
# 概要:
#   CodeCommit リポジトリに承認ルールテンプレートを関連付けます。
#   承認ルールテンプレートは、プルリクエストのマージ前に必要な承認条件を定義します。
#
# 制約事項:
#   - approval_rule_template_name と repository_name は必須
#   - テンプレートとリポジトリは同じリージョンに存在する必要がある
#   - 同じテンプレートを複数のリポジトリに関連付け可能
#
# NOTE:
#   - 承認ルールテンプレートは aws_codecommit_approval_rule_template で作成
#   - リポジトリは aws_codecommit_repository で作成
#   - 関連付けを削除すると、リポジトリから承認ルールテンプレートが解除される
#
#######################################################################################################

resource "aws_codecommit_approval_rule_template_association" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 承認ルールテンプレート設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: 関連付ける承認ルールテンプレート名
  # 設定可能な値: 既存の aws_codecommit_approval_rule_template のテンプレート名
  # 省略時: エラー (必須)
  approval_rule_template_name = "template-name"

  #-------------------------------------------------------------------------------------------------------
  # リポジトリ設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: 承認ルールテンプレートを関連付ける CodeCommit リポジトリ名
  # 設定可能な値: 既存の aws_codecommit_repository のリポジトリ名
  # 省略時: エラー (必須)
  repository_name = "repository-name"

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------

  # 設定内容: リソースを管理するリージョン
  # 設定可能な値: AWS リージョン名 (例: us-east-1, ap-northeast-1)
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"
}

#######################################################################################################
# Attributes Reference
#######################################################################################################
# このリソースは以下の属性をエクスポートします:
#
# - id
#   説明: リソース ID (形式: approval_rule_template_name,repository_name)
#   型: string
#
# - approval_rule_template_name
#   説明: 承認ルールテンプレート名
#   型: string
#
# - repository_name
#   説明: CodeCommit リポジトリ名
#   型: string
#
# - region
#   説明: リソースが管理されているリージョン
#   型: string
#
#######################################################################################################
