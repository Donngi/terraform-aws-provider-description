#---------------------------------------------------------------
# AWS Network ACL (ネットワークアクセスコントロールリスト)
#---------------------------------------------------------------
#
# VPCのサブネットに対するネットワークレベルのアクセス制御を設定する
# リソースです。ネットワークACLはステートレスなファイアウォールとして
# 機能し、インバウンドおよびアウトバウンドトラフィックをルールに基づいて
# 許可または拒否します。
# セキュリティグループと異なり、明示的なDENYルールを設定できます。
#
# 注意: ingress/egress を本リソースで管理すると、aws_network_acl_rule
#       リソースとの競合が発生する場合があります。
#       ルールを個別管理する場合は aws_network_acl_rule を使用してください。
#
# AWS公式ドキュメント:
#   - ネットワークACL: https://docs.aws.amazon.com/vpc/latest/userguide/vpc-network-acls.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/network_acl
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_network_acl" "example" {
  #-------------------------------------------------------------
  # VPC設定
  #-------------------------------------------------------------

  # vpc_id (Required)
  # 設定内容: このネットワークACLを作成するVPCのIDを指定します。
  # 設定可能な値: 有効なVPC ID（例: vpc-12345678）
  vpc_id = "vpc-12345678"

  #-------------------------------------------------------------
  # サブネット関連付け設定
  #-------------------------------------------------------------

  # subnet_ids (Optional)
  # 設定内容: このネットワークACLに関連付けるサブネットIDのセットを指定します。
  # 設定可能な値: 有効なサブネットIDのリスト
  # 省略時: ネットワークACLはサブネットに関連付けられません。
  # 注意: aws_network_acl_association リソースを使用してサブネットを
  #       後から個別に関連付けることも可能です。
  subnet_ids = [
    "subnet-12345678",
    "subnet-87654321",
  ]

  #-------------------------------------------------------------
  # インバウンドルール設定
  #-------------------------------------------------------------

  # ingress (Optional)
  # 設定内容: インバウンド（受信）トラフィックに対するルールを指定します。
  # 省略時: インバウンドルールは設定されません。
  # 注意: aws_network_acl_rule リソースと併用する場合は競合に注意してください。
  ingress {
    # rule_no (Required)
    # 設定内容: ルールの優先順位番号を指定します（番号が小さいほど優先）。
    # 設定可能な値: 1〜32766 の整数（32767はデフォルトルール用に予約）
    rule_no = 100

    # protocol (Required)
    # 設定内容: 対象とするプロトコルを指定します。
    # 設定可能な値:
    #   - "tcp": TCP
    #   - "udp": UDP
    #   - "icmp": ICMP
    #   - "icmpv6": ICMPv6
    #   - "-1": すべてのプロトコル
    #   - プロトコル番号（例: "6" = TCP, "17" = UDP）
    protocol = "tcp"

    # action (Required)
    # 設定内容: ルールに一致したトラフィックへのアクションを指定します。
    # 設定可能な値:
    #   - "allow": トラフィックを許可
    #   - "deny": トラフィックを拒否
    action = "allow"

    # cidr_block (Optional)
    # 設定内容: ルールを適用するIPv4 CIDRブロックを指定します。
    # 設定可能な値: 有効なCIDR表記（例: "0.0.0.0/0", "10.0.0.0/8"）
    # 省略時: cidr_block または ipv6_cidr_block のどちらかが必要です。
    cidr_block = "0.0.0.0/0"

    # ipv6_cidr_block (Optional)
    # 設定内容: ルールを適用するIPv6 CIDRブロックを指定します。
    # 設定可能な値: 有効なIPv6 CIDR表記（例: "::/0"）
    # 省略時: cidr_block を使用する場合は省略可能です。
    # ipv6_cidr_block = "::/0"

    # from_port (Required)
    # 設定内容: ルールを適用するポート範囲の開始ポートを指定します。
    # 設定可能な値: 0〜65535 の整数
    # 注意: protocol が "-1"（すべて）の場合は 0 を指定します。
    from_port = 443

    # to_port (Required)
    # 設定内容: ルールを適用するポート範囲の終了ポートを指定します。
    # 設定可能な値: 0〜65535 の整数（from_port 以上の値）
    # 注意: protocol が "-1"（すべて）の場合は 0 を指定します。
    to_port = 443

    # icmp_type (Optional)
    # 設定内容: ICMPプロトコルのタイプを指定します。
    # 設定可能な値: ICMPタイプ番号（例: 8 = エコーリクエスト, -1 = すべて）
    # 省略時: protocol が icmp または icmpv6 の場合のみ有効です。
    # icmp_type = -1

    # icmp_code (Optional)
    # 設定内容: ICMPプロトコルのコードを指定します。
    # 設定可能な値: ICMPコード番号（例: -1 = すべてのコード）
    # 省略時: protocol が icmp または icmpv6 の場合のみ有効です。
    # icmp_code = -1
  }

  #-------------------------------------------------------------
  # アウトバウンドルール設定
  #-------------------------------------------------------------

  # egress (Optional)
  # 設定内容: アウトバウンド（送信）トラフィックに対するルールを指定します。
  # 省略時: アウトバウンドルールは設定されません。
  # 注意: aws_network_acl_rule リソースと併用する場合は競合に注意してください。
  egress {
    # rule_no (Required)
    # 設定内容: ルールの優先順位番号を指定します（番号が小さいほど優先）。
    # 設定可能な値: 1〜32766 の整数（32767はデフォルトルール用に予約）
    rule_no = 100

    # protocol (Required)
    # 設定内容: 対象とするプロトコルを指定します。
    # 設定可能な値:
    #   - "tcp": TCP
    #   - "udp": UDP
    #   - "icmp": ICMP
    #   - "icmpv6": ICMPv6
    #   - "-1": すべてのプロトコル
    #   - プロトコル番号（例: "6" = TCP, "17" = UDP）
    protocol = "-1"

    # action (Required)
    # 設定内容: ルールに一致したトラフィックへのアクションを指定します。
    # 設定可能な値:
    #   - "allow": トラフィックを許可
    #   - "deny": トラフィックを拒否
    action = "allow"

    # cidr_block (Optional)
    # 設定内容: ルールを適用するIPv4 CIDRブロックを指定します。
    # 設定可能な値: 有効なCIDR表記（例: "0.0.0.0/0", "10.0.0.0/8"）
    # 省略時: cidr_block または ipv6_cidr_block のどちらかが必要です。
    cidr_block = "0.0.0.0/0"

    # ipv6_cidr_block (Optional)
    # 設定内容: ルールを適用するIPv6 CIDRブロックを指定します。
    # 設定可能な値: 有効なIPv6 CIDR表記（例: "::/0"）
    # 省略時: cidr_block を使用する場合は省略可能です。
    # ipv6_cidr_block = "::/0"

    # from_port (Required)
    # 設定内容: ルールを適用するポート範囲の開始ポートを指定します。
    # 設定可能な値: 0〜65535 の整数
    # 注意: protocol が "-1"（すべて）の場合は 0 を指定します。
    from_port = 0

    # to_port (Required)
    # 設定内容: ルールを適用するポート範囲の終了ポートを指定します。
    # 設定可能な値: 0〜65535 の整数（from_port 以上の値）
    # 注意: protocol が "-1"（すべて）の場合は 0 を指定します。
    to_port = 0

    # icmp_type (Optional)
    # 設定内容: ICMPプロトコルのタイプを指定します。
    # 設定可能な値: ICMPタイプ番号（例: 8 = エコーリクエスト, -1 = すべて）
    # 省略時: protocol が icmp または icmpv6 の場合のみ有効です。
    # icmp_type = -1

    # icmp_code (Optional)
    # 設定内容: ICMPプロトコルのコードを指定します。
    # 設定可能な値: ICMPコード番号（例: -1 = すべてのコード）
    # 省略時: protocol が icmp または icmpv6 の場合のみ有効です。
    # icmp_code = -1
  }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしで作成されます。
  # 注意: プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-network-acl"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: ネットワークACLのID
# - arn: ネットワークACLのARN
# - owner_id: ネットワークACLを所有するAWSアカウントのID
# - egress: アウトバウンドルールのセット（設定値がそのまま返却されます）
# - ingress: インバウンドルールのセット（設定値がそのまま返却されます）
# - subnet_ids: 関連付けられているサブネットIDのセット
# - tags_all: プロバイダーの default_tags 設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#---------------------------------------------------------------
