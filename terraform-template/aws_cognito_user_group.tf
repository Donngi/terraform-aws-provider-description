################################################################################
# AWS Cognito User Group
################################################################################
# Amazon Cognito ユーザープールグループリソース
# ユーザーを論理的にグループ化し、IAMロールやアプリケーション内での権限管理を実現
# グループベースでのアクセス制御やユーザー階層の管理に使用
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/cognito_user_group
# Generated: 2026-02-13
#
# NOTE: このテンプレートは参考実装です。実際の環境に応じて値を調整してください。
#
# 主な用途:
# - ユーザーのロールベース分類（管理者、一般ユーザー等）
# - グループ単位での優先順位設定
# - IAMロールとの統合による権限管理
# - アプリケーション内でのグループベースアクセス制御
#
# 関連リソース:
# - aws_cognito_user_pool: グループの所属先プール
# - aws_iam_role: グループに割り当てるIAMロール
# - aws_cognito_user_pool_client: アプリケーションクライアント
################################################################################

#---------------------------------------
# グループ基本設定
#---------------------------------------

resource "aws_cognito_user_group" "example" {
  #---------------------------------------
  # 必須パラメータ
  #---------------------------------------

  # name - グループ名
  # 設定内容: グループの一意識別子
  # 設定可能な値: 1-128文字の英数字、ハイフン、アンダースコア
  # 省略時: エラー（必須）
  name = "administrators"

  # user_pool_id - ユーザープールID
  # 設定内容: グループを作成する対象のユーザープールID
  # 設定可能な値: 有効なCognito User Pool ID（us-east-1_XXXXXXXXX形式）
  # 省略時: エラー（必須）
  user_pool_id = "us-east-1_XXXXXXXXX"

  #---------------------------------------
  # グループメタデータ
  #---------------------------------------

  # description - グループ説明
  # 設定内容: グループの用途や目的を記述
  # 設定可能な値: 最大2048文字の説明文
  # 省略時: 説明なし
  description = "Administrator users with full access"

  #---------------------------------------
  # 優先順位設定
  #---------------------------------------

  # precedence - 優先順位
  # 設定内容: グループの優先度（数値が小さいほど優先）
  # 設定可能な値: 0以上の整数
  # 省略時: 優先順位なし（複数グループ所属時は最小値が使用される）
  # 備考: 同一ユーザーが複数グループに所属する場合の優先制御に使用
  precedence = 1

  #---------------------------------------
  # IAM連携設定
  #---------------------------------------

  # role_arn - IAMロールARN
  # 設定内容: グループメンバーに割り当てるIAMロールのARN
  # 設定可能な値: 有効なIAM Role ARN（arn:aws:iam::123456789012:role/...形式）
  # 省略時: IAMロール割り当てなし
  # 備考: グループ所属ユーザーがCognitoで認証後にこのロールを引き受ける
  role_arn = "arn:aws:iam::123456789012:role/CognitoAdminRole"

  #---------------------------------------
  # リージョン設定
  #---------------------------------------

  #---------------------------------------
  # リージョン設定（通常は省略）
  #---------------------------------------

  # region - リージョン
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: us-east-1, ap-northeast-1等の有効なリージョンコード
  # 省略時: プロバイダー設定のリージョンを使用
  # 備考: 通常はuser_pool_idのリージョンと一致させる
  region = "us-east-1"
}

################################################################################
# Attributes Reference（参照専用属性）
################################################################################
# リソース作成後に参照可能な属性
#
# - id
#   リソースID（<user_pool_id>/<name>形式）
#   例: us-east-1_XXXXXXXXX/administrators
#
# - region
#   リソースが管理されているリージョン
#   例: us-east-1
################################################################################
