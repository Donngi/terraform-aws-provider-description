#---------------------------------------------------------------
# AWS IoT ロールエイリアス
#---------------------------------------------------------------
#
# AWS IoT Core のロールエイリアスをプロビジョニングするリソースです。
# ロールエイリアスを使用すると、接続デバイスが AWS IoT Core を通じて
# IAM ロールの一時的な認証情報を取得できるようになります。
# デバイスはロールエイリアス名を使用して IAM ロールを参照するため、
# 実際の IAM ロール ARN を変更してもデバイス側の設定を変更せずに済みます。
#
# AWS公式ドキュメント:
#   - ロールエイリアスの認可: https://docs.aws.amazon.com/iot/latest/developerguide/authorizing-direct-aws.html
#   - ロールエイリアスの管理: https://docs.aws.amazon.com/iot/latest/developerguide/create-role-alias.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/iot_role_alias
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iot_role_alias" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # alias (Required)
  # 設定内容: ロールエイリアスの名前を指定します。
  # 設定可能な値: 1〜128文字の文字列。使用可能な文字: [\w=,@-]+
  alias = "example-role-alias"

  # role_arn (Required)
  # 設定内容: このロールエイリアスが参照する IAM ロールの ARN を指定します。
  # 設定可能な値: 有効な IAM ロールの ARN
  # 注意: 指定した IAM ロールには AWS IoT Core が AssumeRole できる信頼ポリシーが必要です。
  #       信頼ポリシーのプリンシパルに "credentials.iot.amazonaws.com" を指定してください。
  role_arn = "arn:aws:iam::123456789012:role/my-iot-device-role"

  #-------------------------------------------------------------
  # 認証情報設定
  #-------------------------------------------------------------

  # credential_duration (Optional)
  # 設定内容: ロールエイリアスで取得した一時認証情報の有効期間を秒単位で指定します。
  # 設定可能な値: 900（15分）〜 43200（12時間）
  # 省略時: 3600（1時間）
  # 注意: IAM ロールの最大セッション時間よりも長い値は指定できません。
  credential_duration = 3600

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理する AWS リージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値の文字列ペアのマップ
  # 省略時: タグなし
  # 注意: プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルのタグを上書きします。
  tags = {
    Name        = "example-role-alias"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: ロールエイリアスの Amazon Resource Name (ARN)
#
# - tags_all: プロバイダーの default_tags 設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
