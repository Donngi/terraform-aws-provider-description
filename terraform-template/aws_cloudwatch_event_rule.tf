#----------------------------------------------------------------------------------------------------------------------
# AWS CloudWatch Event Rule (EventBridge Rule)
#----------------------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-12
#
# 機能概要:
#   EventBridge（旧CloudWatch Events）のルールリソース。
#   イベントパターンやスケジュール式に基づいてターゲットにイベントをルーティングする。
#
# 公式ドキュメント:
#   https://docs.aws.amazon.com/eventbridge/latest/userguide/eb-rules.html
#   https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/cloudwatch_event_rule
#
# NOTE:
#   - event_patternとschedule_expressionは排他的（どちらか一方のみ指定可能）
#   - is_enabledは非推奨、stateパラメータの使用を推奨
#   - force_destroyを有効化するとターゲット関連付け済みでも削除可能
#----------------------------------------------------------------------------------------------------------------------

resource "aws_cloudwatch_event_rule" "example" {
  #----------------------------------------------------------------------------------------------------------------------
  # 基本設定
  #----------------------------------------------------------------------------------------------------------------------
  # ルール名
  # 設定内容: EventBridgeルールの名前（64文字以内、英数字・ハイフン・アンダースコア使用可能）
  # 設定可能な値: 任意の文字列（name_prefixとの併用不可）
  # 省略時: 自動生成される一意の名前が割り当てられる
  name = "example-event-rule"

  # ルール名プレフィックス
  # 設定内容: ルール名の接頭辞を指定して一意の名前を自動生成
  # 設定可能な値: 任意の文字列（nameとの併用不可）
  # 省略時: 使用されない
  name_prefix = null

  # 説明
  # 設定内容: ルールの目的や動作を説明するテキスト
  # 設定可能な値: 任意の文字列（512文字以内推奨）
  # 省略時: 説明なし
  description = "Example EventBridge rule"

  #----------------------------------------------------------------------------------------------------------------------
  # イベント設定
  #----------------------------------------------------------------------------------------------------------------------
  # イベントバス名
  # 設定内容: ルールを関連付けるイベントバスの名前
  # 設定可能な値: "default"（デフォルトバス）、カスタムイベントバス名、パートナーイベントバス名
  # 省略時: "default"イベントバスが使用される
  event_bus_name = "default"

  # イベントパターン
  # 設定内容: イベントをフィルタリングするためのJSONパターン（schedule_expressionとの併用不可）
  # 設定可能な値: EventBridgeイベントパターンのJSON文字列
  # 省略時: すべてのイベントにマッチ（schedule_expressionが設定されている場合は不要）
  event_pattern = jsonencode({
    source      = ["aws.ec2"]
    detail-type = ["EC2 Instance State-change Notification"]
    detail = {
      state = ["running"]
    }
  })

  # スケジュール式
  # 設定内容: 定期的にトリガーされるスケジュールをcron/rate式で定義（event_patternとの併用不可）
  # 設定可能な値: "rate(5 minutes)"、"cron(0 12 * * ? *)"など
  # 省略時: イベントパターンベースのルールとして動作
  schedule_expression = null

  #----------------------------------------------------------------------------------------------------------------------
  # ルール制御
  #----------------------------------------------------------------------------------------------------------------------
  # 状態
  # 設定内容: ルールの有効/無効状態
  # 設定可能な値: "ENABLED"（有効）、"DISABLED"（無効）
  # 省略時: "ENABLED"
  state = "ENABLED"

  # 有効フラグ（非推奨）
  # 設定内容: ルールを有効化するかどうか（stateの使用を推奨）
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: true
  # 非推奨: 代わりにstateパラメータを使用してください
  is_enabled = null

  #----------------------------------------------------------------------------------------------------------------------
  # ロール設定
  #----------------------------------------------------------------------------------------------------------------------
  # IAMロールARN
  # 設定内容: EventBridgeがターゲットを呼び出す際に使用するIAMロールのARN
  # 設定可能な値: 有効なIAMロールARN
  # 省略時: ターゲットがリソースベースポリシーをサポートする場合は不要
  role_arn = null

  #----------------------------------------------------------------------------------------------------------------------
  # 削除設定
  #----------------------------------------------------------------------------------------------------------------------
  # 強制削除
  # 設定内容: ルール削除時にターゲットが関連付けられていても強制的に削除
  # 設定可能な値: true（強制削除）、false（ターゲット存在時はエラー）
  # 省略時: false
  force_destroy = false

  #----------------------------------------------------------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------------------------------------------------------
  # リージョン
  # 設定内容: リソースが管理されるAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: "us-east-1"、"ap-northeast-1"）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = null

  #----------------------------------------------------------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------------------------------------------------------
  # タグ
  # 設定内容: リソースに付与するKey-Valueペアのメタデータ
  # 設定可能な値: 最大50個のタグ、キーは128文字、値は256文字まで
  # 省略時: タグなし
  tags = {
    Name        = "example-event-rule"
    Environment = "production"
    ManagedBy   = "Terraform"
  }

  # 統合タグ（すべてのタグ）
  # 設定内容: プロバイダーレベルのデフォルトタグとリソースレベルのタグを統合
  # 設定可能な値: Key-Valueペアのマップ
  # 省略時: リソースタグとプロバイダータグが自動統合される
  # tags_all = {}
}

