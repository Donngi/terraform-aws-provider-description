#-----------------------------------------------------------------------------------------------------------------------
# AWS CloudWatch Evidently Segment
#-----------------------------------------------------------------------------------------------------------------------
# 用途: CloudWatch Evidentlyのセグメント定義
# 概要: ユーザーや属性をグループ化してA/Bテストや機能フラグのターゲット設定を行うセグメントを作成します
#
# 補足:
# - このリソースは非推奨（deprecated）となっており、今後削除される予定
# - 新規の機能フラグ実装にはAWS AppConfig Feature Flagsの使用を推奨
# - JSON形式のパターンで属性マッチングルールを定義
# - 数値比較、文字列一致、リスト包含などの条件指定が可能
# - 複数の条件をAND/ORで組み合わせることができる
# - A/Bテストや段階的機能リリースのターゲットユーザーグループを定義
# - セグメントは実験（Experiment）や機能起動（Launch）から参照される
# - 作成後のname、pattern、descriptionの変更は新規リソースの作成を伴う
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/evidently_segment
# NOTE: このリソースは非推奨です。新規実装ではAWS AppConfig Feature Flagsを使用してください

#-----------------------------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------------------------
# リソース定義
#-----------------------------------------------------------------------------------------------------------------------
resource "aws_evidently_segment" "example" {
  #-----------------------------------------------------------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: セグメントを識別するための一意の名前
  # 設定可能な値: 1-127文字の英数字、ハイフン、アンダースコア
  # 省略時: エラー（必須項目）
  name = "example-segment"

  # 設定内容: セグメントに含めるユーザーや属性を判定するためのルール（JSON形式）
  # 設定可能な値: JSON形式の条件式（数値比較、文字列一致、リスト包含など）
  # 省略時: エラー（必須項目）
  #
  # 【パターン構文の例】
  # - 数値範囲: {"Price":[{"numeric":[">",10,"<=",20]}]}
  # - 文字列一致: {"Region":[{"equals":"us-east-1"}]}
  # - リスト包含: {"Plan":[{"in":["premium","enterprise"]}]}
  # - 複数条件: {"Price":[{"numeric":[">",100]}],"Region":[{"equals":"us-west-2"}]}
  pattern = jsonencode({
    "Price" = [{
      "numeric" = [">", 10, "<=", 20]
    }]
  })

  #-----------------------------------------------------------------------------------------------------------------------
  # 説明・ドキュメント
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: セグメントの用途や目的を説明するテキスト
  # 設定可能な値: 任意の文字列（最大160文字推奨）
  # 省略時: 説明なしでセグメントが作成される
  description = "Price range segment for users with item prices between 10 and 20"

  #-----------------------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: このセグメントを作成するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = "us-east-1"

  #-----------------------------------------------------------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------------------------------------------------------
  # 設定内容: セグメントに付与するメタデータタグ
  # 設定可能な値: キーと値のペアで構成されるマップ（最大50タグ）
  # 省略時: タグなしでリソースが作成される
  #
  # 【タグ付けのベストプラクティス】
  # - Environment: 環境識別（dev, staging, production）
  # - Owner: 管理者やチーム名
  # - CostCenter: コスト配分用のタグ
  # - Project: プロジェクト名
  tags = {
    Name        = "example-segment"
    Environment = "production"
    ManagedBy   = "Terraform"
  }
}

#-----------------------------------------------------------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------------------------------------------------------
# このリソースをTerraformで作成した後に参照可能な属性:
#
# - arn: セグメントのARN（Amazon Resource Name）
# - created_time: セグメントの作成日時（ISO 8601形式）
# - experiment_count: このセグメントを使用している実験の数（実行中以外も含む）
# - id: セグメントのID（ARNと同じ値）
# - last_updated_time: セグメントの最終更新日時（ISO 8601形式）
# - launch_count: このセグメントを使用している機能起動の数（実行中以外も含む）
# - tags_all: プロバイダーのdefault_tagsとマージされた全タグのマップ
