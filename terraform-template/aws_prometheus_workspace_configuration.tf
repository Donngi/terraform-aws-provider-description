#-----------------------------------------------------------------------
# AWS Prometheus Workspace Configuration
#-----------------------------------------------------------------------
# Amazon Managed Service for Prometheus ワークスペースの詳細設定を管理するリソース
# データ保持期間の変更やラベルセット別のアクティブシリーズ数上限を設定できる
# aws_prometheus_workspace リソースと組み合わせて使用する
#
# 主な用途:
# - Prometheus メトリクスデータの保持期間カスタマイズ
# - 特定ラベルセットに対するシリーズ数上限設定（コスト管理）
# - ワークスペースの詳細設定の一元管理
#
# 注意事項:
# - workspace_id は既存の aws_prometheus_workspace リソースを参照すること
# - limits_per_label_set は複数定義可能（ラベルセットごとに別ブロックを記述）
# - 保持期間を短縮するとデータが削除される可能性があるため慎重に設定する
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: このリソースは aws_prometheus_workspace とは独立して管理される
#
# 参考: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/prometheus_workspace_configuration
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------
resource "aws_prometheus_workspace_configuration" "example" {

  # 設定内容: 設定を適用する Prometheus ワークスペースの ID
  # 設定可能な値: 有効な Amazon Managed Prometheus ワークスペース ID
  workspace_id = "ws-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

  #---------------------------------------
  # データ保持設定
  #---------------------------------------

  # 設定内容: メトリクスデータの保持期間（日数）
  # 設定可能な値: 1 以上の整数（例: 150 で約 5 ヶ月）
  # 省略時: AWS デフォルト値が適用される
  retention_period_in_days = 150

  #---------------------------------------
  # リージョン設定
  #---------------------------------------

  # 設定内容: リソースを管理する AWS リージョン
  # 設定可能な値: 有効な AWS リージョンコード（例: "ap-northeast-1"）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = "ap-northeast-1"

  #---------------------------------------
  # ラベルセット別シリーズ上限設定
  #---------------------------------------

  # 設定内容: 特定のラベルセットに対するアクティブシリーズ数の上限を定義するリスト
  # 省略時: シリーズ上限は設定されない
  limits_per_label_set {
    # 設定内容: 上限を適用するラベルと値のマップ
    # 設定可能な値: Prometheus メトリクスのラベル名と値のキーバリューペア
    label_set = {
      job = "my-service"
      env = "production"
    }

    # 設定内容: このラベルセットに許可する最大アクティブシリーズ数
    limits {
      # 設定内容: 最大シリーズ数
      # 設定可能な値: 1 以上の整数
      max_series = 10000
    }
  }

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  timeouts {
    # 設定内容: リソース作成のタイムアウト時間
    # 設定可能な値: "30s"、"5m"、"2h" などの時間文字列
    # 省略時: プロバイダーのデフォルト値が使用される
    create = "30m"

    # 設定内容: リソース更新のタイムアウト時間
    # 設定可能な値: "30s"、"5m"、"2h" などの時間文字列
    # 省略時: プロバイダーのデフォルト値が使用される
    update = "30m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# workspace_id             - 設定対象の Prometheus ワークスペース ID
# retention_period_in_days - 設定されたデータ保持期間（日数）
# region                   - リソースを管理する AWS リージョン
