#---------------------------------------------------------------------------------------------------
# 基本設定
#---------------------------------------------------------------------------------------------------

resource "aws_cloudfront_monitoring_subscription" "example" {
  # 設定内容: 監視対象のCloudFrontディストリビューションID
  # 設定可能な値: 有効なCloudFrontディストリビューションのID（E1234567890ABC形式）
  distribution_id = "E1234567890ABC"

  #-------------------------------------------------------------------------------------------------
  # リアルタイムメトリクス監視設定
  #-------------------------------------------------------------------------------------------------

  monitoring_subscription {
    realtime_metrics_subscription_config {
      # 設定内容: リアルタイムメトリクスのサブスクリプション状態
      # 設定可能な値:
      #   - Enabled: リアルタイムメトリクスを有効化（追加料金が発生）
      #   - Disabled: リアルタイムメトリクスを無効化
      # 省略時: 設定必須（必須項目）
      realtime_metrics_subscription_status = "Enabled"
    }
  }
}

