#-------------------------------------------------------------------------------------------------------
# AWS DataExchange Event Action
#-------------------------------------------------------------------------------------------------------
# AWS DataExchangeのイベントアクションリソース
# リビジョン公開などのイベントに基づいて自動的にアクションを実行する機能を提供
#
# 主な用途:
# - データセットリビジョン公開時の自動エクスポート
# - S3への自動バックアップ設定
# - イベント駆動型のデータ配信ワークフロー
#
# 関連リソース:
# - aws_dataexchange_data_set: データセット本体
# - aws_dataexchange_revision: リビジョン管理
# - aws_s3_bucket: エクスポート先バケット
# - aws_kms_key: 暗号化キー
#
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/dataexchange_event_action
#
# NOTE:
# - イベントアクションは作成後に有効化される
# - 暗号化設定はエクスポート先バケットのポリシーと整合性を保つ必要がある
# - データセットへの適切なアクセス権限が必要
#-------------------------------------------------------------------------------------------------------

resource "aws_dataexchange_event_action" "example" {

  #-------------------------------------------------------------------------------------------------------
  # イベント設定（Event Configuration）
  #-------------------------------------------------------------------------------------------------------
  event {
    # リビジョン公開イベント設定
    revision_published {
      data_set_id = "データセットID" # 必須: 監視対象のDataExchangeデータセットID
    }
  }

  #-------------------------------------------------------------------------------------------------------
  # アクション設定（Action Configuration）
  #-------------------------------------------------------------------------------------------------------
  action {
    # S3へのリビジョンエクスポート設定
    export_revision_to_s3 {
      # エクスポート先設定
      revision_destination {
        bucket = "バケット名" # 必須: エクスポート先S3バケット名

        # エクスポートファイルのキーパターン
        # 設定内容: エクスポートされるオブジェクトのS3キー命名規則
        # 設定可能な値: ${Revision.Id}、${Asset.Name}などのプレースホルダーを含むパターン
        # 省略時: デフォルトのキーパターンが使用される
        # key_pattern = "${Revision.Id}/${Asset.Name}"
      }

      # 暗号化設定
      encryption {
        # 暗号化タイプ
        # 設定内容: S3オブジェクトの暗号化方式
        # 設定可能な値: "aws:kms", "AES256"
        # 省略時: 暗号化なし
        # type = "aws:kms"

        # KMS暗号化キーARN
        # 設定内容: AWS KMSカスタマーマネージドキーのARN
        # 設定可能な値: KMSキーの有効なARN
        # 省略時: typeが"aws:kms"の場合はデフォルトKMSキーを使用
        # kms_key_arn = "arn:aws:kms:ap-northeast-1:123456789012:key/12345678-1234-1234-1234-123456789012"
      }
    }
  }

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定（Region Configuration）
  #-------------------------------------------------------------------------------------------------------
  # リソース管理リージョン
  # 設定内容: このリソースが管理されるAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（us-east-1、ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"

}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# arn          - イベントアクションのARN
# id           - イベントアクションのID
# created_at   - 作成日時（RFC3339形式）
# updated_at   - 最終更新日時（RFC3339形式）
#-------------------------------------------------------------------------------------------------------
