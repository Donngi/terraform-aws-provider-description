#-------------------------------------------------------------------------------------------------------
# Terraform Resource: aws_dx_hosted_transit_virtual_interface_accepter
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/dx_hosted_transit_virtual_interface_accepter
#
# NOTE:
# - 別のAWSアカウントが作成したホスト型トランジット仮想インターフェイスの所有権を受理
# - トランジット仮想インターフェイスをDirect Connect Gatewayに接続
# - アロケーター側とアクセプター側の両方から削除可能だが、Terraformでは
#   アロケーター側（aws_dx_hosted_transit_virtual_interface）からのみ削除可能
# - このリソースを削除してもステートファイルから除外されるだけで
#   実際のDirect Connect仮想インターフェイスは削除されない
#
# 用途:
# - マルチアカウント環境でDirect Connect接続を共有
# - パートナー企業から提供されたDirect Connect接続の受理
# - 組織内の異なるアカウント間でのネットワーク接続
#
# 主な機能:
# - 他アカウントから提供されたホスト型トランジット仮想インターフェイスの受理
# - Direct Connect Gatewayへの接続設定
# - リージョン指定による管理場所の制御
# - タグによるリソース管理とコスト配分
#
# 関連リソース:
# - aws_dx_hosted_transit_virtual_interface（アロケーター側のリソース）
# - aws_dx_gateway（Direct Connect Gateway）
# - aws_dx_gateway_association（Transit Gateway との関連付け）
#-------------------------------------------------------------------------------------------------------

resource "aws_dx_hosted_transit_virtual_interface_accepter" "example" {

  #-------------------------------------------------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------------------------------------------------

  # 仮想インターフェイスID
  # 設定内容: 受理するDirect Connectホスト型トランジット仮想インターフェイスのID
  # 形式: dxvif-xxxxxxxx
  # 参照: アロケーター側で作成されたaws_dx_hosted_transit_virtual_interface.id
  virtual_interface_id = "dxvif-12345678"

  # Direct Connect GatewayID
  # 設定内容: 仮想インターフェイスを接続するDirect Connect GatewayのID
  # 形式: dxgw-xxxxxxxx
  # 用途: トランジット仮想インターフェイスをDX Gatewayに接続
  # 注意: DX Gatewayは仮想インターフェイスを削除する前に削除できない
  dx_gateway_id = "dxgw-12345678"

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------

  # リージョン
  # 設定内容: このリソースが管理されるAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用される
  # 用途: マルチリージョン環境でのリソース管理場所の制御
  region = "ap-northeast-1"

  #-------------------------------------------------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------------------------------------------------

  # リソースタグ
  # 設定内容: 仮想インターフェイスに割り当てるキー・バリュー形式のタグ
  # 用途: リソースの分類、コスト配分、所有者識別、アクセス制御
  # 注意: プロバイダーのdefault_tagsと重複するキーは上書きされる
  tags = {
    Name        = "example-transit-vif-accepter"
    Environment = "production"
    Side        = "Accepter"
    ManagedBy   = "Terraform"
  }

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------

  timeouts {
    # 作成タイムアウト
    # 設定内容: 仮想インターフェイス受理の最大待機時間
    # 省略時: 10分
    # 形式: "10m"（分単位）、"1h"（時間単位）
    create = "10m"

    # 削除タイムアウト
    # 設定内容: 仮想インターフェイス削除の最大待機時間
    # 省略時: 10分
    # 形式: "10m"（分単位）、"1h"（時間単位）
    delete = "10m"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# - id: 仮想インターフェイスID（virtual_interface_idと同じ値）
# - arn: 仮想インターフェイスのARN（Amazon Resource Name）
# - tags_all: リソースに割り当てられた全タグ（プロバイダーのdefault_tagsを含む）
#-------------------------------------------------------------------------------------------------------
