#-----------------------------------------------------------------------
# AWS IAM User Policy Attachments Exclusive
#-----------------------------------------------------------------------
#
# IAMユーザーへのマネージドポリシーアタッチメントを排他的に管理するリソース。
# このリソースは、指定したIAMユーザーにアタッチされているマネージドポリシーの
# 完全な所有権を持ち、policy_arns に列挙されていないポリシーは自動的にデタッチされる。
# このリソースを破棄しても、設定済みポリシーはユーザーからデタッチされない点に注意すること。
#
# AWS公式ドキュメント:
#   - IAM マネージドポリシー: https://docs.aws.amazon.com/IAM/latest/UserGuide/access_policies_managed-vs-inline.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/iam_user_policy_attachments_exclusive
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# NOTE:
#   - aws_iam_user_policy_attachment リソースと併用する場合、そのポリシーARNをpolicy_arnsに含めること（ドリフト防止）
#   - 空リストを指定するとユーザーへのマネージドポリシーアタッチを全て禁止できる
#-----------------------------------------------------------------------

resource "aws_iam_user_policy_attachments_exclusive" "example" {

  # -------------------------------------------------------
  # 対象ユーザー設定
  # -------------------------------------------------------

  # 設定内容: 排他的ポリシー管理を適用するIAMユーザー名
  # 設定可能な値: 既存IAMユーザーの名前（文字列）
  # 省略時: 省略不可（必須）
  user_name = aws_iam_user.example.name

  # -------------------------------------------------------
  # ポリシー設定
  # -------------------------------------------------------

  # 設定内容: ユーザーにアタッチするマネージドIAMポリシーのARNリスト
  #           ここに列挙されていないポリシーがユーザーにアタッチされている場合は自動削除される
  #           空リストを指定するとユーザーへのマネージドポリシーアタッチを全て禁止できる
  # 設定可能な値: IAMポリシーARNの集合（例: ["arn:aws:iam::aws:policy/ReadOnlyAccess"]）
  # 省略時: 省略不可（必須）
  policy_arns = [aws_iam_policy.example.arn]

}

#-----------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------
# このリソースで参照可能な属性値は以下の通り。
#
# user_name   - 排他的ポリシー管理が設定されたIAMユーザー名
# policy_arns - ユーザーにアタッチされているマネージドIAMポリシーARNの集合
