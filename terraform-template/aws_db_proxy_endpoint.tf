#---------------------------------------------------------------
# AWS RDS DB Proxy Endpoint
#---------------------------------------------------------------
#
# RDS Proxy のエンドポイントを作成するリソースです。
# DB Proxy エンドポイントを使用すると、RDS Proxy に追加のエンドポイントを
# 作成し、読み取り専用または読み書き可能なトラフィックを分離できます。
#
# RDS Proxy は、アプリケーションとデータベース間の接続プールを管理し、
# データベース接続の効率を向上させます。追加エンドポイントを使用することで、
# 異なる VPC やセキュリティグループからのアクセスを制御できます。
#
# AWS公式ドキュメント:
#   - RDS Proxy エンドポイント: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/rds-proxy-endpoints.html
#   - RDS Proxy 概要: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/rds-proxy.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/db_proxy_endpoint
#
# Provider Version: 6.28.0
# Generated: 2026-01-22
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_db_proxy_endpoint" "example" {
  #-------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------

  # db_proxy_endpoint_name (Required)
  # 設定内容: プロキシエンドポイントの識別子を指定します。
  # 設定可能な値: 英字で始まり、ASCII 英数字とハイフンのみを含む文字列。
  #               末尾にハイフンを使用したり、連続するハイフンを使用することはできません。
  db_proxy_endpoint_name = "my-proxy-endpoint"

  # db_proxy_name (Required)
  # 設定内容: このエンドポイントを関連付ける DB Proxy の名前を指定します。
  # 設定可能な値: 既存の DB Proxy の名前
  db_proxy_name = "my-db-proxy"

  # vpc_subnet_ids (Required)
  # 設定内容: 新しいプロキシに関連付ける VPC サブネット ID を指定します。
  # 設定可能な値: 1 つ以上の VPC サブネット ID のセット
  # 注意: 高可用性のために複数の AZ のサブネットを指定することを推奨します。
  vpc_subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional, Computed)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # ターゲットロール設定
  #-------------------------------------------------------------

  # target_role (Optional)
  # 設定内容: DB プロキシエンドポイントが読み書き操作に使用できるか、
  #           読み取り専用操作にのみ使用できるかを指定します。
  # 設定可能な値:
  #   - "READ_WRITE" (デフォルト): 読み書き両方の操作が可能
  #   - "READ_ONLY": 読み取り専用操作のみ可能
  # 関連機能: 読み取りレプリカへのルーティング
  #   READ_ONLY を指定すると、Aurora の読み取りレプリカにトラフィックを
  #   ルーティングできます。これにより、読み取りワークロードを分散できます。
  target_role = "READ_ONLY"

  #-------------------------------------------------------------
  # セキュリティ設定
  #-------------------------------------------------------------

  # vpc_security_group_ids (Optional, Computed)
  # 設定内容: 新しいプロキシエンドポイントに関連付ける VPC セキュリティグループ ID を指定します。
  # 設定可能な値: 1 つ以上の VPC セキュリティグループ ID のセット
  # 省略時: VPC のデフォルトセキュリティグループが使用されます
  # 注意: セキュリティグループは、プロキシエンドポイントへのアクセスを制御するために使用されます。
  #       データベースへの接続を許可する適切なインバウンドルールを設定してください。
  vpc_security_group_ids = ["sg-xxxxxxxxxxxxxxxxx"]

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWS リソースタグ付け
  #   プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "my-proxy-endpoint"
    Environment = "production"
  }

  # tags_all (Optional, Computed)
  # 設定内容: プロバイダーの default_tags から継承されたタグを含む全タグのマップです。
  # 注意: 通常は明示的に設定せず、Terraform が自動計算します。
  # tags_all = {}

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト値を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: 作成操作のタイムアウトを指定します。
    # 設定可能な値: "30m" などの duration 文字列
    # 省略時: デフォルトのタイムアウト値が使用されます
    create = "30m"

    # update (Optional)
    # 設定内容: 更新操作のタイムアウトを指定します。
    # 設定可能な値: "30m" などの duration 文字列
    # 省略時: デフォルトのタイムアウト値が使用されます
    update = "30m"

    # delete (Optional)
    # 設定内容: 削除操作のタイムアウトを指定します。
    # 設定可能な値: "60m" などの duration 文字列
    # 省略時: デフォルトのタイムアウト値が使用されます
    delete = "60m"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: プロキシエンドポイントの Amazon Resource Name (ARN)
#
# - endpoint: プロキシに接続するために使用できるエンドポイント。
#             データベースクライアントアプリケーションの接続文字列に
#             このエンドポイント値を含めます。
#
# - id: プロキシ名とプロキシエンドポイント名を "/" で区切った値
#       （形式: DB-PROXY-NAME/DB-PROXY-ENDPOINT-NAME）
#
# - is_default: このエンドポイントが関連付けられた DB Proxy の
#               デフォルトエンドポイントであるかどうかを示します。
#
# - vpc_id: DB プロキシエンドポイントの VPC ID
#---------------------------------------------------------------
