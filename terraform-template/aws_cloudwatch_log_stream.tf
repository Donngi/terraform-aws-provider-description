#######################################################################
# AWS CloudWatch Log Stream
#######################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-12
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/cloudwatch_log_stream
#
# NOTE: AWS CloudWatch Logs のロググループ内に作成されるログストリームを管理
# - ログイベントの保存先となるストリームを定義
# - アプリケーションインスタンスやタスクごとにストリームを分離可能
# - ロググループ内で一意の名前を持つ必要がある

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_cloudwatch_log_stream" "example" {
  # 設定内容: このログストリームが属するロググループの名前
  # 設定可能な値: 既存の CloudWatch Logs ロググループ名
  # 省略時: 必須項目のため指定が必要
  log_group_name = "example-log-group"

  # 設定内容: ログストリームの名前
  # 設定可能な値:
  #   - 1〜512文字の文字列
  #   - 英数字、ハイフン、アンダースコア、ピリオド、スラッシュ、コロン、アスタリスクが使用可能
  #   - ロググループ内で一意である必要がある
  # 省略時: 必須項目のため指定が必要
  name = "example-stream"
}

#-----------------------------------------------------------------------
# 地域設定
#-----------------------------------------------------------------------

resource "aws_cloudwatch_log_stream" "regional" {
  log_group_name = "example-log-group"
  name           = "regional-stream"

  # 設定内容: このリソースを管理する AWS リージョン
  # 設定可能な値: AWS リージョンコード (例: us-east-1, ap-northeast-1)
  # 省略時: プロバイダーの設定リージョンを使用
  region = "ap-northeast-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# arn - ログストリームの ARN
# id - ログストリームの識別子 (log_group_name:name の形式)
