#---------------------------------------------------------------
# AWS App Mesh Service Mesh
#---------------------------------------------------------------
#
# AWS App Meshのサービスメッシュをプロビジョニングするリソースです。
# サービスメッシュは、メッシュ内のサービス間のネットワークトラフィックの
# 論理的な境界を定義します。メッシュを作成後、仮想サービス、仮想ノード、
# 仮想ルーター、ルートを作成してアプリケーション間のトラフィックを
# 分散させることができます。
#
# 重要: AWS App Meshは2026年9月30日にサポート終了予定です。
# 新規プロジェクトではAmazon ECS Service Connectへの移行を検討してください。
#
# AWS公式ドキュメント:
#   - App Mesh概要: https://docs.aws.amazon.com/app-mesh/latest/userguide/what-is-app-mesh.html
#   - サービスメッシュ: https://docs.aws.amazon.com/app-mesh/latest/userguide/meshes.html
#   - App Meshの概念: https://docs.aws.amazon.com/app-mesh/latest/userguide/concepts.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/appmesh_mesh
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_appmesh_mesh" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required, Forces new resource)
  # 設定内容: サービスメッシュの名前を指定します。
  # 設定可能な値: 1〜255文字の文字列
  # 注意: メッシュ名はAWSアカウント内で一意である必要があります。
  name = "example-mesh"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # メッシュ仕様設定
  #-------------------------------------------------------------

  # spec (Optional)
  # 設定内容: サービスメッシュの仕様を定義するブロックです。
  # 省略時: デフォルト設定が適用されます。
  spec {
    #-----------------------------------------------------------
    # エグレスフィルター設定
    #-----------------------------------------------------------

    # egress_filter (Optional)
    # 設定内容: メッシュからの送信トラフィック（エグレス）のフィルタリングルールを定義します。
    # 関連機能: App Mesh エグレスフィルター
    #   メッシュ内のプロキシが外部サービスへのトラフィックをどのように処理するかを制御します。
    egress_filter {
      # type (Optional)
      # 設定内容: エグレスフィルターのタイプを指定します。
      # 設定可能な値:
      #   - "DROP_ALL" (デフォルト): メッシュ内のプロキシ間のトラフィックのみを許可。
      #                              外部サービスへのトラフィックはドロップされます。
      #   - "ALLOW_ALL": 外部サービスへのTCPトラフィックも転送を許可。
      #                  メッシュ内で定義されていないサービスへのトラフィックを許可します。
      # 注意: ALLOW_ALLを使用する場合、仮想ノードでバックエンドを指定すると、
      #       その仮想ノードのすべてのエグレスをバックエンドとして指定する必要があります。
      type = "DROP_ALL"
    }

    #-----------------------------------------------------------
    # サービスディスカバリ設定
    #-----------------------------------------------------------

    # service_discovery (Optional)
    # 設定内容: メッシュ内のサービスディスカバリのIP設定を定義します。
    # 関連機能: App Mesh サービスディスカバリ
    #   メッシュ内のトラフィックで使用するIPバージョンを制御します。
    service_discovery {
      # ip_preference (Optional)
      # 設定内容: メッシュ内のトラフィック制御に使用するIPバージョンの優先設定を指定します。
      # 設定可能な値:
      #   - "IPv6_PREFERRED": IPv6を優先し、利用不可の場合はIPv4にフォールバック。
      #                       Envoyリスナーはすべてのipv4およびIPv6アドレスにバインド。
      #   - "IPv4_PREFERRED": IPv4を優先し、利用不可の場合はIPv6にフォールバック。
      #                       Envoyリスナーはすべてのipv4およびIPv6アドレスにバインド。
      #   - "IPv4_ONLY": IPv4アドレスのみを使用。AWS Cloud MapがIPv6を返した場合は無視。
      #                  Envoyリスナーはすべてのipv4およびIPv6アドレスにバインド。
      #   - "IPv6_ONLY": IPv6アドレスのみを使用。AWS Cloud MapがIPv4を返した場合は無視。
      #                  Envoyリスナーはすべてのipv4およびIPv6アドレスにバインド。
      # 省略時: デフォルト動作（DNSはIPv6優先でIPv4フォールバック、
      #         ローカルアプリエンドポイントはIPv4、リスナーはIPv4のみにバインド）
      # 注意: この設定は仮想ノードで個別にオーバーライド可能ですが、
      #       仮想ゲートウェイではオーバーライドできません。
      ip_preference = "IPv4_PREFERRED"
    }
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-mesh"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: サービスメッシュのID
#
# - arn: サービスメッシュのAmazon Resource Name (ARN)
#
# - created_date: サービスメッシュの作成日時
#
# - last_updated_date: サービスメッシュの最終更新日時
#
# - mesh_owner: サービスメッシュのオーナーのAWSアカウントID
#
# - resource_owner: リソースオーナーのAWSアカウントID
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
