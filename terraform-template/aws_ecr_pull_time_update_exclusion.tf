#-----------------------------------------------------------------------
# Amazon ECR Pull Time Update Exclusion
#-----------------------------------------------------------------------
# ECRイメージプル時間更新の除外設定を管理するリソース
# 特定のIAMプリンシパル（ロールまたはユーザー）によるイメージプルを
# LastRecordedPullTimeタイムスタンプの更新から除外します
#
# 主な用途:
# - CI/CDパイプラインからのプル時刻記録を除外
# - テスト環境でのプル時刻更新を防止
# - ライフサイクルポリシーの判定に影響を与えないプルの除外
#
# 制限事項:
# - アカウントごとに最大100個の除外設定が可能
# - principal_arn の変更は強制的な再作成となります
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ecr_pull_time_update_exclusion
# AWS Documentation: https://docs.aws.amazon.com/AmazonECR/latest/userguide/pull-time-update-exclusions.html
# Generated: 2026-02-17
#
# NOTE: このテンプレートは参考実装です。実際の利用には環境に応じた調整が必要です。
#-----------------------------------------------------------------------

#----------------------------------------------------------------------
# プル時間更新除外設定
#----------------------------------------------------------------------
resource "aws_ecr_pull_time_update_exclusion" "example" {
  #--------------------------------------------------------------------
  # 必須パラメータ
  #--------------------------------------------------------------------

  # 設定内容: ECRイメージプル時間の記録から除外するIAMプリンシパルのARN
  # 設定可能な値: 有効なIAMロールまたはIAMユーザーのARN
  #              （例: arn:aws:iam::123456789012:role/ci-cd-role）
  # 注意事項: この値を変更すると、リソースが強制的に再作成されます
  principal_arn = "arn:aws:iam::123456789012:role/ci-cd-role"

  #--------------------------------------------------------------------
  # オプションパラメータ
  #--------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用されます
  # 用途: マルチリージョン構成でリージョンごとに除外設定を管理する場合に指定
  region = "us-east-1"

  #--------------------------------------------------------------------
  # タグ設定
  #--------------------------------------------------------------------
  # 注意: このリソースはタグをサポートしていません
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - principal_arn - 除外設定されたIAMプリンシパルのARN
# - region - リソースが管理されているAWSリージョン
#-----------------------------------------------------------------------
