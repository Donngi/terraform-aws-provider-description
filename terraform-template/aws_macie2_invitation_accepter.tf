################################################################################
# AWS Macie2 Invitation Accepter
################################################################################
# リソース概要:
# Amazon Macie の招待を受け入れ、メンバーアカウントとして組織に参加するためのリソース
#
# 主な用途:
# - Macie 管理者アカウントからの招待を受け入れる
# - 招待ベースの Macie 組織に参加する
# - マルチアカウント環境での Macie 設定の統合管理を実現
#
# 重要な考慮事項:
# - Macie はリージョナルサービスなので、各リージョンで個別に設定が必要
# - アカウントは同時に複数の管理者アカウントに関連付けることはできない
# - 招待を受け入れる前に、該当リージョンで Macie を有効化する必要がある
# - AWS Organizations を使用する方法が推奨されている（招待ベースよりも）
#
# ドキュメント:
# - API: https://docs.aws.amazon.com/macie/latest/APIReference/invitations-accept.html
# - User Guide: https://docs.aws.amazon.com/macie/latest/user/accounts-mgmt-invitations-administer.html
#
# Provider Version: 6.28.0
################################################################################

resource "aws_macie2_invitation_accepter" "example" {
  #==============================================================================
  # 必須パラメータ (Required Parameters)
  #==============================================================================

  # administrator_account_id - 管理者アカウント ID (必須)
  # 説明:
  # - 招待を送信した Macie 管理者アカウントの AWS アカウント ID
  # - この管理者アカウントに関連付けられたメンバーアカウントとして参加する
  # - 招待を受け取った際に確認できる管理者アカウント ID を指定
  #
  # 重要なポイント:
  # - 12桁の AWS アカウント ID を文字列形式で指定
  # - 招待を送信したアカウントと一致する必要がある
  # - このアカウントは事前に Macie 管理者として設定されている必要がある
  #
  # 制約:
  # - 有効な AWS アカウント ID である必要がある
  # - 招待を実際に送信したアカウント ID と一致する必要がある
  #
  # 使用例:
  # - "123456789012" - 管理者アカウントの ID
  administrator_account_id = "123456789012"

  #==============================================================================
  # オプションパラメータ (Optional Parameters)
  #==============================================================================

  # id - リソース識別子 (オプション・計算済み)
  # 説明:
  # - Terraform によって管理されるリソースの一意の識別子
  # - 通常は自動的に生成されるため、明示的に指定する必要はない
  # - 主に Terraform の状態管理とリソース参照に使用される
  #
  # 重要なポイント:
  # - computed 属性なので、通常は省略される
  # - 他のリソースからこのリソースを参照する際に使用可能
  # - 明示的に指定することも可能だが、一般的ではない
  #
  # 使用例:
  # id = "macie-invitation-acceptance"  # 通常は省略

  # region - リージョン指定 (オプション・計算済み)
  # 説明:
  # - このリソースが管理されるリージョンを明示的に指定
  # - 指定しない場合はプロバイダー設定のリージョンが使用される
  # - Macie はリージョナルサービスのため、各リージョンで個別の設定が必要
  #
  # 重要なポイント:
  # - 招待が送信されたリージョンと同じリージョンで受け入れる必要がある
  # - マルチリージョン構成の場合、各リージョンで個別のリソースが必要
  # - プロバイダーのデフォルトリージョンと異なる場合に指定
  #
  # 制約:
  # - 有効な AWS リージョンコードである必要がある
  # - Macie がサポートされているリージョンである必要がある
  #
  # 使用例:
  # region = "us-east-1"      # 米国東部（バージニア北部）
  # region = "ap-northeast-1" # アジアパシフィック（東京）
  # region = "eu-west-1"      # 欧州（アイルランド）

  #==============================================================================
  # 計算済み属性 (Computed Attributes)
  #==============================================================================

  # invitation_id - 招待 ID (計算済み)
  # 説明:
  # - 受け入れた招待の一意の識別子
  # - 招待が受け入れられた後に自動的に設定される
  # - API リクエストや監査ログでの追跡に使用可能
  #
  # 重要なポイント:
  # - 読み取り専用属性で、設定することはできない
  # - 招待の受け入れ後に参照可能になる
  # - 他のリソースやデータソースで参照可能
  #
  # 使用例（参照）:
  # output "invitation_id" {
  #   value = aws_macie2_invitation_accepter.example.invitation_id
  # }

  #==============================================================================
  # タイムアウト設定 (Timeouts)
  #==============================================================================

  # timeouts - タイムアウト設定
  # 説明:
  # - リソース作成時のタイムアウト期間を設定
  # - 招待の受け入れ処理に時間がかかる場合に調整可能
  #
  # 使用例:
  # timeouts {
  #   create = "60m"  # 作成タイムアウト: 60分
  # }
}

################################################################################
# 実装例 (Implementation Examples)
################################################################################

# 例1: 基本的な招待の受け入れ
# 最小限の設定で管理者アカウントからの招待を受け入れる
resource "aws_macie2_invitation_accepter" "basic" {
  administrator_account_id = "123456789012"
}

# 例2: 特定リージョンでの招待受け入れ
# 明示的にリージョンを指定して招待を受け入れる
resource "aws_macie2_invitation_accepter" "specific_region" {
  administrator_account_id = "123456789012"
  region                   = "us-west-2"

  timeouts {
    create = "30m"
  }
}

# 例3: マルチリージョン構成
# 複数のリージョンで同じ管理者アカウントの招待を受け入れる
resource "aws_macie2_invitation_accepter" "us_east_1" {
  administrator_account_id = "123456789012"
  region                   = "us-east-1"
}

resource "aws_macie2_invitation_accepter" "us_west_2" {
  administrator_account_id = "123456789012"
  region                   = "us-west-2"
}

resource "aws_macie2_invitation_accepter" "ap_northeast_1" {
  administrator_account_id = "123456789012"
  region                   = "ap-northeast-1"
}

# 例4: 招待 ID の出力
# 受け入れた招待の ID を出力して追跡する
resource "aws_macie2_invitation_accepter" "tracked" {
  administrator_account_id = "123456789012"
}

output "macie_invitation_id" {
  description = "Accepted Macie invitation ID"
  value       = aws_macie2_invitation_accepter.tracked.invitation_id
}

# 例5: 他のリソースとの連携
# Macie アカウントの設定と招待受け入れを組み合わせる
resource "aws_macie2_account" "member" {
  finding_publishing_frequency = "FIFTEEN_MINUTES"
  status                       = "ENABLED"
}

resource "aws_macie2_invitation_accepter" "with_account" {
  administrator_account_id = "123456789012"

  # Macie アカウントが有効化されてから招待を受け入れる
  depends_on = [aws_macie2_account.member]
}

################################################################################
# ベストプラクティス (Best Practices)
################################################################################

# 1. 招待の事前確認
#    - 招待を受け入れる前に、管理者アカウントと招待内容を確認する
#    - 誤った管理者アカウントに関連付けないよう注意する

# 2. Macie の有効化
#    - 招待を受け入れる前に、該当リージョンで Macie を有効化する
#    - aws_macie2_account リソースを使用して事前設定を行う

# 3. リージョナルサービスとしての考慮
#    - 各リージョンで個別に招待の受け入れが必要
#    - マルチリージョン構成では、各リージョンでリソースを作成する
#    - region パラメータを明示的に指定することを推奨

# 4. 依存関係の管理
#    - depends_on を使用して、Macie アカウントの有効化が完了してから
#      招待を受け入れるようにする
#    - 適切な順序でリソースを作成することで、エラーを防ぐ

# 5. タイムアウトの調整
#    - ネットワーク遅延や API 制限により処理に時間がかかる場合は
#      タイムアウト設定を調整する

# 6. 組織の移行計画
#    - 可能であれば、招待ベースではなく AWS Organizations を使用する
#    - 既存の招待ベースの組織から AWS Organizations への移行を計画する

# 7. 監査とコンプライアンス
#    - 招待 ID を記録して、監査証跡を維持する
#    - 誰がいつどの管理者アカウントの招待を受け入れたかを追跡する

################################################################################
# 関連リソース (Related Resources)
################################################################################

# aws_macie2_account
# - Macie アカウントの有効化と設定を管理
# - 招待を受け入れる前に設定が必要

# aws_macie2_member
# - 管理者アカウント側で使用するリソース
# - メンバーアカウントを追加し、招待を送信する

# aws_organizations_organization
# - AWS Organizations を使用した統合管理
# - 招待ベースの代わりに推奨される方法

################################################################################
# 注意事項 (Important Notes)
################################################################################

# 1. リージョナルサービス
#    - Macie の設定はリージョンごとに独立している
#    - 管理者とメンバーの関連付けもリージョンごとに行う

# 2. 単一管理者の制限
#    - 各リージョンで1つの管理者アカウントにのみ関連付け可能
#    - 既存の関連付けを解除してから新しい招待を受け入れる必要がある

# 3. 招待の有効期限
#    - 招待には有効期限がある場合があるため、迅速に対応する
#    - 期限切れの招待は受け入れられない

# 4. コストへの影響
#    - Macie は使用量に基づいて課金される
#    - メンバーアカウントとして参加すると、管理者アカウントが
#      一部の設定を管理できるようになる

# 5. セキュリティとアクセス許可
#    - 招待を受け入れると、管理者アカウントが S3 インベントリデータと
#      ポリシー検出結果にアクセスできるようになる
#    - 機密データの取り扱いに注意する

# 6. 削除と関連付け解除
#    - このリソースを削除しても、自動的に関連付けが解除されるわけではない
#    - 明示的に関連付けを解除する必要がある場合がある
