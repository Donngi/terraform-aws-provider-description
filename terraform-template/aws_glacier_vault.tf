#######################################################################
# Amazon S3 Glacier Vault
#######################################################################
# Amazon S3 Glacierのボールト（保管庫）を作成・管理するリソース。
# アーカイブデータの長期保存、バックアップ、コンプライアンス目的に
# 利用される低コストのストレージサービス。
#
# 主な用途:
# - 長期アーカイブデータの保存
# - コンプライアンス要件に基づくデータ保持
# - バックアップデータの低コスト保管
# - 災害復旧用データのオフサイト保管
#
# 参考: https://docs.aws.amazon.com/amazonglacier/latest/dev/introduction.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/glacier_vault
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_glacier_vault" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # ボールト名
  # 設定内容: Glacierボールトの名前
  # 設定可能な値: 英数字、ハイフン、アンダースコアを含む1〜255文字
  # 注意: 同一リージョン・アカウント内で一意である必要がある
  name = "example-glacier-vault"

  #-----------------------------------------------------------------------
  # アクセスポリシーの設定
  #-----------------------------------------------------------------------

  # ボールトアクセスポリシー
  # 設定内容: ボールトへのアクセスを制御するIAMポリシーJSON
  # 用途: クロスアカウントアクセスや特定操作の許可・拒否
  # 省略時: アクセスポリシーなし（IAMユーザー権限のみで制御）
  access_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect    = "Allow"
        Principal = { AWS = "arn:aws:iam::123456789012:root" }
        Action    = "glacier:InitiateJob"
        Resource  = "*"
      }
    ]
  })

  #-----------------------------------------------------------------------
  # 通知設定
  #-----------------------------------------------------------------------

  # ジョブ完了通知の設定
  # 設定内容: Glacierジョブ完了時にSNSトピックへ通知を送信する設定
  # 省略時: 通知なし
  notification {
    # SNSトピックARN
    # 設定内容: 通知を送信するSNSトピックのARN
    sns_topic = aws_sns_topic.example.arn

    # 通知対象イベント
    # 設定内容: 通知を送信するGlacierジョブイベントの種類
    # 設定可能な値:
    #   - ArchiveRetrievalCompleted: アーカイブ取得ジョブ完了時
    #   - InventoryRetrievalCompleted: インベントリ取得ジョブ完了時
    events = [
      "ArchiveRetrievalCompleted",
      "InventoryRetrievalCompleted",
    ]
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: Glacierボールトを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # リソースタグ
  # 設定内容: ボールトに付与するタグ（キー・バリューペア）
  # 用途: リソース管理、コスト配分、アクセス制御
  # 注意: プロバイダーのdefault_tagsと重複するキーは上書きされる
  tags = {
    Name        = "example-glacier-vault"
    Environment = "production"
    Purpose     = "long-term-archive"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   ボールトの名前（name属性と同じ値）
#
# - arn
#   ボールトのARN（Amazon Resource Name）
#
# - location
#   ボールトのURIパス
#
# - tags_all
#   リソースに割り当てられたすべてのタグ
#   （プロバイダーのdefault_tagsから継承されたタグを含む）
#-----------------------------------------------------------------------
