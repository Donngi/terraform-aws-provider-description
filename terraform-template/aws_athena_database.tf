#---------------------------------------------------------------
# AWS Athena Database
#---------------------------------------------------------------
#
# Amazon Athenaのデータベースをプロビジョニングするリソースです。
# Athenaのデータベースは、テーブルの論理的なグループであり、
# 同じ設定を共有するテーブルを整理するために使用されます。
#
# AWS公式ドキュメント:
#   - Athena概要: https://docs.aws.amazon.com/athena/latest/ug/what-is.html
#   - データベースの作成: https://docs.aws.amazon.com/athena/latest/ug/creating-databases.html
#   - 暗号化設定: https://docs.aws.amazon.com/athena/latest/ug/encryption.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/athena_database
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_athena_database" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: 作成するデータベースの名前を指定します。
  # 設定可能な値: 文字列（Athenaの命名規則に従う）
  # 注意: データベース名はAWS Glue Data Catalogに登録されます。
  name = "example_database"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # ストレージ設定
  #-------------------------------------------------------------

  # bucket (Optional)
  # 設定内容: クエリ実行結果を保存するS3バケット名を指定します。
  # 設定可能な値: 有効なS3バケット名
  # 注意: Athenaクエリ実行時、結果ファイルが指定したバケットに作成される場合があります。
  #       バケット削除時の問題を避けるため、バケット側でforce_destroyの使用を検討してください。
  bucket = "example-athena-results-bucket"

  # expected_bucket_owner (Optional)
  # 設定内容: S3バケットの所有者として期待するAWSアカウントIDを指定します。
  # 設定可能な値: 12桁のAWSアカウントID
  # 用途: バケットの所有権を検証し、意図しないバケットへのアクセスを防止します。
  expected_bucket_owner = null

  #-------------------------------------------------------------
  # ワークグループ設定
  #-------------------------------------------------------------

  # workgroup (Optional)
  # 設定内容: このデータベースに関連付けるワークグループ名を指定します。
  # 設定可能な値: 有効なAthenaワークグループ名
  # 用途: ワークグループごとにクエリ設定やコスト管理を分離できます。
  workgroup = null

  #-------------------------------------------------------------
  # メタデータ設定
  #-------------------------------------------------------------

  # comment (Optional)
  # 設定内容: データベースの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 用途: データベースの用途や内容を記録します。
  comment = "Example Athena database for query execution"

  # properties (Optional)
  # 設定内容: データベース定義のカスタムメタデータプロパティを指定します。
  # 設定可能な値: キーと値のペアのマップ（文字列のマップ）
  # 用途: データベースに追加のメタデータを設定します。
  properties = {
    "creator" = "terraform"
  }

  #-------------------------------------------------------------
  # 削除設定
  #-------------------------------------------------------------

  # force_destroy (Optional)
  # 設定内容: データベース削除時にすべてのテーブルを強制削除するかを指定します。
  # 設定可能な値:
  #   - true: データベース内のすべてのテーブルを削除し、エラーなくデータベースを削除可能にします
  #   - false (デフォルト): テーブルが存在する場合、データベース削除はエラーになります
  # 注意: 削除されたテーブルは復旧できません。本番環境では慎重に設定してください。
  force_destroy = false

  #-------------------------------------------------------------
  # ACL設定
  #-------------------------------------------------------------

  # acl_configuration (Optional)
  # 設定内容: クエリ結果の所有権を制御するS3 Canned ACLを設定します。
  # 用途: クエリ結果のストレージにおける所有権制御を行います。
  acl_configuration {
    # s3_acl_option (Required)
    # 設定内容: Athenaがクエリ結果を保存する際に指定するS3 Canned ACLを指定します。
    # 設定可能な値:
    #   - "BUCKET_OWNER_FULL_CONTROL": バケット所有者がフルコントロールを持ちます
    # 用途: クロスアカウントでのクエリ結果アクセス制御に使用します。
    s3_acl_option = "BUCKET_OWNER_FULL_CONTROL"
  }

  #-------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------

  # encryption_configuration (Optional)
  # 設定内容: S3内のデータを復号するためにAthenaが使用する暗号化設定を指定します。
  # 関連機能: Athena暗号化
  #   SSE-S3、SSE-KMS、CSE-KMSの3つの暗号化オプションをサポート。
  #   - https://docs.aws.amazon.com/athena/latest/ug/encryption.html
  encryption_configuration {
    # encryption_option (Required)
    # 設定内容: 暗号化のタイプを指定します。
    # 設定可能な値:
    #   - "SSE_S3": S3管理キーによるサーバーサイド暗号化
    #   - "SSE_KMS": AWS KMS管理キーによるサーバーサイド暗号化
    #   - "CSE_KMS": AWS KMS管理キーによるクライアントサイド暗号化
    # 推奨: より高い制御とシンプルさのため、SSE_KMSの使用を推奨します。
    encryption_option = "SSE_KMS"

    # kms_key (Optional)
    # 設定内容: 暗号化に使用するKMSキーのARNまたはIDを指定します。
    # 設定可能な値: 有効なKMSキーARNまたはID
    # 注意: encryption_optionが"SSE_KMS"または"CSE_KMS"の場合に必須です。
    #       "SSE_S3"を使用する場合は指定不要です。
    kms_key = "arn:aws:kms:ap-northeast-1:123456789012:key/12345678-1234-1234-1234-123456789012"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: データベース名
#---------------------------------------------------------------
