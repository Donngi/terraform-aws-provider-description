# NOTE:
# AWS CodeCatalystプロジェクトを作成・管理します
# CodeCatalystは、ソフトウェア開発チーム向けの統合開発環境サービスです
#
# 主な用途:
# - CodeCatalystスペース内でのプロジェクト作成と管理
# - 開発チームのコラボレーションスペースの構築
# - ソースコード管理、CI/CD、イシュー管理の統合環境
#
# 制約事項:
# - プロジェクトは既存のCodeCatalystスペース内に作成する必要があります
# - スペース名は変更できません（変更すると新規リソースが作成されます）
# - プロジェクト名はシステムにより自動生成されます
#
#---------------------------------------
# リソース定義
#---------------------------------------

resource "aws_codecatalyst_project" "example" {
  #---------------------------------------
  # 必須パラメータ
  #---------------------------------------
  # 設定内容: プロジェクトの表示名
  # 設定可能な値: 任意の文字列（1〜128文字）
  display_name = "MyCodeCatalystProject"

  # 設定内容: プロジェクトが属するスペース名
  # 設定可能な値: 既存のCodeCatalystスペース名
  space_name = "my-space"

  #---------------------------------------
  # オプションパラメータ - プロジェクト情報
  #---------------------------------------
  # 設定内容: プロジェクトの説明
  # 設定可能な値: 任意の文字列（最大256文字）
  # 省略時: 説明なし
  description = "My CodeCatalyst project for development"

  #---------------------------------------
  # オプションパラメータ - リージョン設定
  #---------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: us-west-2, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョン
  region = "us-west-2"

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------
  # timeouts {
  #   # 設定内容: プロジェクト作成のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: 30m
  #   create = "30m"
  #
  #   # 設定内容: プロジェクト更新のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: 30m
  #   update = "30m"
  #
  #   # 設定内容: プロジェクト削除のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: 30m
  #   delete = "30m"
  # }
}

