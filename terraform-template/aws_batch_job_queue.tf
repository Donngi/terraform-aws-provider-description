#---------------------------------------------------------------
# AWS Batch Job Queue
#---------------------------------------------------------------
#
# AWS Batchのジョブキューをプロビジョニングするリソースです。
# ジョブキューは、送信されたバッチジョブを管理・優先順位付けするために使用されます。
# ジョブキューには1つ以上のコンピューティング環境を関連付け、
# ジョブスケジューラがどの環境でジョブを実行するかを決定します。
#
# AWS公式ドキュメント:
#   - AWS Batch ジョブキュー: https://docs.aws.amazon.com/batch/latest/userguide/job_queues.html
#   - CreateJobQueue API: https://docs.aws.amazon.com/batch/latest/APIReference/API_CreateJobQueue.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/batch_job_queue
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_batch_job_queue" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: ジョブキューの名前を指定します。
  # 設定可能な値: 最大128文字。大文字・小文字のアルファベット、数字、
  #               ハイフン(-)、アンダースコア(_)が使用可能
  name = "example-job-queue"

  # state (Required)
  # 設定内容: ジョブキューの状態を指定します。
  # 設定可能な値:
  #   - "ENABLED": ジョブを受け付ける状態。ジョブスケジューラがジョブを評価・実行
  #   - "DISABLED": 新しいジョブをキューに追加できない状態。既存のジョブは完了まで実行
  state = "ENABLED"

  # priority (Required)
  # 設定内容: ジョブキューの優先度を指定します。
  # 設定可能な値: 整数値。値が大きいほど優先度が高い
  # 動作: 同じコンピューティング環境に関連付けられている場合、優先度の高いジョブキューが
  #       先にスケジューリング対象として評価されます。
  # 例: 優先度10のキューは優先度1のキューより先にスケジューリングされる
  priority = 1

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # スケジューリングポリシー設定
  #-------------------------------------------------------------

  # scheduling_policy_arn (Optional)
  # 設定内容: フェアシェアスケジューリングポリシーのARNを指定します。
  # 設定可能な値: 有効なスケジューリングポリシーARN
  #   形式: aws:Partition:batch:Region:Account:scheduling-policy/Name
  # 省略時: FIFO（先入れ先出し）スケジューリングを使用
  # 関連機能: AWS Batch フェアシェアスケジューリング
  #   複数のシェア識別子間でコンピューティングリソースを公平に分配する機能。
  #   一度設定すると、置き換えは可能だが削除はできません。
  #   最大500のアクティブなシェア識別子をサポート。
  #   - https://docs.aws.amazon.com/batch/latest/userguide/create-scheduling-policy.html
  scheduling_policy_arn = null

  #-------------------------------------------------------------
  # コンピューティング環境設定
  #-------------------------------------------------------------

  # compute_environment_order (Optional)
  # 設定内容: ジョブキューにマッピングするコンピューティング環境とその順序を指定します。
  # 制約:
  #   - 最大3つのコンピューティング環境を関連付け可能
  #   - コンピューティング環境はVALID状態である必要があります
  #   - すべてのコンピューティング環境はEC2系(EC2/SPOT)またはFargate系(FARGATE/FARGATE_SPOT)で
  #     統一する必要があります。EC2とFargateを混在させることはできません
  #   - すべてのコンピューティング環境は同じアーキテクチャを共有する必要があります
  # 動作: ジョブスケジューラは順序が低い（order値が小さい）コンピューティング環境から
  #       ジョブの配置を試み、リソースが不足している場合は次の環境に移ります
  compute_environment_order {
    # order (Required)
    # 設定内容: コンピューティング環境の優先順序を指定します。
    # 設定可能な値: 整数値。値が小さいほど優先度が高い
    # 動作: order=1の環境が最初にジョブ配置の対象となる
    order = 1

    # compute_environment (Required)
    # 設定内容: コンピューティング環境のARNを指定します。
    # 設定可能な値: 有効なコンピューティング環境ARN
    compute_environment = "arn:aws:batch:ap-northeast-1:123456789012:compute-environment/example-compute-env"
  }

  #-------------------------------------------------------------
  # ジョブ状態タイムリミットアクション設定
  #-------------------------------------------------------------

  # job_state_time_limit_action (Optional)
  # 設定内容: ジョブが指定された状態で一定時間以上キューの先頭に留まった場合に
  #           AWS Batchが実行するアクションを定義します。
  # 用途: 長時間実行されないジョブを自動的にキャンセルしてリソースを解放する場合に使用
  job_state_time_limit_action {
    # action (Required)
    # 設定内容: 実行するアクションを指定します。
    # 設定可能な値:
    #   - "CANCEL": ジョブをキャンセルする
    action = "CANCEL"

    # max_time_seconds (Required)
    # 設定内容: アクションが実行されるまでの概算時間（秒）を指定します。
    # 設定可能な値: 600〜86400の整数（10分〜24時間）
    max_time_seconds = 3600

    # reason (Required)
    # 設定内容: アクション実行時にログに記録する理由を指定します。
    # 設定可能な値: 任意の文字列
    reason = "Job exceeded time limit in RUNNABLE state"

    # state (Required)
    # 設定内容: アクションをトリガーするジョブの状態を指定します。
    # 設定可能な値:
    #   - "RUNNABLE": ジョブがRUNNABLE状態の場合にアクションを実行
    state = "RUNNABLE"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: リソース作成のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "2h45m" などの時間文字列（s=秒, m=分, h=時間）
    create = "10m"

    # update (Optional)
    # 設定内容: リソース更新のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "2h45m" などの時間文字列（s=秒, m=分, h=時間）
    update = "10m"

    # delete (Optional)
    # 設定内容: リソース削除のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "2h45m" などの時間文字列（s=秒, m=分, h=時間）
    delete = "10m"
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 制約: 最大50個のタグ。キーは最大128文字、値は最大256文字
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  #   - https://docs.aws.amazon.com/batch/latest/userguide/using-tags.html
  tags = {
    Name        = "example-job-queue"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: ジョブキューのAmazon Resource Name (ARN)
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
