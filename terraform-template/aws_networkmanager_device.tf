#---------------------------------------------------------------
# AWS Network Manager Device
#---------------------------------------------------------------
#
# AWS Network Manager のグローバルネットワーク内にデバイスをプロビジョニングするリソースです。
# デバイスはルーター、スイッチ、ファイアウォールなどの物理的または仮想的な
# ネットワーク機器を表します。デバイスはサイトに関連付けて物理的なロケーションを
# 示したり、他のデバイスとの接続を確立するために使用されます。
#
# AWS公式ドキュメント:
#   - Network Manager デバイスの管理: https://docs.aws.amazon.com/network-manager/latest/tgwnm/managing-devices.html
#   - グローバルネットワークの概要: https://docs.aws.amazon.com/network-manager/latest/tgwnm/what-are-global-networks.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/networkmanager_device
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_networkmanager_device" "example" {
  #-------------------------------------------------------------
  # グローバルネットワーク設定
  #-------------------------------------------------------------

  # global_network_id (Required)
  # 設定内容: デバイスが所属するグローバルネットワークのIDを指定します。
  # 設定可能な値: 有効なグローバルネットワークID文字列
  global_network_id = "network-1234567890abcdef0"

  #-------------------------------------------------------------
  # デバイス情報設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: デバイスの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なしで作成されます。
  description = "デバイスの説明"

  # model (Optional)
  # 設定内容: デバイスのモデル名を指定します。
  # 設定可能な値: 任意の文字列（例: "ISR4431", "Catalyst 9300"）
  # 省略時: モデル情報なしで作成されます。
  model = "ISR4431"

  # serial_number (Optional)
  # 設定内容: デバイスのシリアル番号を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: シリアル番号なしで作成されます。
  serial_number = "FTX1234ABCD"

  # type (Optional)
  # 設定内容: デバイスの種類を指定します。
  # 設定可能な値: 任意の文字列（例: "router", "switch", "firewall"）
  # 省略時: デバイスタイプなしで作成されます。
  type = "router"

  # vendor (Optional)
  # 設定内容: デバイスのベンダー名を指定します。
  # 設定可能な値: 任意の文字列（例: "Cisco", "Juniper", "Palo Alto"）
  # 省略時: ベンダー情報なしで作成されます。
  vendor = "Cisco"

  #-------------------------------------------------------------
  # サイト設定
  #-------------------------------------------------------------

  # site_id (Optional)
  # 設定内容: デバイスが設置されているサイトのIDを指定します。
  # 設定可能な値: 有効なサイトID文字列（同一グローバルネットワーク内のサイト）
  # 省略時: デバイスはいずれのサイトにも関連付けられません。
  site_id = "site-1234567890abcdef0"

  #-------------------------------------------------------------
  # 物理ロケーション設定
  #-------------------------------------------------------------

  # location (Optional)
  # 設定内容: デバイスの物理的な地理的ロケーション情報を設定します。
  # 省略時: ロケーション情報なしで作成されます。
  location {
    # address (Optional)
    # 設定内容: デバイスの物理的な住所を指定します。
    # 設定可能な値: 任意の住所文字列
    # 省略時: 住所情報なしで設定されます。
    address = "1-1-1 Marunouchi, Chiyoda-ku, Tokyo, Japan"

    # latitude (Optional)
    # 設定内容: デバイス設置場所の緯度を文字列で指定します。
    # 設定可能な値: -90.0 〜 90.0 の範囲の数値を文字列で指定（例: "35.6762"）
    # 省略時: 緯度情報なしで設定されます。
    latitude = "35.6762"

    # longitude (Optional)
    # 設定内容: デバイス設置場所の経度を文字列で指定します。
    # 設定可能な値: -180.0 〜 180.0 の範囲の数値を文字列で指定（例: "139.6503"）
    # 省略時: 経度情報なしで設定されます。
    longitude = "139.6503"
  }

  #-------------------------------------------------------------
  # AWSロケーション設定
  #-------------------------------------------------------------

  # aws_location (Optional)
  # 設定内容: デバイスが配置されているAWSの場所（サブネットまたはアベイラビリティゾーン）を
  #           設定します。AWSが管理するクラウド側のデバイスに対して使用します。
  # 省略時: AWSロケーション情報なしで作成されます。
  aws_location {
    # subnet_arn (Optional)
    # 設定内容: デバイスが配置されているVPCサブネットのARNを指定します。
    # 設定可能な値: 有効なサブネットARN文字列
    # 省略時: サブネット情報なしで設定されます。
    subnet_arn = "arn:aws:ec2:ap-northeast-1:123456789012:subnet/subnet-0123456789abcdef0"

    # zone (Optional)
    # 設定内容: デバイスが配置されているアベイラビリティゾーンを指定します。
    # 設定可能な値: 有効なアベイラビリティゾーン名（例: "ap-northeast-1a"）
    # 省略時: アベイラビリティゾーン情報なしで設定されます。
    zone = "ap-northeast-1a"
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしで作成されます。
  # 注意: プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-device"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソースの作成完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    create = "30m"

    # update (Optional)
    # 設定内容: リソースの更新完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    update = "30m"

    # delete (Optional)
    # 設定内容: リソースの削除完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    delete = "30m"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: デバイスのAmazon Resource Name (ARN)
#
# - id: デバイスのID
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
