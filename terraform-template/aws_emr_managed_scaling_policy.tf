################################################################################
# EMR Managed Scaling Policy
################################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/emr_managed_scaling_policy
#
# NOTE: EMRクラスターのマネージドスケーリングポリシーを管理するリソース
#       EMR 5.30.0以降でワークロードに基づいてインスタンス数を自動増減させる機能を提供
#       参考: https://docs.aws.amazon.com/emr/latest/ManagementGuide/emr-managed-scaling.html

resource "aws_emr_managed_scaling_policy" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------
  # 設定内容: スケーリングポリシーを適用するEMRクラスターのID
  # 注意事項: クラスターはEMR 5.30.0以降のバージョンが必要（6.0.0を除く）
  cluster_id = "j-XXXXXXXXXXXXX"

  #-----------------------------------------------------------------------
  # コンピュートリソースの制限設定
  #-----------------------------------------------------------------------
  # 設定内容: スケーリングポリシーのコンピュートリソース上限・下限を定義
  # 制約事項: CoreノードとTaskノードのみスケーリング対象（Masterノードは除外）
  compute_limits {
    # 設定内容: スケーリングポリシーで使用する単位タイプ
    # 設定可能な値:
    #   - "Instances"         = インスタンス数でスケーリング
    #   - "VCPU"              = vCPUコア数でスケーリング
    #   - "InstanceFleetUnits" = インスタンスフリート単位でスケーリング
    # 注意事項: InstanceGroupの場合はInstancesまたはVCPU、InstanceFleetの場合はInstanceFleetUnitsを使用
    unit_type = "Instances"

    # 設定内容: スケーリング可能な最小キャパシティ単位数
    # 制約事項: この値を下回るスケーリングは実行されない
    # 推奨値: ワークロードの最小要件に基づいて設定（例: 常時稼働が必要なコアノード数）
    minimum_capacity_units = 2

    # 設定内容: スケーリング可能な最大キャパシティ単位数
    # 制約事項: この値を超えるスケーリングは実行されない
    # 推奨値: コスト上限とパフォーマンス要件のバランスを考慮して設定
    maximum_capacity_units = 10

    # 設定内容: オンデマンドインスタンスの最大キャパシティ単位数
    # 使用用途: オンデマンドとスポットインスタンスの容量割り当てを分割する際に使用
    # 省略時: 制限なし（全てオンデマンドでのスケーリングが可能）
    # 推奨値: コスト最適化のため、必要最小限のオンデマンド容量を設定
    maximum_ondemand_capacity_units = 2

    # 設定内容: コアノードタイプの最大キャパシティ単位数
    # 使用用途: コアノードとタスクノードの容量割り当てを分割する際に使用
    # 省略時: 制限なし（maximum_capacity_units全てがコアノードに割り当て可能）
    # 推奨値: HDFSストレージ要件に基づいてコアノードの上限を設定
    maximum_core_capacity_units = 10
  }

  #-----------------------------------------------------------------------
  # 高度なスケーリング戦略（オプション）
  #-----------------------------------------------------------------------
  # 設定内容: カスタムスケーリング戦略の種類を指定
  # 設定可能な値:
  #   - "DEFAULT"  = 標準のスケーリング戦略
  #   - "ADVANCED" = UtilizationPerformanceIndexを使用した高度なスケーリング戦略
  # 省略時: "DEFAULT"
  # 対応バージョン: EMR 7.0以降でADVANCED戦略が利用可能
  scaling_strategy = "ADVANCED"

  # 設定内容: リソース使用率とパフォーマンスのバランスを調整する指標
  # 設定可能な値: 1～100の整数
  #   - 1～49  = リソース節約を優先（コスト最適化）
  #   - 50     = バランス型（パフォーマンスとコスト最適化のバランス）
  #   - 51～100 = パフォーマンスを優先（積極的なスケーリング）
  # 省略時: 50（バランス型）
  # 使用条件: scaling_strategy = "ADVANCED"が必要
  # 推奨値: SLA要件が厳しい場合は70～100、コスト重視の場合は1～30
  utilization_performance_index = 50

  #-----------------------------------------------------------------------
  # リージョン設定（オプション）
  #-----------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 使用用途: マルチリージョン構成で明示的にリージョンを指定する場合に使用
  region = "ap-northeast-1"
}

################################################################################
# Attributes Reference（参照可能な属性）
################################################################################
# このリソースをデプロイ後に参照可能な属性
#
# - id
#     リソースID（cluster_idと同じ値）
#     参照方法: aws_emr_managed_scaling_policy.example.id
#
# - cluster_id
#     EMRクラスターのID
#     参照方法: aws_emr_managed_scaling_policy.example.cluster_id
#
# - region
#     リソースが管理されているAWSリージョン
#     参照方法: aws_emr_managed_scaling_policy.example.region

################################################################################
