#-----------------------------------------------------------------------
# AWS EC2 スポットインスタンスリクエスト (aws_spot_instance_request)
#-----------------------------------------------------------------------
#
# スポットインスタンスのリクエストを作成・管理するリソースです。
# AWS EC2スポットインスタンスは、オンデマンド価格より最大90%割引で利用できる
# 余剰コンピューティングキャパシティです。
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/spot_instance_request
#
# Provider Version: 6.36.0
# Generated: 2026-03-18
#
# NOTE:
#   - このリソースは「スポットリクエスト」を管理するもので、インスタンス自体の管理はSpotリクエスト経由になります
#   - AWSはこのリソースが使用するレガシーAPIの使用を非推奨としています。aws_instanceのinstance_market_optionsの使用を推奨します
#   - wait_for_fulfillment = true にすると、インスタンスが実際に起動するまでapplyがブロックされます
#   - spot_type = "persistent"の場合、インスタンス中断後に再リクエストされます
#   - spot_type = "one-time"の場合、インスタンスが中断されると再リクエストされません
#   - launch_groupを指定すると、同じグループ内のリクエストは一緒に起動・終了します
#   - user_dataとuser_data_base64は同時に指定できません
#   - security_groupsはEC2-Classic専用です。VPC環境ではvpc_security_group_idsを使用してください
#   - network_interfaceブロックはdeprecatedです
#-----------------------------------------------------------------------

resource "aws_spot_instance_request" "example" {
  #-----------------------------------------------------------------------
  # イメージ・インスタンスタイプ設定
  #-----------------------------------------------------------------------

  # 設定内容: 起動するAmazon Machine Image (AMI) のID
  # 設定可能な値: AMI ID（例: ami-0abcdef1234567890）
  # 省略時: launch_templateから継承される（launch_template未使用時はエラー）
  ami = "ami-0abcdef1234567890"

  # 設定内容: EC2インスタンスタイプ
  # 設定可能な値: t3.micro, m5.large, c5.xlarge など各インスタンスファミリー
  # 省略時: launch_templateから継承される（launch_template未使用時はエラー）
  instance_type = "t3.micro"

  #-----------------------------------------------------------------------
  # スポットリクエスト設定
  #-----------------------------------------------------------------------

  # 設定内容: スポットインスタンスの最高入札価格（時間単位、USD）
  # 設定可能な値: 数値文字列（例: "0.05"）
  # 省略時: オンデマンド価格が上限として使用される
  spot_price = null

  # 設定内容: スポットリクエストのタイプ
  # 設定可能な値: "one-time"（一度だけ）/ "persistent"（中断後に再リクエスト）
  # 省略時: "one-time"
  spot_type = "one-time"

  # 設定内容: スポットインスタンスが中断された際の動作
  # 設定可能な値: "hibernate"（ハイバネーション）/ "stop"（停止）/ "terminate"（終了）
  # 省略時: "terminate"
  instance_interruption_behavior = "terminate"

  # 設定内容: スポットリクエストの有効開始日時（RFC3339形式）
  # 設定可能な値: RFC3339形式の日時文字列（例: "2026-01-01T00:00:00Z"）
  # 省略時: 計算される
  valid_from = null

  # 設定内容: スポットリクエストの有効期限（RFC3339形式）
  # 設定可能な値: RFC3339形式の日時文字列（例: "2026-12-31T23:59:59Z"）
  # 省略時: 計算される（期限なし）
  valid_until = null

  # 設定内容: スポットリクエストのラウンチグループ名
  # 設定可能な値: グループ名文字列
  # 省略時: グループは使用されない
  launch_group = null

  # 設定内容: スポットインスタンスの充足を待機するかどうか
  # 設定可能な値: true / false
  # 省略時: false（非同期でリクエストのみ作成）
  wait_for_fulfillment = false

  #-----------------------------------------------------------------------
  # 起動テンプレート設定
  #-----------------------------------------------------------------------

  # 設定内容: EC2起動テンプレートの参照設定
  # 省略時: 起動テンプレートは使用されない
  # launch_template {
  #   # 設定内容: 使用する起動テンプレートのID
  #   # 設定可能な値: 起動テンプレートID（例: lt-xxxxxxxxxxxxxxxxx）
  #   # 省略時: nameから解決される
  #   id = "lt-xxxxxxxxxxxxxxxxx"
  #
  #   # 設定内容: 使用する起動テンプレートの名前
  #   # 設定可能な値: 起動テンプレート名
  #   # 省略時: idから解決される
  #   name = "example-launch-template"
  #
  #   # 設定内容: 使用する起動テンプレートのバージョン
  #   # 設定可能な値: バージョン番号（例: "1"）、"$Latest"、"$Default"
  #   # 省略時: デフォルトバージョンが使用される
  #   version = "$Latest"
  # }

  #-----------------------------------------------------------------------
  # ネットワーク設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスを配置するサブネットのID
  # 設定可能な値: サブネットID（例: subnet-xxxxxxxxxxxxxxxxx）
  # 省略時: デフォルトサブネットが使用される
  subnet_id = "subnet-xxxxxxxxxxxxxxxxx"

  # 設定内容: インスタンスに関連付けるVPCセキュリティグループのIDリスト
  # 設定可能な値: セキュリティグループIDのセット（例: ["sg-xxxxxxxxxxxxxxxxx"]）
  # 省略時: デフォルトセキュリティグループが使用される
  vpc_security_group_ids = ["sg-xxxxxxxxxxxxxxxxx"]

  # 設定内容: パブリックIPアドレスをインスタンスに自動的に割り当てるかどうか
  # 設定可能な値: true / false
  # 省略時: サブネットのデフォルト設定（map_public_ip_on_launch）が使用される
  associate_public_ip_address = true

  # 設定内容: インスタンスのプライベートIPアドレス
  # 設定可能な値: サブネットのCIDR範囲内のIPv4アドレス（例: "10.0.1.10"）
  # 省略時: サブネットから自動的に割り当てられる
  private_ip = null

  # 設定内容: インスタンスのセカンダリプライベートIPアドレスのセット
  # 設定可能な値: サブネットのCIDR範囲内のIPv4アドレスのセット
  # 省略時: セカンダリIPアドレスは割り当てられない
  secondary_private_ips = null

  # 設定内容: インスタンスに割り当てるIPv6アドレスのリスト
  # 設定可能な値: サブネットのIPv6 CIDRブロック内のアドレスのリスト
  # 省略時: IPv6アドレスは割り当てられない
  ipv6_addresses = null

  # 設定内容: 自動的に割り当てるIPv6アドレスの数
  # 設定可能な値: 0以上の整数
  # 省略時: IPv6アドレスは自動割り当てされない
  ipv6_address_count = null

  # 設定内容: プライマリネットワークインターフェースにIPv6アドレスを有効化するかどうか
  # 設定可能な値: true / false
  # 省略時: 計算される
  enable_primary_ipv6 = null

  # 設定内容: ソース/宛先チェックを無効にするかどうか（ルーター/NAT用途向け）
  # 設定可能な値: true / false
  # 省略時: true（チェックが有効）
  source_dest_check = true

  # 設定内容: EC2-Classic（非VPC）向けセキュリティグループ名のセット
  # 設定可能な値: セキュリティグループ名のセット
  # 省略時: 使用されない（VPC環境ではvpc_security_group_idsを使用）
  security_groups = null

  #-----------------------------------------------------------------------
  # ネットワークインターフェース設定（非推奨）
  #-----------------------------------------------------------------------

  # 設定内容: カスタムネットワークインターフェースのアタッチ設定
  # 省略時: ネットワークインターフェースを個別アタッチしない
  # 備考: このブロックはdeprecatedです
  # network_interface {
  #   # 設定内容: ネットワークインターフェースのデバイスインデックス（必須）
  #   # 設定可能な値: 0以上の整数（0はプライマリ）
  #   device_index = 0
  #
  #   # 設定内容: アタッチするネットワークインターフェースのID（必須）
  #   # 設定可能な値: ネットワークインターフェースID（例: eni-xxxxxxxxxxxxxxxxx）
  #   network_interface_id = "eni-xxxxxxxxxxxxxxxxx"
  #
  #   # 設定内容: インスタンス終了時にネットワークインターフェースを削除するかどうか
  #   # 設定可能な値: true / false
  #   # 省略時: false
  #   delete_on_termination = false
  # }

  #-----------------------------------------------------------------------
  # セカンダリネットワークインターフェース設定
  #-----------------------------------------------------------------------

  # 設定内容: 起動時にアタッチするセカンダリネットワークインターフェースの設定（複数指定可能）
  # 省略時: セカンダリネットワークインターフェースはアタッチされない
  # 備考: 各ネットワークカードに1つのセカンダリインターフェースを持てます。変更時はインスタンスが再作成されます
  # secondary_network_interface {
  #   # 設定内容: セカンダリインターフェースを作成するサブネットのID（必須）
  #   # 設定可能な値: サブネットID（例: subnet-xxxxxxxxxxxxxxxxx）
  #   secondary_subnet_id = "subnet-xxxxxxxxxxxxxxxxx"
  #
  #   # 設定内容: ネットワークカードのインデックス（必須）
  #   # 設定可能な値: 0以上の整数
  #   network_card_index = 1
  #
  #   # 設定内容: ネットワークインターフェースのデバイスインデックス
  #   # 設定可能な値: 0以上の整数
  #   # 省略時: 0
  #   device_index = 0
  #
  #   # 設定内容: ネットワークインターフェースのタイプ
  #   # 設定可能な値: "secondary"
  #   # 省略時: "secondary"
  #   interface_type = "secondary"
  #
  #   # 設定内容: インスタンス終了時にネットワークインターフェースを削除するかどうか
  #   # 設定可能な値: true / false
  #   # 省略時: true
  #   delete_on_termination = true
  #
  #   # 設定内容: ネットワークインターフェースに割り当てるプライベートIPアドレスの数
  #   # 設定可能な値: 1以上の整数
  #   # 省略時: 1
  #   private_ip_address_count = 1
  # }

  #-----------------------------------------------------------------------
  # 配置設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスを配置するアベイラビリティーゾーン
  # 設定可能な値: AZコード（例: ap-northeast-1a, us-east-1b）
  # 省略時: リージョン内のAZから自動的に選択される
  availability_zone = null

  # 設定内容: インスタンスの配置テナンシー
  # 設定可能な値: "default"（共有ハードウェア）/ "dedicated"（専用ハードウェア）/ "host"（専用ホスト）
  # 省略時: "default"
  tenancy = "default"

  # 設定内容: インスタンスを配置する配置グループの名前
  # 設定可能な値: 既存の配置グループ名
  # 省略時: 配置グループは使用されない
  placement_group = null

  # 設定内容: インスタンスを配置する配置グループのID
  # 設定可能な値: 配置グループID（例: pg-xxxxxxxxxxxxxxxxx）
  # 省略時: 配置グループIDは指定されない
  placement_group_id = null

  # 設定内容: パーティション配置グループ内のパーティション番号
  # 設定可能な値: 1以上の整数
  # 省略時: 使用されない（パーティション配置グループ使用時のみ指定）
  placement_partition_number = null

  # 設定内容: 専用ホストのID（tenancy = "host"の場合に使用）
  # 設定可能な値: 専用ホストID（例: h-xxxxxxxxxxxxxxxxx）
  # 省略時: 計算される
  host_id = null

  # 設定内容: 専用ホストのリソースグループARN（tenancy = "host"の場合に使用）
  # 設定可能な値: リソースグループARN
  # 省略時: 計算される
  host_resource_group_arn = null

  #-----------------------------------------------------------------------
  # IAM設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスに関連付けるIAMインスタンスプロファイルの名前またはARN
  # 設定可能な値: IAMインスタンスプロファイル名またはARN
  # 省略時: IAMインスタンスプロファイルは関連付けられない
  iam_instance_profile = null

  #-----------------------------------------------------------------------
  # SSH・認証設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスに使用するSSHキーペアの名前
  # 設定可能な値: 既存のEC2キーペア名
  # 省略時: キーペアは設定されない（SSH接続不可）
  key_name = null

  # 設定内容: Windowsインスタンスのパスワードデータを取得するかどうか
  # 設定可能な値: true / false
  # 省略時: false
  get_password_data = false

  #-----------------------------------------------------------------------
  # ユーザーデータ設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンス起動時に実行するユーザーデータスクリプト
  # 設定可能な値: シェルスクリプトや cloud-init 形式の文字列
  # 省略時: ユーザーデータは設定されない
  # 備考: user_data_base64と同時に使用不可
  user_data = null

  # 設定内容: Base64エンコードされたユーザーデータ
  # 設定可能な値: Base64エンコードされた文字列
  # 省略時: ユーザーデータは設定されない
  # 備考: user_dataと同時に使用不可
  user_data_base64 = null

  # 設定内容: user_dataを変更した際にインスタンスを再作成するかどうか
  # 設定可能な値: true / false
  # 省略時: false（インスタンスを再起動せずにuser_dataを更新）
  user_data_replace_on_change = false

  #-----------------------------------------------------------------------
  # ストレージ設定
  #-----------------------------------------------------------------------

  # 設定内容: EBSストレージを最適化するかどうか（EBS最適化インスタンス）
  # 設定可能な値: true / false
  # 省略時: インスタンスタイプのデフォルト設定に従う
  ebs_optimized = null

  # 設定内容: ルートブロックデバイスの設定
  # 省略時: AMIのデフォルト設定が使用される
  root_block_device {
    # 設定内容: ルートボリュームのサイズ（GB）
    # 設定可能な値: 1以上の整数（AMIの最小サイズ以上）
    # 省略時: AMIのデフォルトサイズ
    volume_size = 20

    # 設定内容: ルートボリュームのタイプ
    # 設定可能な値: "gp2" / "gp3" / "io1" / "io2" / "sc1" / "st1" / "standard"
    # 省略時: "gp2"
    volume_type = "gp3"

    # 設定内容: ルートボリュームのIOPS（io1/io2/gp3のみ）
    # 設定可能な値: io1=100〜64000, io2=100〜256000, gp3=3000〜16000
    # 省略時: gp3は3000, io1/io2はvolume_sizeに基づく
    iops = 3000

    # 設定内容: ルートボリュームのスループット（MB/s、gp3のみ）
    # 設定可能な値: 125〜1000
    # 省略時: 125
    throughput = 125

    # 設定内容: ルートボリュームの暗号化
    # 設定可能な値: true / false
    # 省略時: false（ただし、KMSキーを指定した場合はtrue）
    encrypted = true

    # 設定内容: ルートボリュームの暗号化に使用するKMSキーARN
    # 設定可能な値: KMSキーARN（例: arn:aws:kms:...）
    # 省略時: AWSマネージドキー（aws/ebs）が使用される
    kms_key_id = null

    # 設定内容: インスタンス終了時にルートボリュームを削除するかどうか
    # 設定可能な値: true / false
    # 省略時: true
    delete_on_termination = true

    # 設定内容: ルートボリュームに付与するタグ
    # 設定可能な値: キーと値のペアのマップ
    # 省略時: タグは設定されない
    tags = {
      Name = "example-root-volume"
    }
  }

  # 設定内容: 追加EBSブロックデバイスの設定（複数指定可能）
  # 省略時: 追加EBSボリュームは作成されない
  # ebs_block_device {
  #   # 設定内容: デバイス名（必須）
  #   # 設定可能な値: "/dev/sdh", "/dev/xvdb" など
  #   device_name = "/dev/sdh"
  #
  #   # 設定内容: ボリュームサイズ（GB）
  #   # 設定可能な値: 1以上の整数
  #   # 省略時: AMIのデフォルトサイズ
  #   volume_size = 50
  #
  #   # 設定内容: ボリュームタイプ
  #   # 設定可能な値: "gp2" / "gp3" / "io1" / "io2" / "sc1" / "st1" / "standard"
  #   # 省略時: "gp2"
  #   volume_type = "gp3"
  #
  #   # 設定内容: IOPSの数（io1/io2/gp3のみ）
  #   # 設定可能な値: io1=100〜64000, io2=100〜256000, gp3=3000〜16000
  #   # 省略時: gp3は3000
  #   iops = 3000
  #
  #   # 設定内容: スループット（MB/s、gp3のみ）
  #   # 設定可能な値: 125〜1000
  #   # 省略時: 125
  #   throughput = 125
  #
  #   # 設定内容: ボリュームを暗号化するかどうか
  #   # 設定可能な値: true / false
  #   # 省略時: 計算される
  #   encrypted = true
  #
  #   # 設定内容: 暗号化に使用するKMSキーARN
  #   # 設定可能な値: KMSキーARN
  #   # 省略時: AWSマネージドキーが使用される
  #   kms_key_id = null
  #
  #   # 設定内容: スナップショットから作成する場合のスナップショットID
  #   # 設定可能な値: スナップショットID（例: snap-xxxxxxxxxxxxxxxxx）
  #   # 省略時: スナップショットは使用されない
  #   snapshot_id = null
  #
  #   # 設定内容: インスタンス終了時にボリュームを削除するかどうか
  #   # 設定可能な値: true / false
  #   # 省略時: false
  #   delete_on_termination = false
  #
  #   # 設定内容: ボリュームに付与するタグ
  #   # 設定可能な値: キーと値のペアのマップ
  #   # 省略時: タグは設定されない
  #   tags = {}
  # }

  # 設定内容: インスタンスストア（エフェメラル）ブロックデバイスの設定（複数指定可能）
  # 省略時: インスタンスストアは設定されない
  # ephemeral_block_device {
  #   # 設定内容: デバイス名（必須）
  #   # 設定可能な値: "/dev/sdh", "/dev/xvdb" など
  #   device_name = "/dev/sdh"
  #
  #   # 設定内容: 仮想デバイス名
  #   # 設定可能な値: "ephemeral0" / "ephemeral1" など
  #   # 省略時: 使用されない
  #   virtual_name = "ephemeral0"
  #
  #   # 設定内容: デバイスを抑制するかどうか（AMIのマッピングを上書き）
  #   # 設定可能な値: true / false
  #   # 省略時: false
  #   no_device = false
  # }

  # 設定内容: インスタンス終了時にEBSボリューム（ルート以外）に付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されない
  volume_tags = null

  #-----------------------------------------------------------------------
  # セキュリティ設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスの停止保護を有効にするかどうか（APIによる停止を防止）
  # 設定可能な値: true / false
  # 省略時: 計算される
  disable_api_stop = false

  # 設定内容: インスタンスの終了保護を有効にするかどうか（APIによる終了を防止）
  # 設定可能な値: true / false
  # 省略時: 計算される
  disable_api_termination = false

  # 設定内容: インスタンス停止時にEBSボリュームを保持するためのハイバネーション設定
  # 設定可能な値: true / false
  # 省略時: false
  # 備考: AMIがハイバネーションをサポートしている必要があります
  hibernation = false

  # 設定内容: インスタンスを終了する際にTerraform管理外のリソースも強制削除するかどうか
  # 設定可能な値: true / false
  # 省略時: false
  force_destroy = false

  # 設定内容: AWS Nitro Enclaves（機密コンピューティング環境）の設定
  # 省略時: Enclaveは無効
  enclave_options {
    # 設定内容: AWS Nitro Enclavesを有効にするかどうか
    # 設定可能な値: true / false
    # 省略時: 計算される
    enabled = false
  }

  #-----------------------------------------------------------------------
  # モニタリング設定
  #-----------------------------------------------------------------------

  # 設定内容: 詳細モニタリング（CloudWatch）を有効にするかどうか
  # 設定可能な値: true / false
  # 省略時: 計算される（デフォルトは基本モニタリング）
  monitoring = false

  #-----------------------------------------------------------------------
  # CPU設定
  #-----------------------------------------------------------------------

  # 設定内容: CPUオプションの設定
  # 省略時: インスタンスタイプのデフォルト設定が使用される
  cpu_options {
    # 設定内容: インスタンスのvCPUコア数
    # 設定可能な値: インスタンスタイプが対応するコア数の範囲内の整数
    # 省略時: 計算される
    core_count = null

    # 設定内容: 1コアあたりのスレッド数（ハイパースレッディングの制御）
    # 設定可能な値: 1（無効化）または 2（有効化）
    # 省略時: 計算される（通常2）
    threads_per_core = null

    # 設定内容: AMD SEV-SNP（機密仮想マシン）の有効化
    # 設定可能な値: "enabled" / "disabled"
    # 省略時: 計算される
    amd_sev_snp = null

    # 設定内容: ネステッド仮想化の有効化
    # 設定可能な値: "enabled" / "disabled"
    # 省略時: 計算される
    # 備考: 第8世代Intelベースインスタンス（C8i, M8i, R8i およびそのflexバリアント）のみ対応
    nested_virtualization = null
  }

  # 設定内容: バースト対応インスタンス（T系）のクレジット仕様
  # 省略時: スタンダードクレジット仕様が使用される
  credit_specification {
    # 設定内容: CPUクレジット仕様
    # 設定可能な値: "standard"（残高がなくなるとバーストを停止）/ "unlimited"（追加料金でバースト継続）
    # 省略時: インスタンスタイプによって異なる
    cpu_credits = "standard"
  }

  #-----------------------------------------------------------------------
  # インスタンスライフサイクル設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスのシャットダウン動作
  # 設定可能な値: "stop"（停止）/ "terminate"（終了）
  # 省略時: 計算される（通常は"stop"）
  instance_initiated_shutdown_behavior = "stop"

  #-----------------------------------------------------------------------
  # キャパシティ予約設定
  #-----------------------------------------------------------------------

  # 設定内容: キャパシティ予約の設定
  # 省略時: キャパシティ予約は使用されない
  # capacity_reservation_specification {
  #   # 設定内容: キャパシティ予約の選択方法
  #   # 設定可能な値: "open"（利用可能な予約を自動使用）/ "none"（予約を使用しない）/ "targeted"（特定の予約を指定）
  #   # 省略時: "open"
  #   capacity_reservation_preference = "open"
  #
  #   # 設定内容: 特定のキャパシティ予約ターゲット設定
  #   capacity_reservation_target {
  #     # 設定内容: ターゲットのキャパシティ予約ID
  #     # 設定可能な値: キャパシティ予約ID（例: cr-xxxxxxxxxxxxxxxxx）
  #     # 省略時: 使用されない
  #     capacity_reservation_id = null
  #
  #     # 設定内容: ターゲットのキャパシティ予約リソースグループARN
  #     # 設定可能な値: リソースグループARN
  #     # 省略時: 使用されない
  #     capacity_reservation_resource_group_arn = null
  #   }
  # }

  #-----------------------------------------------------------------------
  # メタデータ設定
  #-----------------------------------------------------------------------

  # 設定内容: EC2インスタンスメタデータサービス（IMDS）の設定
  # 省略時: デフォルト設定が使用される
  metadata_options {
    # 設定内容: メタデータサービスへのHTTPエンドポイントの有効化
    # 設定可能な値: "enabled" / "disabled"
    # 省略時: "enabled"
    http_endpoint = "enabled"

    # 設定内容: IMDSv2（セッション指向メタデータサービス）の要求設定
    # 設定可能な値: "optional"（IMDSv1とIMDSv2両方を許可）/ "required"（IMDSv2のみ許可）
    # 省略時: 計算される（セキュリティ強化のため"required"を推奨）
    http_tokens = "required"

    # 設定内容: HTTPのPUTレスポンスホップ制限
    # 設定可能な値: 1〜64
    # 省略時: 計算される（通常は1。コンテナからメタデータにアクセスする場合は2以上）
    http_put_response_hop_limit = 1

    # 設定内容: IPv6エンドポイントを介したメタデータへのアクセス
    # 設定可能な値: "enabled" / "disabled"
    # 省略時: "disabled"
    http_protocol_ipv6 = "disabled"

    # 設定内容: インスタンスタグをメタデータから参照できるようにするかどうか
    # 設定可能な値: "enabled" / "disabled"
    # 省略時: 計算される
    instance_metadata_tags = "disabled"
  }

  #-----------------------------------------------------------------------
  # メンテナンス設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスの自動リカバリ設定
  # 省略時: デフォルト設定が使用される
  maintenance_options {
    # 設定内容: インスタンスの自動リカバリ動作
    # 設定可能な値: "default"（インスタンスタイプのデフォルト）/ "disabled"（自動リカバリ無効）
    # 省略時: 計算される
    auto_recovery = "default"
  }

  #-----------------------------------------------------------------------
  # DNS設定
  #-----------------------------------------------------------------------

  # 設定内容: プライベートDNS名のオプション設定
  # 省略時: デフォルト設定が使用される
  private_dns_name_options {
    # 設定内容: プライベートDNSにリソース名ベースのAレコードを有効にするかどうか
    # 設定可能な値: true / false
    # 省略時: 計算される
    enable_resource_name_dns_a_record = null

    # 設定内容: プライベートDNSにリソース名ベースのAAAAレコード（IPv6）を有効にするかどうか
    # 設定可能な値: true / false
    # 省略時: 計算される
    enable_resource_name_dns_aaaa_record = null

    # 設定内容: プライベートDNSのホスト名タイプ
    # 設定可能な値: "ip-name"（IPアドレスベース）/ "resource-name"（リソース名ベース）
    # 省略時: 計算される
    hostname_type = null
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダーで設定されたリージョンが使用される
  region = null

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに割り当てるタグのマップ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されない
  tags = {
    Name        = "example-spot-instance-request"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # 設定内容: リソース操作のタイムアウト時間
  # timeouts {
  #   # 設定内容: スポットリクエスト作成のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "10m", "1h"）
  #   # 省略時: デフォルトのタイムアウト設定が使用される
  #   create = "10m"
  #
  #   # 設定内容: スポットリクエスト削除のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "20m", "1h"）
  #   # 省略時: デフォルトのタイムアウト設定が使用される
  #   delete = "20m"
  #
  #   # 設定内容: スポットリクエスト読み取りのタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "10m", "1h"）
  #   # 省略時: デフォルトのタイムアウト設定が使用される
  #   read = "10m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースが公開する属性の参照方法
#
# - id: スポットリクエストID（例: sir-xxxxxxxxxx）
# - arn: インスタンスのARN
# - spot_instance_id: 充足されたスポットインスタンスのID
# - spot_bid_status: スポットリクエストのビッドステータス
# - spot_request_state: スポットリクエストの状態（open / active / closed など）
# - instance_state: インスタンスの現在の状態（running / stopped など）
# - private_ip: プライベートIPアドレス
# - public_ip: パブリックIPアドレス
# - private_dns: プライベートDNS名
# - public_dns: パブリックDNS名
# - primary_network_interface_id: プライマリネットワークインターフェースのID
# - outpost_arn: OutpostのARN（Outpost上のインスタンスの場合）
# - password_data: Windows管理者パスワード（get_password_data=trueの場合）
# - tags_all: プロバイダーのdefault_tagsを含む全タグのマップ
#-----------------------------------------------------------------------
