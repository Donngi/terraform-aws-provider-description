#-------------------------------------------------------------------------------------------------------
# Amazon Comprehend ドキュメント分類器
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-13
#
# 用途:
#   - カスタムドキュメント分類モデルの作成と管理
#   - テキストデータの自動カテゴリ分類
#   - マルチクラスまたはマルチラベル分類モデルのトレーニング
#   - VPC内での分類器トレーニングのサポート
#
# 主な機能:
#   - カスタムトレーニングデータによる分類モデルの構築
#   - S3ベースのトレーニングデータおよび出力の管理
#   - 拡張マニフェストファイルを使用した高度なトレーニング
#   - モデルおよびストレージの暗号化サポート
#
# 制限事項:
#   - トレーニングには十分なラベル付きデータが必要
#   - 1つの分類器につき1つの言語コードのみサポート
#   - トレーニングの完了には時間がかかる場合がある（数時間）
#   - 一部のリージョンでのみ利用可能
#
# NOTE:
#   - トレーニングデータは適切なフォーマット（CSVまたは拡張マニフェスト）で準備する必要がある
#   - マルチラベル分類の場合、十分な数のラベル付きサンプルが各ラベルに必要
#   - VPC設定を使用する場合、S3 VPCエンドポイントの設定が推奨される
#
# 関連リソース:
#   - aws_iam_role - データアクセスロールの定義
#   - aws_kms_key - モデルおよびボリュームの暗号化
#   - aws_s3_bucket - トレーニングデータと出力の保存
#   - aws_vpc - VPC内でのトレーニング実行
#   - aws_subnet - トレーニング用サブネット
#   - aws_security_group - トレーニング用セキュリティグループ
#
# 参考ドキュメント:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/comprehend_document_classifier
#   - https://docs.aws.amazon.com/comprehend/latest/dg/how-document-classification.html
#-------------------------------------------------------------------------------------------------------

resource "aws_comprehend_document_classifier" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 分類器の名前
  # 制約: 最大63文字、英数字とハイフンのみ使用可能
  # 注意: 分類器名は同一リージョン内で一意である必要がある
  name = "my-document-classifier"

  # 設定内容: トレーニングデータにアクセスするためのIAMロールのARN
  # 必須項目: S3バケットへの読み取り/書き込み権限が必要
  # 注意: Comprehendサービスがこのロールを引き受けられる信頼関係が必要
  data_access_role_arn = "arn:aws:iam::123456789012:role/ComprehendDataAccessRole"

  # 設定内容: トレーニングデータの言語コード
  # 設定可能な値: en, es, fr, de, it, pt, ar, hi, ja, ko, zh, zh-TW
  # 注意: 1つの分類器につき1つの言語のみサポート
  language_code = "en"

  #-------------------------------------------------------------------------------------------------------
  # モード設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 分類器のモード
  # 設定可能な値: MULTI_CLASS（デフォルト）, MULTI_LABEL
  # MULTI_CLASS: 各ドキュメントに1つのラベルのみ割り当て
  # MULTI_LABEL: 各ドキュメントに複数のラベルを割り当て可能
  mode = "MULTI_CLASS"

  #-------------------------------------------------------------------------------------------------------
  # バージョン管理
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: 分類器のバージョン名
  # 注意: version_nameとversion_name_prefixは同時に指定できない
  version_name = "v1.0"

  # 設定内容: バージョン名のプレフィックス（自動生成用）
  # 省略時: Terraformが一意の名前を生成
  # 注意: このプレフィックスに基づいてTerraformが自動的に一意の名前を生成
  version_name_prefix = "v1-"

  #-------------------------------------------------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: モデルデータを暗号化するためのKMSキーID
  # 形式: キーID、キーARN、エイリアス名、エイリアスARNのいずれか
  # 省略時: AWS管理キーで暗号化
  model_kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  # 設定内容: トレーニング中に使用されるストレージボリュームを暗号化するためのKMSキーID
  # 形式: キーID、キーARN、エイリアス名、エイリアスARNのいずれか
  # 省略時: AWS管理キーで暗号化
  volume_kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: 通常は省略してプロバイダー設定に依存することを推奨
  region = "us-east-1"

  #-------------------------------------------------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: リソースに付与するタグ
  # 用途: コスト管理、リソース管理、アクセス制御
  tags = {
    Name        = "MyDocumentClassifier"
    Environment = "Production"
    Project     = "TextAnalysis"
    ManagedBy   = "Terraform"
  }

  #-------------------------------------------------------------------------------------------------------
  # 入力データ設定（必須）
  #-------------------------------------------------------------------------------------------------------
  input_data_config {
    # 設定内容: トレーニングデータのフォーマット
    # 設定可能な値: COMPREHEND_CSV（デフォルト）, AUGMENTED_MANIFEST
    # COMPREHEND_CSV: CSV形式のトレーニングデータ
    # AUGMENTED_MANIFEST: SageMaker Ground Truthなどで生成された拡張マニフェスト
    # data_format = "COMPREHEND_CSV"

    # 設定内容: CSVファイル内のラベル区切り文字
    # 省略時: "|"（パイプ文字）
    # 注意: MULTI_LABELモードで複数のラベルを区切る際に使用
    # label_delimiter = "|"

    # 設定内容: トレーニングデータが保存されているS3 URI
    # 形式: s3://bucket-name/prefix/
    # 注意: CSVファイルまたは拡張マニフェストファイルへのパス
    # s3_uri = "s3://my-training-bucket/training-data/"

    # 設定内容: テストデータが保存されているS3 URI（オプション）
    # 形式: s3://bucket-name/prefix/
    # 注意: 指定すると分類器のパフォーマンス評価に使用される
    # test_s3_uri = "s3://my-training-bucket/test-data/"

    #-------------------------------------------------------------------------------------------------------
    # 拡張マニフェスト設定
    #-------------------------------------------------------------------------------------------------------
    # 設定内容: 拡張マニフェストファイルの設定
    # 用途: SageMaker Ground Truthなどで生成されたアノテーションデータの使用
    # 注意: data_formatが"AUGMENTED_MANIFEST"の場合に使用
    # augmented_manifests {
    #   # 設定内容: マニフェストファイルが保存されているS3 URI
    #   # 形式: s3://bucket-name/path/to/manifest.jsonl
    #   s3_uri = "s3://my-training-bucket/manifests/training.manifest"
    #
    #   # 設定内容: マニフェストファイル内で使用される属性名のリスト
    #   # 注意: ドキュメントのラベルを含む属性名を指定
    #   attribute_names = ["class-name"]
    #
    #   # 設定内容: アノテーションデータが保存されているS3 URI
    #   # 形式: s3://bucket-name/annotations/
    #   # 注意: SageMaker Ground Truthの出力アノテーションの場所
    #   # annotation_data_s3_uri = "s3://my-training-bucket/annotations/"
    #
    #   # 設定内容: ソースドキュメントが保存されているS3 URI
    #   # 形式: s3://bucket-name/documents/
    #   # 注意: トレーニング用の元のドキュメントファイルの場所
    #   # source_documents_s3_uri = "s3://my-training-bucket/documents/"
    #
    #   # 設定内容: データセットの分割タイプ
    #   # 設定可能な値: TRAIN, TEST
    #   # 注意: このマニフェストがトレーニング用かテスト用かを指定
    #   # split = "TRAIN"
    #
    #   # 設定内容: ドキュメントのタイプ
    #   # 設定可能な値: PLAIN_TEXT_DOCUMENT, SEMI_STRUCTURED_DOCUMENT
    #   # PLAIN_TEXT_DOCUMENT: プレーンテキストドキュメント
    #   # SEMI_STRUCTURED_DOCUMENT: PDFなどの半構造化ドキュメント
    #   # document_type = "PLAIN_TEXT_DOCUMENT"
    # }
  }

  #-------------------------------------------------------------------------------------------------------
  # 出力データ設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: トレーニング結果の出力先設定
  # 注意: トレーニングの統計情報やモデルアーティファクトが保存される
  # output_data_config {
  #   # 設定内容: 出力データを保存するS3 URI
  #   # 形式: s3://bucket-name/output/
  #   s3_uri = "s3://my-training-bucket/output/"
  #
  #   # 設定内容: 出力データを暗号化するためのKMSキーID
  #   # 形式: キーID、キーARN、エイリアス名、エイリアスARNのいずれか
  #   # 省略時: S3バケットのデフォルト暗号化設定を使用
  #   # kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"
  # }

  #-------------------------------------------------------------------------------------------------------
  # VPC設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: トレーニングジョブを実行するVPCの設定
  # 用途: プライベートネットワーク内でのトレーニング実行、VPCエンドポイント経由でのS3アクセス
  # 注意: VPC設定を使用すると、トレーニングデータがパブリックインターネットを経由しない
  # vpc_config {
  #   # 設定内容: トレーニングジョブに関連付けるセキュリティグループIDのリスト
  #   # 注意: S3 VPCエンドポイントへのアウトバウンドアクセスを許可する必要がある
  #   security_group_ids = ["sg-12345678"]
  #
  #   # 設定内容: トレーニングジョブを実行するサブネットIDのリスト
  #   # 注意: プライベートサブネットを使用し、S3 VPCエンドポイントを設定することを推奨
  #   subnets = ["subnet-12345678", "subnet-87654321"]
  # }

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------
  # timeouts {
  #   # 設定内容: 作成処理のタイムアウト時間
  #   # 省略時: 60m（60分）
  #   # 注意: トレーニングには時間がかかるため、十分な時間を設定
  #   create = "120m"
  #
  #   # 設定内容: 更新処理のタイムアウト時間
  #   # 省略時: 60m（60分）
  #   update = "120m"
  #
  #   # 設定内容: 削除処理のタイムアウト時間
  #   # 省略時: 60m（60分）
  #   delete = "30m"
  # }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースから参照可能な属性:
#
# - id
#   説明: ドキュメント分類器の一意の識別子（ARNと同じ）
#   形式: arn:aws:comprehend:region:account-id:document-classifier/name/version
#
# - arn
#   説明: ドキュメント分類器のARN
#   形式: arn:aws:comprehend:region:account-id:document-classifier/name/version
#
# - tags_all
#   説明: プロバイダーレベルのデフォルトタグを含む、リソースに割り当てられた全てのタグ
#
# - version_name
#   説明: 分類器のバージョン名（明示的に指定またはTerraformによって生成）
#
# - output_data_config.output_s3_uri
#   説明: トレーニング結果が実際に出力されたS3 URI
#   形式: s3://bucket-name/account-id-CLASSIFIER_NAME-version/output/output.tar.gz
#-------------------------------------------------------------------------------------------------------
