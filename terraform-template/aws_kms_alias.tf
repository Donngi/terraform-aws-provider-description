#---------------------------------------------------------------
# AWS KMS Alias
#---------------------------------------------------------------
#
# AWS KMS (Key Management Service) のカスタマーマネージドキー（CMK）に
# 別名（エイリアス）を付与するリソースです。
# エイリアスを使用することで、キーIDやARNの代わりに人間が読みやすい名前で
# KMSキーを参照できるようになります。
#
# 主なユースケース:
#   - CMKに意味のある名前を付けて管理を容易にする
#   - アプリケーションコード内でキーIDの代わりにエイリアス名を使用する
#   - キーのローテーション時にエイリアスを別のキーに付け替えることでコード変更不要にする
#   - 複数のキーを論理的にグルーピングして管理する
#
# 重要な注意事項:
#   - エイリアス名は必ず "alias/" プレフィックスで始める必要があります。
#     例: "alias/my-key"
#   - "alias/aws/" プレフィックスはAWSマネージドキー専用のため使用できません。
#   - 1つのエイリアスは1つのキーにのみ紐付けられます（1対1の関係）。
#   - 同一リージョン内でエイリアス名はユニークである必要があります。
#   - エイリアスを削除してもKMSキー自体は削除されません。
#
# AWS公式ドキュメント:
#   - KMS エイリアス概要: https://docs.aws.amazon.com/kms/latest/developerguide/kms-alias.html
#   - エイリアスの使用: https://docs.aws.amazon.com/kms/latest/developerguide/alias-using.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/kms_alias
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_kms_alias" "example" {
  #---------------------------------------------------------------
  # キー紐付け設定
  #---------------------------------------------------------------

  # target_key_id (Required)
  # 設定内容: エイリアスを紐付けるKMSキーのIDまたはARNを指定します。
  # 設定可能な値: KMSキーのID（UUID形式）、ARN、またはエイリアス名の文字列
  # 省略時: 設定必須のため省略不可
  #
  # 指定方法の例:
  #   - キーID: "1234abcd-12ab-34cd-56ef-1234567890ab"
  #   - キーARN: "arn:aws:kms:us-east-1:123456789012:key/1234abcd-..."
  #   - aws_kms_key リソース参照: aws_kms_key.example.id
  target_key_id = aws_kms_key.example.id

  #---------------------------------------------------------------
  # 名前設定
  #---------------------------------------------------------------

  # name (Optional)
  # 設定内容: KMSエイリアスの名前を指定します。name と name_prefix は同時に指定できません。
  # 設定可能な値: "alias/" プレフィックスで始まる文字列。英数字、ハイフン、アンダースコア、スラッシュが使用可能
  # 省略時: name_prefix が指定されている場合はそちらを使用。両方省略時はTerraformが一意の名前を自動生成します
  #
  # 制約:
  #   - 必ず "alias/" プレフィックスで始まること（例: "alias/my-key"）
  #   - "alias/aws/" プレフィックスは予約済みのため使用不可
  #   - 同一リージョン内でユニークである必要があります
  #   - 変更するとリソースの再作成が発生します
  name = "alias/example-key"

  # name_prefix (Optional)
  # 設定内容: KMSエイリアス名のプレフィックスを指定します。Terraformが一意のサフィックスを付与します。
  # 設定可能な値: "alias/" プレフィックスで始まる文字列
  # 省略時: name を使用。name も未指定の場合は完全にランダムな名前が生成されます
  #
  # 注意:
  #   - name と同時に指定できません。どちらか一方のみ使用してください。
  #   - 名前の衝突を避けたい場合や複数のエイリアスを動的に生成する場合に便利です。
  name_prefix = null

  #---------------------------------------------------------------
  # リージョン設定
  #---------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: AWSリージョンコード文字列（例: "us-east-1", "ap-northeast-1"）
  # 省略時: プロバイダー設定で指定されたリージョンを使用します
  #
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

