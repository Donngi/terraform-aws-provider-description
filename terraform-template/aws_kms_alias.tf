#     例: arn:aws:kms:ap-northeast-1:123456789012:alias/example-key
#
# - id
#     エイリアス名（name と同一）
#     例: alias/example-key
#
# - target_key_arn
#     紐付けられたKMSキーのARN
#     例: arn:aws:kms:ap-northeast-1:123456789012:key/1234abcd-...
