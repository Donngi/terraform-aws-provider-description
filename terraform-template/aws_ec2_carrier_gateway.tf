#
# 概要: Wavelength ZoneのVPCにキャリアゲートウェイを作成するリソース。
# キャリアゲートウェイは、5G/LTEモバイル通信キャリアネットワークとWavelength
# Zone内のリソース間の通信を可能にします。
#
# 主な用途:
# - Wavelength ZoneでのMEC（Multi-Access Edge Computing）アプリケーション展開
# - モバイルデバイスからのインバウンドトラフィック受信
# - キャリアネットワークおよびインターネットへのアウトバウンドトラフィック送信
# - 超低レイテンシが必要な5Gアプリケーションの構築
#
# 制約事項:
# - Wavelength Zoneのサブネットを含むVPCでのみ使用可能
# - IPv4トラフィックのみサポート（IPv6は未サポート）
# - キャリアゲートウェイとWavelength Zone間のMTUは1500バイト
# - 使用前にWavelength Zoneへのオプトインが必要
#
# 関連リソース:
# - aws_vpc: キャリアゲートウェイをアタッチするVPC
# - aws_subnet: Wavelength Zone内のサブネット
# - aws_ec2_carrier_ip: キャリアIPアドレス
# - aws_route_table: キャリアゲートウェイへのルーティング設定
#
# Terraformドキュメント:
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_carrier_gateway
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------
resource "aws_ec2_carrier_gateway" "example" {
  # VPC ID（必須）
  # 設定内容: キャリアゲートウェイをアタッチするVPCのID
  # 制約事項: Wavelength Zoneのサブネットを含むVPCである必要がある
  # 変更時の影響: 変更するとリソースの再作成が発生（既存の接続が切断される）
  vpc_id = "vpc-0123456789abcdef0"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # リージョン指定（オプション）
  # 設定内容: リソースを管理するリージョン
  # 省略時: プロバイダー設定のリージョンが使用される
  # 注意事項: マルチリージョン構成で明示的にリージョンを指定する場合に指定
  region = "us-west-2"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # リソースタグ
  # 設定内容: キャリアゲートウェイに付与するタグのマップ
  # 推奨事項: 環境、用途、管理者などの情報をタグで管理
  # 制約事項: タグキーは最大128文字、タグ値は最大256文字
  tags = {
    Name        = "wavelength-carrier-gateway"
    Environment = "production"
    Purpose     = "5g-edge-computing"
    ManagedBy   = "terraform"
  }

  # 全タグ（プロバイダーレベルのタグを含む）
  # 設定内容: プロバイダーのdefault_tagsと統合された全タグ
  # 省略時: プロバイダーのdefault_tagsが自動適用される
  # 注意事項: 通常はプロバイダーのdefault_tagsで管理し、個別指定は不要
  # tags_all = {
  #   Name        = "wavelength-carrier-gateway"
  #   Environment = "production"
  #   CostCenter  = "engineering"  # プロバイダーのdefault_tagsから継承
  # }
}

