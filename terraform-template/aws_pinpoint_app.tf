#-----------------------------------------------------------------------
# AWS Pinpoint App
#-----------------------------------------------------------------------
# Amazon Pinpointアプリケーション（プロジェクト）を管理するリソース。
# キャンペーン設定、送信制限、サイレント時間などのアプリケーション設定を定義する。
#
# 主な用途:
# - モバイルプッシュ通知・SMS・メール配信のアプリケーション管理
# - キャンペーン送信のレート制限・日次上限の設定
# - キャンペーン配信前後のLambdaフック設定
# - 夜間など特定時間帯の通知送信停止（サイレント時間）設定
#
# 注意事項:
# - nameとname_prefixは同時指定不可（どちらか一方のみ指定）
# - campaign_hookでLambdaを使用する場合はLambda側でPinpointへの権限付与が必要
# - quiet_timeはアプリ全体に適用され、個別キャンペーンで上書き可能
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: limitsの各値はAWSサービスの上限値の範囲内で設定すること
#
# 参考: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/pinpoint_app
#-----------------------------------------------------------------------

# Attributes Reference:
# - application_id: アプリケーションID
# - arn: ARN
# - id: リソースID（application_idと同値）
# - name: アプリケーション名
# - name_prefix: 名前プレフィックス
# - tags_all: 全タグ（継承タグを含む）

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------
resource "aws_pinpoint_app" "this" {
  # 設定内容: アプリケーション名
  # 設定可能な値: 文字列
  # 省略時: 自動生成
  name = "example-pinpoint-app"

  # 設定内容: アプリケーション名のプレフィックス（nameと排他）
  # 設定可能な値: 文字列
  # 省略時: 省略可
  # 注意: nameと同時指定不可（どちらか一方のみ指定）
  name_prefix = null

  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: "ap-northeast-1"）
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  # 設定内容: リソースタグ
  # 設定可能な値: キーと値のマップ
  # 省略時: タグなし
  tags = {
    Environment = "production"
    Project     = "example"
  }

  #-----------------------------------------------------------------------
  # キャンペーンフック設定
  #-----------------------------------------------------------------------
  campaign_hook {
    # 設定内容: キャンペーン送信前に呼び出すLambda関数名またはARN
    # 設定可能な値: Lambda関数名またはARN文字列
    # 省略時: フックなし
    lambda_function_name = null

    # 設定内容: キャンペーンフックのモード
    # 設定可能な値: "DELIVERY"（フィルタリング）, "FILTER"（メッセージ変更）
    # 省略時: 省略可
    mode = null

    # 設定内容: キャンペーンイベントのWebhook URL
    # 設定可能な値: HTTPS URL文字列
    # 省略時: 省略可
    web_url = null
  }

  #-----------------------------------------------------------------------
  # 送信制限設定
  #-----------------------------------------------------------------------
  limits {
    # 設定内容: エンドポイントが1日に受信できるメッセージの最大数
    # 設定可能な値: 1〜100の整数
    # 省略時: 制限なし
    daily = 10

    # 設定内容: キャンペーンの最大実行時間（秒）
    # 設定可能な値: 60〜259200の整数
    # 省略時: 制限なし
    maximum_duration = 600

    # 設定内容: 1秒あたりの最大メッセージ送信数
    # 設定可能な値: 50〜20000の整数
    # 省略時: 制限なし
    messages_per_second = 100

    # 設定内容: エンドポイントが受信できるメッセージの通算最大数
    # 設定可能な値: 1〜100の整数
    # 省略時: 制限なし
    total = 100
  }

  #-----------------------------------------------------------------------
  # サイレント時間設定
  #-----------------------------------------------------------------------
  quiet_time {
    # 設定内容: サイレント時間の開始時刻（HH:MM形式、24時間表記）
    # 設定可能な値: "00:00"〜"23:59" 形式の文字列
    # 省略時: サイレント時間なし
    start = "22:00"

    # 設定内容: サイレント時間の終了時刻（HH:MM形式、24時間表記）
    # 設定可能な値: "00:00"〜"23:59" 形式の文字列
    # 省略時: サイレント時間なし
    end = "07:00"
  }
}
