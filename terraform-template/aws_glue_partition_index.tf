#---------------------------------------------------------------
# AWS Glue Partition Index
#---------------------------------------------------------------
#
# AWS Glueテーブル上にパーティションインデックスを作成するリソース。
# パーティションインデックスはテーブルで定義されたパーティションキーの
# サブセットであり、クエリのパフォーマンスを最適化するために使用される。
# インデックスは文字列、数値、日付データ型に対して作成でき、
# =, >, >=, <, <= 演算子をサポートする。
# 1つのテーブルに最大3つのパーティションインデックスを作成できる。
#
# AWS公式ドキュメント:
#   - パーティションインデックスの作成: https://docs.aws.amazon.com/glue/latest/dg/partition-indexes.html
#   - CreatePartitionIndex API: https://docs.aws.amazon.com/glue/latest/webapi/API_CreatePartitionIndex.html
#   - PartitionIndex: https://docs.aws.amazon.com/glue/latest/webapi/API_PartitionIndex.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/glue_partition_index
#
# Provider Version: 6.28.0
# Generated: 2026-01-27
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_glue_partition_index" "example" {
  #---------------------------------------------------------------
  # Required Parameters
  #---------------------------------------------------------------

  # (必須) テーブルが属するメタデータデータベースの名前
  # Hive互換性のため、全て小文字である必要がある
  # 例: "my_database"
  database_name = "example_database"

  # (必須) パーティションインデックスを作成するテーブルの名前
  # Hive互換性のため、全て小文字である必要がある
  # 例: "my_table"
  table_name = "example_table"

  #---------------------------------------------------------------
  # Optional Parameters
  #---------------------------------------------------------------

  # (オプション) テーブルが存在するカタログID
  # 指定しない場合はAWSアカウントIDが使用される
  # 例: "123456789012"
  # catalog_id = null

  # (オプション) このリソースが管理されるリージョン
  # 指定しない場合、プロバイダー設定のリージョンが使用される
  # 例: "us-east-1"
  # region = null

  #---------------------------------------------------------------
  # Nested Blocks
  #---------------------------------------------------------------

  # (必須) パーティションインデックスの設定
  # このブロックは必須であり、1つだけ指定できる
  partition_index {
    # (オプション) パーティションインデックスの名前
    # 1文字以上255文字以下の文字列
    # 例: "my_index", "date_region_index"
    index_name = "example_index"

    # (オプション) パーティションインデックスのキーとなるパーティションキーのリスト
    # テーブルに既に定義されているパーティションキーから選択する
    # Data Catalogは、インデックス作成時に指定された順序でパーティション値を連結する
    # 最初のキーがクエリ式に含まれている場合にインデックスが使用される
    # 例: ["year", "month", "day"]
    keys = ["partition_key_1", "partition_key_2"]
  }

  # (オプション) タイムアウト設定
  # timeouts {
  #   # パーティションインデックス作成のタイムアウト
  #   # デフォルト: 10m (10分)
  #   # 例: "20m", "1h"
  #   create = "10m"
  #
  #   # パーティションインデックス削除のタイムアウト
  #   # デフォルト: 10m (10分)
  #   # 例: "20m", "1h"
  #   delete = "10m"
  # }
}

#---------------------------------------------------------------
# Attributes Reference
#---------------------------------------------------------------
#
# このリソースは以下の属性をエクスポートします:
#
# - id: カタログID、データベース名、テーブル名、インデックス名を含む識別子
#       フォーマット: {catalog_id}:{database_name}:{table_name}:{index_name}
#
# - partition_index.index_status: パーティションインデックスのステータス (computed)
#       値: CREATING, ACTIVE, DELETING, FAILED
#       インデックスがACTIVE状態になると、クエリでの使用が可能になる
#
#---------------------------------------------------------------
# 使用上の注意
#---------------------------------------------------------------
#
# 1. パーティションインデックスの作成:
#    - テーブルに最大3つまでインデックスを作成可能
#    - インデックスは文字列、数値、日付データ型をサポート
#    - =, >, >=, <, <= 演算子をサポート
#
# 2. インデックス作成の失敗条件:
#    - パーティションが暗号化されている場合
#    - 無効なパーティションタイプ
#    - パーティション値の欠落
#    - サポートされていない文字の使用
#
# 3. パーティション追加時の検証:
#    - インデックス作成後、新しいパーティションはインデックスキーの
#      データ型チェックが実施される
#    - U+0000, U+0001, U+0002の文字を含むパーティション追加は失敗する
#
# 4. クエリでの利用:
#    - GetPartitions呼び出し時、インデックスの最初のキーが
#      式に含まれている場合にインデックスが使用される
#    - Redshift Spectrum、Amazon EMR、Glue ETL Spark DataFramesは
#      インデックスがACTIVE状態になると自動的に利用可能
#    - Athenaでインデックスを有効化するには、テーブルプロパティに
#      partition_filtering.enabled=trueを設定する必要がある
#
# 5. パフォーマンス最適化:
#    - インデックス作成により、スキャンするデータ量を削減
#    - クエリパフォーマンスの向上とコスト削減が期待できる
#    - パーティションメタデータに直接プッシュダウン述語を適用可能
#
#---------------------------------------------------------------
