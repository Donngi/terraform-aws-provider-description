#######################################################################
# Network Manager VPC Attachment
#######################################################################
# AWS Cloud WAN のコアネットワークに VPC をアタッチするためのリソース。
# コアネットワークのセグメントにVPCを接続し、グローバルなWANネットワークを
# 構築する際に使用する。
#
# 主な用途:
# - AWS Cloud WAN コアネットワークへの VPC の接続
# - マルチリージョン・マルチ拠点のWANネットワーク構成
# - VPC間のセグメントポリシーに基づくトラフィック制御
# - アプライアンスモードによるファイアウォール統合構成
#
# 参考: https://docs.aws.amazon.com/network-manager/latest/cloudwan/cloudwan-core-network-policy-attachments.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/networkmanager_vpc_attachment
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_networkmanager_vpc_attachment" "example" {
  #-----------------------------------------------------------------------
  # コアネットワーク識別の設定
  #-----------------------------------------------------------------------

  # アタッチ先のコアネットワークID（必須）
  # 設定内容: VPCを接続するCloud WANコアネットワークのID
  # 省略時: 指定必須
  core_network_id = aws_networkmanager_core_network.example.id

  #-----------------------------------------------------------------------
  # アタッチ対象VPCの設定
  #-----------------------------------------------------------------------

  # アタッチするVPCのARN（必須）
  # 設定内容: コアネットワークに接続するVPCのARN
  # 省略時: 指定必須
  vpc_arn = aws_vpc.example.arn

  # アタッチメントに使用するサブネットのARNセット（必須）
  # 設定内容: アタッチメントのエンドポイントを配置するサブネットのARNリスト
  # 注意: 各アベイラビリティゾーンにつき1つのサブネットのみ指定可能
  # 省略時: 指定必須
  subnet_arns = [
    aws_subnet.example_a.arn,
    aws_subnet.example_b.arn,
  ]

  #-----------------------------------------------------------------------
  # ルーティングポリシーの設定
  #-----------------------------------------------------------------------

  # ルーティングポリシーラベル
  # 設定内容: アタッチメントに適用するルーティングポリシーのラベル
  # 用途: コアネットワークポリシーでのルーティング制御に使用
  # 省略時: なし
  routing_policy_label = "example-label"

  #-----------------------------------------------------------------------
  # アタッチメントオプションの設定
  #-----------------------------------------------------------------------

  options {
    # アプライアンスモードのサポート
    # 設定内容: アプライアンス（ファイアウォール等）統合モードを有効にするか
    # 設定可能な値: true / false
    # 用途: トラフィックを特定のアプライアンスに集約して検査する場合に有効化
    # 省略時: false（プロバイダーのデフォルト）
    appliance_mode_support = false

    # DNSサポート
    # 設定内容: VPCアタッチメントのDNS解決を有効にするか
    # 設定可能な値: true / false
    # 省略時: true（プロバイダーのデフォルト）
    dns_support = true

    # IPv6サポート
    # 設定内容: VPCアタッチメントでIPv6を有効にするか
    # 設定可能な値: true / false
    # 省略時: false（プロバイダーのデフォルト）
    ipv6_support = false

    # セキュリティグループ参照サポート
    # 設定内容: VPC間でセキュリティグループ参照を有効にするか
    # 設定可能な値: true / false
    # 用途: 異なるVPCのセキュリティグループをルールで参照する場合に有効化
    # 省略時: false（プロバイダーのデフォルト）
    security_group_referencing_support = false
  }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # リソースタグ
  # 設定内容: VPCアタッチメントに付与するタグ（キー・バリューペア）
  # 用途: リソース管理、コスト配分、アクセス制御
  # 注意: プロバイダーのdefault_tagsと重複するキーは上書きされる
  tags = {
    Name        = "example-vpc-attachment"
    Environment = "production"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 作成タイムアウト
    # 設定内容: リソース作成完了までの最大待機時間
    # 省略時: プロバイダーのデフォルト
    create = "30m"

    # 更新タイムアウト
    # 設定内容: リソース更新完了までの最大待機時間
    # 省略時: プロバイダーのデフォルト
    update = "30m"

    # 削除タイムアウト
    # 設定内容: リソース削除完了までの最大待機時間
    # 省略時: プロバイダーのデフォルト
    delete = "30m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: アタッチメントのID
# - arn: VPCアタッチメントのARN
# - attachment_policy_rule_number: 関連付けられたポリシールール番号
# - attachment_type: アタッチメントの種類（常に "VPC"）
# - core_network_arn: コアネットワークのARN
# - edge_location: アタッチメントのエッジロケーション（AWSリージョン）
# - owner_account_id: アタッチメントを所有するAWSアカウントID
# - resource_arn: アタッチされたVPCのARN
# - segment_name: アタッチメントが属するコアネットワークのセグメント名
# - state: アタッチメントの現在の状態
# - tags_all: 全タグ（default_tagsから継承されたタグを含む）
#-----------------------------------------------------------------------
