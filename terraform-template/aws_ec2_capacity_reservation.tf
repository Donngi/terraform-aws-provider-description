#--------------------------------------------------------------
# EC2 Capacity Reservation
#--------------------------------------------------------------
# 特定のアベイラビリティゾーンにEC2インスタンスの容量を予約するリソース
# オンデマンドキャパシティ予約により、需要の急増時でも確実にインスタンスを起動可能
#
# 主な用途:
# - ディザスタリカバリ用のスタンバイキャパシティ確保
# - ビジネスクリティカルなワークロード向けの容量保証
# - 予測可能な需要増加への対応（セール期間など）
#
# 料金:
# - 予約した容量分の料金が、インスタンス使用の有無に関わらず発生
# - 通常のオンデマンド料金と同額の時間単位課金
#
# 関連リソース:
# - aws_ec2_capacity_reservation_fleet: 複数のインスタンスタイプ/AZにまたがる容量予約
# - aws_placement_group: クラスター配置グループとの組み合わせ
#
# Generated: 2026-02-14
# AWS Provider Version: 6.28.0
# Terraform AWS Provider URL: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_capacity_reservation
#
# NOTE: 全てのオプション属性はコメントアウトされています。
#       必要に応じてコメントを解除して使用してください。
#--------------------------------------------------------------

resource "aws_ec2_capacity_reservation" "example" {
  #---------------------------------------------------------------
  # 基本設定
  #---------------------------------------------------------------
  # 設定内容: 容量を予約するアベイラビリティゾーン
  # 設定可能な値: 有効なアベイラビリティゾーン名（例: ap-northeast-1a, us-east-1b）
  # 注意事項:
  # - 予約後のアベイラビリティゾーン変更は不可
  # - インスタンス起動時に同じAZを指定する必要あり
  # - ローカルゾーンやWavelengthゾーンも指定可能
  availability_zone = "ap-northeast-1a"

  # 設定内容: 予約する容量のインスタンスタイプ
  # 設定可能な値: 有効なEC2インスタンスタイプ（例: t3.micro, m5.large, c5.xlarge）
  # 注意事項:
  # - 予約後のインスタンスタイプ変更は不可
  # - ベアメタルインスタンスにも対応
  # - インスタンスファミリーはC, M, R, I, T, Gなどをサポート
  instance_type = "t3.micro"

  # 設定内容: 予約する容量のOSプラットフォーム
  # 設定可能な値:
  # - Linux/UNIX: 標準的なLinuxディストリビューション
  # - Red Hat Enterprise Linux: RHEL専用
  # - SUSE Linux: SUSE専用
  # - Windows: 標準Windows Server
  # - Windows with SQL Server: SQL Server付きWindows
  # - Windows with SQL Server Enterprise: SQL Server Enterprise付き
  # - Windows with SQL Server Standard: SQL Server Standard付き
  # - Windows with SQL Server Web: SQL Server Web付き
  # 注意事項:
  # - 予約後のプラットフォーム変更は不可
  # - インスタンス起動時に同じプラットフォームを使用する必要あり
  # - ライセンス費用はプラットフォームに応じて変動
  instance_platform = "Linux/UNIX"

  # 設定内容: 予約するインスタンス数
  # 設定可能な値: 1〜1000の整数
  # 注意事項:
  # - 予約後に増減可能（アクティブ状態の場合）
  # - 将来日付予約の場合、コミットメント期間中は減少不可
  # - 予約数分の料金が常時発生
  instance_count = 1

  #---------------------------------------------------------------
  # インスタンスマッチング設定
  #---------------------------------------------------------------
  # 設定内容: 予約容量へのインスタンス起動方法
  # 設定可能な値:
  # - open: 属性が一致するインスタンスを自動的に予約容量で起動（デフォルト）
  # - targeted: 明示的にこの予約を指定したインスタンスのみ起動可能
  # 省略時: open
  # 注意事項:
  # - open: 意図しないインスタンスが予約容量を消費する可能性あり
  # - targeted: capacity-reservation-specification設定が必須
  # - 将来日付予約では必ずtargetedを指定する必要あり
  # - アクティブ後にtargetedからopenへの変更は可能（逆は不可）
  instance_match_criteria = "open"

  #---------------------------------------------------------------
  # テナンシー設定
  #---------------------------------------------------------------
  # 設定内容: インスタンスのテナンシータイプ
  # 設定可能な値:
  # - default: 共有ハードウェア（デフォルト）
  # - dedicated: 専有ハードウェア
  # 省略時: default
  # 注意事項:
  # - dedicated指定時は専有インスタンス料金が追加で発生
  # - 予約後のテナンシー変更は不可
  # - VPCのテナンシー設定とは独立して動作
  tenancy = "default"

  #---------------------------------------------------------------
  # インスタンス機能設定
  #---------------------------------------------------------------
  # 設定内容: EBS最適化インスタンスのサポート有無
  # 設定可能な値: true（サポート）/ false（非サポート）
  # 省略時: インスタンスタイプのデフォルト設定に従う
  # 注意事項:
  # - 一部のインスタンスタイプはデフォルトでEBS最適化済み
  # - EBS最適化により専用ネットワーク帯域が確保される
  # - trueを指定した場合、起動するインスタンスもEBS最適化が必要
  ebs_optimized = false

  # 設定内容: エフェメラルストレージを持つインスタンスのサポート有無
  # 設定可能な値: true（サポート）/ false（非サポート）
  # 省略時: false
  # 注意事項:
  # - エフェメラルストレージ = インスタンスストア（一時的なブロックレベルストレージ）
  # - trueを指定した場合、NVMeベースのインスタンスストアをサポート
  # - 一部のインスタンスタイプのみ利用可能
  # - 非推奨属性となっており将来的に廃止予定
  ephemeral_storage = false

  #---------------------------------------------------------------
  # 配置設定
  #---------------------------------------------------------------
  # 設定内容: 容量を予約するOutpostのARN
  # 設定可能な値: OutpostのARN形式文字列
  # 省略時: 指定なし（AWS標準リージョン）
  # 注意事項:
  # - AWS Outposts環境でのみ使用
  # - Outpost ARN指定時はavailability_zoneも必須
  # - 予約後のOutpost変更は不可
  outpost_arn = "arn:aws:outposts:ap-northeast-1:123456789012:outpost/op-1234567890abcdef0"

  # 設定内容: クラスター配置グループのARN
  # 設定可能な値: 配置グループのARN形式文字列
  # 省略時: 指定なし（配置グループ未使用）
  # 注意事項:
  # - 低レイテンシが必要なHPC・MLワークロードで使用
  # - クラスター配置グループは同一AZ内で動作
  # - 予約後の配置グループ変更は不可
  placement_group_arn = "arn:aws:ec2:ap-northeast-1:123456789012:placement-group/pg-example"

  #---------------------------------------------------------------
  # 有効期限設定
  #---------------------------------------------------------------
  # 設定内容: 予約の終了タイプ
  # 設定可能な値:
  # - unlimited: 明示的にキャンセルするまで継続（デフォルト）
  # - limited: end_dateで指定した日時に自動終了
  # 省略時: unlimited
  # 注意事項:
  # - limited指定時はend_dateも必須
  # - 終了後は予約容量が解放され課金も停止
  # - 実行中のインスタンスは中断なく継続
  end_date_type = "unlimited"

  # 設定内容: 予約の終了日時
  # 設定可能な値: RFC3339形式のタイムスタンプ（例: 2024-12-31T23:59:59Z）
  # 省略時: 指定なし
  # 注意事項:
  # - end_date_type = "limited"の場合のみ有効
  # - UTC時刻で指定する必要あり
  # - 過去の日時は指定不可
  # - 最低1時間以上の予約期間が必要
  end_date = "2024-12-31T23:59:59Z"

  #---------------------------------------------------------------
  # リージョン設定
  #---------------------------------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョン
  # 注意事項:
  # - 通常はプロバイダー設定を使用するため省略推奨
  # - マルチリージョン構成で明示的な指定が必要な場合のみ使用
  region = "ap-northeast-1"

  #---------------------------------------------------------------
  # タグ設定
  #---------------------------------------------------------------
  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 注意事項:
  # - コスト配分タグとして使用可能
  # - プロバイダーのdefault_tagsと統合される
  # - 最大50個のタグまで設定可能
  tags = {
    Name        = "example-capacity-reservation"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #---------------------------------------------------------------
  # タイムアウト設定
  #---------------------------------------------------------------
  # timeouts {
  #   # 設定内容: 作成時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: 10m, 1h）
  #   # 省略時: 10m
  #   # create = "10m"
  #
  #   # 設定内容: 更新時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: 10m, 1h）
  #   # 省略時: 10m
  #   # update = "10m"
  #
  #   # 設定内容: 削除時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: 10m, 1h）
  #   # 省略時: 10m
  #   # delete = "10m"
  # }
}

#--------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#--------------------------------------------------------------
# このリソースの作成後に参照可能な属性:
#
# - id: Capacity ReservationのID（cr-xxxxxxxxxxxxxxxxx形式）
# - arn: Capacity ReservationのARN
# - owner_id: 予約を所有するAWSアカウントID
# - tags_all: プロバイダーのdefault_tagsとマージされた全タグ
