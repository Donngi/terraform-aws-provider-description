resource "aws_media_packagev2_channel_group" "example" {
  #-------------------------------------------------------------
  # チャンネルグループ識別設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: チャンネルグループを識別するための一意の名前を指定します。
  # 設定可能な値: 文字列（英数字、アンダースコア、ハイフン）、1〜256文字
  # 注意: アカウントとリージョン内で一意である必要があります。
  name = "my-channel-group"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional, Computed)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # 説明設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: チャンネルグループの目的や用途を説明するテキストを指定します。
  # 設定可能な値: 任意の文字列、0〜1024文字
  # 省略時: 説明なし
  description = "MediaPackage v2 channel group for live streaming"

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 用途: コスト管理、リソース分類、アクセス制御などに使用します。
  tags = {
    Name        = "my-channel-group"
    Environment = "production"
  }

  # tags_all (Computed)
  # 設定内容: プロバイダーの default_tags から継承されたタグを含む全タグのマップです。
  # 注意: 通常は明示的に設定せず、Terraform が自動計算します。
  # tags_all = {}
}

