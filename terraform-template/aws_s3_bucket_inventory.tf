#---------------------------------------------------------------
# Amazon S3 Bucket Inventory
#---------------------------------------------------------------
#
# Amazon S3バケットのインベントリ設定をプロビジョニングするリソースです。
# インベントリ設定では、バケット内のオブジェクトとそのメタデータのリストを
# 定期的（日次または週次）に生成し、指定した宛先バケットに CSV・ORC・Parquet
# 形式で出力します。バケットごとに最大1,000件のインベントリ設定が可能です。
# なお、S3ディレクトリバケットにはこのリソースを使用できません。
#
# AWS公式ドキュメント:
#   - Amazon S3 インベントリの設定: https://docs.aws.amazon.com/AmazonS3/latest/userguide/configure-inventory.html
#   - InventoryConfiguration API: https://docs.aws.amazon.com/AmazonS3/latest/API/API_InventoryConfiguration.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/s3_bucket_inventory
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_s3_bucket_inventory" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # bucket (Required)
  # 設定内容: インベントリリストの対象となるソースバケット名を指定します。
  # 設定可能な値: 有効なS3バケット名またはバケットID
  bucket = "my-source-bucket"

  # name (Required)
  # 設定内容: バケットのインベントリ設定の一意な識別子を指定します。
  # 設定可能な値: 文字列（英数字、ハイフン、アンダースコアを使用可能）
  name = "EntireBucketDaily"

  # included_object_versions (Required)
  # 設定内容: インベントリリストに含めるオブジェクトバージョンを指定します。
  # 設定可能な値:
  #   - "All": 全バージョンを含む。バージョン関連フィールド（VersionId、IsLatest、DeleteMarker）も出力
  #   - "Current": 現行バージョンのみ。バージョン関連フィールドは出力されない
  included_object_versions = "All"

  #-------------------------------------------------------------
  # 有効化設定
  #-------------------------------------------------------------

  # enabled (Optional)
  # 設定内容: インベントリ設定を有効化するかどうかを指定します。
  # 設定可能な値:
  #   - true (デフォルト): インベントリリストを生成する
  #   - false: インベントリリストを生成しない
  # 省略時: true
  enabled = true

  #-------------------------------------------------------------
  # オプションフィールド設定
  #-------------------------------------------------------------

  # optional_fields (Optional)
  # 設定内容: インベントリ結果に含めるオプションフィールドのリストを指定します。
  # 設定可能な値（指定可能なフィールド名のセット）:
  #   - "Size": オブジェクトのサイズ
  #   - "LastModifiedDate": 最終更新日時
  #   - "StorageClass": ストレージクラス
  #   - "ETag": オブジェクトのETag
  #   - "IsMultipartUploaded": マルチパートアップロードかどうか
  #   - "ReplicationStatus": レプリケーションステータス
  #   - "EncryptionStatus": 暗号化ステータス
  #   - "ObjectLockRetainUntilDate": オブジェクトロック保持期限日
  #   - "ObjectLockMode": オブジェクトロックモード
  #   - "ObjectLockLegalHoldStatus": オブジェクトロック法的ホールドステータス
  #   - "IntelligentTieringAccessTier": インテリジェントティアリングアクセス層
  #   - "BucketKeyStatus": バケットキーステータス
  #   - "ChecksumAlgorithm": チェックサムアルゴリズム
  #   - "ObjectAccessControlList": オブジェクトACL
  #   - "ObjectOwner": オブジェクト所有者
  # 参考: https://docs.aws.amazon.com/AmazonS3/latest/API/API_InventoryConfiguration.html#AmazonS3-Type-InventoryConfiguration-OptionalFields
  optional_fields = ["Size", "LastModifiedDate", "StorageClass", "ETag"]

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # フィルター設定
  #-------------------------------------------------------------

  # filter (Optional)
  # 設定内容: インベントリに含めるオブジェクトのフィルター設定ブロックです。
  #           フィルターの条件を満たすオブジェクトのみがインベントリに含まれます。
  filter {

    # prefix (Optional)
    # 設定内容: インベントリ対象オブジェクトのプレフィックスを指定します。
    #           指定したプレフィックスで始まるオブジェクトのみが対象となります。
    # 設定可能な値: 任意の文字列
    # 省略時: 全オブジェクトが対象
    prefix = "documents/"
  }

  #-------------------------------------------------------------
  # スケジュール設定
  #-------------------------------------------------------------

  # schedule (Required)
  # 設定内容: インベントリ結果を生成するスケジュールの設定ブロックです。
  schedule {

    # frequency (Required)
    # 設定内容: インベントリ結果を生成する頻度を指定します。
    # 設定可能な値:
    #   - "Daily": 毎日生成（最初のレポートは設定後24時間以内に利用可能）
    #   - "Weekly": 毎週生成（最初のレポートは設定後48時間以内に利用可能）
    frequency = "Daily"
  }

  #-------------------------------------------------------------
  # 宛先設定
  #-------------------------------------------------------------

  # destination (Required)
  # 設定内容: インベントリ結果の発行先に関する情報を含む設定ブロックです。
  destination {

    #-----------------------------------------------------------
    # 宛先バケット設定
    #-----------------------------------------------------------

    # bucket (Required)
    # 設定内容: インベントリ結果を発行するS3バケットの設定ブロックです。
    bucket {

      # bucket_arn (Required)
      # 設定内容: 宛先バケットのAmazon Resource Name (ARN)を指定します。
      # 設定可能な値: 有効なS3バケットARN
      # 注意: 宛先バケットはソースバケットと同じAWSリージョンに存在する必要があります。
      #       また、インベントリの書き込みを許可するバケットポリシーを宛先バケットに設定する必要があります。
      bucket_arn = "arn:aws:s3:::my-inventory-destination-bucket"

      # format (Required)
      # 設定内容: インベントリ結果の出力フォーマットを指定します。
      # 設定可能な値:
      #   - "CSV": カンマ区切りテキスト形式
      #   - "ORC": Apache ORC形式（列指向フォーマット。圧縮率が高い）
      #   - "Parquet": Apache Parquet形式（列指向フォーマット。分析クエリに最適）
      format = "ORC"

      # account_id (Optional)
      # 設定内容: 宛先バケットを所有するアカウントIDを指定します。
      # 設定可能な値: 有効なAWSアカウントID（12桁の数字）
      # 省略時: 未設定
      # 注意: 宛先バケットの所有権が変更された場合の問題を防ぐため、設定を推奨します。
      account_id = "123456789012"

      # prefix (Optional)
      # 設定内容: 全インベントリ結果ファイルの先頭に付与するプレフィックスを指定します。
      # 設定可能な値: 任意の文字列
      # 省略時: プレフィックスなし
      prefix = "inventory"

      #---------------------------------------------------------
      # 暗号化設定
      #---------------------------------------------------------

      # encryption (Optional)
      # 設定内容: インベントリファイルのサーバーサイド暗号化の設定ブロックです。
      #           sse_kms または sse_s3 のいずれか一方を指定します。
      encryption {

        #-------------------------------------------------------
        # SSE-KMS暗号化設定
        #-------------------------------------------------------

        # sse_kms (Optional)
        # 設定内容: AWS KMS管理キーを使用したサーバーサイド暗号化（SSE-KMS）の設定ブロックです。
        # 注意: sse_s3 と排他的（どちらか一方のみ指定可能）
        sse_kms {

          # key_id (Required)
          # 設定内容: インベントリファイルの暗号化に使用するKMSカスタマーマスターキー（CMK）のARNを指定します。
          # 設定可能な値: 有効なKMSキーARN
          key_id = "arn:aws:kms:ap-northeast-1:123456789012:key/12345678-1234-1234-1234-123456789012"
        }

        #-------------------------------------------------------
        # SSE-S3暗号化設定
        #-------------------------------------------------------

        # sse_s3 (Optional)
        # 設定内容: Amazon S3管理キーを使用したサーバーサイド暗号化（SSE-S3）の設定ブロックです。
        #           設定内容なし（空ブロック）で有効化されます。
        # 注意: sse_kms と排他的（どちらか一方のみ指定可能）
        # sse_s3 {}
      }
    }
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: インベントリ設定の識別子
#       {bucket}:{name} 形式の文字列
#---------------------------------------------------------------
