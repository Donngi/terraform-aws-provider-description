#---------------------------------------------------------------
# IAM Group Membership
#---------------------------------------------------------------
#
# IAMグループに対するユーザーのメンバーシップを管理するリソース。
# 指定したIAMグループに複数のIAMユーザーを一括で追加します。
#
# 重要な注意事項:
#   - 同じグループ名で複数のaws_iam_group_membershipリソースを使用すると
#     競合が発生し、予期しない動作を引き起こします
#   - 排他的な管理となるため、このリソースで指定したユーザー以外は
#     グループから削除されます
#   - 非排他的にユーザーとグループの関係を管理したい場合は
#     aws_iam_user_group_membershipリソースを使用してください
#
# AWS公式ドキュメント:
#   - IAM Groups: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_groups.html
#   - Edit users in IAM groups: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_groups_manage_add-remove-users.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/iam_group_membership
#
# Provider Version: 6.28.0
# Generated: 2026-01-27
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iam_group_membership" "example" {
  #---------------------------------------------------------------
  # 必須パラメータ
  #---------------------------------------------------------------

  # name - (Required) グループメンバーシップを識別するための名前。
  #
  # この名前はTerraform内でこのメンバーシップリソースを識別するためのもので、
  # AWS IAM上のグループ名やユーザー名とは独立した識別子です。
  # グループとユーザーの関係を説明する分かりやすい名前を付けることを推奨します。
  #
  # 例: "developers-group-membership", "admins-team-membership"
  #
  # Type: string
  name = "example-group-membership"

  # group - (Required) ユーザーリストを関連付けるIAMグループの名前。
  #
  # 既存のIAMグループの名前を指定します。このグループに対して、
  # usersパラメータで指定したユーザーが追加されます。
  # グループが存在しない場合はエラーになります。
  #
  # 注意: 同じグループに対して複数のaws_iam_group_membershipリソースを
  #       定義すると競合が発生します。1つのグループに対しては1つの
  #       メンバーシップリソースのみを使用してください。
  #
  # Type: string
  group = aws_iam_group.example.name

  # users - (Required) グループに関連付けるIAMユーザー名のリスト。
  #
  # グループに追加したいIAMユーザーの名前をセット形式で指定します。
  # このリソースは排他的な管理を行うため、ここに指定されていない
  # ユーザーはグループから削除されます。
  #
  # 空のリストを指定することも可能ですが、その場合はグループから
  # 全てのユーザーが削除されます。
  #
  # 例:
  #   users = [
  #     aws_iam_user.developer1.name,
  #     aws_iam_user.developer2.name,
  #   ]
  #
  # Type: set(string)
  users = [
    aws_iam_user.example.name,
  ]

  #---------------------------------------------------------------
  # オプションパラメータ
  #---------------------------------------------------------------

  # 現在、このリソースには追加のオプションパラメータはありません。

  #---------------------------------------------------------------
  # 注意事項・ベストプラクティス
  #---------------------------------------------------------------

  # 1. 排他的管理
  #    このリソースはグループメンバーシップを排他的に管理します。
  #    usersに指定されていないユーザーは自動的にグループから削除されます。
  #
  # 2. 競合の回避
  #    1つのIAMグループに対して複数のaws_iam_group_membershipリソースを
  #    定義しないでください。競合が発生し、予期しない動作を引き起こします。
  #
  # 3. 非排他的な管理が必要な場合
  #    複数のリソースやモジュールで同じグループのメンバーシップを管理したい
  #    場合は、aws_iam_user_group_membershipリソースの使用を検討してください。
  #    これにより、ユーザー側からグループへの参加を管理できます。
  #
  # 4. グループとユーザーの存在
  #    指定するgroupとusersは既に存在している必要があります。
  #    Terraformで同時に作成する場合は、依存関係が正しく設定されていることを
  #    確認してください（通常は参照により自動的に依存関係が作成されます）。
}

