# ================================================================================
# AWS Security Hub Organization Admin Account
# ================================================================================
# Security Hub組織の管理者アカウントを管理します。
# このリソースを利用するAWSアカウントはOrganizationsのプライマリアカウントである必要があります。
#
# 【重要な前提条件】
# - AWS Organizationsが有効化されていること
# - Security Hubサービスへのアクセスが組織レベルで許可されていること
# - 管理者として指定するアカウントでSecurity Hubが有効化されていること
#
# 【参考URL】
# - https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/securityhub_organization_admin_account
# - https://docs.aws.amazon.com/securityhub/latest/userguide/designate-orgs-admin-account.html
# ================================================================================

# --------------------------------------------------------------------------------
# Security Hub Organization Admin Account
# --------------------------------------------------------------------------------
# Security Hub組織の管理者アカウントを指定します。
# 管理者アカウントは、組織全体のセキュリティ状態を一元管理できます。
# --------------------------------------------------------------------------------
resource "aws_securityhub_organization_admin_account" "example" {
  # ------------------------------------------------------------
  # 管理者アカウントID (必須)
  # ------------------------------------------------------------
  # Security Hub管理者として指定するAWSアカウントIDを設定します。
  #
  # 【設定値】12桁のAWSアカウントID
  # 【設定例】"123456789012"
  #
  # 【注意事項】
  # - 指定するアカウントは組織のメンバーアカウントである必要があります
  # - 管理者アカウントでは事前にSecurity Hubが有効化されている必要があります
  # - 組織ごとに1つの管理者アカウントのみ指定できます
  #
  # 【運用上の考慮点】
  # - 管理者アカウントは組織全体のセキュリティ結果を集約・分析します
  # - セキュリティチームがアクセス可能なアカウントを指定することを推奨します
  # - 管理者アカウントの変更は慎重に行う必要があります
  # ------------------------------------------------------------
  admin_account_id = "123456789012" # 実際のアカウントIDに置き換えてください

  # ------------------------------------------------------------
  # リージョン (オプション)
  # ------------------------------------------------------------
  # このリソースを管理するAWSリージョンを指定します。
  # 指定しない場合、プロバイダー設定のリージョンが使用されます。
  #
  # 【設定値】AWSリージョンコード
  # 【設定例】"us-east-1", "ap-northeast-1"
  # 【デフォルト】プロバイダー設定のリージョン
  #
  # 【注意事項】
  # - Security Hubは各リージョンで個別に管理されます
  # - 複数リージョンで使用する場合は、リージョンごとに本リソースを定義します
  # - Security Hubの集約リージョンとして使用する場合が多いです
  # ------------------------------------------------------------
  # region = "us-east-1"

  # ------------------------------------------------------------
  # 依存関係の管理
  # ------------------------------------------------------------
  # Security Hub組織管理者を指定する前に、以下が完了している必要があります:
  # 1. AWS Organizationsの有効化
  # 2. Security Hubサービスへのアクセス許可
  # 3. 管理者アカウントでのSecurity Hub有効化
  #
  # 【推奨される依存関係設定】
  # depends_on = [
  #   aws_organizations_organization.example,
  #   aws_securityhub_account.example
  # ]
  # ------------------------------------------------------------
}

# ================================================================================
# 出力値 (Computed Attributes)
# ================================================================================
# 以下の属性は、リソース作成後に参照可能です:
#
# - id: AWSアカウント識別子（admin_account_idと同じ値）
#
# 【使用例】
# output "admin_account_id" {
#   description = "Security Hub管理者アカウントID"
#   value       = aws_securityhub_organization_admin_account.example.id
# }
# ================================================================================

# ================================================================================
# 関連リソースの設定例
# ================================================================================
# Security Hub組織管理者の設定には、通常以下のリソースと組み合わせて使用します:
#
# 1. AWS Organizations の有効化
# ----------------------------------------
# resource "aws_organizations_organization" "example" {
#   aws_service_access_principals = ["securityhub.amazonaws.com"]
#   feature_set                   = "ALL"
# }
#
# 2. Security Hub アカウントの有効化
# ----------------------------------------
# resource "aws_securityhub_account" "example" {}
#
# 3. 組織メンバーでのSecurity Hub自動有効化
# ----------------------------------------
# resource "aws_securityhub_organization_configuration" "example" {
#   auto_enable           = true
#   auto_enable_standards = "DEFAULT"
#
#   organization_configuration {
#     configuration_type = "CENTRAL"
#   }
# }
#
# 4. Security Hubスタンダードの有効化
# ----------------------------------------
# resource "aws_securityhub_standards_subscription" "cis" {
#   standards_arn = "arn:aws:securityhub:us-east-1::standards/cis-aws-foundations-benchmark/v/1.4.0"
#
#   depends_on = [aws_securityhub_account.example]
# }
# ================================================================================

# ================================================================================
# ベストプラクティス
# ================================================================================
# 1. 管理者アカウントの選定
#    - セキュリティチームが管理する専用アカウントを推奨
#    - 本番ワークロードと分離したアカウントを使用
#
# 2. マルチリージョン対応
#    - 使用する全てのリージョンで管理者アカウントを設定
#    - 必要に応じて集約リージョンを設定
#
# 3. 自動化とコンプライアンス
#    - auto_enableを使用して新規アカウントを自動的に保護
#    - Security Hubスタンダードを適切に選択・有効化
#
# 4. アクセス管理
#    - 管理者アカウントへのアクセスを最小限に制限
#    - IAMロールを使用した適切な権限管理を実施
#
# 5. モニタリングと対応
#    - Security Hub検出結果の定期的なレビュー
#    - EventBridgeを使用した自動対応の検討
# ================================================================================

# ================================================================================
# 削除時の注意事項
# ================================================================================
# このリソースを削除する場合の注意点:
#
# 1. 管理者アカウントの削除により、組織レベルのSecurity Hub管理が無効化されます
# 2. メンバーアカウントのSecurity Hub設定は維持されますが、一元管理はできなくなります
# 3. 削除前に、組織構成やセキュリティ管理体制への影響を確認してください
# 4. 新しい管理者アカウントを設定する場合は、削除後に再度リソースを作成します
# ================================================================================
