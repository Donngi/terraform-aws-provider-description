#-----------------------------------------------------------------------
# EC2 Secondary Network
#-----------------------------------------------------------------------
# NOTE: このファイルは参照用テンプレートです。実際の使用前に環境に合わせた調整が必要です。
# Provider Version: 6.36.0
# Generated: 2026-03-18
#
# 概要: RDMA（Remote Direct Memory Access）ネットワーキング用のセカンダリネットワークを
# 作成するリソース。高性能コンピューティング（HPC）やML/AIワークロード向けに、
# 低レイテンシ・高帯域幅の専用ネットワークインフラを提供します。
#
# 主な用途:
# - HPCクラスターにおけるノード間の高速RDMA通信
# - 大規模MLモデルの分散トレーニングにおけるパラメータ同期
# - 低レイテンシが要求されるリアルタイムデータ処理
# - GPUクラスター間の高帯域幅通信
#
# 制約事項:
# - ネットワークタイプは現在 "rdma" のみサポート
# - CIDRブロックサイズは /12 から /28 の範囲で指定
# - RDMA対応インスタンスタイプ（P5, Trn1等）での利用が前提
#
# 関連リソース:
# - aws_vpc: メインVPCネットワーク
# - aws_instance: RDMA対応EC2インスタンス
# - aws_ec2_capacity_block_reservation: GPU容量の事前予約
#
# Terraform Registry:
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_secondary_network
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# ネットワーク設定
#-----------------------------------------------------------------------
resource "aws_ec2_secondary_network" "example" {
  # IPv4 CIDRブロック（必須）
  # 設定内容: セカンダリネットワークに割り当てるIPv4 CIDRブロック
  # 設定可能な値: /12 から /28 の範囲のCIDRブロック（例: "10.0.0.0/16", "172.16.0.0/12"）
  # 変更時の影響: リソースの再作成が発生
  ipv4_cidr_block = "10.0.0.0/16"

  # ネットワークタイプ（必須）
  # 設定内容: セカンダリネットワークの種類
  # 設定可能な値: "rdma"（現在はRDMAのみサポート）
  # 変更時の影響: リソースの再作成が発生
  network_type = "rdma"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # リージョン指定（オプション）
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用される
  # 備考: マルチリージョン構成で明示的にリージョンを指定する場合に設定
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # リソースタグ
  # 設定内容: セカンダリネットワークに付与するタグのマップ
  # 省略時: タグなし（プロバイダーのdefault_tagsは自動適用）
  # 推奨事項: 環境識別、コスト配分、用途などの情報をタグで管理
  tags = {
    Name        = "rdma-secondary-network"
    Environment = "production"
    Workload    = "hpc-ml-training"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------
  timeouts {
    # 設定内容: セカンダリネットワーク作成処理のタイムアウト時間
    # 省略時: デフォルトのタイムアウト値を使用
    # 形式: "30s", "5m", "1h"等の時間文字列
    # create = "10m"

    # 設定内容: セカンダリネットワーク更新処理のタイムアウト時間
    # 省略時: デフォルトのタイムアウト値を使用
    # update = "10m"

    # 設定内容: セカンダリネットワーク削除処理のタイムアウト時間
    # 省略時: デフォルトのタイムアウト値を使用
    # delete = "10m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference (参照専用属性)
#-----------------------------------------------------------------------
# このリソース作成後に参照可能な値:
#
# id                          - セカンダリネットワークのID
# arn                         - セカンダリネットワークのARN
# secondary_network_id        - セカンダリネットワークのID
# state                       - セカンダリネットワークの現在の状態
# owner_id                    - 所有者のAWSアカウントID
# ipv4_cidr_block_associations - IPv4 CIDRブロックの関連付けリスト
#   association_id             - 関連付けID
#   cidr_block                 - IPv4 CIDRブロック
#   state                      - 関連付けの状態
# tags_all                    - プロバイダーのdefault_tagsを含む全タグ
#
# 参照例:
#   aws_ec2_secondary_network.example.arn
#   aws_ec2_secondary_network.example.secondary_network_id
#-----------------------------------------------------------------------

terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.36.0"
    }
  }
}
