#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iam_account_alias" "example" {
  #-------------------------------------------------------------
  # エイリアス設定
  #-------------------------------------------------------------

  # account_alias (Required)
  # 設定内容: AWSアカウントに割り当てるエイリアス名を指定します。
  #           設定したエイリアスはAWSマネジメントコンソールのサインインURLに使用されます。
  #           例: https://{account_alias}.signin.aws.amazon.com/console
  # 設定可能な値: 3〜63文字の小文字英数字またはハイフン（-）の文字列。
  #              ハイフンを連続して使用することはできません。
  #              先頭・末尾にハイフンを使用することはできません。
  # 参考: https://docs.aws.amazon.com/IAM/latest/UserGuide/account-alias-create.html
  account_alias = "my-account-alias"
}

