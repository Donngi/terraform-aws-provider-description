#---------------------------------------
# AWS Firewall Manager 管理者アカウント
#---------------------------------------
# AWS Firewall Managerの管理者アカウントを関連付け/関連付け解除するリソース。
# この操作は必ず us-east-1 リージョンで実行する必要があります。
# Organizations のマスターアカウントまたはメンバーアカウントを管理者として指定できます。
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/fms_admin_account
#
# NOTE: この操作は us-east-1 リージョンで実行する必要があります。
#       管理者アカウントを削除すると、組織内の全てのFirewall Managerポリシーが無効化されます。

resource "aws_fms_admin_account" "example" {
  #---------------------------------------
  # 管理者アカウント設定
  #---------------------------------------

  # 設定内容: AWS Firewall Manager管理者として関連付けるAWSアカウントID
  # 設定可能な値: 有効なAWSアカウントID（12桁の数字）
  # 省略時: 現在のアカウントIDが使用される
  # 注意: ドリフト検出を実行する場合は明示的に指定が必要
  account_id = "123456789012"

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  timeouts {
    # 設定内容: リソース作成時のタイムアウト時間
    # 設定可能な値: Go言語の時間形式（例: "30m", "1h"）
    # 省略時: デフォルトのタイムアウト値が適用される
    create = "30m"

    # 設定内容: リソース削除時のタイムアウト時間
    # 設定可能な値: Go言語の時間形式（例: "30m", "1h"）
    # 省略時: デフォルトのタイムアウト値が適用される
    delete = "30m"
  }
}

#---------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# - id
#   AWS Firewall Manager管理者アカウントのAWSアカウントID
