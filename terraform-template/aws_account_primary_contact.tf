#---------------------------------------
# aws_account_primary_contact
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-11
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/account_primary_contact
#
# NOTE:
# AWSアカウントのプライマリ連絡先情報を管理します
# このリソースは、アカウントに関連付けられた主要な連絡先の情報を設定するために使用されます
#
# 主な用途:
# - AWSアカウントのプライマリ連絡先情報の登録と管理
# - メンバーアカウントの連絡先情報の一元管理
# - 企業の正式な連絡先情報の設定
#
# 制約事項:
# - 電話番号は検証され、一部の国では有効化がチェックされます
# - 国コードはISO-3166の2文字コードを使用する必要があります
# - 一部の国では州/地域の指定が必須となります

#---------------------------------------
# リソース定義
#---------------------------------------

resource "aws_account_primary_contact" "example" {

  #---------------------------------------
  # 基本情報
  #---------------------------------------

  # 設定内容: プライマリ連絡先のフルネーム
  # 設定可能な値: 任意の文字列
  # 省略時: 設定必須
  full_name = "Example User"

  # 設定内容: プライマリ連絡先の電話番号
  # 設定可能な値: 国際電話番号形式（例: +64211111111）
  # 省略時: 設定必須
  phone_number = "+1234567890"

  #---------------------------------------
  # 住所情報
  #---------------------------------------

  # 設定内容: 住所の1行目
  # 設定可能な値: 任意の文字列
  # 省略時: 設定必須
  address_line_1 = "123 Main Street"

  # 設定内容: 住所の2行目
  # 設定可能な値: 任意の文字列
  # 省略時: null（設定不要）
  address_line_2 = "Suite 100"

  # 設定内容: 住所の3行目
  # 設定可能な値: 任意の文字列
  # 省略時: null（設定不要）
  address_line_3 = "Building A"

  # 設定内容: 都市名
  # 設定可能な値: 任意の文字列
  # 省略時: 設定必須
  city = "Seattle"

  # 設定内容: 郵便番号
  # 設定可能な値: 任意の文字列
  # 省略時: 設定必須
  postal_code = "98101"

  # 設定内容: 国コード
  # 設定可能な値: ISO-3166の2文字国コード（例: US, JP, GB）
  # 省略時: 設定必須
  country_code = "US"

  # 設定内容: 州または地域
  # 設定可能な値: 任意の文字列
  # 省略時: null（一部の国では必須）
  state_or_region = "WA"

  # 設定内容: 地区または郡
  # 設定可能な値: 任意の文字列
  # 省略時: null（設定不要）
  district_or_county = "King"

  #---------------------------------------
  # 組織情報
  #---------------------------------------

  # 設定内容: 会社名
  # 設定可能な値: 任意の文字列
  # 省略時: null（設定不要）
  company_name = "Example Corporation"

  # 設定内容: ウェブサイトURL
  # 設定可能な値: 有効なURL形式の文字列
  # 省略時: null（設定不要）
  website_url = "https://www.example.com"

  #---------------------------------------
  # アカウント管理
  #---------------------------------------

  # 設定内容: 対象アカウントID
  # 設定可能な値: AWSアカウントID（12桁の数字）
  # 省略時: 現在のユーザーのアカウントを管理
  account_id = "123456789012"

}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# - id
#   リソースの識別子（通常はアカウントIDと同じ）
#
# 参照例:
# output "primary_contact_id" {
#   value = aws_account_primary_contact.example.id
# }
