#---------------------------------------------------------------
# AWS KMS マルチリージョンレプリカキー
#---------------------------------------------------------------
#
# AWS Key Management Service (KMS) のマルチリージョンレプリカキーを
# プロビジョニングするリソースです。
# マルチリージョンキーは、異なるAWSリージョンに同一のキーマテリアルと
# キーIDを持つKMSキーを配置し、リージョンをまたいだ暗号化・復号を
# 再暗号化なしで実行できるようにします。
# レプリカキーはプライマリキーと同じキーIDを共有しますが、ARNや
# キーポリシーはリージョンごとに独立して管理されます。
#
# AWS公式ドキュメント:
#   - マルチリージョンキーの概要: https://docs.aws.amazon.com/kms/latest/developerguide/multi-region-keys-overview.html
#   - レプリカキーの作成: https://docs.aws.amazon.com/kms/latest/developerguide/multi-region-keys-replicate.html
#   - マルチリージョンキーのアクセス制御: https://docs.aws.amazon.com/kms/latest/developerguide/multi-region-keys-auth.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/kms_replica_key
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_kms_replica_key" "example" {
  #-------------------------------------------------------------
  # プライマリキー設定
  #-------------------------------------------------------------

  # primary_key_arn (Required)
  # 設定内容: レプリケート元となるマルチリージョンプライマリキーのARNを指定します。
  # 設定可能な値: 有効なKMSマルチリージョンプライマリキーのARN
  # 注意: プライマリキーは同一AWSパーティション内の異なるリージョンに存在する必要があります。
  #       各リージョンにはプライマリキーのレプリカを1つだけ作成できます。
  #       プライマリキーは multi_region = true で作成されている必要があります。
  # 参考: https://docs.aws.amazon.com/kms/latest/developerguide/multi-region-keys-overview.html
  primary_key_arn = "arn:aws:kms:us-east-1:123456789012:key/mrk-1234abcd12ab34cd56ef1234567890ab"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-west-2）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: KMSレプリカキーの説明を指定します。
  # 設定可能な値: 0-8192文字の文字列
  # 省略時: 空の説明が設定されます。
  # 注意: 説明にはCloudTrailログやその他の出力に表示される可能性があるため、
  #       機密情報や個人情報を含めないようにしてください。
  description = "Multi-Region replica key"

  # enabled (Optional)
  # 設定内容: レプリカキーを有効にするかを指定します。
  # 設定可能な値:
  #   - true (デフォルト): キーを有効化。暗号化オペレーションに使用可能
  #   - false: キーを無効化。無効化されたキーは暗号化オペレーションに使用できません
  # 省略時: true（キーは有効状態で作成されます）
  enabled = true

  #-------------------------------------------------------------
  # キーポリシー設定
  #-------------------------------------------------------------

  # policy (Optional)
  # 設定内容: KMSレプリカキーに適用するキーポリシーをJSON形式で指定します。
  # 設定可能な値: 有効なIAMポリシードキュメントのJSON文字列
  # 省略時: AWSのデフォルトキーポリシーが適用されます。
  #         デフォルトポリシーはAWSアカウントのルートユーザーにキーへのフルアクセスを許可します。
  # 注意: キーポリシーには、後続のPutKeyPolicy操作を実行する主体を許可する記述が必要です。
  #       ポリシーサイズは32KB以下である必要があります。
  # 参考: https://docs.aws.amazon.com/kms/latest/developerguide/key-policies.html
  policy = null

  # bypass_policy_lockout_safety_check (Optional)
  # 設定内容: キーポリシーのロックアウト安全チェックをバイパスするかを指定します。
  # 設定可能な値:
  #   - false (デフォルト): 安全チェックを実施。キーが管理不能になるリスクを防止
  #   - true: 安全チェックをバイパス。KMSキーが管理不能になるリスクが増大するため、
  #           慎重に使用してください
  # 省略時: false（安全チェックが有効）
  # 参考: https://docs.aws.amazon.com/kms/latest/developerguide/key-policies.html#key-policy-default-allow-root-enable-iam
  bypass_policy_lockout_safety_check = false

  #-------------------------------------------------------------
  # 削除設定
  #-------------------------------------------------------------

  # deletion_window_in_days (Optional)
  # 設定内容: キー削除前の待機期間を日数で指定します。
  #           待機期間終了後、AWS KMSはKMSキーを削除します。
  # 設定可能な値: 7〜30（整数）
  # 省略時: 30（30日間の待機期間が設定されます）
  # 注意: 削除スケジュール設定後もキャンセルが可能ですが、
  #       削除完了後は復元できません。
  deletion_window_in_days = 30

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: レプリカキーに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # 注意: プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルのタグを上書きします。
  #       タグにはCloudTrailログなどの出力に表示される可能性があるため、
  #       機密情報を含めないようにしてください。
  tags = {
    Name        = "my-replica-key"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: レプリカキーのAmazon Resource Name (ARN)。
#        関連するマルチリージョンキーのARNはリージョン値のみが異なります。
#
# - key_id: レプリカキーのキーID。
#           関連するマルチリージョンキーは同一のキーIDを共有します。
#
# - key_rotation_enabled: キーローテーションが有効かを示すブール値。
#                         マルチリージョンキーの共有プロパティです。
#
# - key_spec: KMSキー内のキーマテリアルの種類。
#             マルチリージョンキーの共有プロパティです。
#
# - key_usage: KMSキーで実行可能な暗号化オペレーション。
#              マルチリージョンキーの共有プロパティです。
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
