#---------------------------------------------------------------
# AWS MediaLive Multiplex
#---------------------------------------------------------------
#
# Amazon MediaLive のマルチプレックスをプロビジョニングするリソースです。
# マルチプレックスは複数のビデオストリームを1つのトランスポートストリームに
# 多重化するサービスであり、DVBやATSCなどの放送規格に準拠したコンテンツ配信に使用されます。
# マルチプレックスは複数のプログラムを束ねて、複数のリージョンにある視聴者へ
# 効率的にコンテンツを配信するために利用されます。
#
# AWS公式ドキュメント:
#   - マルチプレックスの概要: https://docs.aws.amazon.com/medialive/latest/ug/eml-multiplex.html
#   - マルチプレックスの作成: https://docs.aws.amazon.com/medialive/latest/ug/creating-multiplex.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/medialive_multiplex
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_medialive_multiplex" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: マルチプレックスの名前を指定します。
  # 設定可能な値: 任意の文字列
  name = "example-multiplex"

  # availability_zones (Required)
  # 設定内容: マルチプレックスを展開するアベイラビリティーゾーンのリストを指定します。
  # 設定可能な値: 2つのアベイラビリティーゾーン文字列のリスト（例: ["ap-northeast-1a", "ap-northeast-1c"]）
  # 注意: マルチプレックスは高可用性のため必ず2つのアベイラビリティーゾーンを指定する必要があります。
  #       指定したリージョンでサポートされているアベイラビリティーゾーンを選択してください。
  availability_zones = [
    "us-east-1a",
    "us-east-1b",
  ]

  # start_multiplex (Optional)
  # 設定内容: マルチプレックスを作成後すぐに起動するかどうかを指定します。
  # 設定可能な値: true（作成後に自動起動）, false（作成後に停止状態を維持）
  # 省略時: false（マルチプレックスは停止状態で作成されます）
  # 注意: true に設定すると課金が発生します。不要な場合は false のままにしてください。
  start_multiplex = false

  #-------------------------------------------------------------
  # マルチプレックス設定
  #-------------------------------------------------------------

  # multiplex_settings (Required)
  # 設定内容: マルチプレックスのトランスポートストリーム設定を指定します。
  # 設定可能な値: 以下の属性を含む1つのブロック
  multiplex_settings {
    # transport_stream_bitrate (Required)
    # 設定内容: トランスポートストリームのビットレートをbps単位で指定します。
    # 設定可能な値: 1,000,000（1Mbps）から100,000,000（100Mbps）の整数
    # 注意: このビットレートはすべてのプログラムが共有します。
    #       各プログラムの合計ビットレートがこの値を超えないように設定してください。
    transport_stream_bitrate = 10000000

    # transport_stream_id (Required)
    # 設定内容: トランスポートストリームのIDを指定します。
    # 設定可能な値: 0から65535の整数
    # 注意: このIDはトランスポートストリームを一意に識別するために使用されます。
    transport_stream_id = 1

    # transport_stream_reserved_bitrate (Optional)
    # 設定内容: トランスポートストリームの予約済みビットレートをbps単位で指定します。
    # 設定可能な値: 0以上の整数（transport_stream_bitrate以下である必要があります）
    # 省略時: 0（予約済みビットレートなし）
    # 用途: 非サービスデータ用に一部のビットレートを予約したい場合に使用します。
    transport_stream_reserved_bitrate = 0

    # maximum_video_buffer_delay_milliseconds (Optional)
    # 設定内容: 最大ビデオバッファ遅延をミリ秒単位で指定します。
    # 設定可能な値: 800から3000のミリ秒単位の整数
    # 省略時: 1000（1秒）
    # 用途: バッファ遅延を調整することでネットワーク輻輳への耐性を向上できます。
    maximum_video_buffer_delay_milliseconds = 1000
  }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: マルチプレックスに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  #   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs#default_tags-configuration-block
  tags = {
    Name        = "example-multiplex"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: リソース作成のタイムアウト時間を指定します。
    # 設定可能な値: 期間を表す文字列（例: "5m", "1h"）
    create = null

    # update (Optional)
    # 設定内容: リソース更新のタイムアウト時間を指定します。
    # 設定可能な値: 期間を表す文字列（例: "5m", "1h"）
    update = null

    # delete (Optional)
    # 設定内容: リソース削除のタイムアウト時間を指定します。
    # 設定可能な値: 期間を表す文字列（例: "5m", "1h"）
    delete = null
  }
}

