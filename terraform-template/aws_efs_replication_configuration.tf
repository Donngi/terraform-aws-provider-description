#---------------------------------------
# EFSレプリケーション設定
#---------------------------------------
# Resource: aws_efs_replication_configuration
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# 説明: 既存のEFSファイルシステムのレプリカを同一または別のリージョンに作成します。
#       このリソースを作成すると、ソースEFSファイルシステムが新しい読み取り専用のレプリケート先EFSファイルシステムにレプリケートされます。
#       このリソースを削除すると、ソースからレプリケート先へのレプリケーションが停止し、レプリケート先ファイルシステムは読み取り専用ではなくなります。
#
# NOTE: このリソースを削除しても、作成されたレプリケート先ファイルシステムは削除されません。
#
# 公式ドキュメント: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/efs_replication_configuration
#---------------------------------------

#---------------------------------------
# リソース定義
#---------------------------------------
resource "aws_efs_replication_configuration" "example" {
  #---------------------------------------
  # 必須項目
  #---------------------------------------

  # ソースファイルシステムID
  # 設定内容: レプリケート元となるEFSファイルシステムのID
  # 設定例: aws_efs_file_system.example.id
  source_file_system_id = "fs-12345678"

  #---------------------------------------
  # レプリケーション先設定
  #---------------------------------------

  destination {
    # レプリケート先リージョン
    # 設定内容: レプリカを作成するリージョンを指定します
    # 設定可能な値: AWSリージョンコード（例: us-west-2, ap-northeast-1）
    # 省略時: プロバイダー設定のリージョンが使用されます
    region = "us-west-2"

    # アベイラビリティゾーン名
    # 設定内容: レプリカを作成するアベイラビリティゾーンを指定すると、One Zoneストレージでレプリカが作成されます
    # 設定可能な値: AZの名前（例: us-west-2b）
    # 省略時: リージョナルストレージが使用されます
    # availability_zone_name = "us-west-2b"

    # レプリケート先ファイルシステムID
    # 設定内容: レプリケート先として使用する既存のファイルシステムのIDを指定します
    # 省略時: EFSがデフォルト設定で新しいファイルシステムを作成します
    # file_system_id = "fs-87654321"

    # KMSキーID
    # 設定内容: レプリカファイルシステムの暗号化に使用するKMSキーのID、ARN、エイリアス、またはエイリアスARNを指定します
    # 設定可能な値: KMSキーID、ARN、alias/key-name、arn:aws:kms:region:account-id:alias/key-name
    # 省略時: EFSのデフォルトKMSキー /aws/elasticfilesystem が使用されます
    # kms_key_id = "arn:aws:kms:us-west-2:123456789012:key/1234abcd-12ab-34cd-56ef-1234567890ab"
  }

  #---------------------------------------
  # リソース管理リージョン設定
  #---------------------------------------

  # 管理リージョン
  # 設定内容: このリソースを管理するリージョンを指定します
  # 設定可能な値: AWSリージョンコード（例: us-east-1, eu-west-1）
  # 省略時: プロバイダー設定のリージョンが使用されます
  # region = "us-east-1"

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  # timeouts {
  #   # 作成タイムアウト
  #   # 設定内容: レプリケーション設定の作成時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: 30m, 1h）
  #   # 省略時: 20m
  #   create = "30m"
  #
  #   # 削除タイムアウト
  #   # 設定内容: レプリケーション設定の削除時のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: 30m, 1h）
  #   # 省略時: 20m
  #   delete = "30m"
  # }
}

#---------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------
# このリソースから以下の値を参照できます:
#
# 基本情報:
# - creation_time: レプリケーション設定が作成された日時
# - source_file_system_arn: 現在のソースファイルシステムのARN
# - source_file_system_region: ソースファイルシステムが配置されているリージョン
# - original_source_file_system_arn: レプリケーション設定における元のソースファイルシステムのARN
#
# レプリケート先情報:
# - destination[0].file_system_id: レプリカのファイルシステムID
# - destination[0].status: レプリケーションのステータス
# - destination[0].region: レプリカが配置されているリージョン
#
# 参照例:
# aws_efs_replication_configuration.example.destination[0].file_system_id
