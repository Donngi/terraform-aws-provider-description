################################################################################
# AWS Signer Signing Profile Permission
# Resource: aws_signer_signing_profile_permission
# Provider Version: 6.28.0
#
# Description:
# Creates a Signer Signing Profile Permission. That is, a cross-account
# permission for a signing profile.
#
# Use Cases:
# - Grant cross-account access to signing profiles
# - Allow other AWS accounts to start signing jobs
# - Enable signature revocation from other accounts
# - Provide read access to signing profiles
################################################################################

resource "aws_signer_signing_profile_permission" "example" {
  #-----------------------------------------------------------------------------
  # REQUIRED PARAMETERS
  # These parameters must be configured for the resource to work properly
  #-----------------------------------------------------------------------------

  # profile_name - (Required)
  # Name of the signing profile to add the cross-account permissions.
  #
  # Type: string
  # Example: "my-signing-profile"
  # Reference: aws_signer_signing_profile.prod_sp.name
  profile_name = "REPLACE_WITH_PROFILE_NAME"

  # action - (Required)
  # An AWS Signer action permitted as part of cross-account permissions.
  #
  # Type: string
  # Valid values:
  #   - "signer:StartSigningJob"   - Allow starting signing jobs
  #   - "signer:GetSigningProfile" - Allow reading signing profile details
  #   - "signer:RevokeSignature"   - Allow revoking signatures
  #   - "signer:SignPayload"       - Allow signing payloads
  #
  # Example: "signer:StartSigningJob"
  action = "signer:StartSigningJob"

  # principal - (Required)
  # The AWS principal to be granted a cross-account permission.
  #
  # Type: string
  # Format: Can be an AWS account ID, IAM role ARN, or IAM user ARN
  #
  # Examples:
  #   - "123456789012"                                    (AWS Account ID)
  #   - "arn:aws:iam::123456789012:role/MyRole"         (IAM Role ARN)
  #   - "arn:aws:iam::123456789012:user/MyUser"         (IAM User ARN)
  principal = "REPLACE_WITH_PRINCIPAL"

  #-----------------------------------------------------------------------------
  # OPTIONAL PARAMETERS
  # These parameters have sensible defaults or are optional
  #-----------------------------------------------------------------------------

  # profile_version - (Optional, Computed)
  # The signing profile version that a permission applies to.
  # If not specified, the permission applies to all versions.
  #
  # Type: string
  # Default: Applies to all versions if not specified
  # Computed: Yes - AWS generates a version if not specified
  #
  # Example: "a1b2c3d4"
  # Reference: aws_signer_signing_profile.prod_sp.version
  # profile_version = "REPLACE_WITH_VERSION"

  # statement_id - (Optional, Computed)
  # A unique statement identifier.
  # If not specified, Terraform will generate one automatically.
  # Conflicts with: statement_id_prefix
  #
  # Type: string
  # Default: Auto-generated by Terraform
  # Computed: Yes
  #
  # Example: "ProdAccountStartSigningJob"
  # Note: Must be unique within the signing profile
  # statement_id = "REPLACE_WITH_STATEMENT_ID"

  # statement_id_prefix - (Optional, Computed)
  # A statement identifier prefix. Terraform will generate a unique suffix.
  # Use this when you want a consistent prefix but need uniqueness.
  # Conflicts with: statement_id
  #
  # Type: string
  # Default: None
  # Computed: Yes - Terraform adds a unique suffix
  #
  # Example: "version-permission-" results in "version-permission-20231201123456"
  # Note: Cannot be used with statement_id
  # statement_id_prefix = "REPLACE_WITH_PREFIX"

  # region - (Optional, Computed)
  # Region where this resource will be managed.
  #
  # Type: string
  # Default: Uses the region from provider configuration
  # Computed: Yes
  #
  # Example: "us-east-1"
  # Documentation: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  # region = "us-east-1"

  #-----------------------------------------------------------------------------
  # COMPUTED ATTRIBUTES (Read-Only)
  # These attributes are set by AWS and cannot be configured
  #-----------------------------------------------------------------------------

  # id - (Computed)
  # The unique identifier of the signing profile permission.
  # Format: profile_name/statement_id
  #
  # Type: string
  # Usage: Reference as aws_signer_signing_profile_permission.example.id
}

################################################################################
# EXAMPLE CONFIGURATIONS
################################################################################

# Example 1: Basic cross-account permission for starting signing jobs
#
# resource "aws_signer_signing_profile_permission" "basic" {
#   profile_name = aws_signer_signing_profile.prod_sp.name
#   action       = "signer:StartSigningJob"
#   principal    = "123456789012"
# }

# Example 2: Permission with explicit statement ID
#
# resource "aws_signer_signing_profile_permission" "with_statement_id" {
#   profile_name = aws_signer_signing_profile.prod_sp.name
#   action       = "signer:GetSigningProfile"
#   principal    = "arn:aws:iam::123456789012:role/TeamRole"
#   statement_id = "ProdAccountStartSigningJob_StatementId"
# }

# Example 3: Version-specific permission with statement ID prefix
#
