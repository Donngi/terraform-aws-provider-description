#-------------------------------------------------------------------------------------------------------
# AWS Cognito User Pool Domain
#-------------------------------------------------------------------------------------------------------
# Amazon Cognito User Poolのカスタムドメインまたはプレフィックスドメインを設定するリソース
# カスタムドメインを使用する場合はus-east-1のACM証明書が必要、プレフィックスドメインの場合は証明書不要
# マネージドログイン（バージョン2）を使用するとブランディングデザイナーによる高度なUI設定が可能
#
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/cognito_user_pool_domain
#
# NOTE:
# - カスタムドメイン使用時は、us-east-1リージョンのACM証明書が必須
# - カスタムドメイン設定後、Route53でCNAME/ALIASレコードの追加が必要
# - managed_login_versionを2に設定するとブランディングデザイナーが利用可能
# - プレフィックスドメインは自動的に{domain}.auth.{region}.amazoncognito.com形式で生成
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# 基本設定
#-------------------------------------------------------------------------------------------------------
resource "aws_cognito_user_pool_domain" "example" {
  # 設定内容: ユーザープールドメイン名（カスタムドメインの場合は完全修飾ドメイン名、プレフィックスドメインの場合はプレフィックスのみ）
  # 例: カスタムドメイン「auth.example.com」、プレフィックスドメイン「myapp-auth」
  domain = "example-domain"

  # 設定内容: 関連付けるCognito User PoolのID
  # 形式: ap-northeast-1_XXXXXXXXX
  user_pool_id = "ap-northeast-1_example"

  #-------------------------------------------------------------------------------------------------------
  # カスタムドメイン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: カスタムドメイン用のACM証明書ARN（us-east-1リージョンで発行済みの証明書が必須）
  # 省略時: プレフィックスドメイン（{domain}.auth.{region}.amazoncognito.com形式）として設定
  # 注意: カスタムドメイン使用時はRoute53でCNAMEレコードまたはALIASレコードの設定が別途必要
  certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxx"

  #-------------------------------------------------------------------------------------------------------
  # マネージドログイン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: マネージドログインのバージョン（ホスティングUIのバージョンを制御）
  # 設定可能な値: 1（クラシックなホスティングUI）、2（ブランディングデザイナーを使用する新しいマネージドログイン）
  # 省略時: デフォルトのバージョンが使用される
  managed_login_version = 2

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference
#-------------------------------------------------------------------------------------------------------
# このリソースからは以下の属性を参照可能:
#
# aws_account_id                   : User Pool所有者のAWSアカウントID
# cloudfront_distribution          : CloudFrontディストリビューションエンドポイント（例: dpp0gtxikpq3y.cloudfront.net）
#                                    DNSプロバイダーでエイリアスターゲットとして設定
# cloudfront_distribution_arn      : CloudFrontディストリビューションのARN（Route53レコード作成時に使用）
# cloudfront_distribution_zone_id  : CloudFrontディストリビューションのRoute53ホストゾーンID（ALIASレコード作成時に使用）
# s3_bucket                        : ドメインの静的ファイル格納先S3バケット名
# version                          : アプリケーションバージョン番号
#
# 参照例:
# output "cognito_domain_cloudfront" {
#   value = aws_cognito_user_pool_domain.example.cloudfront_distribution
# }
