#---------------------------------------------------------------
# AWS VPC Endpoint Policy
#---------------------------------------------------------------
#
# VPCエンドポイントにアタッチするエンドポイントポリシーを管理します。
# エンドポイントポリシーは、VPCエンドポイントを経由してエンドポイントサービスに
# アクセスできるプリンシパル、実行できるアクション、アクセスできるリソースを
# 制御するIAMリソースポリシーです。
#
# このリソースは aws_vpc_endpoint リソースの policy 引数とは独立して
# エンドポイントポリシーを管理します。
#
# AWS公式ドキュメント:
#   - VPCエンドポイントポリシー: https://docs.aws.amazon.com/vpc/latest/privatelink/vpc-endpoints-access.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/vpc_endpoint_policy
#
# Provider Version: 6.28.0
# Generated: 2026-02-19
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_vpc_endpoint_policy" "example" {
  #-------------------------------------------------------------
  # エンドポイント設定（必須）
  #-------------------------------------------------------------

  # vpc_endpoint_id (Required)
  # 設定内容: ポリシーをアタッチするVPCエンドポイントのIDを指定します。
  # 設定可能な値: 有効なVPCエンドポイントID（例: vpce-xxxxxxxxxxxxxxxxx）
  # 注意: 対象のエンドポイントはポリシーをサポートするタイプである必要があります。
  # 参考: https://docs.aws.amazon.com/vpc/latest/privatelink/vpc-endpoints-access.html
  vpc_endpoint_id = "vpce-12345678901234567"

  #-------------------------------------------------------------
  # アクセスポリシー設定
  #-------------------------------------------------------------

  # policy (Optional, Computed)
  # 設定内容: VPCエンドポイントにアタッチするIAMポリシードキュメントをJSON形式で指定します。
  # 設定可能な値: JSON形式のIAMポリシードキュメント文字列
  # 省略時: すべてのプリンシパルによるすべてのアクションを許可するデフォルトポリシーが適用されます。
  # 関連機能: エンドポイントポリシー
  #   エンドポイントポリシーは、指定されたVPCエンドポイントを経由してサービスに
  #   アクセスできるプリンシパル、実行可能なアクション、アクセス可能なリソースを制御します。
  #   aws_iam_policy_document データソースを使用してポリシーを構築することを推奨します。
  #   - https://docs.aws.amazon.com/vpc/latest/privatelink/vpc-endpoints-access.html
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect    = "Allow"
        Principal = "*"
        Action    = "*"
        Resource  = "*"
      }
    ]
  })

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional, Computed)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: 各操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: 作成操作のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "10m", "1h"）
    create = "10m"

    # delete (Optional)
    # 設定内容: 削除操作のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "10m", "1h"）
    delete = "10m"
  }
}

