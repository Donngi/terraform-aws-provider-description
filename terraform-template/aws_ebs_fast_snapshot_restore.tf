#-----------------------------------------------------------------------------------------------------------------------
# AWS EBS Fast Snapshot Restore
#-----------------------------------------------------------------------------------------------------------------------
# EBSスナップショットの高速スナップショット復元機能を有効化するリソース。
# 特定のアベイラビリティーゾーンでスナップショットからのボリューム作成を高速化し、初期化遅延を排除する。
#
# 主な機能:
# - 特定のアベイラビリティーゾーンでスナップショットからのボリューム作成を高速化
# - スナップショットの即時利用可能化（初期化遅延の排除）
# - 最大10個のアベイラビリティーゾーンで同時有効化可能
# - 有効化状態の監視とステータス確認
#
# 制約事項:
# - 有効化には追加料金が発生する（アベイラビリティーゾーン×時間単位課金）
# - 最適化完了まで数時間かかる場合がある
# - スナップショット削除時は自動的に無効化される
# - 共有スナップショットの場合、共有解除時も自動的に無効化される
#
# Provider Version: 6.28.0
# Generated: 2026-02-14
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ebs_fast_snapshot_restore
#
# NOTE: このテンプレートは学習・参考用です。本番環境で使用する前に必ず公式ドキュメントを確認してください。
#-----------------------------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------------------------
# スナップショット識別
#-----------------------------------------------------------------------------------------------------------------------
# 高速復元を有効化するスナップショットとアベイラビリティーゾーンの指定

resource "aws_ebs_fast_snapshot_restore" "example" {
  # スナップショットID
  # 設定内容: 高速復元を有効化するEBSスナップショットのID
  # 設定可能な値: snap-xxxxxxxxxxxxxxxxx形式（17文字の16進数）
  # 省略時: 必須項目
  snapshot_id = "snap-0123456789abcdef0"

  # アベイラビリティーゾーン
  # 設定内容: 高速復元を有効化するアベイラビリティーゾーン
  # 設定可能な値: {region}{zone-identifier}形式（例: us-east-1a, ap-northeast-1c）
  # 省略時: 必須項目
  availability_zone = "us-east-1a"

  #-----------------------------------------------------------------------------------------------------------------------
  # オプション設定
  #-----------------------------------------------------------------------------------------------------------------------

  # リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（us-east-1, ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  #-----------------------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------------------------------------------------------
  # リソース作成・削除のタイムアウト時間設定

  timeouts {
    # 作成タイムアウト
    # 設定内容: 高速復元の有効化タイムアウト時間
    # 設定可能な値: Go言語のtime.ParseDuration形式（例: "10m", "1h", "90s"）
    # 省略時: 10分
    create = "15m"

    # 削除タイムアウト
    # 設定内容: 高速復元の無効化タイムアウト時間
    # 設定可能な値: Go言語のtime.ParseDuration形式（例: "5m", "10m"）
    # 省略時: 10分
    delete = "10m"
  }
}

#-----------------------------------------------------------------------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-----------------------------------------------------------------------------------------------------------------------
# このリソースから参照可能な属性値

# id     - リソースの一意識別子（{snapshot_id}/{availability_zone}形式）
# state  - 高速復元の現在の状態
#          enabling: 有効化処理中
#          optimizing: 最適化処理中（一部の性能向上効果あり）
#          enabled: 完全に有効化済み（フル性能で利用可能）
#          disabling: 無効化処理中
#          disabled: 無効化済み
# region - リソースが管理されているリージョン
