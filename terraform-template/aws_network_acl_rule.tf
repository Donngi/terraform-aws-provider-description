#---------------------------------------------------------------
# AWS Network ACL Rule
#---------------------------------------------------------------
#
# ネットワークACL（Network Access Control List）にルール（エントリ）を
# 追加するリソースです。ルール番号で指定した順序でトラフィックを評価し、
# インバウンドまたはアウトバウンドのパケットを許可または拒否します。
# ネットワークACLはステートレスなサブネットレベルのファイアウォールとして
# 機能します。
#
# 注意: aws_network_acl リソースのインラインルールと
#       aws_network_acl_rule リソースを同時に使用することはできません。
#       同時に使用するとルール設定が競合し、上書きが発生します。
#
# AWS公式ドキュメント:
#   - ネットワークACLのルール: https://docs.aws.amazon.com/vpc/latest/userguide/nacl-rules.html
#   - ネットワークACLの制御: https://docs.aws.amazon.com/vpc/latest/userguide/vpc-network-acls.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/network_acl_rule
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_network_acl_rule" "example" {
  #-------------------------------------------------------------
  # ネットワークACL設定
  #-------------------------------------------------------------

  # network_acl_id (Required)
  # 設定内容: ルールを追加するネットワークACLのIDを指定します。
  # 設定可能な値: 有効なネットワークACL ID（例: acl-12345678）
  # 省略時: 必須項目のため省略不可
  network_acl_id = aws_network_acl.example.id

  #-------------------------------------------------------------
  # ルール設定
  #-------------------------------------------------------------

  # rule_number (Required)
  # 設定内容: ルールのルール番号を指定します。
  #           ACLエントリはルール番号の昇順で処理されます。
  # 設定可能な値: 1〜32766 の整数
  # 省略時: 必須項目のため省略不可
  # 注意: ルール番号の間に余白を持たせることで、後からルールを追加しやすくなります。
  #       例: 100, 200, 300 のように100刻みで設定するのが一般的です。
  # 参考: https://docs.aws.amazon.com/vpc/latest/userguide/nacl-rules.html
  rule_number = 100

  # rule_action (Required)
  # 設定内容: ルールに一致するトラフィックを許可または拒否するかを指定します。
  # 設定可能な値:
  #   - "allow": トラフィックを許可します
  #   - "deny": トラフィックを拒否します
  # 省略時: 必須項目のため省略不可
  rule_action = "allow"

  # protocol (Required)
  # 設定内容: ルールが適用されるプロトコルを指定します。
  # 設定可能な値:
  #   - "-1" または "all": すべてのプロトコル
  #   - "6" または "tcp": TCP
  #   - "17" または "udp": UDP
  #   - "1" または "icmp": ICMP（IPv4）
  #   - "58" または "icmpv6": ICMPv6（IPv6）
  #   その他のIANA割り当てプロトコル番号も使用可能
  # 省略時: 必須項目のため省略不可
  # 注意: protocol が "-1"（all）の場合、from_port と to_port の値は無視されます。
  protocol = "tcp"

  #-------------------------------------------------------------
  # トラフィック方向設定
  #-------------------------------------------------------------

  # egress (Optional)
  # 設定内容: このルールがエグレスルール（サブネットから送出するトラフィックへの適用）か
  #           インバウンドルール（サブネットへの受信トラフィックへの適用）かを指定します。
  # 設定可能な値:
  #   - true: エグレスルール（アウトバウンド）
  #   - false: インバウンドルール（デフォルト）
  # 省略時: false（インバウンドルール）
  egress = false

  #-------------------------------------------------------------
  # CIDR設定
  #-------------------------------------------------------------

  # cidr_block (Optional)
  # 設定内容: 許可または拒否するネットワーク範囲をIPv4 CIDR表記で指定します。
  # 設定可能な値: 有効なIPv4 CIDR ブロック（例: 10.0.0.0/16, 172.16.0.0/24, 0.0.0.0/0）
  # 省略時: IPv4 CIDR範囲を対象としない（ipv6_cidr_block と組み合わせて使用可能）
  # 注意: cidr_block または ipv6_cidr_block のいずれか一方を指定する必要があります。
  #       指定されたCIDR値は自動的に正規形式に変換されます。
  cidr_block = "10.0.0.0/16"

  # ipv6_cidr_block (Optional)
  # 設定内容: 許可または拒否するネットワーク範囲をIPv6 CIDR表記で指定します。
  # 設定可能な値: 有効なIPv6 CIDR ブロック（例: ::/0, 2001:db8::/32）
  # 省略時: IPv6 CIDR範囲を対象としない
  # 注意: cidr_block または ipv6_cidr_block のいずれか一方を指定する必要があります。
  ipv6_cidr_block = null

  #-------------------------------------------------------------
  # ポート設定
  #-------------------------------------------------------------

  # from_port (Optional)
  # 設定内容: ルールが適用されるポート範囲の開始ポートを指定します。
  # 設定可能な値: 0〜65535 の整数
  # 省略時: ポート範囲の指定なし
  # 注意: protocol が "-1"（all）の場合、この値は無視されます。
  #       TCP または UDP プロトコルを使用する場合に有効です。
  from_port = 443

  # to_port (Optional)
  # 設定内容: ルールが適用されるポート範囲の終了ポートを指定します。
  # 設定可能な値: 0〜65535 の整数（from_port 以上の値）
  # 省略時: ポート範囲の指定なし
  # 注意: protocol が "-1"（all）の場合、この値は無視されます。
  #       単一ポートの場合は from_port と同じ値を指定します。
  to_port = 443

  #-------------------------------------------------------------
  # ICMP設定
  #-------------------------------------------------------------

  # icmp_type (Optional)
  # 設定内容: ICMPプロトコルのICMPタイプを指定します。
  # 設定可能な値:
  #   - -1: すべてのICMPタイプ（ワイルドカード）
  #   - 0: エコー応答
  #   - 8: エコー要求（ping）
  #   その他のICMPタイプ番号（IANA仕様に準拠）
  # 省略時: ICMPタイプを指定しない
  # 注意: protocol が "icmp" または "1" の場合に使用します。
  #       icmp_type が -1（ワイルドカード）の場合、icmp_code も -1 に設定する必要があります。
  # 参考: https://www.iana.org/assignments/icmp-parameters/icmp-parameters.xhtml
  icmp_type = null

  # icmp_code (Optional)
  # 設定内容: ICMPプロトコルのICMPコードを指定します。
  # 設定可能な値:
  #   - -1: すべてのICMPコード（ワイルドカード）
  #   - 0: ネットワーク到達不能など（タイプに依存）
  #   その他のICMPコード番号（IANA仕様に準拠）
  # 省略時: ICMPコードを指定しない
  # 注意: protocol が "icmp" または "1" の場合に使用します。
  #       icmp_type が -1（ワイルドカード）の場合、icmp_code も -1 に設定する必要があります。
  # 参考: https://www.iana.org/assignments/icmp-parameters/icmp-parameters.xhtml
  icmp_code = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

