# AWS Configの設定履歴データの保持期間を設定するリソース。
# 記録されたすべての設定アイテム、設定履歴ファイル、構成スナップショットについて、
# 指定した期間が経過した後にAWS Configによって削除されます。
# デフォルトでは履歴データは無期限に保持されますが、コンプライアンス要件や
# ストレージコストに応じて保持期間を設定できます。
# リージョンごとに1つのリテンション設定のみが有効です。

resource "aws_config_retention_configuration" "example" {
  #-----------------------------------------------------------------------
  # データ保持設定
  #-----------------------------------------------------------------------
  # 設定内容: AWS Configデータの保持期間（日数）
  # 設定可能な値: 30〜2557（約7年）の整数
  # 省略時: 設定不可（必須項目）
  retention_period_in_days = 90

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"
}

################################################################################
# Attributes Reference
################################################################################

# 以下の属性がエクスポートされ、他のリソースから参照可能です:
#
# - id: リテンション設定のID（リソース識別子）
# - name: リテンション設定の名前
# - region: リソースが作成されたリージョン

