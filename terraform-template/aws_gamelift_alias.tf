###############################################################################################
# Terraform Template: aws_gamelift_alias
###############################################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# 概要:
#   このリソースは、Amazon GameLift のエイリアスを作成します。
#   エイリアスは GameLift フリートへの参照を抽象化し、ゲームクライアントのコードを
#   変更することなくフリートの切り替えが可能になります。
#
# 主な用途:
#   - ゲームサーバーフリートへの抽象的な参照の作成
#   - ダウンタイムなしでのフリート切り替え
#   - ターミナルメッセージによるメンテナンス通知
#   - Blue/Green デプロイメントの実装
#
# 制限事項:
#   - 各エイリアスは1つのリージョン内でのみ有効
#   - SIMPLE タイプの場合は fleet_id が必須
#   - TERMINAL タイプの場合は message が必須
#
# 関連ドキュメント:
#   - https://docs.aws.amazon.com/gamelift/latest/developerguide/aliases-creating.html
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/gamelift_alias
#
# NOTE:
#   routing_strategy ブロック内の fleet_id と message は、type の値に応じて
#   適切に設定する必要があります（SIMPLE の場合は fleet_id、TERMINAL の場合は message）
#
###############################################################################################

#-------
# リソース定義
#-------
resource "aws_gamelift_alias" "example" {

  #-------
  # 基本設定
  #-------
  # 設定内容: エイリアスの名前
  # 設定可能な値: 1～1024文字の文字列
  # 省略時: 必須項目のため指定が必要
  name = "example-gamelift-alias"

  # 設定内容: エイリアスの説明
  # 設定可能な値: 最大1024文字の文字列
  # 省略時: 説明なし
  description = "GameLift エイリアスの説明"

  #-------
  # ルーティング設定
  #-------
  # 設定内容: エイリアスのルーティング戦略
  # 設定可能な値: routing_strategy ブロック（必須）
  # 省略時: 必須項目のため指定が必要
  routing_strategy {
    # 設定内容: ルーティングタイプ
    # 設定可能な値: SIMPLE（フリートにルーティング）, TERMINAL（メッセージを返す）
    # 省略時: 必須項目のため指定が必要
    type = "SIMPLE"

    # 設定内容: ルーティング先のフリート ID
    # 設定可能な値: GameLift フリートの ID（type が SIMPLE の場合に必須）
    # 省略時: type が TERMINAL の場合は不要
    fleet_id = "fleet-12345678-1234-1234-1234-123456789012"

    # 設定内容: ターミナルメッセージ
    # 設定可能な値: 最大1024文字のメッセージ（type が TERMINAL の場合に必須）
    # 省略時: type が SIMPLE の場合は不要
    # message = "メンテナンス中です。しばらくお待ちください。"
  }


  #-------
  # リージョン設定
  #-------
  # 設定内容: このリソースを管理するリージョン
  # 設定可能な値: AWS リージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #-------
  # タグ設定
  #-------
  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-gamelift-alias"
    Environment = "production"
    ManagedBy   = "Terraform"
  }
}

###############################################################################################
# Attributes Reference（参照可能な属性）
###############################################################################################
# このリソースでは以下の属性を参照できます:
#
# - id
#   エイリアスの ID
#
# - arn
#   エイリアスの ARN
#   形式: arn:aws:gamelift:<region>:<account-id>:alias/<alias-id>
#
# - region
#   このリソースが管理されているリージョン
#   プロバイダー設定のリージョンが使用される
#
# - tags_all
#   プロバイダーの default_tags とマージされたすべてのタグ
#
###############################################################################################
