###############################################################################################
# Terraform Template: aws_grafana_workspace_service_account_token
###############################################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# 概要:
#   このリソースは、Amazon Managed Grafana ワークスペースのサービスアカウントに対する
#   トークンを作成します。サービスアカウントトークンは、Grafana API や
#   プラグインの認証に使用できるベアラートークンです。
#
# 主な用途:
#   - Grafana API へのプログラムアクセス用トークンの発行
#   - CI/CD パイプラインからの Grafana ダッシュボード操作
#   - Grafana プラグインや外部ツールとの連携認証
#   - サービスアカウントベースのアクセス制御実装
#
# 制限事項:
#   - トークンキー（key 属性）は作成時にのみ取得可能。Terraform の state には保存されない
#   - seconds_to_live で指定した有効期限を過ぎると、トークンは無効になる
#   - トークンを更新するには削除して再作成が必要
#   - サービスアカウント（aws_grafana_workspace_service_account）が事前に存在する必要がある
#
# 関連ドキュメント:
#   - https://docs.aws.amazon.com/grafana/latest/userguide/service-accounts.html
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/grafana_workspace_service_account_token
#
# NOTE:
#   key 属性は sensitive = true であり、Terraform の出力では自動的にマスクされます。
#   トークンキーは作成後に参照できないため、作成直後に安全な場所に保存してください。
#
###############################################################################################

#-------
# リソース定義
#-------
resource "aws_grafana_workspace_service_account_token" "example" {

  #-------
  # ワークスペース・サービスアカウント設定
  #-------
  # 設定内容: トークンを作成する Grafana ワークスペースの ID
  # 設定可能な値: 既存の Amazon Managed Grafana ワークスペースの ID
  # 省略時: 必須項目のため指定が必要
  workspace_id = "g-1234567890"

  # 設定内容: トークンを作成するサービスアカウントの ID
  # 設定可能な値: 既存のサービスアカウントの ID（数値文字列）
  # 省略時: 必須項目のため指定が必要
  service_account_id = "1"

  #-------
  # トークン設定
  #-------
  # 設定内容: サービスアカウントトークンの名前
  # 設定可能な値: 1～128文字の文字列（ワークスペース内でユニーク）
  # 省略時: 必須項目のため指定が必要
  name = "example-token"

  # 設定内容: トークンの有効期間（秒単位）
  # 設定可能な値: 1 ～ 2592000（30日）の整数
  #   例: 3600（1時間）, 86400（1日）, 604800（1週間）, 2592000（30日）
  # 省略時: 必須項目のため指定が必要
  seconds_to_live = 2592000

  #-------
  # リージョン設定
  #-------
  # 設定内容: このリソースを管理するリージョン
  # 設定可能な値: AWS リージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"
}

###############################################################################################
# Attributes Reference（参照可能な属性）
###############################################################################################
# このリソースでは以下の属性を参照できます:
#
# - id
#   トークンの ID（workspace_id/service_account_id/service_account_token_id 形式）
#
# - service_account_token_id
#   サービスアカウントトークンの一意の ID
#
# - key
#   トークンキー（ベアラートークン）。sensitive 属性のため出力はマスクされる。
#   作成時にのみ取得可能であり、以降の参照では空文字列となる。
#
# - created_at
#   トークンが作成された日時（RFC3339 形式）
#
# - expires_at
#   トークンの有効期限（RFC3339 形式）
#
# - region
#   このリソースが管理されているリージョン
#
###############################################################################################
