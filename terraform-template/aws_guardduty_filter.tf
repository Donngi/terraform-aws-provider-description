#---------------------------------------------------------------
# AWS GuardDuty Filter
#---------------------------------------------------------------
#
# Amazon GuardDuty のフィルタリングルールをプロビジョニングするリソースです。
# フィルターを使用して特定の条件に一致する検出結果を自動的にアーカイブするか、
# 検出結果の優先度を変更（NOOP）する設定を定義します。
#
# AWS公式ドキュメント:
#   - GuardDuty フィルタリング: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_filter-findings.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/guardduty_filter
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_guardduty_filter" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # detector_id (Required)
  # 設定内容: このフィルターを関連付けるGuardDuty検出器のIDを指定します。
  # 設定可能な値: 有効なGuardDuty検出器のID文字列
  detector_id = "abc123def456abc123def456abc12345"

  # name (Required)
  # 設定内容: フィルターの名前を指定します。
  # 設定可能な値: 3〜64文字の英数字、ハイフン、アンダースコアが使用可能
  name = "MyFilter"

  # action (Required)
  # 設定内容: フィルター条件に一致する検出結果に適用するアクションを指定します。
  # 設定可能な値:
  #   - "ARCHIVE": 一致する検出結果を自動的にアーカイブします
  #   - "NOOP": 検出結果をアーカイブせず、フィルターのランクを評価のみ行います
  action = "ARCHIVE"

  # rank (Required)
  # 設定内容: フィルターの優先順位を指定します。数値が小さいほど優先度が高くなります。
  # 設定可能な値: 1〜100 の整数。同一検出器内で一意である必要があります。
  rank = 1

  #-------------------------------------------------------------
  # 説明設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: フィルターの説明を指定します。
  # 設定可能な値: 0〜512文字の文字列
  # 省略時: 説明なし
  description = "フィルターの説明文"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # 検出結果フィルター条件設定
  #-------------------------------------------------------------

  # finding_criteria (Required)
  # 設定内容: フィルターの検索条件を定義するブロックです。最大1つ指定できます。
  # 関連機能: GuardDuty 検出結果フィルタリング
  #   フィールド名と条件の組み合わせで、対象とする検出結果を絞り込みます。
  #   - https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_filter-findings.html#filter_criteria
  finding_criteria {

    #-------------------------------------------------------------
    # フィルター条件 (criterion)
    #-------------------------------------------------------------

    # criterion (Required)
    # 設定内容: 個々の検索条件を定義するブロックです。複数指定でAND条件となります。
    # 設定可能な値: 1つ以上のcriterionブロックを指定します（set型）
    # 参考: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_filter-findings.html#filter_criteria
    criterion {

      # field (Required)
      # 設定内容: 評価対象のフィールド名を指定します。
      # 設定可能な値: GuardDuty で使用可能なフィールド名（例: region, severity, type, accountId 等）
      # 参考: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_filter-findings.html#filter_criteria
      field = "region"

      # equals (Optional)
      # 設定内容: フィールドの値が指定リストのいずれかに等しい場合に一致する条件です。
      # 設定可能な値: 文字列のリスト
      # 省略時: この条件は評価されません
      equals = ["eu-west-1"]

      # not_equals (Optional)
      # 設定内容: フィールドの値が指定リストのいずれにも等しくない場合に一致する条件です。
      # 設定可能な値: 文字列のリスト
      # 省略時: この条件は評価されません
      not_equals = null

      # greater_than (Optional)
      # 設定内容: フィールドの値が指定値より大きい場合に一致する条件です。
      # 設定可能な値: 整数文字列、またはRFC 3339形式の日付文字列（例: "2020-01-01T00:00:00Z"）
      # 省略時: この条件は評価されません
      greater_than = null

      # greater_than_or_equal (Optional)
      # 設定内容: フィールドの値が指定値以上の場合に一致する条件です。
      # 設定可能な値: 整数文字列、またはRFC 3339形式の日付文字列（例: "2020-01-01T00:00:00Z"）
      # 省略時: この条件は評価されません
      greater_than_or_equal = null

      # less_than (Optional)
      # 設定内容: フィールドの値が指定値より小さい場合に一致する条件です。
      # 設定可能な値: 整数文字列、またはRFC 3339形式の日付文字列（例: "2020-02-01T00:00:00Z"）
      # 省略時: この条件は評価されません
      less_than = null

      # less_than_or_equal (Optional)
      # 設定内容: フィールドの値が指定値以下の場合に一致する条件です。
      # 設定可能な値: 整数文字列、またはRFC 3339形式の日付文字列（例: "2020-02-01T00:00:00Z"）
      # 省略時: この条件は評価されません
      less_than_or_equal = null

      # matches (Optional)
      # 設定内容: フィールドの値が指定リストのいずれかのパターンに一致する場合に一致する条件です。
      # 設定可能な値: 文字列のリスト（ワイルドカードパターン対応）
      # 省略時: この条件は評価されません
      matches = null

      # not_matches (Optional)
      # 設定内容: フィールドの値が指定リストのいずれのパターンにも一致しない場合に一致する条件です。
      # 設定可能な値: 文字列のリスト（ワイルドカードパターン対応）
      # 省略時: この条件は評価されません
      not_matches = null
    }
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "my-guardduty-filter"
    Environment = "production"
  }
}

#---------------------------------------------------------------
