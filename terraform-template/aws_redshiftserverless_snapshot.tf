#---------------------------------------------------------------
# Amazon Redshift Serverless Snapshot
#---------------------------------------------------------------
#
# Amazon Redshift Serverlessの手動スナップショットをプロビジョニングするリソースです。
# スナップショットは名前空間（Namespace）のデータをポイントインタイムでバックアップします。
# 手動スナップショットは明示的に削除するまで保持され、別リージョンへの復元にも利用できます。
#
# AWS公式ドキュメント:
#   https://docs.aws.amazon.com/redshift/latest/mgmt/serverless-snapshots-recovery-points.html
#
# Terraform Registry:
#   https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/redshiftserverless_snapshot
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_redshiftserverless_snapshot" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # 設定内容: スナップショットを取得するRedshift Serverless名前空間の名前
  # 設定可能な値: 有効なRedshift Serverless名前空間名
  # 省略時: 必須項目のため省略不可
  namespace_name = "my-redshiftserverless-namespace"

  # 設定内容: スナップショットの一意な名前
  # 設定可能な値: 英数字またはハイフンで構成される一意な名前（AWSアカウント全体で一意）
  # 省略時: 必須項目のため省略不可
  snapshot_name = "my-serverless-snapshot"

  #-------------------------------------------------------------
  # 保持期間設定
  #-------------------------------------------------------------

  # 設定内容: スナップショットを保持する日数
  # 設定可能な値: -1（無期限）、1〜3653（日数）
  # 省略時: -1（無期限保持）
  retention_period = -1

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1、us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = null
}

#---------------------------------------------------------------
# Attributes Reference（読み取り専用属性）
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: スナップショット名（snapshot_name と同値）
# - arn: スナップショットのARN
# - admin_username: スナップショット取得元名前空間の管理者ユーザー名
# - kms_key_id: データ暗号化に使用されたKMSキーのID
# - namespace_arn: スナップショット取得元名前空間のARN
# - owner_account: スナップショットを作成したAWSアカウントID
# - accounts_with_restore_access: 復元アクセス権を持つAWSアカウントのセット
# - accounts_with_provisioned_restore_access: プロビジョニング済みクラスターへの
#                                             復元アクセス権を持つAWSアカウントのセット
#---------------------------------------------------------------
