#---------------------------------------------------------------
# Amazon FSx for OpenZFS Volume
#---------------------------------------------------------------
#
# Amazon FSx for OpenZFS ボリュームを管理するリソース。
# FSx for OpenZFS ファイルシステム内に論理的に分離された名前空間を作成し、
# ストレージ容量、圧縮、NFS エクスポート、レコードサイズ、ユーザー/グループクォータを
# ボリュームレベルで独立して管理できます。
#
# AWS公式ドキュメント:
#   - Managing volumes: https://docs.aws.amazon.com/fsx/latest/OpenZFSGuide/managing-volumes.html
#   - Creating volumes: https://docs.aws.amazon.com/fsx/latest/OpenZFSGuide/creating-volumes.html
#   - Performance: https://docs.aws.amazon.com/fsx/latest/OpenZFSGuide/performance.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/fsx_openzfs_volume
#
# Provider Version: 6.28.0
# Generated: 2026-01-27
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_fsx_openzfs_volume" "example" {
  #---------------------------------------------------------------
  # 必須パラメータ
  #---------------------------------------------------------------

  # ボリューム名
  # 最大203文字の英数字とアンダースコア(_)を使用可能
  # ファイルシステム内でボリュームを識別するための名前
  name = "example-volume"

  # 親ボリュームID
  # このボリュームの親となるボリュームのID
  # aws_fsx_openzfs_file_system の root_volume_id、
  # または別の aws_fsx_openzfs_volume の id を指定
  # すべてのボリュームはルートボリュームまたは他のボリュームの子孫として作成される
  parent_volume_id = aws_fsx_openzfs_file_system.example.root_volume_id

  #---------------------------------------------------------------
  # オプションパラメータ - ストレージ設定
  #---------------------------------------------------------------

  # データ圧縮タイプ
  # ボリューム上のデータを圧縮する方法を指定
  # 有効な値:
  #   - "NONE": 圧縮なし
  #   - "ZSTD": Zstandard圧縮（推奨）
  # 子ボリュームで圧縮オプションを指定しない場合、親ボリュームから継承
  # ファイルシステムのこのオプションはルートボリュームに適用される
  # デフォルト: 親ボリュームの設定を継承
  data_compression_type = "ZSTD"

  # ストレージ容量クォータ（GiB）
  # ボリュームが親ボリュームから使用できる最大ストレージ容量
  # 有効な値: 0 〜 2147483647 GiB
  # 未指定の場合、親ボリュームのストレージ容量が上限となる
  storage_capacity_quota_gib = 100

  # ストレージ容量予約（GiB）
  # 親ボリュームから予約する最小ストレージ容量
  # 有効な値: 0 〜 2147483647 GiB
  # 予約された容量は他のボリュームでは使用できなくなる
  # シンプロビジョニングされたボリュームでは予約を設定することで
  # 最小限のストレージ容量を保証できる
  storage_capacity_reservation_gib = 50

  # レコードサイズ（KiB）
  # OpenZFS ボリュームのレコードサイズ（ZFS データセットのブロックサイズ）
  # 有効な値: 4, 8, 16, 32, 64, 128, 256, 512, 1024 KiB
  # デフォルト: 128 KiB
  # ワークロードに応じて最適なサイズを選択:
  #   - 小さなファイルが多い場合: 小さいレコードサイズ（4-32 KiB）
  #   - 大きなファイルやシーケンシャルアクセス: 大きいレコードサイズ（128-1024 KiB）
  record_size_kib = 128

  #---------------------------------------------------------------
  # オプションパラメータ - アクセス制御
  #---------------------------------------------------------------

  # 読み取り専用フラグ
  # ボリュームを読み取り専用にするかどうかを指定
  # true の場合、ボリュームへの書き込みは許可されない
  # デフォルト: false
  read_only = false

  #---------------------------------------------------------------
  # オプションパラメータ - スナップショット設定
  #---------------------------------------------------------------

  # タグをスナップショットにコピー
  # ボリュームのタグをスナップショットにコピーするかどうかを指定
  # デフォルト: false
  copy_tags_to_snapshots = true

  # ボリューム削除オプション
  # ボリューム削除時の動作を指定
  # 有効な値: "DELETE_CHILD_VOLUMES_AND_SNAPSHOTS"
  # この設定により、すべての子ボリュームとスナップショットも削除される
  # この設定は、リソースを削除する前に個別に適用する必要がある
  # 注意: 子ボリュームやスナップショットが存在する場合、
  # この設定なしではボリュームの削除は失敗する
  delete_volume_options = ["DELETE_CHILD_VOLUMES_AND_SNAPSHOTS"]

  #---------------------------------------------------------------
  # オプションパラメータ - リージョン設定
  #---------------------------------------------------------------

  # リージョン
  # このリソースが管理されるAWSリージョン
  # 未指定の場合、プロバイダー設定のリージョンが使用される
  # 通常は明示的に指定する必要はない
  # region = "us-east-1"

  #---------------------------------------------------------------
  # オプションパラメータ - タグ
  #---------------------------------------------------------------

  # タグ
  # ボリュームに割り当てるタグのマップ
  # プロバイダーの default_tags 設定ブロックと組み合わせて使用可能
  tags = {
    Name        = "example-openzfs-volume"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #---------------------------------------------------------------
  # オプションパラメータ - ボリュームタイプ
  #---------------------------------------------------------------

  # ボリュームタイプ
  # ボリュームのタイプを指定
  # 詳細はAWS公式ドキュメントを参照
  # volume_type = "OPENZFS"

  #---------------------------------------------------------------
  # ネストブロック: NFS エクスポート設定
  #---------------------------------------------------------------

  # NFS エクスポート設定
  # ルートボリュームのNFSエクスポート設定
  # 最大1つのブロックを指定可能
  # Linux、Windows、macOSクライアントからNFSプロトコル経由で
  # ボリュームにアクセスするための設定
  nfs_exports {
    # クライアント設定
    # NFSファイルシステムをマウントするためのクライアントとオプションの設定
    # 最小1つ、最大25個のclient_configurationsブロックを指定可能
    client_configurations {
      # クライアント指定
      # ファイルシステムをマウントできるクライアントを指定
      # 有効な値:
      #   - "*": すべてのクライアント（ワイルドカード）
      #   - IPアドレス: "0.0.0.0"
      #   - CIDRアドレス: "192.0.2.0/24"
      # デフォルトではワイルドカード(*)が使用される
      clients = "*"

      # マウントオプション
      # ファイルシステムをマウントする際のオプション
      # 最大20個のオプションを指定可能
      # 詳細は Linux NFS exports man page を参照
      # デフォルトで使用されるオプション:
      #   - "crossmount": スナップショットディレクトリへのアクセスに必要
      #   - "sync": ディスクへの書き込みを同期的に実行
      #
      # よく使用されるオプション:
      #   - "rw": 読み書き可能（デフォルト）
      #   - "ro": 読み取り専用
      #   - "async": 非同期書き込み（パフォーマンス向上、データ損失リスクあり）
      #   - "no_root_squash": root ユーザーの権限を保持
      #   - "all_squash": すべてのユーザーを匿名ユーザーにマッピング
      options = ["rw", "crossmount", "sync"]
    }
  }

  #---------------------------------------------------------------
  # ネストブロック: 元スナップショット設定
  #---------------------------------------------------------------

  # 元スナップショット設定
  # OpenZFS ボリュームを作成する際に使用するスナップショットの設定
  # このボリュームのデータの元となるスナップショットを指定
  # 最大1つのブロックを指定可能
  #
  # origin_snapshot {
  #   # スナップショットARN
  #   # データの元となるスナップショットのAmazon Resource Name
  #   snapshot_arn = "arn:aws:fsx:us-east-1:123456789012:snapshot/fs-0123456789abcdef0/fsvol-0123456789abcdef0/fsvolsnap-0123456789abcdef0"
  #
  #   # コピー戦略
  #   # スナップショットからボリュームへのデータ転送方法を指定
  #   # 有効な値:
  #   #   - "CLONE": クローンボリュームを作成（即座に作成、初期状態では追加容量なし、スナップショットへの依存あり）
  #   #   - "FULL_COPY": フルコピーボリュームを作成（すべてのデータを転送、完全に独立、作成に時間がかかる）
  #   copy_strategy = "CLONE"
  # }

  #---------------------------------------------------------------
  # ネストブロック: ユーザー/グループクォータ設定
  #---------------------------------------------------------------

  # ユーザーおよびグループクォータ
  # ボリューム上でユーザーまたはグループが使用できるストレージ容量を指定
  # 最大数はFSx for OpenZFS リソースクォータで定義される上限に従う
  #
  # user_and_group_quotas {
  #   # ID
  #   # ユーザーまたはグループのID
  #   # 有効な値: 0 〜 2147483647
  #   id = 1001
  #
  #   # ストレージ容量クォータ（GiB）
  #   # ユーザーまたはグループが使用できるストレージ容量（GiB）
  #   # 有効な値: 0 〜 2147483647 GiB
  #   storage_capacity_quota_gib = 10
  #
  #   # タイプ
  #   # クォータをユーザーに適用するかグループに適用するかを指定
  #   # 有効な値:
  #   #   - "USER": ユーザークォータ
  #   #   - "GROUP": グループクォータ
  #   type = "USER"
  # }

  #---------------------------------------------------------------
  # ネストブロック: タイムアウト設定
  #---------------------------------------------------------------

  # タイムアウト設定
  # リソース操作のタイムアウト時間をカスタマイズ
  #
  # timeouts {
  #   # 作成時のタイムアウト
  #   # デフォルト: 30m（30分）
  #   create = "30m"
  #
  #   # 更新時のタイムアウト
  #   # デフォルト: 30m（30分）
  #   update = "30m"
  #
  #   # 削除時のタイムアウト
  #   # デフォルト: 30m（30分）
  #   delete = "30m"
  # }
}

#---------------------------------------------------------------
# Attributes Reference
#---------------------------------------------------------------
#
# このリソースは以下の属性をエクスポートします:
#
# - arn
#   ボリュームのAmazon Resource Name
#
# - id
#   ボリュームの識別子（例: fsvol-12345678）
#
# - tags_all
#   リソースに割り当てられたすべてのタグのマップ
#   プロバイダーの default_tags 設定ブロックから継承されたタグを含む
#
# 使用例:
#   output "volume_id" {
#     value = aws_fsx_openzfs_volume.example.id
#   }
#
#   output "volume_arn" {
#     value = aws_fsx_openzfs_volume.example.arn
#   }
#
