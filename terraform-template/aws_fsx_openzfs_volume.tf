#-----------------------------------------------------------------------
# Amazon FSx for OpenZFS Volume
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
#
# 用途: Amazon FSx for OpenZFSファイルシステム内にボリュームを作成するリソース
#
# 主な機能:
# - OpenZFSボリュームの作成と管理
# - 親ボリュームからの継承階層管理
# - データ圧縮の設定
# - NFSエクスポート構成の管理
# - ユーザー・グループ単位のストレージクォータ設定
# - スナップショットからのボリューム作成
#
# 関連ドキュメント:
# https://docs.aws.amazon.com/fsx/latest/OpenZFSGuide/what-is-fsx.html
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/fsx_openzfs_volume
#
# NOTE:
# - 子ボリュームとスナップショットを削除する場合、delete_volume_optionsを事前に設定する必要がある
# - 最大25個のクライアント設定を定義可能
# - ユーザー/グループクォータ数の上限はFSx for OpenZFSのリソース制限に準拠
# - 圧縮オプションを指定しない子ボリュームは親ボリュームから継承する
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_fsx_openzfs_volume" "example" {
  # ボリューム名
  # 設定内容: ボリュームの名前（最大203文字の英数字とアンダースコア）
  # 必須設定: はい
  name = "my-openzfs-volume"

  # 親ボリュームID
  # 設定内容: このボリュームの親となるボリュームのID（ルートボリュームまたは別のOpenZFSボリューム）
  # 必須設定: はい
  # 補足: aws_fsx_openzfs_file_systemのroot_volume_idまたは別のaws_fsx_openzfs_volumeのidを指定
  parent_volume_id = "fsvol-0123456789abcdef0"

  #-----------------------------------------------------------------------
  # データ管理設定
  #-----------------------------------------------------------------------

  # データ圧縮タイプ
  # 設定内容: ボリューム上のデータを圧縮する方法
  # 設定可能な値: NONE（圧縮なし）, ZSTD（Zstandard圧縮）
  # 省略時: 指定しない子ボリュームは親ボリュームから継承
  data_compression_type = "ZSTD"

  # レコードサイズ
  # 設定内容: OpenZFSボリュームのレコードサイズ（KiB単位）
  # 設定可能な値: 4, 8, 16, 32, 64, 128, 256, 512, 1024
  # 省略時: 128 KiB
  record_size_kib = 128

  # 読み取り専用フラグ
  # 設定内容: ボリュームを読み取り専用にするかどうか
  # 省略時: false（読み書き可能）
  read_only = false

  #-----------------------------------------------------------------------
  # ストレージ容量設定
  #-----------------------------------------------------------------------

  # ストレージ容量クォータ
  # 設定内容: ボリュームが親ボリュームから使用できる最大ストレージ容量（GiB単位）
  # 補足: 設定しない場合は親ボリュームの容量まで使用可能
  storage_capacity_quota_gib = 1024

  # ストレージ容量予約
  # 設定内容: 親ボリュームから予約するストレージ容量（GiB単位）
  # 補足: このボリューム専用に確保される容量
  storage_capacity_reservation_gib = 512

  #-----------------------------------------------------------------------
  # スナップショット設定
  #-----------------------------------------------------------------------

  # スナップショットへのタグコピー
  # 設定内容: ファイルシステムのタグをスナップショットにコピーするかどうか
  # 省略時: false（コピーしない）
  copy_tags_to_snapshots = true

  # 削除時オプション
  # 設定内容: ボリューム削除時に子ボリュームとスナップショットも削除するかどうか
  # 設定可能な値: DELETE_CHILD_VOLUMES_AND_SNAPSHOTS
  # 補足: リソース削除前に別途この設定を適用する必要がある
  delete_volume_options = ["DELETE_CHILD_VOLUMES_AND_SNAPSHOTS"]

  #-----------------------------------------------------------------------
  # NFSエクスポート設定
  #-----------------------------------------------------------------------

  # nfs_exports {
  #   # クライアント設定（必須、1〜25個まで設定可能）
  #   client_configurations {
  #     # クライアント指定
  #     # 設定内容: ファイルシステムをマウントできるクライアントの指定
  #     # 設定可能な値: ワイルドカード（*）、IPアドレス（0.0.0.0）、CIDR（192.0.2.0/24）
  #     # 省略時: ワイルドカード（*）
  #     clients = "*"
  #
  #     # マウントオプション
  #     # 設定内容: ファイルシステムマウント時のオプション（最大20個）
  #     # 省略時: crossmount, syncがデフォルトで使用される
  #     # 補足: 詳細はLinux NFS exportsのマニュアルページを参照
  #     options = ["rw", "crossmount", "sync"]
  #   }
  #
  #   # 複数のクライアント設定を追加可能
  #   # client_configurations {
  #   #   clients = "192.0.2.0/24"
  #   #   options = ["ro", "sync"]
  #   # }
  # }

  #-----------------------------------------------------------------------
  # ユーザー・グループクォータ設定
  #-----------------------------------------------------------------------

  # user_and_group_quotas {
  #   # ユーザーまたはグループのID
  #   # 設定内容: クォータを適用するユーザーまたはグループのID
  #   # 設定可能な値: 0〜2147483647
  #   id = 1000
  #
  #   # ストレージ容量クォータ
  #   # 設定内容: ユーザーまたはグループが使用できるストレージ容量（GiB単位）
  #   # 設定可能な値: 0〜2147483647
  #   storage_capacity_quota_gib = 100
  #
  #   # クォータタイプ
  #   # 設定内容: クォータをユーザーまたはグループのどちらに適用するか
  #   # 設定可能な値: USER（ユーザー）, GROUP（グループ）
  #   type = "USER"
  # }
  #
  # # 複数のユーザー・グループクォータを追加可能
  # # user_and_group_quotas {
  # #   id                         = 2000
  # #   storage_capacity_quota_gib = 200
  # #   type                       = "GROUP"
  # # }

  #-----------------------------------------------------------------------
  # スナップショット起点設定
  #-----------------------------------------------------------------------

  # origin_snapshot {
  #   # コピー戦略
  #   # 設定内容: スナップショットからボリュームを作成する際の戦略
  #   # 補足: スナップショットからボリュームを作成する場合に指定
  #   copy_strategy = "CLONE"
  #
  #   # スナップショットARN
  #   # 設定内容: ボリューム作成元となるスナップショットのARN
  #   snapshot_arn = "arn:aws:fsx:us-east-1:123456789012:snapshot/fs-0123456789abcdef0/fsvolsnap-0123456789abcdef0"
  # }

  #-----------------------------------------------------------------------
  # リソース管理設定
  #-----------------------------------------------------------------------

  # ボリュームタイプ
  # 設定内容: ボリュームのタイプ
  # 補足: OpenZFSボリュームのタイプを指定
  volume_type = "OPENZFS"

  # リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 補足: 通常はプロバイダー設定のリージョンが使用されるため指定不要
  region = "us-east-1"

  # タグ
  # 設定内容: ボリュームに付与するタグのマップ
  # 補足: プロバイダーのdefault_tagsと組み合わせて使用可能
  tags = {
    Name        = "my-openzfs-volume"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 作成タイムアウト
  #   # 設定内容: ボリューム作成処理のタイムアウト時間
  #   # create = "30m"
  #
  #   # 更新タイムアウト
  #   # 設定内容: ボリューム更新処理のタイムアウト時間
  #   # update = "30m"
  #
  #   # 削除タイムアウト
  #   # 設定内容: ボリューム削除処理のタイムアウト時間
  #   # delete = "30m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照専用属性）
#-----------------------------------------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# arn - ボリュームのAmazon Resource Name（ARN）
# id - ボリュームの識別子（例: fsvol-12345678）
# tags_all - リソースに割り当てられたすべてのタグ
#            （プロバイダーのdefault_tagsから継承されたタグを含む）
#
# 参照方法:
# aws_fsx_openzfs_volume.example.arn
# aws_fsx_openzfs_volume.example.id
# aws_fsx_openzfs_volume.example.tags_all
#-----------------------------------------------------------------------
