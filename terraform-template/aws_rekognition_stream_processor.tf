#---------------------------------------------------------------
# Amazon Rekognition Stream Processor
#---------------------------------------------------------------
#
# Amazon Rekognitionのストリームプロセッサーをプロビジョニングするリソースです。
# Kinesis Video Streamsからのビデオストリームを処理し、顔認識や
# コンテンツモデレーションなどのリアルタイム分析を実行します。
#
# AWS公式ドキュメント:
#   https://docs.aws.amazon.com/rekognition/latest/dg/streaming-video.html
#
# Terraform Registry:
#   https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/rekognition_stream_processor
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_rekognition_stream_processor" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # 設定内容: ストリームプロセッサーの名前
  # 設定可能な値: 英数字、アンダースコア、ハイフンで構成される一意な名前（最大128文字）
  # 省略時: 必須項目のため省略不可
  name = "my-stream-processor"

  # 設定内容: ストリームプロセッサーが使用するIAMロールのARN
  # 設定可能な値: Kinesis Video StreamsおよびKinesis Data Streamsへのアクセス権を持つIAMロールARN
  # 省略時: 必須項目のため省略不可
  role_arn = "arn:aws:iam::123456789012:role/rekognition-stream-processor-role"

  #-------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------

  # 設定内容: ストリームプロセッサーのデータ暗号化に使用するKMSキーのID
  # 設定可能な値: KMSキーID、キーARN、またはキーエイリアス
  # 省略時: AWSマネージドキーを使用
  kms_key_id = null

  #-------------------------------------------------------------
  # 入力設定
  #-------------------------------------------------------------

  input {
    # 設定内容: 処理対象のKinesis Video Streamの設定
    kinesis_video_stream {
      # 設定内容: 入力元Kinesis Video StreamのARN
      # 設定可能な値: 有効なKinesis Video StreamのARN
      # 省略時: 必須項目のため省略不可
      arn = "arn:aws:kinesisvideo:ap-northeast-1:123456789012:stream/my-video-stream/0000000000000"
    }
  }

  #-------------------------------------------------------------
  # 出力設定
  #-------------------------------------------------------------

  output {
    # 設定内容: 検出結果の出力先Kinesis Data Streamの設定
    kinesis_data_stream {
      # 設定内容: 出力先Kinesis Data StreamのARN
      # 設定可能な値: 有効なKinesis Data StreamのARN
      # 省略時: 省略可能（s3_destinationと排他的ではない）
      arn = "arn:aws:kinesis:ap-northeast-1:123456789012:stream/my-output-stream"
    }

    # 設定内容: 検出結果の出力先S3バケットの設定（コンテンツモデレーション用）
    # 省略時: Kinesis Data Streamのみに出力
    # s3_destination {
    #   # 設定内容: 出力先S3バケット名
    #   bucket = "my-rekognition-output-bucket"
    #   # 設定内容: S3オブジェクトのキープレフィックス
    #   key_prefix = "stream-processor-output/"
    # }
  }

  #-------------------------------------------------------------
  # 分析設定
  #-------------------------------------------------------------

  settings {
    # 設定内容: 顔検索設定（コレクションを使用した顔認識）
    face_search {
      # 設定内容: 検索対象の顔コレクションのID
      # 設定可能な値: 有効なRekognitionコレクションID
      # 省略時: 顔検索を使用しない場合は省略
      collection_id = "my-face-collection"

      # 設定内容: 顔マッチングの信頼度しきい値（%）
      # 設定可能な値: 0〜100の数値
      # 省略時: 80（デフォルト値）
      face_match_threshold = 80
    }

    # 設定内容: コンテンツモデレーション設定（不適切コンテンツ検出）
    # 省略時: コンテンツモデレーションを使用しない
    # connected_home {
    #   # 設定内容: 検出するラベルのリスト
    #   # 設定可能な値: "PERSON", "PET", "PACKAGE", "ALL" 等
    #   labels = ["PERSON", "PET"]
    #   # 設定内容: 最小信頼度しきい値（%）
    #   min_confidence = 75
    # }
  }

  #-------------------------------------------------------------
  # 通知設定
  #-------------------------------------------------------------

  # 設定内容: ストリームプロセッサーのイベント通知先SNSトピックの設定
  # 省略時: 通知を送信しない
  notification_channel {
    # 設定内容: 通知先Amazon SNSトピックのARN
    # 設定可能な値: 有効なSNSトピックのARN
    # 省略時: 必須項目のため省略不可
    sns_topic_arn = "arn:aws:sns:ap-northeast-1:123456789012:rekognition-notifications"
  }

  #-------------------------------------------------------------
  # データ共有設定
  #-------------------------------------------------------------

  # 設定内容: AWSとのデータ共有設定（モデル改善への協力）
  # 省略時: データ共有を行わない
  data_sharing_preference {
    # 設定内容: AWSとのデータ共有を有効にするかどうか
    # 設定可能な値: true（共有する）、false（共有しない）
    # 省略時: false
    opt_in = false
  }

  #-------------------------------------------------------------
  # 対象エリア設定
  #-------------------------------------------------------------

  # 設定内容: フレーム内の関心領域（検出対象エリア）の設定
  # 省略時: フレーム全体を対象とする
  # regions_of_interest {
  #   # 設定内容: 関心領域の座標（ポリゴン）
  #   polygon {
  #     x = 0.1
  #     y = 0.1
  #   }
  #   polygon {
  #     x = 0.9
  #     y = 0.1
  #   }
  #   polygon {
  #     x = 0.9
  #     y = 0.9
  #   }
  #   polygon {
  #     x = 0.1
  #     y = 0.9
  #   }
  #
  #   # 設定内容: 関心領域のバウンディングボックス（ポリゴンの代替）
  #   # bounding_box {
  #   #   left   = 0.1
  #   #   top    = 0.1
  #   #   width  = 0.8
  #   #   height = 0.8
  #   # }
  # }

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1、us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # 設定内容: リソースに付与するタグのマップ
  # 設定可能な値: キーと値のペアで構成されるマップ（最大50個）
  # 省略時: タグなし
  tags = {
    Name        = "my-stream-processor"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # 設定内容: リソース作成のタイムアウト時間
    # 設定可能な値: Goのtime.Duration形式（例: "30m"、"1h"）
    # 省略時: デフォルトタイムアウトを使用
    create = "30m"

    # 設定内容: リソース削除のタイムアウト時間
    # 省略時: デフォルトタイムアウトを使用
    delete = "30m"
  }
}

#---------------------------------------------------------------
# Attributes Reference（読み取り専用属性）
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: ストリームプロセッサーのARN
# - stream_processor_arn: ストリームプロセッサーのARN（arnと同値）
# - tags_all: 継承タグを含む全タグマップ
#---------------------------------------------------------------
