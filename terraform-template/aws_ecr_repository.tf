#-----------------------------------------------------------------------
# AWS ECR Repository
#-----------------------------------------------------------------------
# ECR (Elastic Container Registry) のプライベートリポジトリを作成・管理する。
# コンテナイメージの保存、バージョン管理、脆弱性スキャン、暗号化設定が可能。
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ecr_repository
#
# NOTE: このテンプレートは全設定項目を網羅した参考例です。
#       実際の使用時は必要な項目のみを残し、不要な項目は削除してください。
#
# 主な用途:
# - Dockerコンテナイメージの保存とバージョン管理
# - イメージのプッシュ時スキャンによる脆弱性検出
# - KMS暗号化による保存時のセキュリティ強化
# - タグのイミュータビリティによる本番環境保護
#
# 関連リソース:
# - aws_ecr_lifecycle_policy: イメージのライフサイクル管理
# - aws_ecr_repository_policy: リポジトリアクセス権限
# - aws_ecr_registry_policy: レジストリ全体のポリシー
# - aws_ecr_registry_scanning_configuration: レジストリスキャン設定
#
# 参考: https://docs.aws.amazon.com/ecr/
#-----------------------------------------------------------------------

resource "aws_ecr_repository" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # リポジトリ名
  # 設定内容: ECRリポジトリの一意な名前（小文字、数字、ハイフン、アンダースコア、スラッシュのみ使用可能）
  # 設定可能な値: 最大256文字の英数字とハイフン、アンダースコア、スラッシュ（例: "myapp", "team/service-name"）
  # 省略時: なし（必須項目）
  name = "example-repository"

  #-----------------------------------------------------------------------
  # イメージタグの変更可否設定
  #-----------------------------------------------------------------------

  # イメージタグの変更可否
  # 設定内容: リポジトリ内のイメージタグを上書き可能かどうかを制御
  # 設定可能な値:
  #   - "MUTABLE": タグの上書き可能（開発環境向け）
  #   - "IMMUTABLE": タグの上書き不可（本番環境推奨）
  #   - "IMMUTABLE_WITH_EXCLUSION": 一部タグのみ上書き可能（除外フィルタ併用）
  #   - "MUTABLE_WITH_EXCLUSION": 一部タグのみ上書き不可（除外フィルタ併用）
  # 省略時: "MUTABLE"
  image_tag_mutability = "IMMUTABLE"

  # イメージタグ変更可否の除外フィルタ（最大5個まで設定可能）
  # 設定内容: image_tag_mutabilityの設定から除外するタグパターンを指定
  # 適用条件: image_tag_mutabilityが"IMMUTABLE_WITH_EXCLUSION"または"MUTABLE_WITH_EXCLUSION"の場合のみ有効
  # 省略時: なし（オプション）
  image_tag_mutability_exclusion_filter {
    # フィルタパターン
    # 設定内容: タグ名のパターンマッチング（ワイルドカード*使用可能、最大2個まで）
    # 設定可能な値: 最大128文字の英数字と特殊文字（._*-）、ワイルドカード*は最大2個
    # 省略時: なし（必須項目）
    filter = "latest*"

    # フィルタタイプ
    # 設定内容: フィルタのマッチング方式
    # 設定可能な値: "WILDCARD"（ワイルドカードパターンマッチング）
    # 省略時: なし（必須項目）
    filter_type = "WILDCARD"
  }

  #-----------------------------------------------------------------------
  # 暗号化設定
  #-----------------------------------------------------------------------

  # リポジトリの暗号化設定
  # 設定内容: イメージ保存時の暗号化方式とKMSキーの指定
  # 省略時: AES256暗号化（AWS管理キー使用）
  encryption_configuration {
    # 暗号化タイプ
    # 設定内容: イメージデータの暗号化方式
    # 設定可能な値:
    #   - "AES256": AWS管理の暗号化キー（デフォルト、追加料金なし）
    #   - "KMS": カスタマー管理のKMSキー（kms_keyと併用、KMS料金発生）
    # 省略時: "AES256"
    encryption_type = "KMS"

    # KMSキーARN
    # 設定内容: 暗号化に使用するKMSキーのARN（encryption_type="KMS"の場合のみ有効）
    # 設定可能な値: KMSキーのARNまたはエイリアス（例: "arn:aws:kms:us-east-1:123456789012:key/..."）
    # 省略時: AWSデフォルトのECR用KMSキー（aws/ecr）を使用
    kms_key = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"
  }

  #-----------------------------------------------------------------------
  # イメージスキャン設定
  #-----------------------------------------------------------------------

  # イメージスキャン設定
  # 設定内容: イメージプッシュ時の脆弱性スキャン実行設定
  # 省略時: 手動スキャンのみ（自動スキャンなし）
  image_scanning_configuration {
    # プッシュ時スキャン有効化
    # 設定内容: イメージプッシュ時に自動的に脆弱性スキャンを実行するかどうか
    # 設定可能な値:
    #   - true: プッシュ時に自動スキャン実行（セキュリティ強化、本番環境推奨）
    #   - false: 手動スキャンのみ（スキャン実行は手動トリガー）
    # 省略時: なし（必須項目）
    scan_on_push = true
  }

  #-----------------------------------------------------------------------
  # リソース削除設定
  #-----------------------------------------------------------------------

  # イメージ含むリポジトリの強制削除
  # 設定内容: イメージが存在する状態でリポジトリを削除可能にするかどうか
  # 設定可能な値:
  #   - true: イメージが存在しても削除可能（データ損失注意）
  #   - false: イメージが存在する場合は削除エラー（安全）
  # 省略時: false
  force_delete = false

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: "us-east-1", "ap-northeast-1"）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # リソースタグ
  # 設定内容: リポジトリに付与するタグ（コスト管理、検索、組織ポリシーに使用）
  # 設定可能な値: キーと値のマップ（最大50個、キー128文字/値256文字まで）
  # 省略時: なし（プロバイダーのdefault_tagsのみ適用）
  tags = {
    Name        = "example-repository"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # リソース操作のタイムアウト設定
  # 省略時: デフォルトのタイムアウト値を使用
  timeouts {
    # 削除操作のタイムアウト
    # 設定内容: リポジトリ削除操作の最大待機時間
    # 設定可能な値: 時間文字列（例: "20m", "1h"）
    # 省略時: デフォルトのタイムアウト値
    delete = "20m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースの作成後に参照可能な属性:
#
# - arn                : リポジトリの完全ARN
# - registry_id        : リポジトリが作成されたレジストリID（AWSアカウントID）
# - repository_url     : リポジトリのURL（形式: {アカウントID}.dkr.ecr.{リージョン}.amazonaws.com/{リポジトリ名}）
# - tags_all           : リソースに割り当てられた全タグ（プロバイダーdefault_tags含む）
#
# 参照例:
#   aws_ecr_repository.example.arn
#   aws_ecr_repository.example.repository_url
#-----------------------------------------------------------------------
