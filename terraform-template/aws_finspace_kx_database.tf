#----------------------------------------------------------------------
# AWS FinSpace Kx Database
#----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/finspace_kx_database
#
# NOTE: Amazon FinSpaceは2026年10月7日にサポート終了予定です。
#       2025年10月7日以降、新規顧客の受付は終了します。
#
# FinSpace Kx環境内にkdbデータベースを作成します。
# kdb Insightsは金融サービス業界向けの高速データベースソリューションであり、
# 市場データ分析やリスク計算などに使用されます。
#
# 主な用途:
# - kdb Insights環境での金融データベース作成
# - 市場データ分析基盤の構築
# - リアルタイムおよび履歴データストレージ
# - データベースメンテナンスとスキーマ変更管理
#
# 制限事項:
# - データベース名は3〜63文字で英数字とハイフン、アンダースコアのみ使用可能
# - 作成後はFinSpace環境内でのみアクセス可能
#----------------------------------------------------------------------

#----------------------------------------------------------------------
# 基本設定
#----------------------------------------------------------------------

resource "aws_finspace_kx_database" "example" {
  # 設定内容: KX環境の一意識別子
  # 設定可能な値: aws_finspace_kx_environment.id
  # FinSpaceのKX環境IDを指定します。
  # この環境内にデータベースが作成されます。
  environment_id = "environment-id"

  # 設定内容: KXデータベースの名前
  # 設定可能な値: 3〜63文字の英数字、ハイフン、アンダースコア（先頭と末尾は英数字）
  # パターン: ^[a-zA-Z0-9][a-zA-Z0-9-_]*[a-zA-Z0-9]$
  # データベースの一意な識別名です。
  name = "my-kx-database"

  #----------------------------------------------------------------------
  # オプション設定
  #----------------------------------------------------------------------

  # 設定内容: データベースの説明
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  # データベースの目的や用途を記述します。
  description = "Production market data database"

  # 設定内容: リソースのリージョン指定
  # 設定可能な値: AWSリージョンコード（us-east-1, ap-northeast-1など）
  # 省略時: プロバイダー設定のリージョン
  # 通常は環境と同じリージョンで作成されます。
  region = "us-east-1"

  #----------------------------------------------------------------------
  # タグ設定
  #----------------------------------------------------------------------

  # 設定内容: リソースタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  # リソース管理とコスト配分のためのタグです。
  tags = {
    Environment = "Production"
    Project     = "MarketData"
    Owner       = "FinanceTeam"
  }

  #----------------------------------------------------------------------
  # タイムアウト設定
  #----------------------------------------------------------------------

  # timeouts {
  #   # 設定内容: データベース作成のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: デフォルトタイムアウト
  #   # create = "30m"
  #
  #   # 設定内容: データベース更新のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: デフォルトタイムアウト
  #   # update = "30m"
  #
  #   # 設定内容: データベース削除のタイムアウト時間
  #   # 設定可能な値: 時間文字列（例: "30m", "1h"）
  #   # 省略時: デフォルトタイムアウト
  #   # delete = "30m"
  # }
}

#----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#----------------------------------------------------------------------
# arn                     - データベースのARN
# created_timestamp       - データベース作成時刻（エポック秒）
# id                      - 環境IDとデータベース名のカンマ区切り文字列
# last_modified_timestamp - 最終更新時刻（エポック秒）
# tags_all                - プロバイダーのdefault_tagsを含む全タグ
