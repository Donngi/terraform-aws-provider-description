################################################################################
# aws_prometheus_alert_manager_definition - Amazon Managed Service for Prometheus Alert Manager Definition
################################################################################
# Provider Version: 6.28.0
# Resource Type: aws_prometheus_alert_manager_definition
# Official Documentation: https://raw.githubusercontent.com/hashicorp/terraform-provider-aws/main/website/docs/r/prometheus_alert_manager_definition.html.markdown
#
# Description:
# Manages an Amazon Managed Service for Prometheus (AMP) Alert Manager Definition.
# Alert Manager processes alerts generated by Prometheus alerting rules, handling
# deduplication, grouping, and routing to downstream receivers.
#
# Use Cases:
# - Route Prometheus alerts to Amazon SNS topics
# - Manage alert deduplication and grouping
# - Configure alert inhibition rules
# - Set up silences for maintenance windows
# - Customize alert message templates
#
# Key Features:
# - Alert deduplication and grouping
# - Routing alerts based on labels
# - Inhibition rules to suppress related alerts
# - Silence functionality for maintenance periods
# - Amazon SNS integration (only supported receiver)
# - Prometheus template support for custom messages
################################################################################

resource "aws_prometheus_alert_manager_definition" "example" {
  ################################################################################
  # Basic Configuration
  ################################################################################

  # workspace_id - (Required)
  # Description: ID of the prometheus workspace the alert manager definition should be linked to
  # Type: string
  # Note: References the workspace where alerting rules are defined
  # Example: "ws-12345678-1234-1234-1234-123456789012"
  # See more: https://docs.aws.amazon.com/prometheus/latest/userguide/AMP-onboard-create-workspace.html
  workspace_id = aws_prometheus_workspace.example.id

  # definition - (Required)
  # Description: The alert manager definition that you want to be applied (YAML format)
  # Type: string
  # Note: Must contain all configuration inside alertmanager_config key
  # Only Amazon SNS is supported as receiver
  # See more: https://docs.aws.amazon.com/prometheus/latest/userguide/AMP-alert-manager.html
  #
  # Structure:
  # alertmanager_config: |
  #   route:
  #     receiver: 'receiver-name'
  #     [optional routing configuration]
  #   receivers:
  #     - name: 'receiver-name'
  #       sns_configs:
  #         - topic_arn: arn:aws:sns:region:account:topic
  #           sigv4:
  #             region: region
  #
  # Optional sections:
  # - template_files: Prometheus templates for custom message formatting
  # - inhibit_rules: Rules to suppress certain alerts
  # - global: Global configuration settings
  definition = <<EOF
alertmanager_config: |
  route:
    receiver: 'default'
  receivers:
    - name: 'default'
EOF

  ################################################################################
  # Region Configuration
  ################################################################################

  # region - (Optional)
  # Description: Region where this resource will be managed
  # Type: string
  # Default: Defaults to the Region set in the provider configuration
  # Note: This is an advanced configuration option
  # See more: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  # Example: "us-east-1", "eu-west-1"
  # region = "us-east-1"
}

################################################################################
# Computed Attributes (Read-Only)
################################################################################
#
# These attributes are exported by the resource and can be referenced:
#
# - id (string)
#   Description: Identifier of the alert manager definition (same as workspace_id)
#   Example: aws_prometheus_alert_manager_definition.example.id
#

