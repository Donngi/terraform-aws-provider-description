#---------------------------------------------------------------
# AWS Elemental MediaConvert Queue
#---------------------------------------------------------------
#
# AWS Elemental MediaConvert のキューをプロビジョニングするリソースです。
# MediaConvert は、ファイルベースの動画処理サービスで、オンデマンドで
# 動画コンテンツをフォーマット変換、パッケージング、配信用に最適化します。
# キューは、トランスコーディングジョブの処理順序と優先度を管理します。
#
# 主な特徴:
#   - オンデマンドキュー: 従量課金でジョブごとに処理
#   - 予約キュー: 予約容量を購入して安定した処理能力を確保
#   - 同時実行制御: 処理するジョブの最大同時実行数を制御可能
#
# AWS公式ドキュメント:
#   - MediaConvert キュー概要: https://docs.aws.amazon.com/mediaconvert/latest/ug/working-with-queues.html
#   - 料金プラン: https://docs.aws.amazon.com/mediaconvert/latest/ug/reserved-pricing.html
#   - ジョブの管理: https://docs.aws.amazon.com/mediaconvert/latest/ug/working-with-jobs.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/media_convert_queue
#
# Provider Version: 6.28.0
# Generated: 2026-02-04
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_media_convert_queue" "example" {
  #-------------------------------------------------------------
  # 必須パラメータ
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: キューを識別するための一意の名前を指定します。
  # 設定可能な値: 文字列（英数字、ハイフン、アンダースコア）
  # 注意: この名前はアカウント内で一意である必要があります。
  name = "my-mediaconvert-queue"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional, Computed)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  # 注意: MediaConvert は一部のリージョンでのみ利用可能です。
  region = null

  #-------------------------------------------------------------
  # キューの説明
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: キューの目的や用途を説明するテキストを指定します。
  # 設定可能な値: 任意の文字列
  # 用途: コンソールでのキュー識別や、用途の文書化に使用します。
  description = "MediaConvert queue for video transcoding jobs"

  #-------------------------------------------------------------
  # 料金プラン設定
  #-------------------------------------------------------------

  # pricing_plan (Optional)
  # 設定内容: キューの料金プランを指定します。
  # 設定可能な値:
  #   - "ON_DEMAND" (デフォルト): オンデマンド料金プラン。使用した分だけ課金。
  #   - "RESERVED": 予約料金プラン。事前に容量を予約して割引価格を適用。
  # 注意:
  #   - RESERVED に設定する場合、reservation_plan_settings が必須です。
  #   - オンデマンドから予約への変更は、予約設定を追加する必要があります。
  # 参考: https://aws.amazon.com/mediaconvert/pricing/
  pricing_plan = "ON_DEMAND"

  #-------------------------------------------------------------
  # 同時実行制御
  #-------------------------------------------------------------

  # concurrent_jobs (Optional, Computed)
  # 設定内容: キューで同時に処理できる最大ジョブ数を指定します。
  # 設定可能な値: 正の整数
  # 省略時:
  #   - オンデマンドキュー: サービスクォータによって制限されます。
  #     （デフォルトで、オンデマンドキューあたりの最大同時ジョブ数と
  #      アカウントあたりの最大同時ジョブ数に制約されます）
  #   - 予約キュー: 予約プランで指定した予約スロット数に基づきます。
  # 注意:
  #   - オンデマンドキューの場合、入力値は AWS のサービスクォータによって
  #     制約されます。Service Quotas コンソールで上限を確認・変更できます。
  #   - 予約キューの場合、この値は指定せず、予約スロット数で制御します。
  concurrent_jobs = null

  #-------------------------------------------------------------
  # キューのステータス
  #-------------------------------------------------------------

  # status (Optional)
  # 設定内容: キューの現在の状態を指定します。
  # 設定可能な値:
  #   - "ACTIVE": キューはジョブを受け付けて処理します。
  #   - "PAUSED" (デフォルト): キューは一時停止し、新しいジョブは処理されません。
  #                            既存の実行中ジョブは完了まで継続されます。
  # 用途:
  #   - ジョブの受付を一時的に停止する場合に PAUSED を設定します。
  #   - メンテナンスやトラブルシューティング時に有用です。
  # 注意: キューを作成する際は ACTIVE に設定してジョブを受け付けるようにします。
  status = "PAUSED"

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 用途: コスト管理、リソース分類、アクセス制御などに使用します。
  # 関連機能: AWS リソースタグ付け
  #   プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "my-mediaconvert-queue"
    Environment = "production"
    Purpose     = "video-transcoding"
  }

  # tags_all (Optional, Computed)
  # 設定内容: プロバイダーの default_tags から継承されたタグを含む全タグのマップです。
  # 注意: 通常は明示的に設定せず、Terraform が自動計算します。
  # tags_all = {}

  #-------------------------------------------------------------
  # 予約プラン設定（pricing_plan が "RESERVED" の場合のみ）
  #-------------------------------------------------------------

  # reservation_plan_settings (Optional)
  # 設定内容: 予約キューの料金プラン詳細を指定します。
  # 必須条件: pricing_plan が "RESERVED" の場合、このブロックは必須です。
  # 最大項目数: 1
  # 関連機能: MediaConvert 予約料金プラン
  #   予約トランスコードスロット (RTS) を購入して、割引価格で処理能力を確保します。
  #   1年間のコミットメント期間があります。
  # 参考: https://docs.aws.amazon.com/mediaconvert/latest/ug/reserved-pricing.html

  # reservation_plan_settings {
  #   # commitment (Required)
  #   # 設定内容: 予約プランのコミットメント期間の長さを指定します。
  #   # 設定可能な値:
  #   #   - "ONE_YEAR": 1年間のコミットメント期間
  #   # 注意: 現時点では ONE_YEAR のみがサポートされています。
  #   commitment = "ONE_YEAR"
  #
  #   # renewal_type (Required)
  #   # 設定内容: 予約プランの更新タイプを指定します。
  #   # 設定可能な値:
  #   #   - "AUTO_RENEW": コミットメント期間終了時に自動更新されます。
  #   #   - "EXPIRE": コミットメント期間終了時に自動的に期限切れになります。
  #   # 注意:
  #   #   - AUTO_RENEW を選択すると、明示的にキャンセルするまで毎年更新されます。
  #   #   - EXPIRE を選択すると、期間終了後は手動で更新が必要です。
  #   renewal_type = "EXPIRE"
  #
  #   # reserved_slots (Required)
  #   # 設定内容: 予約するトランスコードスロット (RTS) の数を指定します。
  #   # 設定可能な値: 正の整数
  #   # 説明:
  #   #   - 各 RTS は、1つのジョブを同時に処理できます。
  #   #   - 必要な同時実行ジョブ数に基づいてスロット数を決定します。
  #   #   - スロット数によって料金が決まります。
  #   # 例: 10 のスロットを予約すると、最大10個のジョブを同時に処理できます。
  #   reserved_slots = 10
  # }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: キューの名前（name と同じ値）
#
# - arn: キューの Amazon Resource Name (ARN)
#       形式: arn:aws:mediaconvert:region:account-id:queues/queue-name
#       用途: IAM ポリシー、CloudWatch メトリクス、API 呼び出しなどで使用
#
# - tags_all: プロバイダーの default_tags 設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#

