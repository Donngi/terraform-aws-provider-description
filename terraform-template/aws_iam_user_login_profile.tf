#######################################################################
# IAM User Login Profile
#######################################################################
# IAMユーザーのAWSマネジメントコンソールへのログインプロファイルを管理する
# リソース。初回パスワードの生成とPGP暗号化による安全な配布をサポートする。
#
# 主な用途:
# - IAMユーザーへの初期パスワード発行
# - PGP/Keybaseを使用した暗号化パスワードの安全な配布
# - パスワードリセット強制によるセキュリティポリシーの適用
#
# 注意:
# - 作成時のみパスワードが生成される（ドリフト検出は行われない）
# - パスワードをリセットするには taint またはいずれかの引数を変更する
# - pgp_keyを指定しない場合、パスワードはステートファイルに平文保存される
#
# 参考: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_passwords_admin-change-user.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/iam_user_login_profile
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_iam_user_login_profile" "example" {
  #-----------------------------------------------------------------------
  # ユーザー設定
  #-----------------------------------------------------------------------

  # 対象IAMユーザーの名前
  # 設定内容: ログインプロファイルを作成するIAMユーザー名
  # 注意: 事前に aws_iam_user リソースで作成されている必要がある
  user = aws_iam_user.example.name

  #-----------------------------------------------------------------------
  # パスワード設定
  #-----------------------------------------------------------------------

  # 生成パスワードの長さ
  # 設定内容: リソース作成時に生成されるパスワードの文字数
  # 設定可能な値: 整数（最小8、最大128）
  # 省略時: 20
  # 注意: 作成時のみ有効。変更してもドリフト検出は行われない
  password_length = 20

  # パスワードリセットの強制
  # 設定内容: 初回ログイン時にパスワード変更を強制するか
  # 設定可能な値: true / false
  # 省略時: AWSのデフォルト動作に依存
  # 注意: 作成時のみ有効。変更してもドリフト検出は行われない
  password_reset_required = true

  #-----------------------------------------------------------------------
  # 暗号化設定
  #-----------------------------------------------------------------------

  # PGP公開鍵またはKeybaseユーザー名
  # 設定内容: パスワードの暗号化に使用するPGP公開鍵
  # 設定可能な値:
  #   - "keybase:ユーザー名": Keybaseを使用する場合
  #   - Base64エンコードされたPGP公開鍵: 直接指定する場合
  # 省略時: パスワードはステートファイルに平文で保存される（非推奨）
  # 注意: 作成時のみ有効。変更してもドリフト検出は行われない
  pgp_key = "keybase:some_person_that_exists"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   ログインプロファイルが関連付けられたIAMユーザー名
#
# - encrypted_password
#   PGP暗号化されたBase64エンコードのパスワード
#   pgp_keyを指定した場合のみ利用可能
#
# - key_fingerprint
#   暗号化に使用されたPGP公開鍵のフィンガープリント
#   Terraform作成時のみ利用可能（インポート時は空）
#
# - password
#   平文パスワード。pgp_keyを指定しない場合のみ利用可能
#   セキュリティリスクがあるため pgp_key の使用を推奨する
#-----------------------------------------------------------------------
