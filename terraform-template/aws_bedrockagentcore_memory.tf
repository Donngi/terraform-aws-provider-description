    Name        = "example-memory"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソースの作成・削除操作のタイムアウト時間を指定します。
  timeouts {
    # create (Optional)
    # 設定内容: リソース作成操作のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "2h45m" などの時間文字列（秒: s、分: m、時: h）
    # 省略時: デフォルトのタイムアウト値が使用されます
    create = "30m"

    # delete (Optional)
    # 設定内容: リソース削除操作のタイムアウト時間を指定します。
    # 設定可能な値: "30s", "2h45m" などの時間文字列（秒: s、分: m、時: h）
    # 省略時: デフォルトのタイムアウト値が使用されます
    delete = "30m"
  }
}

