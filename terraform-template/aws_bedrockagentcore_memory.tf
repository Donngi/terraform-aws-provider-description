  memory_execution_role_arn = "arn:aws:iam::123456789012:role/bedrock-agentcore-memory-role"

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
