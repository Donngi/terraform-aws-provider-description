  # 設定可能な値: 7から365の範囲の正の整数
  # 関連機能: AgentCore Memory イベント保持
  #   短期メモリおよび長期メモリの生成元となる生のイベントデータの保持期間を制御します。
  #   期限切れのイベントは自動的に削除されます。
  #   - https://docs.aws.amazon.com/bedrock-agentcore/latest/devguide/memory.html
  event_expiry_duration = 30

  #-------------------------------------------------------------
  # 暗号化設定
  #-------------------------------------------------------------

  # encryption_key_arn (Optional)
  # 設定内容: メモリの暗号化に使用するKMSキーのARNを指定します。
  # 設定可能な値: 有効なKMSキーARN
  # 省略時: AWSマネージドの暗号化が使用されます
  # 関連機能: AgentCore Memory データ暗号化
  #   AWS KMSカスタマーマネージドキーを使用してメモリデータを暗号化し、
  #   データのセキュリティとコンプライアンス要件を満たすことができます。
  encryption_key_arn = "arn:aws:kms:ap-northeast-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #-------------------------------------------------------------
  # IAMロール設定
  #-------------------------------------------------------------

  # memory_execution_role_arn (Optional)
  # 設定内容: メモリサービスが操作を実行するために引き受けるIAMロールのARNを指定します。
