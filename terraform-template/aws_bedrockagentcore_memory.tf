  # description (Optional)
  # 設定内容: メモリの説明を指定します。
  # 設定可能な値: 文字列
  # 用途: メモリの用途や目的を記録するために使用
  description = "Memory for customer service agent"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
