#---------------------------------------------------------------
# AWS S3 Bucket Intelligent-Tiering Configuration
#---------------------------------------------------------------
#
# S3インテリジェントティアリング設定リソースをプロビジョニングします。
# このリソースは、S3バケットのインテリジェントティアリング設定を管理し、
# アクセスパターンに基づいてオブジェクトを自動的に最適なストレージ
# クラスに移動します。アーカイブアクセスおよびディープアーカイブ
# アクセス層への自動移行を設定できます。
#
# 注意: このリソースはS3ディレクトリバケットでは使用できません。
#
# AWS公式ドキュメント:
#   - S3インテリジェントティアリング概要:
#     https://docs.aws.amazon.com/AmazonS3/latest/userguide/intelligent-tiering.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/s3_bucket_intelligent_tiering_configuration
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_s3_bucket_intelligent_tiering_configuration" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # bucket (Required)
  # 設定内容: このインテリジェントティアリング設定を関連付けるバケットの名前を指定します。
  # 設定可能な値: 既存のS3バケット名
  bucket = "example-bucket"

  # name (Required)
  # 設定内容: バケットに対するS3インテリジェントティアリング設定を識別する一意の名前を指定します。
  # 設定可能な値: 任意の文字列
  name = "EntireBucket"

  #-------------------------------------------------------------
  # ステータス設定
  #-------------------------------------------------------------

  # status (Optional)
  # 設定内容: この設定のステータスを指定します。
  # 設定可能な値: "Enabled"（有効）, "Disabled"（無効）
  # 省略時: Enabledとして扱われます
  status = "Enabled"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # フィルタ設定
  #-------------------------------------------------------------

  # filter (Optional)
  # 設定内容: 設定を適用するオブジェクトのフィルタリング条件を指定します。
  # 設定可能な値: prefixまたはtagsのいずれか、あるいは両方の組み合わせ
  # 省略時: バケット内の全オブジェクトに設定が適用されます（最大1つのブロック）
  filter {
    # prefix (Optional)
    # 設定内容: 設定を適用するオブジェクトのキー名プレフィックスを指定します。
    # 設定可能な値: 任意の文字列（パス形式も可）
    prefix = "documents/"

    # tags (Optional)
    # 設定内容: 設定を適用するオブジェクトのタグセットを指定します。
    # 設定可能な値: キーと値のペアのマップ
    # 注意: 指定したタグがすべてオブジェクトのタグセットに存在する場合のみ設定が適用されます
    tags = {
      priority = "high"
      class    = "blue"
    }
  }

  #-------------------------------------------------------------
  # ティアリング設定
  #-------------------------------------------------------------

  # tiering (Required)
  # 設定内容: インテリジェントティアリングストレージクラスのティア移行条件を指定します。
  # 設定可能な値: 1つ以上のtieringブロックを指定します
  # 注意: ARCHIVE_ACCESSは最小125日、DEEP_ARCHIVE_ACCESSは最小180日以上の設定が必要です
  tiering {
    # access_tier (Required)
    # 設定内容: S3インテリジェントティアリングのアクセス層を指定します。
    # 設定可能な値: "ARCHIVE_ACCESS"（アーカイブアクセス）, "DEEP_ARCHIVE_ACCESS"（ディープアーカイブアクセス）
    access_tier = "ARCHIVE_ACCESS"

    # days (Required)
    # 設定内容: オブジェクトへのアクセスがない状態が続いた場合に、対応する層への移行が開始されるまでの日数を指定します。
    # 設定可能な値: ARCHIVE_ACCESSの場合は125以上、DEEP_ARCHIVE_ACCESSの場合は180以上の整数
    days = 125
  }

  tiering {
    # access_tier (Required)
    # 設定内容: S3インテリジェントティアリングのアクセス層を指定します。
    # 設定可能な値: "ARCHIVE_ACCESS"（アーカイブアクセス）, "DEEP_ARCHIVE_ACCESS"（ディープアーカイブアクセス）
    access_tier = "DEEP_ARCHIVE_ACCESS"

    # days (Required)
    # 設定内容: オブジェクトへのアクセスがない状態が続いた場合に、対応する層への移行が開始されるまでの日数を指定します。
    # 設定可能な値: ARCHIVE_ACCESSの場合は125以上、DEEP_ARCHIVE_ACCESSの場合は180以上の整数
    days = 180
  }
}

