#-----------------------------------------------------------------------
# AWS Default Security Group
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/default_security_group
#
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# デフォルトセキュリティグループの管理リソース
#
# NOTE: このリソースは特殊な動作をします - 新規作成ではなく既存リソースを管理下に置きます
#-----------------------------------------------------------------------
# デフォルトまたは非デフォルトVPCのデフォルトセキュリティグループを管理するリソース。
# このリソースは特殊な動作をするため、使用前に注意事項をよく確認してください。
#
# 【重要な注意事項】
# - Terraformはこのリソースを新規作成せず、既存のデフォルトセキュリティグループを「管理下に置く」動作をします
# - 管理開始時、既存の全てのingress/egressルールを即座に削除し、構成に定義されたルールのみを作成します
# - インラインルールは絶対的に扱われ、外部からの追加/削除は差分として検出されます
# - aws_security_group_ruleリソースとは互換性がありません（併用不可）
#
# 【推奨される使用方法】
# - デフォルトセキュリティグループは使用せず、カスタムセキュリティグループを作成することが推奨されます
# - セキュリティベストプラクティスとして、デフォルトセキュリティグループの全トラフィックを拒否することが推奨されます
#   （AWS Config管理ルール: vpc-default-security-group-closed）
#
# 【デフォルトセキュリティグループについて】
# - VPC作成時に自動的に作成される「default」という名前のセキュリティグループ
# - リソース作成時に明示的なセキュリティグループを指定しない場合に関連付けられます
# - ルールは変更可能ですが、セキュリティグループ自体は削除できません
# - デフォルトのルール:
#   - Inbound: 同じセキュリティグループ内のリソースからの全トラフィックを許可
#   - Outbound: 全てのIPv4/IPv6トラフィックを許可
#
#-----------------------------------------------------------------------

resource "aws_default_security_group" "example" {
  #-----------------------------------------------------------------------
  # VPC識別
  #-----------------------------------------------------------------------
  # 設定内容: デフォルトセキュリティグループを管理するVPCのID
  # 省略時: デフォルトVPCのデフォルトセキュリティグループが対象になります
  # 注意: vpc_idを変更してもリソースは再作成されますが、変更前のVPCのデフォルトセキュリティグループに
  #       加えられた変更（追加/削除/変更されたルール）は元に戻りません。現在の状態のまま残ります
  vpc_id = "vpc-12345678"

  #-----------------------------------------------------------------------
  # インバウンドルール
  #-----------------------------------------------------------------------
  # 設定内容: インバウンドトラフィックを許可するルールの設定
  # 省略時: インバウンドトラフィックは全て拒否されます（管理開始時に既存ルールは削除されます）
  # 注意: VPCでのみ使用可能。複数のingressブロックを定義できます
  ingress {
    # 設定内容: プロトコル（tcp, udp, icmp, icmpv6, 数値、または全プロトコルの場合は-1）
    # 注意: -1を指定する場合、from_portとto_portは0にする必要があります
    protocol = "tcp"

    # 設定内容: 開始ポート番号（ICMPの場合はタイプ番号）
    # 注意: protocolが-1の場合は0を指定する必要があります
    from_port = 443

    # 設定内容: 終了ポート番号（ICMPの場合はコード番号）
    # 注意: protocolが-1の場合は0を指定する必要があります
    to_port = 443

    # 設定内容: トラフィックを許可するIPv4 CIDRブロックのリスト
    # 省略時: IPv4 CIDRブロックからのトラフィックは許可されません
    cidr_blocks = ["10.0.0.0/16"]

    # 設定内容: トラフィックを許可するIPv6 CIDRブロックのリスト
    # 省略時: IPv6 CIDRブロックからのトラフィックは許可されません
    ipv6_cidr_blocks = []

    # 設定内容: トラフィックを許可するセキュリティグループIDのリスト
    # 省略時: 他のセキュリティグループからのトラフィックは許可されません
    # 注意: デフォルトVPCではグループ名も使用可能ですが、それ以外ではグループIDを使用してください
    security_groups = []

    # 設定内容: VPCエンドポイントへのアクセスを許可するプレフィックスリストIDのリスト
    # 省略時: プレフィックスリストからのトラフィックは許可されません
    prefix_list_ids = []

    # 設定内容: このセキュリティグループ自身をソースとして追加するかどうか
    # 設定可能な値: true（同じセキュリティグループ内のリソース間通信を許可）、false
    # 省略時: false（セキュリティグループ内通信は許可されません）
    self = true

    # 設定内容: このルールの説明
    # 省略時: 説明なし
    description = "Allow HTTPS from VPC"
  }

  #-----------------------------------------------------------------------
  # アウトバウンドルール
  #-----------------------------------------------------------------------
  # 設定内容: アウトバウンドトラフィックを許可するルールの設定
  # 省略時: アウトバウンドトラフィックは全て拒否されます（管理開始時に既存ルールは削除されます）
  # 注意: VPCでのみ使用可能。複数のegressブロックを定義できます
  egress {
    # 設定内容: プロトコル（tcp, udp, icmp, icmpv6, 数値、または全プロトコルの場合は-1）
    protocol = "-1"

    # 設定内容: 開始ポート番号（ICMPの場合はタイプ番号）
    from_port = 0

    # 設定内容: 終了ポート番号（ICMPの場合はコード番号）
    to_port = 0

    # 設定内容: トラフィックを許可するIPv4 CIDRブロックのリスト
    cidr_blocks = ["0.0.0.0/0"]

    # 設定内容: トラフィックを許可するIPv6 CIDRブロックのリスト
    ipv6_cidr_blocks = []

    # 設定内容: トラフィックを許可するセキュリティグループIDのリスト
    security_groups = []

    # 設定内容: VPCエンドポイントへのアクセスを許可するプレフィックスリストIDのリスト
    prefix_list_ids = []

    # 設定内容: このセキュリティグループ自身を宛先として追加するかどうか
    # 設定可能な値: true、false
    # 省略時: false
    self = false

    # 設定内容: このルールの説明
    description = "Allow all outbound traffic"
  }

  #-----------------------------------------------------------------------
  # リソース削除時の動作
  #-----------------------------------------------------------------------
  # 設定内容: リソース削除時にルールを取り消すかどうか
  # 設定可能な値: true（削除時にルールを取り消す）、false（削除時にルールを残す）
  # 省略時: false
  # 注意: セキュリティグループ自体は削除されません（デフォルトセキュリティグループは削除不可のため）
  revoke_rules_on_delete = false

  #-----------------------------------------------------------------------
  # リージョン指定
  #-----------------------------------------------------------------------
  # 設定内容: このリソースを管理するリージョン
  # 省略時: プロバイダー設定のリージョンが使用されます
  # 注意: リージョン固有のエンドポイントで管理されます
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ
  #-----------------------------------------------------------------------
  # 設定内容: リソースに割り当てるタグ（キーと値のマップ）
  # 省略時: タグなし（プロバイダーのdefault_tagsは適用されます）
  tags = {
    Name        = "default-security-group"
    Environment = "production"
    ManagedBy   = "terraform"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn                - セキュリティグループのARN
# - id                 - セキュリティグループのID
# - name               - セキュリティグループの名前（常に"default"）
# - name_prefix        - セキュリティグループの名前プレフィックス
# - description        - セキュリティグループの説明
# - owner_id           - セキュリティグループのオーナーID（AWSアカウントID）
# - vpc_id             - セキュリティグループが属するVPCのID
# - tags_all           - リソースに割り当てられた全タグ（プロバイダーのdefault_tagsを含む）
#
# 参照方法:
#   aws_default_security_group.example.id
#   aws_default_security_group.example.arn
#   aws_default_security_group.example.owner_id
