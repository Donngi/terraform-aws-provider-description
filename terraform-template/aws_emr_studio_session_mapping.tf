#-------------------------------------------------------------------------------------------------------
# Terraform AWS Provider Resource Template
#-------------------------------------------------------------------------------------------------------
# Resource: aws_emr_studio_session_mapping
# Provider: hashicorp/aws
# Provider Version: 6.28.0
# Generated: 2025-01-30
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/emr_studio_session_mapping
#
# NOTE: このテンプレートは参考例です。実際の環境に合わせて値を変更してください。
#-------------------------------------------------------------------------------------------------------
# 機能:
#   - EMR StudioへのIAMユーザーまたはグループのマッピングを管理
#   - AWS SSO Identity StoreのIDとEMR Studioの関連付け
#   - セッションポリシーによるアクセス制御の設定
#
# ユースケース:
#   - EMR Studioへのユーザーアクセス権限の付与
#   - グループ単位でのアクセス管理
#   - セッション単位の詳細な権限制御
#
# 前提条件:
#   - EMR Studioが作成済みであること
#   - AWS SSO Identity Storeが設定済みであること
#   - セッションポリシーとなるIAMポリシーが存在すること
#
# 制約事項:
#   - identity_idまたはidentity_nameのいずれかが必須
#   - identity_typeはUSERまたはGROUPのみ指定可能
#-------------------------------------------------------------------------------------------------------

#-------------------------------------------------------------------------------------------------------
# EMR Studioセッションマッピング
#-------------------------------------------------------------------------------------------------------
resource "aws_emr_studio_session_mapping" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------------------------------------------------

  # Studio ID設定
  # 設定内容: マッピング先のEMR StudioのID
  # 制約: 存在するEMR StudioのIDである必要がある
  studio_id = "es-XXXXXXXXXXXXXXXXXXXX"

  # IDタイプ設定
  # 設定内容: マッピング対象のIDタイプ
  # 設定可能な値: USER（ユーザー）, GROUP（グループ）
  identity_type = "USER"

  # セッションポリシーARN設定
  # 設定内容: マッピングされたユーザー/グループに適用されるIAMポリシーのARN
  # 制約: ユーザーロールのARNではなく、セッションポリシーのARNを指定
  session_policy_arn = "arn:aws:iam::123456789012:policy/EMRStudioSessionPolicy"

  #-------------------------------------------------------------------------------------------------------
  # ID識別設定（identity_idまたはidentity_nameのいずれかを指定）
  #-------------------------------------------------------------------------------------------------------

  # ID識別子設定
  # 設定内容: AWS SSO Identity StoreのユーザーIDまたはグループID
  # 省略時: identity_nameを使用してIDが特定される
  # 備考: identity_idとidentity_nameのどちらかを指定（両方でも可）
  identity_id = "1234567890-abcdef12-3456-7890-abcd-ef1234567890"

  # ID名設定
  # 設定内容: AWS SSO Identity Storeのユーザー名またはグループ名
  # 省略時: identity_idを使用してIDが特定される
  # 備考: identity_idとidentity_nameのどちらかを指定（両方でも可）
  # 値の形式: "user@example.com"（ユーザー）または"MyGroup"（グループ）
  identity_name = "user@example.com"

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------

  # リージョン設定
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 備考: 明示的に指定することでマルチリージョン構成に対応可能
  region = "us-east-1"
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# このリソースでは以下の属性が参照可能:
#
# - id: セッションマッピングのID
#     形式: studio_id:identity_type:identity_id
#     用途: リソースの一意識別、他リソースからの参照
#
# - identity_id: IDタイプがUSERまたはGROUPのID（computed）
#     用途: 設定されたアイデンティティIDの確認
#
# - identity_name: IDタイプがUSERまたはGROUPの名前（computed）
#     用途: 設定されたアイデンティティ名の確認
#-------------------------------------------------------------------------------------------------------
