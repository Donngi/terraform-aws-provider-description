#######################################################################
# AWS Config Configuration Recorder
#######################################################################
# AWS Configの設定レコーダーを作成・管理するリソース
# リソース構成の変更を記録し、設定履歴とスナップショットを提供します
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/config_configuration_recorder
# Generated: 2026-02-13
#
# 主な用途:
# - AWSリソースの構成変更履歴を記録
# - コンプライアンス監査のための構成データ収集
# - リソース構成の継続的なモニタリング
# - 構成変更の追跡とレビュー
#
# 制約事項:
# - 各リージョンで最大1つのConfiguration Recorderのみ作成可能
# - 記録を開始するには対応するDelivery Channelが必要
# - グローバルリソースの記録は1つのリージョンでのみ有効化を推奨
# - 記録には適切なIAMロールとS3バケットが必要
#
# NOTE:
# - 大量のリソースを記録する場合、配信チャネルのS3コストに注意
# - all_supported=trueの場合、新しいリソースタイプが自動的に記録対象になる
# - グローバルリソース（IAM等）の重複記録を避けるため、リージョン設計が重要
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------
resource "aws_config_configuration_recorder" "example" {
  # 設定内容: Configuration Recorderの名前
  # 省略時: "default"
  # 備考: 各リージョンで一意である必要があります
  name = "example-recorder"

  # 設定内容: Configuration RecorderがAWS Configサービスを呼び出すために使用するIAMロールのARN
  # 必須項目: はい
  # 備考: ロールにはAWS Configが必要とする権限が必要です（AWS_ConfigRole等）
  role_arn = "arn:aws:iam::123456789012:role/aws-config-role"

  # 設定内容: このリソースが管理されるAWSリージョン
  # 省略時: プロバイダー設定で指定されたリージョン
  # 備考: 通常は省略してプロバイダー設定のリージョンを使用します
  region = null

  #-----------------------------------------------------------------------
  # 記録グループ設定
  #-----------------------------------------------------------------------
  # 記録対象のリソースタイプとグローバルリソースの記録設定を定義
  recording_group {
    # 設定内容: サポートされている全てのリソースタイプを記録するかどうか
    # 設定可能な値: true, false
    # 省略時: true
    # 備考: trueの場合、新しくサポートされるリソースタイプも自動的に記録対象になります
    all_supported = true

    # 設定内容: グローバルリソース（IAM、グローバルサービス等）を記録するかどうか
    # 設定可能な値: true, false
    # 省略時: false
    # 備考: 通常は1つのリージョンでのみtrueに設定します（重複記録を避けるため）
    include_global_resource_types = true

    # 設定内容: 記録する特定のリソースタイプのリスト
    # 省略時: なし（all_supportedがtrueの場合は不要）
    # 備考: all_supportedがfalseの場合に使用します
    # resource_types = [
    #   "AWS::EC2::Instance",
    #   "AWS::EC2::Volume",
    # ]

    #-----------------------------------------------------------------------
    # リソースタイプ除外設定
    #-----------------------------------------------------------------------
    # 特定のリソースタイプを記録対象から除外
    # exclusion_by_resource_types {
    #   # 設定内容: 記録から除外するリソースタイプのリスト
    #   # 省略時: なし（全てのリソースタイプが記録対象）
    #   # 備考: all_supportedがtrueの場合にのみ使用可能
    #   resource_types = [
    #     "AWS::EC2::SecurityGroup",
    #   ]
    # }

    #-----------------------------------------------------------------------
    # 記録戦略設定
    #-----------------------------------------------------------------------
    # リソースタイプの選択方法を制御
    # recording_strategy {
    #   # 設定内容: 記録戦略のタイプ
    #   # 設定可能な値: ALL_SUPPORTED_RESOURCE_TYPES, INCLUSION_BY_RESOURCE_TYPES, EXCLUSION_BY_RESOURCE_TYPES
    #   # 省略時: ALL_SUPPORTED_RESOURCE_TYPES
    #   # 備考: この設定により、all_supported、resource_types、exclusion_by_resource_typesの動作が決定されます
    #   use_only = "ALL_SUPPORTED_RESOURCE_TYPES"
    # }
  }

  #-----------------------------------------------------------------------
  # 記録モード設定
  #-----------------------------------------------------------------------
  # リソース構成の記録頻度を制御
  recording_mode {
    # 設定内容: 記録の頻度
    # 設定可能な値: CONTINUOUS（継続的）, DAILY（1日1回）
    # 省略時: CONTINUOUS
    # 備考: CONTINUOUSは構成変更時に即座に記録、DAILYは1日1回の記録
    recording_frequency = "CONTINUOUS"

    #-----------------------------------------------------------------------
    # 記録モードオーバーライド設定
    #-----------------------------------------------------------------------
    # 特定のリソースタイプに対して異なる記録頻度を設定
    # recording_mode_override {
    #   # 設定内容: このオーバーライド設定の説明
    #   # 省略時: なし
    #   # 備考: 管理目的で使用される説明文
    #   description = "特定リソースの日次記録設定"
    #
    #   # 設定内容: オーバーライドする記録頻度
    #   # 設定可能な値: CONTINUOUS, DAILY
    #   # 必須項目: はい
    #   # 備考: 指定したリソースタイプに適用される記録頻度
    #   recording_frequency = "DAILY"
    #
    #   # 設定内容: オーバーライドを適用するリソースタイプのリスト
    #   # 必須項目: はい
    #   # 備考: これらのリソースタイプは、デフォルトの記録頻度ではなく、ここで指定した頻度で記録されます
    #   resource_types = [
    #     "AWS::EC2::Volume",
    #     "AWS::EC2::Snapshot",
    #   ]
    # }
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースをデプロイ後に参照できる属性:
#
# - id
#   リソースID（通常はConfiguration Recorderの名前）
#
# - name
#   Configuration Recorderの名前
#
# - role_arn
#   使用されているIAMロールのARN
#
# - region
#   Configuration Recorderが管理されているAWSリージョン
