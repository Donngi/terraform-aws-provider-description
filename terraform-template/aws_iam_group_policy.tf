# - id: グループ名とポリシー名を":"で連結した文字列（例: group_name:policy_name）
#
# - group: ポリシーがアタッチされたIAMグループの名前
#
# - name: ポリシーの名前
#
# - name_prefix: ポリシー名のプレフィックス
#
