#---------------------------------------------------------------
# AWS IAM グループインラインポリシー
#---------------------------------------------------------------
#
# IAM グループに直接アタッチするインラインポリシーをプロビジョニングするリソースです。
# インラインポリシーはグループに埋め込まれた形式で管理され、
# グループと一体化したポリシーとして機能します。
#
# 管理ポリシー（aws_iam_policy）との違い:
#   - インラインポリシーはグループに直接埋め込まれ、グループ削除時に一緒に削除されます。
#   - 管理ポリシーは独立したリソースとして存在し、複数のエンティティに再利用できます。
#   - AWSでは再利用性・管理性の観点から管理ポリシーの使用を推奨しています。
#
# AWS公式ドキュメント:
#   - IAM グループポリシー: https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_policies.html
#   - インラインポリシーと管理ポリシーの比較: https://docs.aws.amazon.com/IAM/latest/UserGuide/access_policies_managed-vs-inline.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/iam_group_policy
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iam_group_policy" "example" {
  #-------------------------------------------------------------
  # グループ設定
  #-------------------------------------------------------------

  # group (Required)
  # 設定内容: ポリシーをアタッチするIAMグループの名前を指定します。
  # 設定可能な値: 既存のIAMグループ名、またはaws_iam_groupリソースの参照
  group = "example-group"

  #-------------------------------------------------------------
  # ポリシー設定
  #-------------------------------------------------------------

  # policy (Required)
  # 設定内容: グループにアタッチするインラインポリシーのJSON文字列を指定します。
  # 設定可能な値: 有効なIAMポリシーのJSON文字列
  # 注意: jsonencode()関数またはaws_iam_policy_documentデータソースを使用することを推奨します。
  #       ポリシーサイズは2048文字以内に制限されています。
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::example-bucket",
          "arn:aws:s3:::example-bucket/*"
        ]
      }
    ]
  })

  #-------------------------------------------------------------
  # 名前設定
  #-------------------------------------------------------------

  # name (Optional)
  # 設定内容: ポリシーの名前を指定します。
  # 設定可能な値: 英字、数字、ハイフン、アンダースコア、プラス記号、等号、カンマ、ピリオド、アットマーク
  # 省略時: Terraformが自動でユニークな名前を生成します
  # 注意: nameとname_prefixは同時に指定できません
  name = "example-group-policy"

  # name_prefix (Optional)
  # 設定内容: ポリシー名のプレフィックスを指定します。指定した値にユニークなサフィックスが付加されます。
  # 設定可能な値: 英字、数字、ハイフン、アンダースコア、プラス記号、等号、カンマ、ピリオド、アットマーク
  # 省略時: nameで指定した名前、またはTerraformが自動生成した名前を使用
  # 注意: nameとname_prefixは同時に指定できません。どちらか一方のみ使用してください。
  name_prefix = null
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
