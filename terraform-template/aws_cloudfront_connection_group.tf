#---------------------------------------
# CloudFront Connection Group
#---------------------------------------
# CloudFrontのマルチテナント配信において複数の配信テナントを管理するための接続グループ
# デフォルトでは配信テナント作成時に自動作成されるが、独自の接続グループを作成することで
# 配信テナントを個別に管理したり、エンタープライズアプリケーションを分離できる
#
# 主な用途:
# - マルチテナント配信の接続グループ作成
# - Anycast静的IPリストとの関連付け
# - IPv6サポートの有効化
# - 配信テナントの分離管理
#
# 【注意事項】
# - 配信テナント削除後でないと接続グループは削除できない
# - 配信テナントの接続グループ変更時はレイテンシーが増加する
# - 配信テナント変更後はDNSレコードを新しいエンドポイントに更新する必要がある
# - price_classを「Use all edge locations」に設定しないとAnycast静的IPリストは使用できない
#
# Provider Version: 6.28.0
# Generated: 2026-02-12
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/cloudfront_connection_group
#
# NOTE: このテンプレートは参考実装です。実際の環境に合わせて適宜修正してください。

#---------------------------------------
# 基本設定
#---------------------------------------

resource "aws_cloudfront_connection_group" "example" {
  # 設定内容: 接続グループの名前
  # 設定可能な値: 任意の文字列
  name = "example-connection-group"

  #---------------------------------------
  # Anycast静的IP設定
  #---------------------------------------

  # 設定内容: 関連付けるAnycast静的IPリストのID
  # 設定可能な値: CloudFrontサポートエンジニアリングから取得したAnycast静的IPリストID
  # 省略時: Anycast静的IPリストを使用しない
  anycast_ip_list_id = "example-anycast-ip-list-id"

  #---------------------------------------
  # 有効化設定
  #---------------------------------------

  # 設定内容: 接続グループの有効化フラグ
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: true
  enabled = true

  # 設定内容: IPv6サポートの有効化フラグ
  # 設定可能な値: true（有効）、false（無効）
  # 省略時: false
  ipv6_enabled = true

  #---------------------------------------
  # デプロイ待機設定
  #---------------------------------------

  # 設定内容: 接続グループのデプロイ完了を待機するかどうか
  # 設定可能な値: true（待機する）、false（待機しない）
  # 省略時: true
  wait_for_deployment = true

  #---------------------------------------
  # タグ設定
  #---------------------------------------

  # 設定内容: 接続グループに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Environment = "production"
    Application = "multi-tenant-cdn"
  }

  #---------------------------------------
  # タイムアウト設定
  #---------------------------------------

  # timeouts {
  #   # 設定内容: 作成時のタイムアウト時間
  #   # 設定可能な値: "30s"、"2h45m"等のDuration形式文字列
  #   # 省略時: 90分
  #   # create = "90m"
  #
  #   # 設定内容: 更新時のタイムアウト時間
  #   # 設定可能な値: "30s"、"2h45m"等のDuration形式文字列
  #   # 省略時: 90分
  #   # update = "90m"
  #
  #   # 設定内容: 削除時のタイムアウト時間
  #   # 設定可能な値: "30s"、"2h45m"等のDuration形式文字列
  #   # 省略時: 90分
  #   # delete = "90m"
  # }
}

#---------------------------------------
# Attributes Reference
#---------------------------------------
# - id: 接続グループの一意識別子
# - arn: 接続グループのARN
# - etag: 接続グループのETag（更新検出用）
# - is_default: デフォルト接続グループかどうか
# - last_modified_time: 最終更新日時
# - routing_endpoint: 割り当てられたDNS名（配信テナントのCNAMEレコード設定に使用）
# - status: 接続グループのステータス（Deploying、Deployed等）
# - tags_all: デフォルトタグを含む全てのタグ
