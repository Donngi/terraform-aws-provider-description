################################################################################
# AWS DynamoDB Global Table
# https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/dynamodb_global_table
#
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# NOTE: このリソースは従来のDynamoDB Global Tables (Version 2017.11.29) を管理します。
#       新しいバージョン (Version 2019.11.21) を使用する場合は aws_dynamodb_table の
#       replica ブロックを使用してください。グローバルテーブルを作成する前に、
#       各レプリカリージョンに同名のテーブルを事前に作成しておく必要があります。
################################################################################

#-------------------------------------------------------------------------------
# リソース定義
#-------------------------------------------------------------------------------

resource "aws_dynamodb_global_table" "example" {
  # グローバルテーブル名
  # 設定内容: DynamoDBグローバルテーブルの名前
  # 制約事項: 既存のDynamoDBテーブル名と一致する必要があり、各レプリカリージョンに同名のテーブルが存在している必要がある
  name = "example-global-table"

  #-----------------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースが管理されるAWSリージョン
  # 省略時: プロバイダー設定のリージョンが使用される
  region = "us-east-1"

  #-----------------------------------------------------------------------------
  # レプリカ設定
  #-----------------------------------------------------------------------------

  # レプリカリージョン（最小1個必須）
  # 設定内容: グローバルテーブルを複製するリージョンのリスト
  # 制約事項: 各リージョンに同名のDynamoDBテーブルが事前に作成されている必要がある
  replica {
    # レプリカリージョン名
    # 設定内容: DynamoDBテーブルをレプリケートするAWSリージョン
    # 設定可能な値: us-east-1, us-west-2, eu-west-1等の有効なAWSリージョンコード
    region_name = "us-east-1"
  }

  replica {
    region_name = "us-west-2"
  }

  replica {
    region_name = "ap-northeast-1"
  }

  #-----------------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------------

  # リソース操作のタイムアウト設定
  # timeouts {
  #   # 作成時のタイムアウト
  #   # 設定内容: グローバルテーブル作成処理の最大待機時間
  #   # 省略時: デフォルトのタイムアウト値が使用される
  #   create = "10m"
  #
  #   # 更新時のタイムアウト
  #   # 設定内容: グローバルテーブル更新処理の最大待機時間
  #   # 省略時: デフォルトのタイムアウト値が使用される
  #   update = "10m"
  #
  #   # 削除時のタイムアウト
  #   # 設定内容: グローバルテーブル削除処理の最大待機時間
  #   # 省略時: デフォルトのタイムアウト値が使用される
  #   delete = "10m"
  # }
}

################################################################################
# Attributes Reference
################################################################################

# このリソースは以下の属性をエクスポートします:
#
# - id: グローバルテーブル名（nameと同じ値）
# - arn: グローバルテーブルのARN（Amazon Resource Name）
# - name: グローバルテーブルの名前
# - region: リソースが管理されているリージョン
# - replica: レプリカリージョンのリスト
#   - region_name: レプリカが配置されているリージョン名
