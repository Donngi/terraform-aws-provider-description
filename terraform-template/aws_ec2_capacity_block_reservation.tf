#-----------------------------------------------------------------------
# EC2 Capacity Block Reservation
#-----------------------------------------------------------------------
# 用途: ML/AIワークロード向けにGPUインスタンス容量を事前予約
# 説明: 機械学習トレーニングや推論ワークロード用のアクセラレートコンピューティングインスタンス(P5, P4d, Trn1等)を指定期間(1〜182日間)確保し、必要なタイミングで確実に起動できるよう容量を保証
# ユースケース:
#   - 大規模MLモデルのトレーニングジョブ用GPU容量の確保
#   - 生成AIモデルのファインチューニング実行環境の予約
#   - 定期的な推論バッチ処理向けの計画的容量確保
#   - 研究開発プロジェクトでの確実なリソース割り当て
# 料金: 予約期間中の固定料金(需給バランスにより変動、予約後は価格固定)
# 注意事項:
#   - 予約後のキャンセル不可(購入前に要件を慎重に確認)
#   - 予約開始8週間前から購入可能
#   - 1ブロックあたり最大64インスタンス、合計256インスタンスまで予約可能
#   - インスタンスは予約終了30分前(UltraServerは60分前)までに終了が必要
# AWS公式ドキュメント: https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/capacity-blocks-how.html
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_capacity_block_reservation
# Provider Version: 6.28.0
# Generated: 2026-02-14
# NOTE: このファイルは参照用テンプレートです。実際の使用前に環境に合わせた調整が必要です。

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_ec2_capacity_block_reservation" "example" {
  # 設定内容: Capacity Blockオファリングの識別子(事前に検索APIで取得した予約可能なブロックのID)
  # 必須項目: はい
  # 備考: `aws ec2 describe-capacity-block-offerings`コマンドで取得したoffering-idを指定
  capacity_block_offering_id = "cbof-01234567890abcdef"

  # 設定内容: 予約するインスタンスのプラットフォーム
  # 設定可能な値: Linux/UNIX, Windows等のOSプラットフォーム
  # 必須項目: はい
  # 備考: MLワークロードでは通常Linux/UNIXを指定
  instance_platform = "Linux/UNIX"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 備考: 明示的にリージョンを指定する場合のみ設定
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソース識別・管理用のタグ
  # 形式: キー・バリューのマップ
  # 推奨用途: プロジェクト名、コスト配分、環境区分等の管理情報を付与
  tags = {
    Name        = "ml-training-capacity-block"
    Project     = "generative-ai-research"
    Environment = "production"
    CostCenter  = "ml-engineering"
    Workload    = "model-training"
  }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 設定内容: 予約作成処理のタイムアウト時間
    # 省略時: デフォルトのタイムアウト値を使用
    # 形式: "30s", "5m", "1h"等の時間文字列
    # create = "10m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference (参照専用属性)
#-----------------------------------------------------------------------
# このリソース作成後に参照可能な値:
#
# arn                  - Capacity Block予約のARN
# availability_zone    - 予約されたアベイラビリティーゾーン
# instance_type        - 予約されたインスタンスタイプ(p5.48xlarge, trn1.32xlarge等)
# instance_count       - 予約されたインスタンス数
# start_date           - 予約開始日時(RFC3339形式)
# end_date             - 予約終了日時(RFC3339形式)
# created_date         - 予約作成日時(RFC3339形式)
#
# 参照例:
#   aws_ec2_capacity_block_reservation.example.id
#   aws_ec2_capacity_block_reservation.example.availability_zone

#-----------------------------------------------------------------------
# Terraform設定
#-----------------------------------------------------------------------

terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.28.0"
    }
  }
}
