#----------------------------------------------------------------------
# AWS Provider Version: 6.28.0
# Resource: aws_docdb_subnet_group
# Generated: 2026-02-14
#
# Amazon DocumentDB サブネットグループの作成・管理を行うリソース
#
# 主な機能:
# - DocumentDBクラスター用のサブネットグループ定義
# - マルチAZ配置のためのサブネット管理
# - タグベースのリソース管理
#
# NOTE: DocumentDBクラスターは最低2つの異なるAZに配置されたサブネットが必要
#
# 関連ドキュメント:
# https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/docdb_subnet_group
#----------------------------------------------------------------------

resource "aws_docdb_subnet_group" "example" {
  #-----------------------------------------------------------------------
  # サブネット構成
  #-----------------------------------------------------------------------

  # subnet_ids - DocumentDBクラスターが配置されるサブネットのIDリスト
  # 設定内容: VPC内のサブネットIDを指定（最低2つの異なるAZが必要）
  # 必須項目: Yes
  subnet_ids = [
    "subnet-12345678",
    "subnet-87654321"
  ]

  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------

  # name - サブネットグループの名前
  # 設定内容: サブネットグループを識別する一意の名前（63文字以内、英小文字・数字・ハイフンのみ）
  # 省略時: Terraformが自動生成（name_prefixが未設定の場合）
  # 注意: name と name_prefix は同時に指定不可
  name = "docdb-subnet-group"

  # name_prefix - サブネットグループ名のプレフィックス
  # 設定内容: 自動生成される名前の接頭辞を指定
  # 省略時: null（nameが未設定の場合はTerraformがランダムな名前を生成）
  # 注意: name と name_prefix は同時に指定不可
  name_prefix = null

  # description - サブネットグループの説明
  # 設定内容: 任意の説明文（用途・環境などを記載）
  # 省略時: "Managed by Terraform"
  description = "DocumentDB subnet group for production environment"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # region - このリソースが管理されるAWSリージョン
  # 設定内容: リージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # tags - リソースに付与するタグ
  # 設定内容: Key-Value形式のマップでリソース管理用のメタデータを定義
  # 省略時: タグなし
  tags = {
    Name        = "docdb-subnet-group"
    Environment = "production"
    ManagedBy   = "Terraform"
  }

  # tags_all - すべてのタグ（プロバイダーのdefault_tagsとマージされる）
  # 設定内容: プロバイダーレベルのタグと個別タグの統合結果
  # 省略時: tags と default_tags がマージされた値
  # 注意: 通常は明示的に設定する必要なし（Terraform内部で自動管理）
  # tags_all = {}
}

#----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#----------------------------------------------------------------------
# リソース作成後に参照可能な属性:
#
# - id
#   サブネットグループのID（nameと同じ値）
#
# - arn
#   サブネットグループのARN
#   形式: arn:aws:rds:<region>:<account-id>:subgrp:<name>
#
# - supported_network_types
#   サポートされているネットワークタイプのセット
#
# - region
#   リソースが管理されているリージョン
#
# - tags_all
#   すべてのタグ（プロバイダーのdefault_tagsを含む）
#----------------------------------------------------------------------
