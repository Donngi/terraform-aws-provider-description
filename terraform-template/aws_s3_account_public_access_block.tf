################################################################################
# AWS S3 Account Public Access Block
################################################################################
# S3アカウントレベルのパブリックアクセスブロック設定を管理します。
# この設定により、アカウント内のすべてのS3バケットに対して一元的に
# パブリックアクセスを制御できます。
#
# 重要な注意事項:
# - 各AWSアカウントに設定できるS3パブリックアクセスブロック設定は1つのみです
# - 同じAWSアカウントに対して複数のリソースを設定すると、永続的な差分が発生します
# - 新しいバケットとオブジェクトは、デフォルトでパブリックアクセスを許可しません
# - アカウントレベルの設定は、個々のバケット設定を上書きします
# - 既存のポリシーやACLには影響しません（新規作成時のみ適用）
#
# AWS公式ドキュメント:
# https://docs.aws.amazon.com/AmazonS3/latest/userguide/access-control-block-public-access.html
# https://docs.aws.amazon.com/AmazonS3/latest/userguide/configuring-block-public-access-account.html
#
# Terraform Provider ドキュメント:
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/s3_account_public_access_block
#
# 高度な使用方法:
# このリソースでカスタムAPIエンドポイントを使用する場合は、
# s3endpointではなく、s3controlエンドポイントプロバイダー設定を使用してください。

resource "aws_s3_account_public_access_block" "example" {
  ############################################################################
  # アカウント設定
  ############################################################################

  # account_id - (オプション) 設定するAWSアカウントID
  # - 指定しない場合、Terraform AWSプロバイダーのアカウントIDが自動的に使用されます
  # - クロスアカウント設定を行う場合のみ指定してください
  # - 型: string
  # - デフォルト: 現在のアカウントID（自動決定）
  # - 例: "123456789012"
  # account_id = "123456789012"

  ############################################################################
  # Block Public ACLs 設定
  ############################################################################

  # block_public_acls - (オプション) パブリックACLをブロックするかどうか
  # - Amazon S3がこのアカウント内のバケットに対するパブリックACLをブロックするかを制御
  # - 既存のポリシーやACLには影響しません
  # - 型: bool
  # - デフォルト: false
  #
  # trueに設定した場合の動作:
  # - パブリックアクセスを許可するACLを指定した PUT Bucket acl および PUT Object acl 呼び出しが失敗します
  # - パブリックACLを含むリクエストの PUT Object 呼び出しが失敗します
  # - PUT Bucket 呼び出しでパブリックACLを持つバケットの作成が失敗します
  #
  # セキュリティのベストプラクティス:
  # - 本番環境では true に設定することを強く推奨します
  # - パブリックアクセスが不要な場合は必ず有効化してください
  #
  # 例: パブリックACLをブロック（推奨）
  block_public_acls = true

  ############################################################################
  # Block Public Policy 設定
  ############################################################################

  # block_public_policy - (オプション) パブリックバケットポリシーをブロックするかどうか
  # - Amazon S3がこのアカウント内のバケットに対するパブリックバケットポリシーをブロックするかを制御
  # - 既存のバケットポリシーには影響しません
  # - 型: bool
  # - デフォルト: false
  #
  # trueに設定した場合の動作:
  # - パブリックアクセスを許可するバケットポリシーを指定した PUT Bucket policy 呼び出しが拒否されます
  # - 新しいバケットポリシーでパブリックアクセスを許可できなくなります
  #
  # セキュリティのベストプラクティス:
  # - 本番環境では true に設定することを強く推奨します
  # - CloudFrontディストリビューションなど、特定のユースケースを除き有効化してください
  #
  # 例: パブリックバケットポリシーをブロック（推奨）
  block_public_policy = true

  ############################################################################
  # Ignore Public ACLs 設定
  ############################################################################

  # ignore_public_acls - (オプション) パブリックACLを無視するかどうか
  # - Amazon S3がこのアカウント内のバケットに対するパブリックACLを無視するかを制御
  # - 既存のACLの永続性には影響せず、新しいパブリックACLの設定を防ぎません
  # - 型: bool
  # - デフォルト: false
  #
  # trueに設定した場合の動作:
  # - このアカウント内のバケットおよび含まれるオブジェクトのすべてのパブリックACLを無視します
  # - パブリックACLを含む PUT Object 呼び出しは引き続き許可されます
  # - ACL自体は保存されますが、パブリックアクセス許可は無視されます
  #
  # block_public_aclsとの違い:
  # - block_public_acls: パブリックACLの作成自体を拒否
  # - ignore_public_acls: パブリックACLの作成は許可するが、効果を無視
  #
  # セキュリティのベストプラクティス:
  # - 本番環境では true に設定することを推奨します
  # - レガシーアプリケーションでACL設定が必要な場合に有用です
  #
  # 例: パブリックACLを無視（推奨）
  # ignore_public_acls = true

  ############################################################################
  # Restrict Public Buckets 設定
  ############################################################################

  # restrict_public_buckets - (オプション) パブリックバケットポリシーを制限するかどうか
  # - Amazon S3がこのアカウント内のパブリックバケットポリシーを制限するかを制御
  # - 以前に保存されたバケットポリシーには影響しませんが、
  #   パブリックおよびクロスアカウントアクセスはブロックされます
  # - 型: bool
  # - デフォルト: false
  #
  # trueに設定した場合の動作:
  # - パブリックポリシーを持つバケットへのアクセスは、バケット所有者とAWSサービスのみに制限されます
  # - パブリックポリシー内のすべてのクロスアカウントアクセスがブロックされます
  #   （特定アカウントへの非パブリック委任を含む）
  # - バケットまたはアクセスポイント所有者のアカウント内のAWSサービスプリンシパルと
  #   承認されたユーザーのみがアクセスできます
  #
  # セキュリティのベストプラクティス:
  # - 本番環境では true に設定することを強く推奨します
  # - クロスアカウントアクセスが必要な場合でも、明示的なIAMロール経由のアクセスを推奨
  #
  # 例: パブリックバケットを制限（推奨）
  # restrict_public_buckets = true
}

################################################################################
# Outputs
################################################################################
# アカウントのパブリックアクセスブロック設定の状態を出力します。
# これらの出力は、設定の確認や他のリソースでの参照に使用できます。

output "s3_account_public_access_block_id" {
  description = "S3アカウントパブリックアクセスブロックのID（AWSアカウントID）"
  value       = aws_s3_account_public_access_block.example.id
}

output "s3_account_public_access_block_account_id" {
  description = "設定が適用されているAWSアカウントID"
  value       = aws_s3_account_public_access_block.example.account_id
}

################################################################################
# 使用例: 完全にセキュアな設定（本番環境推奨）
################################################################################
/*
resource "aws_s3_account_public_access_block" "secure" {
  # すべてのパブリックアクセスブロック設定を有効化
  # これは最もセキュアな設定で、本番環境で強く推奨されます
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}
*/

################################################################################
# 使用例: 特定のアカウント向け設定
################################################################################
/*
resource "aws_s3_account_public_access_block" "specific_account" {
  # クロスアカウント設定の例
  account_id = "123456789012"

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}
*/

################################################################################
# 使用例: 段階的な移行（一時的な設定）
################################################################################
/*
resource "aws_s3_account_public_access_block" "gradual_migration" {
  # 既存のパブリックACLは許可するが、新規作成はブロック
  # レガシーシステムからの移行時に使用
  block_public_acls   = true  # 新規パブリックACLの作成をブロック
  ignore_public_acls  = false # 既存のパブリックACLは有効のまま

  block_public_policy     = true
  restrict_public_buckets = true
}
*/

################################################################################
# 4つの設定の組み合わせパターン
################################################################################
# 各設定は独立して機能しますが、組み合わせることで多層防御を実現できます:
#
# 【パターン1】最大セキュリティ（推奨）
# - すべての設定を true に設定
# - 新規・既存両方のパブリックアクセスを完全にブロック
#
# 【パターン2】新規のみブロック
# - block_public_acls = true
# - block_public_policy = true
# - ignore_public_acls = false
# - restrict_public_buckets = false
# - 既存の設定を保持しつつ、新規パブリックアクセスを防止
#
# 【パターン3】既存を無効化
# - block_public_acls = false
# - block_public_policy = false
# - ignore_public_acls = true
# - restrict_public_buckets = true
# - 既存のパブリックACL/ポリシーは保持するが、効果を無効化
#
# 【パターン4】完全オープン（非推奨）
# - すべての設定を false に設定（またはリソース自体を作成しない）
# - パブリックアクセスの制御を個別のバケットレベルに委任
# - セキュリティリスクが高いため、特別な理由がない限り避けてください

################################################################################
# トラブルシューティング
################################################################################
# 問題: 設定が適用されない
# 解決策:
# - AWS Organizations でアカウントレベルの設定が有効な場合、
#   組織レベルのポリシーが優先されます
# - 組織の設定を確認してください
#
# 問題: 既存のパブリックバケットにアクセスできない
# 解決策:
# - この設定は既存の設定を変更しませんが、アクセスはブロックされる可能性があります
# - 意図的なパブリックアクセスが必要な場合は、設定を調整してください
#
# 問題: 複数のリソース定義による競合
# 解決策:
# - 1つのAWSアカウントに対して1つのリソース定義のみを使用してください
# - 複数定義すると永続的な差分が発生します
#
# 問題: Terraform の差分が解消されない
# 解決策:
# - AWS Organizations の設定を確認
# - account_id が正しく設定されているか確認
# - 他のTerraformプロジェクトで同じリソースを管理していないか確認

################################################################################
# IAM Permissions
################################################################################
# このリソースを管理するために必要な最小限のIAM権限:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "s3:GetAccountPublicAccessBlock",
#         "s3:PutAccountPublicAccessBlock"
#       ],
#       "Resource": "*"
#     }
#   ]
# }
#
# 注意: これらはs3controlサービスのAPIを使用します

################################################################################
# Import
################################################################################
# 既存のS3アカウントパブリックアクセスブロック設定をインポートする場合:
#
# terraform import aws_s3_account_public_access_block.example 123456789012
#
# AWSアカウントIDを使用してインポートします。
# account_id を指定していない場合は、現在のアカウントIDを使用します。
