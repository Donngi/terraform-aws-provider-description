#---------------------------------------------------------------
# AWS Internet Gateway
#---------------------------------------------------------------
#
# VPC にインターネット接続を提供するリソースです。
# インターネットゲートウェイは VPC とインターネット間の通信を可能にし、
# パブリック IPv4 または IPv6 アドレスを持つリソースがインターネットと
# 通信できるようにします。水平スケーリング、冗長性、高可用性を備えています。
#
# 主な機能:
#   - VPC ルートテーブルでインターネット向けトラフィックのターゲットとして機能
#   - IPv4 トラフィックに対してネットワークアドレス変換（NAT）を実行
#   - パブリックサブネットのインスタンスにインターネット接続を提供
#   - IPv6 トラフィックはグローバルに一意のアドレスで直接通信
#
# NOTE: インターネットゲートウェイ自体に料金はかかりませんが、
#       使用する EC2 インスタンスのデータ転送に料金が発生します。
#
# AWS公式ドキュメント:
#   - Internet Gateway 概要: https://docs.aws.amazon.com/vpc/latest/userguide/VPC_Internet_Gateway.html
#   - インターネットアクセスの追加: https://docs.aws.amazon.com/vpc/latest/userguide/working-with-igw.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/internet_gateway
#
# Provider Version: 6.28.0
# Generated: 2026-01-28
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_internet_gateway" "example" {
  #-------------------------------------------------------------
  # VPC アタッチメント設定
  #-------------------------------------------------------------

  # vpc_id (Optional)
  # 設定内容: インターネットゲートウェイをアタッチする VPC の ID を指定します。
  # 設定可能な値: 有効な VPC ID（例: vpc-1234567890abcdef0）
  # 省略時: インターネットゲートウェイは作成されますが、VPC にアタッチされません。
  # 注意:
  #   - 別の方法として aws_internet_gateway_attachment リソースを使用して
  #     インターネットゲートウェイを VPC にアタッチすることもできます。
  #   - インターネットゲートウェイは一度に1つの VPC にのみアタッチできます。
  #   - VPC にパブリック IP アドレスまたは Elastic IP アドレスを持つ
  #     リソースがある場合、デタッチできません。
  # AWS参考: https://docs.aws.amazon.com/vpc/latest/userguide/working-with-igw.html
  vpc_id = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースが管理されるリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定で指定されたリージョンがデフォルトとして使用されます。
  # AWS参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されません。
  # 注意:
  #   - プロバイダーレベルで default_tags が設定されている場合、
  #     同じキーのタグはリソースレベルの値で上書きされます。
  #   - タグはリソースの管理、コスト配分、アクセス制御に役立ちます。
  # AWS参考: https://docs.aws.amazon.com/vpc/latest/userguide/vpc-tagging.html
  tags = {
    Name        = "example-igw"
    Environment = "production"
    ManagedBy   = "terraform"
  }

  #-------------------------------------------------------------
  # 依存関係の推奨事項
  #-------------------------------------------------------------
  #
  # AWS インスタンスや Elastic IP がインターネットゲートウェイに
  # 依存していることを明示的に示すことが推奨されます。
  #
  # 例:
  # resource "aws_internet_gateway" "gw" {
  #   vpc_id = aws_vpc.main.id
  # }
  #
  # resource "aws_instance" "foo" {
  #   # ... その他の引数 ...
  #   depends_on = [aws_internet_gateway.gw]
  # }
  #
  # この設定により、インスタンスがインターネットゲートウェイの
  # 作成完了後に起動されることが保証されます。
  #
}

#---------------------------------------------------------------
# アウトプット例
#---------------------------------------------------------------
#
# インターネットゲートウェイの情報を出力する場合の例:
#
# output "internet_gateway_id" {
#   description = "インターネットゲートウェイの ID"
#   value       = aws_internet_gateway.example.id
# }
#
# output "internet_gateway_arn" {
#   description = "インターネットゲートウェイの ARN"
#   value       = aws_internet_gateway.example.arn
# }
#
# output "internet_gateway_owner_id" {
#   description = "インターネットゲートウェイを所有する AWS アカウント ID"
#   value       = aws_internet_gateway.example.owner_id
# }
#
# output "internet_gateway_tags_all" {
#   description = "プロバイダーのdefault_tagsを含むすべてのタグ"
#   value       = aws_internet_gateway.example.tags_all
# }
#
#---------------------------------------------------------------

#---------------------------------------------------------------
# 属性リファレンス
#---------------------------------------------------------------
#
# このリソースは以下の属性をエクスポートします:
#
# - id
#   説明: インターネットゲートウェイの ID
#   用途: 他のリソースでの参照、ルートテーブルのターゲット指定など
#
# - arn
#   説明: インターネットゲートウェイの ARN
#   用途: IAM ポリシーでのリソース指定、タグベースのアクセス制御など
#
# - owner_id
#   説明: インターネットゲートウェイを所有する AWS アカウントの ID
#   用途: クロスアカウント参照、監査目的など
#
# - tags_all
#   説明: リソースに割り当てられたすべてのタグのマップ
#          （プロバイダーの default_tags から継承されたタグを含む）
#   用途: タグの完全なリストの取得、他のリソースへのタグの伝播など
#
#---------------------------------------------------------------

#---------------------------------------------------------------
# 使用例: ルートテーブルとの統合
#---------------------------------------------------------------
#
# インターネットゲートウェイを作成後、パブリックサブネットの
# ルートテーブルにインターネット向けトラフィックのルートを追加します:
#
# resource "aws_route_table" "public" {
#   vpc_id = aws_vpc.main.id
#
#   route {
#     cidr_block = "0.0.0.0/0"
#     gateway_id = aws_internet_gateway.example.id
#   }
#
#   route {
#     ipv6_cidr_block = "::/0"
#     gateway_id      = aws_internet_gateway.example.id
#   }
#
#   tags = {
#     Name = "public-route-table"
#   }
# }
#
# resource "aws_route_table_association" "public" {
#   subnet_id      = aws_subnet.public.id
#   route_table_id = aws_route_table.public.id
# }
#
#---------------------------------------------------------------

#---------------------------------------------------------------
# 使用例: aws_internet_gateway_attachment を使用した代替方法
#---------------------------------------------------------------
#
# インターネットゲートウェイの作成とアタッチメントを分離したい場合:
#
# resource "aws_internet_gateway" "example" {
#   # vpc_id は指定しない
#   tags = {
#     Name = "example-igw"
#   }
# }
#
# resource "aws_internet_gateway_attachment" "example" {
#   internet_gateway_id = aws_internet_gateway.example.id
#   vpc_id              = aws_vpc.main.id
# }
#
# この方法は、インターネットゲートウェイのライフサイクルを
# VPC から独立して管理したい場合に有用です。
#
#---------------------------------------------------------------

#---------------------------------------------------------------
# ベストプラクティス
#---------------------------------------------------------------
#
# 1. 命名規則
#    - タグで適切な Name を設定し、管理しやすくする
#    - Environment や ManagedBy などのタグで運用情報を記録
#
# 2. セキュリティ
#    - インターネットゲートウェイは必要な VPC にのみアタッチする
#    - パブリックサブネットとプライベートサブネットを明確に分離
#    - セキュリティグループと NACL で適切にアクセス制御を実施
#
# 3. 高可用性
#    - インターネットゲートウェイは AWS が自動的に冗長化
#    - マルチ AZ 構成のサブネットで使用することを推奨
#
# 4. コスト最適化
#    - インターネットゲートウェイ自体は無料
#    - データ転送料金に注意（特にクロスリージョン、インターネット送信）
#    - NAT ゲートウェイの使用が必要かどうかを検討
#
# 5. 依存関係管理
#    - depends_on を使用して、インスタンスや他のリソースが
#      インターネットゲートウェイの作成後に起動されるようにする
#
# 6. インポート
#    - 既存のインターネットゲートウェイは以下でインポート可能:
#      terraform import aws_internet_gateway.example igw-1234567890abcdef0
#
#---------------------------------------------------------------
