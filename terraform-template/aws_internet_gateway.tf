resource "aws_internet_gateway" "example" {
  #-------------------------------------------------------------
  # VPC接続設定
  #-------------------------------------------------------------

  # vpc_id (Optional)
  # 設定内容: インターネットゲートウェイをアタッチするVPCのIDを指定します。
  # 設定可能な値: 有効なVPC ID（例: vpc-12345678）
  # 省略時: インターネットゲートウェイはVPCにアタッチされない状態で作成されます。
  # 注意: aws_internet_gateway_attachment リソースを使用して後からアタッチする方法もあります。
  #       インターネットアクセスを必要とするEC2インスタンスやEIPはこのゲートウェイに依存させることを推奨します。
  vpc_id = "vpc-12345678"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしで作成されます。
  # 注意: プロバイダーレベルの default_tags 設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "main-internet-gateway"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を設定するブロックです。
  timeouts {

    # create (Optional)
    # 設定内容: リソース作成時のタイムアウト時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "20m", "1h30m"）
    # 省略時: プロバイダーのデフォルトタイムアウト値を使用します。
    create = "20m"

    # update (Optional)
    # 設定内容: リソース更新時のタイムアウト時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "20m", "1h30m"）
    # 省略時: プロバイダーのデフォルトタイムアウト値を使用します。
    update = "20m"

    # delete (Optional)
    # 設定内容: リソース削除時のタイムアウト時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "20m", "1h30m"）
    # 省略時: プロバイダーのデフォルトタイムアウト値を使用します。
    delete = "20m"
  }
}

