#######################################################################
# GuardDuty 招待受諾
#######################################################################
# 別AWSアカウント（管理者アカウント）からのGuardDuty招待を受諾するリソース。
# マルチアカウント構成でGuardDuty管理者アカウントのメンバーアカウントとして
# 参加する際に使用する。
#
# 主な用途:
# - 組織内のGuardDutyマルチアカウント管理への参加
# - セキュリティ管理の一元化（管理者アカウントへの参加）
# - 招待ベースのメンバーアカウント登録（Organizations管理外）
#
# 参考: https://docs.aws.amazon.com/guardduty/latest/ug/guardduty_accounts.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/guardduty_invite_accepter
#
# NOTE: このテンプレートの属性は実際の要件に応じてコメントを外して使用してください
#-----------------------------------------------------------------------

resource "aws_guardduty_invite_accepter" "example" {
  #-----------------------------------------------------------------------
  # 検出器の設定
  #-----------------------------------------------------------------------

  # メンバーアカウントのGuardDuty検出器ID
  # 設定内容: 招待を受諾するメンバーアカウント側の検出器ID
  # 用途: このアカウントのGuardDutyディテクターを管理者アカウントに紐付ける
  # 注意: 同一リージョンにGuardDuty検出器が事前に作成されている必要がある
  detector_id = aws_guardduty_detector.member.id

  #-----------------------------------------------------------------------
  # 管理者アカウントの設定
  #-----------------------------------------------------------------------

  # GuardDuty管理者（マスター）アカウントID
  # 設定内容: 招待を送信したAWSアカウントの12桁のアカウントID
  # 用途: 招待元の管理者アカウントを特定してメンバー関係を確立する
  # 注意: 管理者アカウント側でaws_guardduty_memberリソースにより
  #       招待が送信されている必要がある
  master_account_id = "123456789012"

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # 作成タイムアウト
    # 設定内容: 招待受諾処理のタイムアウト時間
    # 設定可能な値: "Ns"（秒）、"Nm"（分）、"Nh"（時間）形式の文字列
    # 省略時: 1m
    create = "1m"
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # リソース管理リージョン
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョン
  region = "us-east-1"
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id
#   GuardDuty検出器のID（detector_idと同一）
#-----------------------------------------------------------------------
