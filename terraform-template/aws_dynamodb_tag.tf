#---------------------------------------
# DynamoDBタグ設定
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/dynamodb_tag
#
# 用途: DynamoDBテーブルまたはグローバルセカンダリインデックスに個別のタグを追加・管理
# 機能: 単一タグのキーと値を指定してリソースにタグ付けを実施
# 制約: タグキーは大文字小文字を区別し、リソースごとに一意である必要がある
# 料金: タグ自体に追加料金なし（DynamoDBリソースの課金は別途発生）
# 依存: DynamoDBテーブルまたはグローバルセカンダリインデックスが事前に作成されている必要あり
#
# NOTE: このテンプレートは日本語で記述されています。実際の運用環境では組織の命名規則とタグ戦略に従ってください。
#---------------------------------------

resource "aws_dynamodb_tag" "example" {
  #---------------------------------------
  # リソース識別
  #---------------------------------------
  # 設定内容: タグを付与するDynamoDBリソースのARN（テーブルまたはグローバルセカンダリインデックス）
  # 形式: arn:aws:dynamodb:region:account-id:table/table-name または arn:aws:dynamodb:region:account-id:table/table-name/index/index-name
  # 制約: 有効なDynamoDBリソースARNである必要がある
  resource_arn = "arn:aws:dynamodb:us-east-1:123456789012:table/example-table"

  #---------------------------------------
  # タグ設定
  #---------------------------------------
  # 設定内容: タグのキー名
  # 制約: 最大128文字、大文字小文字を区別、aws:プレフィックスは予約済み
  # 推奨: 組織のタグ命名規則に従うこと
  key = "Environment"

  # 設定内容: タグの値
  # 制約: 最大256文字
  # 用途: タグキーに対応する説明的な値を設定
  value = "Production"

  #---------------------------------------
  # リージョン設定（オプション）
  #---------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 用途: マルチリージョン環境で明示的にリージョンを指定する場合に使用
  region = "us-east-1"
}

#---------------------------------------
# 使用上の注意
#---------------------------------------
# - aws_dynamodb_tableリソースのtagsブロックとの併用時は、tag_resourceを使用してタグ管理を分離することを推奨
# - 同一リソースARNとタグキーの組み合わせは一意である必要がある
# - タグの削除はリソースの削除により実行される
# - DynamoDBグローバルテーブルの場合、各リージョンのレプリカに個別にタグ付けが必要
# - terraform importを使用する場合、形式は resource_arn,key となる

#---------------------------------------
# Attributes Reference
#---------------------------------------
# 以下の属性がエクスポートされ、他のリソースから参照可能:
#
# id                - タグリソースの識別子（resource_arn,key形式）
# resource_arn      - タグが付与されているDynamoDBリソースのARN
# key               - タグのキー名
# value             - タグの値
# region            - リソースが管理されているAWSリージョン
