#---------------------------------------------------------------
# Amazon ECR レプリケーション設定
#---------------------------------------------------------------
#
# Amazon ECR (Elastic Container Registry) のレプリケーション設定を管理します。
# プライベートリポジトリのコンテナイメージを、同一アカウント内またはクロスアカウントで
# 他のAWSリージョンに自動的にレプリケーションします。
# 最大10個のレプリケーションルールを設定でき、各ルールは最大25個の送信先を指定可能です。
# リポジトリフィルタを使用して、特定のリポジトリのみをレプリケーション対象にできます。
#
# ユースケース:
# - ディザスタリカバリやマルチリージョン展開のための自動イメージ配信
# - 地理的に分散したクラスターへの低レイテンシなイメージ配信
# - クロスアカウントでのイメージ共有とアクセス管理
#
# 制約事項:
# - レプリケーション設定はレジストリごとに1つまで
# - ルールは最大10個、送信先は各ルールにつき最大25個
# - リポジトリフィルタは各ルールにつき最大100個
# - レプリケーション先リージョンとレジストリIDの組み合わせは一意である必要があります
#
# AWS公式ドキュメント:
#   - レプリケーション概要: https://docs.aws.amazon.com/AmazonECR/latest/userguide/replication.html
#   - プライベートレジストリ設定: https://docs.aws.amazon.com/AmazonECR/latest/userguide/registry-settings.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ecr_replication_configuration
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_ecr_replication_configuration" "example" {
  #---------------------------------------
  # リソース管理設定
  #---------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: レプリケーション設定自体を管理するリージョンであり、レプリケーション先とは異なります
  region = "us-east-1"

  #---------------------------------------
  # レプリケーション設定
  #---------------------------------------

  replication_configuration {
    rule {
      #---------------------------------------
      # レプリケーション先の設定
      #---------------------------------------
      # 最小1個、最大25個まで指定可能

      destination {
        # 設定内容: レプリケーション先のAWSリージョン
        # 設定可能な値: 有効なAWSリージョンコード
        # 注意: 送信元リージョンとは異なるリージョンを指定する必要があります
        region = "us-west-2"

        # 設定内容: レプリケーション先のAWSアカウントID（12桁）
        # 設定可能な値: 有効なAWSアカウントID
        # 注意: 同一アカウントまたはクロスアカウントのレジストリIDを指定
        # クロスアカウントの場合、送信先アカウント側でレジストリポリシーの設定が必要です
        registry_id = "123456789012"
      }

      # 追加のレプリケーション先（複数指定可能）
      # destination {
      #   region      = "eu-west-1"
      #   registry_id = "123456789012"
      # }

      #---------------------------------------
      # リポジトリフィルタ（オプション）
      #---------------------------------------
      # 特定のリポジトリのみをレプリケーション対象とする場合に使用
      # 最大100個まで指定可能

      repository_filter {
        # 設定内容: レプリケーション対象とするリポジトリのフィルタ条件
        # 設定可能な値: リポジトリ名のプレフィックス文字列（例: prod-, app/）
        # 注意: 指定したプレフィックスで始まるリポジトリ名がマッチ対象となります
        filter = "prod-"

        # 設定内容: フィルタのタイプ
        # 設定可能な値: PREFIX_MATCH（現在サポートされている唯一の値）
        # 注意: PREFIX_MATCHはリポジトリ名の先頭一致でフィルタリングします
        filter_type = "PREFIX_MATCH"
      }

      # 複数のフィルタを設定可能（OR条件）
      # repository_filter {
      #   filter      = "staging-"
      #   filter_type = "PREFIX_MATCH"
      # }
    }

    # 追加のレプリケーションルール（最大10個まで指定可能）
    # rule {
    #   destination {
    #     region      = "ap-northeast-1"
    #     registry_id = "123456789012"
    #   }
    #
    #   repository_filter {
    #     filter      = "app/"
    #     filter_type = "PREFIX_MATCH"
    #   }
    # }
  }
}

