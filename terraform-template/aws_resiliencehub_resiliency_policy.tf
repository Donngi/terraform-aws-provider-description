#---------------------------------------------------------------
# AWS Resilience Hub Resiliency Policy
#---------------------------------------------------------------
#
# AWS Resilience Hubの回復性ポリシーを定義するリソースです。
# このポリシーは、アプリケーションの復旧目標時間（RTO: Recovery Time Objective）と
# 復旧時点目標（RPO: Recovery Point Objective）を定義し、
# さまざまな障害シナリオ（リージョン障害、AZ障害、インフラ障害、アプリケーション障害）に対する
# 回復性の要件を設定します。
#
# AWS公式ドキュメント:
#   - AWS Resilience Hub: https://docs.aws.amazon.com/resilience-hub/latest/userguide/what-is.html
#   - Resiliency Policy: https://docs.aws.amazon.com/resilience-hub/latest/userguide/resiliency-policies.html
#   - RTO and RPO: https://docs.aws.amazon.com/resilience-hub/latest/userguide/concepts-terms.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/resiliencehub_resiliency_policy
#
# Provider Version: 6.28.0
# Generated: 2026-02-03
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_resiliencehub_resiliency_policy" "example" {
  #-------------------------------------------------------------
  # 基本設定 (必須)
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: 回復性ポリシーの名前を指定します。
  # 設定可能な値: 任意の文字列
  # 注意: ポリシー名は一意である必要があります。
  #       ポリシーを識別するための分かりやすい名前を付けることを推奨します。
  name = "example-resiliency-policy"

  # tier (Required)
  # 設定内容: 回復性ポリシーの重要度ティアを指定します。
  # 設定可能な値:
  #   - MissionCritical: ミッションクリティカル（最も厳格な要件）
  #   - Critical: クリティカル（厳格な要件）
  #   - Important: 重要（標準的な要件）
  #   - CoreServices: コアサービス（基本的な要件）
  #   - NonCritical: 非クリティカル（最も緩い要件）
  # 関連機能: このティアは推定コスト見積もりに影響を与えます。
  #   ティアが高いほど、より厳格なRTO/RPO要件が推奨され、
  #   それに伴うインフラコストも増加する傾向があります。
  tier = "Important"

  #-------------------------------------------------------------
  # ポリシー設定 (必須)
  #-------------------------------------------------------------

  # policy (Required)
  # 設定内容: 回復性障害ポリシーを定義します。
  # 注意: azとsoftwareとhardwareのブロックは必須です。
  #       regionブロックはオプションです。
  policy {
    # az (Required)
    # 設定内容: アベイラビリティゾーン（AZ）障害に対する回復性目標を指定します。
    # 概要: 単一AZ障害が発生した場合のRTOとRPOを定義します。
    #       Multi-AZ構成のアプリケーションに重要です。
    az {
      # rpo (Required)
      # 設定内容: 復旧時点目標（RPO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: AZ障害発生時に許容できる最大データ損失時間を表します。
      #       例: "1h" = 最大1時間分のデータ損失を許容
      # 関連機能: この値が小さいほど、より頻繁なバックアップや
      #   レプリケーション設定が必要になります。
      rpo = "1h"

      # rto (Required)
      # 設定内容: 復旧目標時間（RTO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: AZ障害から復旧するまでの目標時間を表します。
      #       例: "2h" = 障害発生後2時間以内にサービスを復旧
      # 関連機能: この値が小さいほど、自動フェイルオーバーや
      #   高可用性構成が重要になります。
      rto = "2h"
    }

    # hardware (Required)
    # 設定内容: インフラストラクチャ（ハードウェア）障害に対する回復性目標を指定します。
    # 概要: 物理的なインフラ障害（サーバー障害、ネットワーク障害など）が
    #       発生した場合のRTOとRPOを定義します。
    hardware {
      # rpo (Required)
      # 設定内容: 復旧時点目標（RPO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: インフラ障害発生時に許容できる最大データ損失時間を表します。
      # 関連機能: EBSスナップショット、データベースレプリカなどの
      #   バックアップ戦略に影響します。
      rpo = "1h"

      # rto (Required)
      # 設定内容: 復旧目標時間（RTO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: インフラ障害から復旧するまでの目標時間を表します。
      # 関連機能: Auto Scaling、ELBヘルスチェック、自動復旧設定などに
      #   関連します。
      rto = "2h"
    }

    # software (Required)
    # 設定内容: アプリケーション（ソフトウェア）障害に対する回復性目標を指定します。
    # 概要: アプリケーションレベルの障害（バグ、設定ミス、デプロイ失敗など）が
    #       発生した場合のRTOとRPOを定義します。
    software {
      # rpo (Required)
      # 設定内容: 復旧時点目標（RPO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: アプリケーション障害発生時に許容できる最大データ損失時間を表します。
      # 関連機能: アプリケーションレベルのバックアップ、
      #   トランザクションログ、監査ログなどに関連します。
      rpo = "1h"

      # rto (Required)
      # 設定内容: 復旧目標時間（RTO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: アプリケーション障害から復旧するまでの目標時間を表します。
      # 関連機能: ロールバック戦略、カナリアデプロイ、
      #   Blue/Greenデプロイなどに関連します。
      rto = "2h"
    }

    # region (Optional)
    # 設定内容: リージョン障害に対する回復性目標を指定します。
    # 概要: リージョン全体の障害が発生した場合のRTOとRPOを定義します。
    # 注意: このブロックはオプションです。
    #       マルチリージョン構成のアプリケーションにのみ関連します。
    region {
      # rpo (Optional)
      # 設定内容: 復旧時点目標（RPO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: リージョン障害発生時に許容できる最大データ損失時間を表します。
      # 関連機能: クロスリージョンレプリケーション、
      #   グローバルデータベース、S3クロスリージョンレプリケーションなどに
      #   関連します。
      # 省略時: リージョン障害に対する要件が定義されません
      rpo = "24h"

      # rto (Optional)
      # 設定内容: 復旧目標時間（RTO）をGo duration形式で指定します。
      # 設定可能な値: "1h", "2h45m", "30m", "24h" などの時間文字列
      # 意味: リージョン障害から復旧するまでの目標時間を表します。
      # 関連機能: Route 53フェイルオーバールーティング、
      #   グローバルアクセラレータ、マルチリージョンフェイルオーバー
      #   などに関連します。
      # 省略時: リージョン障害に対する要件が定義されません
      rto = "24h"
    }
  }

  #-------------------------------------------------------------
  # 説明 (オプション)
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: ポリシーの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 推奨: ポリシーの目的、適用対象、特記事項などを記述することを推奨します。
  # 省略時: 説明なしでポリシーが作成されます
  description = "Example resiliency policy for production workloads"

  #-------------------------------------------------------------
  # データロケーション制約 (オプション)
  #-------------------------------------------------------------

  # data_location_constraint (Optional)
  # 設定内容: 回復性ポリシーデータを保存できる地理的な場所の制約を指定します。
  # 設定可能な値:
  #   - AnyLocation: データをどの場所にも保存可能（デフォルト）
  #   - SameContinent: データを同じ大陸内にのみ保存
  #   - SameCountry: データを同じ国内にのみ保存
  # 用途: データ主権要件やコンプライアンス要件がある場合に使用します。
  # 関連機能: GDPRなどのデータ保護規制に対応する際に重要です。
  # 省略時: "AnyLocation"として扱われます（計算属性）
  data_location_constraint = "SameContinent"

  #-------------------------------------------------------------
  # リージョン設定 (オプション)
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: us-east-1, eu-west-1, ap-northeast-1）
  # 省略時: プロバイダー設定で指定されたリージョンが使用されます（計算属性）
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タグ設定 (オプション)
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 用途: リソースの整理、コスト配分、アクセス制御などに使用します。
  # 注意: プロバイダーのdefault_tags設定と併用できます。
  #       同じキーが指定された場合、このタグが優先されます。
  # 省略時: タグなしでリソースが作成されます
  tags = {
    Environment = "Production"
    Application = "WebApp"
    ManagedBy   = "Terraform"
  }

  #-------------------------------------------------------------
  # タイムアウト設定 (オプション)
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソース作成時のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "30s", "5m", "1h", "2h45m"）
    # 省略時: デフォルトのタイムアウト値が使用されます
    # 注意: ポリシー作成は通常数秒以内に完了しますが、
    #       ネットワークの問題などで遅延する可能性があります。
    create = null

    # update (Optional)
    # 設定内容: リソース更新時のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "30s", "5m", "1h", "2h45m"）
    # 省略時: デフォルトのタイムアウト値が使用されます
    # 注意: ポリシー更新は通常数秒以内に完了します。
    update = null

    # delete (Optional)
    # 設定内容: リソース削除時のタイムアウト時間を指定します。
    # 設定可能な値: 時間文字列（例: "30s", "5m", "1h", "2h45m"）
    # 省略時: デフォルトのタイムアウト値が使用されます
    # 注意: ポリシーがアプリケーションで使用されている場合、
    #       削除が失敗する可能性があります。
    #       使用されていないことを確認してから削除してください。
    delete = null
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: 回復性ポリシーのAmazon Resource Name (ARN)
#   形式: arn:aws:resiliencehub:region:account-id:resiliency-policy/policy-id
#   用途: 他のリソースからこのポリシーを参照する際に使用します
#
# - estimated_cost_tier: 回復性ポリシーの推定コストティア
#   取り得る値: L1, L2, L3, L4（L1が最も低コスト、L4が最も高コスト）
#   概要: 定義されたRTO/RPO目標を達成するために必要な
#         推定インフラコストのティアを示します。
#   注意: これは推定値であり、実際のコストは使用するリソースに依存します。
#
# - tags_all: リソースに割り当てられたすべてのタグのマップ
#   概要: tagsで明示的に設定したタグと、
#         プロバイダーのdefault_tagsから継承したタグの両方を含みます。
#
#---------------------------------------------------------------

