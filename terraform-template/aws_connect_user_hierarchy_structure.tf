#######################################################################
# AWS Connect ユーザー階層構造
#######################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/connect_user_hierarchy_structure
#
# NOTE:
# Amazon Connect インスタンスのユーザー階層構造を定義するリソース
# 最大5階層のレベルでユーザーを組織化し、権限やルーティング設定に利用可能
# 参考: https://docs.aws.amazon.com/connect/latest/adminguide/agent-hierarchy.html
#
# 主な用途:
# - コンタクトセンターの組織構造の定義
# - エージェントのグルーピングとアクセス制御
# - リアルタイムメトリクスと履歴レポートのフィルタリング
# - ルーティングプロファイルとキューの割り当て管理
#
# 注意事項:
# - 階層構造は各Connectインスタンスに1つのみ作成可能
# - 作成後に階層レベルの削除はできないため、事前設計が重要
# - 各レベルの名前は変更可能だが、構造自体の変更は制限される
# - 既存のユーザーが階層に関連付けられている場合、変更に影響を与える可能性がある
#######################################################################

terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.28.0"
    }
  }
}

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_connect_user_hierarchy_structure" "example" {
  #-----------------------------------------------------------------------
  # Connect インスタンス設定
  #-----------------------------------------------------------------------
  # 設定内容: この階層構造を適用するConnect インスタンスのID
  # 形式: arn:aws:connect:region:account-id:instance/instance-id または instance-id
  # 注意: 各インスタンスに対して1つの階層構造のみ作成可能
  instance_id = "aaaaaaaa-bbbb-cccc-dddd-example12345"

  #-----------------------------------------------------------------------
  # リージョン設定（オプション）
  #-----------------------------------------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: クロスリージョン管理が必要な場合のみ指定
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # 階層構造定義
  #-----------------------------------------------------------------------
  # Connectの組織構造を最大5階層で定義
  # 各レベルは独立して定義可能で、必要なレベルのみ設定できる
  hierarchy_structure {
    #-----------------------------------------------------------------------
    # レベル1（最上位階層）
    #-----------------------------------------------------------------------
    # 例: 地域、事業部、国など最も大きな組織単位
    level_one {
      # 設定内容: 階層レベル1の表示名
      # 制約: 最大50文字、一意である必要がある
      # 例: "Region", "Division", "Country"
      name = "Region"
    }

    #-----------------------------------------------------------------------
    # レベル2
    #-----------------------------------------------------------------------
    # 例: オフィス、部署、州など中規模の組織単位
    level_two {
      # 設定内容: 階層レベル2の表示名
      # 制約: 最大50文字、一意である必要がある
      # 例: "Office", "Department", "State"
      name = "Office"
    }

    #-----------------------------------------------------------------------
    # レベル3
    #-----------------------------------------------------------------------
    # 例: チーム、グループ、市など小規模の組織単位
    level_three {
      # 設定内容: 階層レベル3の表示名
      # 制約: 最大50文字、一意である必要がある
      # 例: "Team", "Group", "City"
      name = "Team"
    }

    #-----------------------------------------------------------------------
    # レベル4
    #-----------------------------------------------------------------------
    # 例: サブチーム、ユニット、エリアなど詳細な組織単位
    level_four {
      # 設定内容: 階層レベル4の表示名
      # 制約: 最大50文字、一意である必要がある
      # 例: "Sub-Team", "Unit", "Area"
      name = "Sub-Team"
    }

    #-----------------------------------------------------------------------
    # レベル5（最下位階層）
    #-----------------------------------------------------------------------
    # 例: 個別エージェント、スキル、シフトなど最も細かい組織単位
    level_five {
      # 設定内容: 階層レベル5の表示名
      # 制約: 最大50文字、一意である必要がある
      # 例: "Agent", "Skill", "Shift"
      name = "Agent"
    }
  }
}

#######################################################################
# Attributes Reference（参照可能な属性）
#######################################################################
# このリソースでは以下の属性を参照できます:
#
# - id: 階層構造のID（通常はinstance_idと同じ）
# - instance_id: Connect インスタンスのID
# - region: リソースが管理されているリージョン
# - hierarchy_structure.*.level_one.*.id: レベル1の階層ID
# - hierarchy_structure.*.level_one.*.arn: レベル1のARN
# - hierarchy_structure.*.level_two.*.id: レベル2の階層ID
# - hierarchy_structure.*.level_two.*.arn: レベル2のARN
# - hierarchy_structure.*.level_three.*.id: レベル3の階層ID
# - hierarchy_structure.*.level_three.*.arn: レベル3のARN
# - hierarchy_structure.*.level_four.*.id: レベル4の階層ID
# - hierarchy_structure.*.level_four.*.arn: レベル4のARN
# - hierarchy_structure.*.level_five.*.id: レベル5の階層ID
# - hierarchy_structure.*.level_five.*.arn: レベル5のARN
#
# 参照方法:
# aws_connect_user_hierarchy_structure.example.hierarchy_structure[0].level_one[0].id
#######################################################################
