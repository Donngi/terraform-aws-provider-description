#---------------------------------------
# Terraform AWS EC2 Instance State Resource Template
#---------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-15
#
# 用途: EC2インスタンスの電源状態（起動/停止）を管理するリソース
#
# 主な機能:
# - インスタンスの起動状態管理（running/stopped）
# - 強制停止の制御
# - リージョン指定によるクロスリージョン管理
#
# NOTE: ユーザーデータ処理の完了を検出するAPIがないため、スクリプト実行中に状態変更が発生する可能性がある
# NOTE: Windowsインスタンスでは強制停止を推奨しない（ファイルシステムキャッシュがフラッシュされない）
#
# 関連ドキュメント:
# https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ec2_instance_state
#---------------------------------------

#---------------------------------------
# Basic Configuration（基本設定）
#---------------------------------------

resource "aws_ec2_instance_state" "example" {
  # 設定内容: 対象となるEC2インスタンスのID
  # 設定可能な値: 有効なEC2インスタンスID（例: i-1234567890abcdef0）
  instance_id = "i-1234567890abcdef0"

  # 設定内容: インスタンスの目的の電源状態
  # 設定可能な値: stopped（停止）, running（起動）
  state = "stopped"

  #---------------------------------------
  # Advanced Settings（詳細設定）
  #---------------------------------------

  # 設定内容: stateがstoppedの場合に強制停止をリクエストするかどうか
  # 設定可能な値: true（強制停止）, false（通常停止）
  # 省略時: false
  # 注意: 強制停止を実行するとファイルシステムキャッシュやメタデータがフラッシュされず、
  #       その後のファイルシステムチェックと修復が必要になる
  #       Windowsインスタンスでは推奨されない
  force = false

  #---------------------------------------
  # Region Configuration（リージョン設定）
  #---------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: 有効なAWSリージョン名（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"
}

#---------------------------------------
# Timeouts Configuration（タイムアウト設定）
#---------------------------------------

resource "aws_ec2_instance_state" "with_timeouts" {
  instance_id = "i-1234567890abcdef0"
  state       = "running"

  # 設定内容: 各操作のタイムアウト時間
  timeouts {
    # 設定内容: リソース作成時のタイムアウト
    # 設定可能な値: 時間文字列（例: 10m, 1h）
    # 省略時: デフォルトのタイムアウト値
    create = "10m"

    # 設定内容: リソース更新時のタイムアウト
    # 設定可能な値: 時間文字列（例: 10m, 1h）
    # 省略時: デフォルトのタイムアウト値
    update = "10m"

    # 設定内容: リソース削除時のタイムアウト
    # 設定可能な値: 時間文字列（例: 10m, 1h）
    # 省略時: デフォルトのタイムアウト値
    delete = "10m"
  }
}

#---------------------------------------
# Attributes Reference（参照可能な属性）
#---------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# - id: インスタンスのID（instance_idと同じ値）
#---------------------------------------
