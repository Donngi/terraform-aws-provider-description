#-----------------------------------------------------------------------
# CloudWatch Evidently Launch (非推奨 - AppConfig使用を推奨)
#-----------------------------------------------------------------------
# CloudWatch Evidentlyのローンチリソースを定義
# A/Bテストや段階的な機能リリース（カナリアデプロイ）を実施する際に
# 機能バリエーションとトラフィック配分スケジュールを管理する
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/evidently_launch
# Generated: 2026-02-17
#
# NOTE: このリソースは非推奨となっており、2025年10月17日にサービス終了予定
#       新規実装では AWS AppConfig の機能フラグを使用すること
#       https://aws.amazon.com/blogs/mt/using-aws-appconfig-feature-flags/
#
# 主な用途:
#   - 機能フラグベースのA/Bテスト実施
#   - 段階的なトラフィック配分による機能ロールアウト
#   - セグメント別のバリエーション配信
#   - メトリクス監視付きの機能リリース管理
#
# 関連リソース:
#   - aws_evidently_project: Evidentlyプロジェクト（親リソース）
#   - aws_evidently_feature: 機能とバリエーションの定義
#   - aws_evidently_segment: オーディエンスセグメント定義
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_evidently_launch" "example" {
  # 設定内容: ローンチの一意の名前
  # 設定可能な値: 1〜127文字の英数字、ハイフン、アンダースコア
  # 省略時: 必須パラメータのため指定必須
  name = "my-feature-launch"

  # 設定内容: このローンチを含むEvidentlyプロジェクトの名前またはARN
  # 設定可能な値: プロジェクト名（例: my-project）またはARN
  # 省略時: 必須パラメータのため指定必須
  project = aws_evidently_project.example.name

  # 設定内容: ローンチの説明文
  # 設定可能な値: 任意のテキスト（目的や対象機能を記述）
  # 省略時: 説明なしでローンチが作成される
  description = "新機能の段階的ロールアウト実験"

  # 設定内容: ユーザーセッションをバリエーションに割り当てる際のランダム化ソルト
  # 設定可能な値: 任意の文字列（エンティティIDと組み合わせてハッシュ生成に使用）
  # 省略時: ローンチ名がランダム化ソルトとして使用される
  randomization_salt = "custom-random-salt-2024"

  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: us-east-1, ap-northeast-1）
  # 省略時: プロバイダー設定のリージョンが使用される
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # グループ設定（必須ブロック、1〜5個）
  #-----------------------------------------------------------------------

  # 各グループはバリエーションとその設定を定義
  groups {
    # 設定内容: このローンチで使用する機能の名前
    # 設定可能な値: aws_evidently_featureリソースで定義した機能名
    # 省略時: 必須パラメータのため指定必須
    feature = aws_evidently_feature.example.name

    # 設定内容: このローンチグループの名前
    # 設定可能な値: 任意の名前（バリエーション名と同一にするのが一般的）
    # 省略時: 必須パラメータのため指定必須
    name = "Variation1"

    # 設定内容: このグループで使用する機能バリエーション
    # 設定可能な値: aws_evidently_featureで定義したバリエーション名
    # 省略時: 必須パラメータのため指定必須
    variation = "Variation1"

    # 設定内容: このローンチグループの説明文
    # 設定可能な値: 任意のテキスト（対象ユーザーや目的を記述）
    # 省略時: 説明なしでグループが作成される
    description = "コントロールグループ（既存機能）"
  }

  # 複数グループを定義する例（最大5個まで）
  groups {
    feature     = aws_evidently_feature.example.name
    name        = "Variation2"
    variation   = "Variation2"
    description = "実験グループ（新機能）"
  }

  #-----------------------------------------------------------------------
  # トラフィック配分スケジュール設定
  #-----------------------------------------------------------------------

  scheduled_splits_config {
    # ステップ定義（1〜6個まで設定可能）
    # 各ステップで開始時刻とバリエーション別のトラフィック配分を指定
    steps {
      # 設定内容: 各バリエーションへのトラフィック配分パーセンテージ
      # 設定可能な値: バリエーション名をキー、0〜100の数値を値とするマップ
      # 省略時: 必須パラメータのため指定必須
      # 注意: 合計が100を超えても良い（配分は比率で計算される）
      group_weights = {
        "Variation1" = 90
        "Variation2" = 10
      }

      # 設定内容: このステップの開始日時
      # 設定可能な値: RFC3339形式またはタイムゾーン付き日時文字列
      # 省略時: 必須パラメータのため指定必須
      # 形式例: "2024-01-07T01:43:59+00:00" または "2024-01-07 01:43:59+00:00"
      start_time = "2024-01-07T01:43:59+00:00"

      #-----------------------------------------------------------------------
      # セグメントオーバーライド設定（オプション、最大6個）
      #-----------------------------------------------------------------------

      # 特定のオーディエンスセグメントに異なるトラフィック配分を適用
      # segment_overrides {
      #   # 設定内容: セグメントオーバーライドの評価順序
      #   # 設定可能な値: 正の整数（小さい値が先に評価される）
      #   # 省略時: 必須パラメータのため指定必須
      #   evaluation_order = 1
      #
      #   # 設定内容: 使用するセグメントの名前またはARN
      #   # 設定可能な値: aws_evidently_segmentで定義したセグメント名またはARN
      #   # 省略時: 必須パラメータのため指定必須
      #   segment = aws_evidently_segment.premium_users.name
      #
      #   # 設定内容: このセグメント向けのトラフィック配分（千分率）
      #   # 設定可能な値: バリエーション名をキー、0〜100000の値（千分率、50000=50%）
      #   # 省略時: 必須パラメータのため指定必須
      #   weights = {
      #     "Variation2" = 50000  # プレミアムユーザーには50%
      #   }
      # }
    }

    # 段階的なロールアウトの例（2ステップ目）
    # steps {
    #   group_weights = {
    #     "Variation1" = 50
    #     "Variation2" = 50
    #   }
    #   start_time = "2024-01-14T01:43:59+00:00"
    # }
  }

  #-----------------------------------------------------------------------
  # メトリクス監視設定（オプション、最大3個）
  #-----------------------------------------------------------------------

  # ローンチのパフォーマンスを監視するメトリクス定義
  # metric_monitors {
  #   metric_definition {
  #     # 設定内容: メトリクス値を記録する主体（ユーザーやセッション）を識別するキー
  #     # 設定可能な値: イベントデータ内のJSONパス（例: userDetails.userID）
  #     # 省略時: 必須パラメータのため指定必須
  #     entity_id_key = "userDetails.userId"
  #
  #     # 設定内容: メトリクスを記録するEventBridgeイベントパターン
  #     # 設定可能な値: EventBridgeイベントパターンのJSON文字列
  #     # 省略時: 全イベントが対象となる
  #     event_pattern = jsonencode({
  #       "detail-type" : ["Purchase Completed"],
  #       "detail" : {
  #         "price" : [{ "numeric" : [">", 0, "<=", 100] }]
  #       }
  #     })
  #
  #     # 設定内容: メトリクスの名前
  #     # 設定可能な値: 任意の名前（識別可能な名称を推奨）
  #     # 省略時: 必須パラメータのため指定必須
  #     name = "purchase_conversion_rate"
  #
  #     # 設定内容: メトリクスの単位ラベル
  #     # 設定可能な値: 任意のテキスト（例: "conversions", "milliseconds"）
  #     # 省略時: 単位ラベルなしで記録される
  #     unit_label = "conversions"
  #
  #     # 設定内容: メトリクス値として追跡する値のキー
  #     # 設定可能な値: イベントデータ内のJSONパス
  #     # 省略時: 必須パラメータのため指定必須
  #     value_key = "detail.conversionValue"
  #   }
  # }

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 設定内容: ローンチ作成時の最大待機時間
  #   # 設定可能な値: 時間文字列（例: "2m", "5m"）
  #   # 省略時: デフォルトのタイムアウト値が使用される
  #   create = "2m"
  #
  #   # 設定内容: ローンチ更新時の最大待機時間
  #   # 設定可能な値: 時間文字列（例: "2m", "5m"）
  #   # 省略時: デフォルトのタイムアウト値が使用される
  #   update = "2m"
  #
  #   # 設定内容: ローンチ削除時の最大待機時間
  #   # 設定可能な値: 時間文字列（例: "2m", "5m"）
  #   # 省略時: デフォルトのタイムアウト値が使用される
  #   delete = "2m"
  # }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしでリソースが作成される
  tags = {
    Name        = "my-feature-launch"
    Environment = "production"
    Team        = "product"
    ManagedBy   = "terraform"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# - id: ローンチの一意識別子（形式: "launch_name:project_name"）
# - arn: ローンチのARN
# - status: 現在の状態（CREATED, UPDATING, RUNNING, COMPLETED, CANCELLED）
# - type: ローンチのタイプ
# - created_time: 作成日時（RFC3339形式）
# - last_updated_time: 最終更新日時（RFC3339形式）
# - status_reason: 停止理由説明文
# - execution.started_time: 実行開始日時
# - execution.ended_time: 実行終了日時
# - tags_all: プロバイダーdefault_tags含む全タグ
#-----------------------------------------------------------------------
