#-----------------------------------------------------------------------
# AWS Network Manager Site-to-Site VPN Attachment
#-----------------------------------------------------------------------
# AWS Cloud WAN のコアネットワークに Site-to-Site VPN 接続をアタッチするリソース。
# コアネットワーク上の VPN アタッチメントとして既存の VPN 接続を関連付け、
# グローバルネットワークの一部としてオンプレミス環境との接続を実現します。
#
# 主な用途:
# - Cloud WAN コアネットワークへのオンプレミス VPN 接続の統合
# - グローバルネットワーク上でのセグメント間ルーティング制御
# - マルチリージョン WAN トポロジーにおける VPN 終端点の管理
#
# 参考: https://docs.aws.amazon.com/network-manager/latest/cloudwan/cloudwan-vpn-attachments.html
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/networkmanager_site_to_site_vpn_attachment
#
# NOTE:
# - アタッチメント作成前に、コアネットワークと VPN 接続が両方存在している必要があります
# - VPN 接続は AWS Site-to-Site VPN として事前に作成されている必要があります
# - アタッチメントのセグメント割り当てはコアネットワークポリシーのルールで決定されます
# - routing_policy_label はコアネットワークポリシーで定義されたラベルと一致する必要があります
#-----------------------------------------------------------------------

resource "aws_networkmanager_site_to_site_vpn_attachment" "example" {
  #-----------------------------------------------------------------------
  # コアネットワーク接続設定
  #-----------------------------------------------------------------------

  # アタッチ先のコアネットワーク ID
  # 設定内容: VPN 接続をアタッチする Cloud WAN コアネットワークの ID
  # 形式: core-network-xxxxxxxxxxxxxxxxx
  core_network_id = "core-network-0a1b2c3d4e5f6g7h8"

  # アタッチする VPN 接続の ARN
  # 設定内容: コアネットワークに接続する Site-to-Site VPN 接続のリソース ARN
  # 形式: arn:aws:ec2:region:account-id:vpn-connection/vpn-xxxxxxxxxxxxxxxxx
  vpn_connection_arn = "arn:aws:ec2:ap-northeast-1:123456789012:vpn-connection/vpn-0a1b2c3d4e5f6g7h8"

  #-----------------------------------------------------------------------
  # ルーティングポリシー設定
  #-----------------------------------------------------------------------

  # ルーティングポリシーラベル
  # 設定内容: このアタッチメントに適用するルーティングポリシーのラベル名
  # 用途: コアネットワークポリシー内で定義されたラベルを指定してルーティング制御を実施
  # 注意: 指定する値はコアネットワークポリシードキュメントで事前に定義されている必要があります
  # 省略時: コアネットワークのデフォルトルーティングポリシーが適用されます
  routing_policy_label = "production"

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  timeouts {
    # リソース作成のタイムアウト
    # 設定内容: アタッチメント作成処理の最大待機時間
    # 設定可能な値: Goの時間書式（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウト
    create = "30m"

    # リソース更新のタイムアウト
    # 設定内容: アタッチメント更新処理の最大待機時間
    # 設定可能な値: Goの時間書式（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウト
    update = "30m"

    # リソース削除のタイムアウト
    # 設定内容: アタッチメント削除処理の最大待機時間
    # 設定可能な値: Goの時間書式（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウト
    delete = "30m"
  }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # リソースタグ
  # 設定内容: アタッチメントに付与するタグ（キー・バリューペア）
  # 用途: リソース管理、コスト配分、アクセス制御
  # 注意: プロバイダーの default_tags と重複するキーは上書きされます
  tags = {
    Name        = "example-vpn-attachment"
    Environment = "production"
    ManagedBy   = "terraform"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: アタッチメントの ID
# - arn: アタッチメントの ARN
# - attachment_policy_rule_number: 関連付けられたポリシールール番号
# - attachment_type: アタッチメントのタイプ（"VPN"）
# - core_network_arn: コアネットワークの ARN
# - edge_location: アタッチメントのエッジロケーション（AWS リージョン）
# - owner_account_id: アタッチメントを所有する AWS アカウント ID
# - resource_arn: 関連付けられたリソースの ARN
# - segment_name: 割り当てられたコアネットワークセグメント名
# - state: アタッチメントの現在の状態（CREATING / AVAILABLE / DELETING など）
# - tags_all: 全タグのマップ（default_tags 継承分を含む）
#-----------------------------------------------------------------------
