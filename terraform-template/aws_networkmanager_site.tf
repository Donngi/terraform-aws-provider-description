#---------------------------------------------------------------
# AWS Network Manager Site
#---------------------------------------------------------------
#
# グローバルネットワーク内のサイト（拠点）を作成・管理するリソースです。
# サイトはオンプレミスのデータセンターや支社などの物理的なロケーションを
# 表現し、デバイスやリンクのグループ化に使用されます。
# サイトはグローバルネットワーク固有のリソースであり、共有はできません。
#
# AWS公式ドキュメント:
#   - Network Manager サイトの作成: https://docs.aws.amazon.com/network-manager/latest/tgwnm/creating-a-site.html
#   - グローバルネットワークの概要: https://docs.aws.amazon.com/network-manager/latest/tgwnm/what-is-network-manager.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/networkmanager_site
#
# Provider Version: 6.28.0
# Generated: 2026-02-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_networkmanager_site" "example" {
  #-------------------------------------------------------------
  # グローバルネットワーク設定
  #-------------------------------------------------------------

  # global_network_id (Required)
  # 設定内容: サイトが所属するグローバルネットワークのIDを指定します。
  # 設定可能な値: 有効なグローバルネットワークID文字列
  global_network_id = "network-1234567890abcdef0"

  #-------------------------------------------------------------
  # 説明設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: サイトの説明を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なしで作成されます。
  description = "東京オフィスのサイト"

  #-------------------------------------------------------------
  # ロケーション設定
  #-------------------------------------------------------------

  location {
    # address (Optional)
    # 設定内容: サイトの物理的な住所を指定します。
    # 設定可能な値: 任意の住所文字列（例: "1-1-1 Chiyoda, Tokyo, Japan"）
    # 省略時: 住所なしで設定されます。
    address = "1-1-1 Chiyoda, Chiyoda-ku, Tokyo, Japan"

    # latitude (Optional)
    # 設定内容: サイトの緯度を指定します。
    # 設定可能な値: 緯度を表す文字列（例: "35.6762"）
    # 省略時: 緯度なしで設定されます。
    latitude = "35.6762"

    # longitude (Optional)
    # 設定内容: サイトの経度を指定します。
    # 設定可能な値: 経度を表す文字列（例: "139.6503"）
    # 省略時: 経度なしで設定されます。
    longitude = "139.6503"
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしで作成されます。
  # 注意: プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-site"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソースの作成完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    create = "30m"

    # update (Optional)
    # 設定内容: リソースの更新完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    update = "30m"

    # delete (Optional)
    # 設定内容: リソースの削除完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    delete = "30m"
  }
}

