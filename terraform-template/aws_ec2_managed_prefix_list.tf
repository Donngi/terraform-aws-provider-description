#######################################################################
# AWS Managed Prefix List
#######################################################################
# VPC内で使用するIPアドレス範囲のセットを定義・管理するリソース
# セキュリティグループやルートテーブルで参照可能な名前付きIPアドレスリストを作成
# AWS管理のプレフィックスリスト（AWS提供サービスのIPレンジ）とは異なり、ユーザーが独自に定義
#
# Provider Version: 6.28.0
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/ec2_managed_prefix_list
# Generated: 2026-02-15
# NOTE: このテンプレートは実際の環境に合わせて適切に修正してください

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_ec2_managed_prefix_list" "example" {
  # 設定内容: プレフィックスリストの名前
  # 制約事項: 同一リージョン内で一意である必要がある
  name = "my-prefix-list"

  # 設定内容: プレフィックスリストのアドレスファミリー
  # 設定可能な値: "IPv4" | "IPv6"
  # 制約事項: 作成後は変更不可（再作成が必要）
  address_family = "IPv4"

  # 設定内容: プレフィックスリストに格納可能な最大エントリ数
  # 制約事項: 作成後に増加は可能だが、減少は現在のエントリ数以下には設定できない
  # 注意事項: エントリ数に応じて料金が発生する可能性がある
  max_entries = 5

  #-----------------------------------------------------------------------
  # エントリ定義
  #-----------------------------------------------------------------------

  # 設定内容: プレフィックスリストに含めるCIDRブロックのリスト
  # 制約事項: エントリ数はmax_entries以下である必要がある
  entry {
    # 設定内容: CIDRブロック（IPv4の場合は "x.x.x.x/x" 形式、IPv6の場合は "xxxx::/x" 形式）
    # 制約事項: address_familyで指定した形式と一致する必要がある
    cidr = "10.0.0.0/8"

    # 設定内容: エントリの説明（オプション）
    # 用途: 各CIDRブロックの用途や目的を明確化
    description = "プライベートネットワーク - クラスA"
  }

  entry {
    cidr        = "172.16.0.0/12"
    description = "プライベートネットワーク - クラスB"
  }

  entry {
    cidr        = "192.168.0.0/16"
    description = "プライベートネットワーク - クラスC"
  }

  #-----------------------------------------------------------------------
  # リージョン設定（オプション）
  #-----------------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意事項: 通常は省略し、プロバイダー設定に従うことを推奨
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------

  # 設定内容: リソースに付与するタグ
  # 用途: リソース管理、コスト配分、検索・フィルタリングに使用
  tags = {
    Name        = "my-prefix-list"
    Environment = "production"
    ManagedBy   = "terraform"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースから参照可能な属性:
#
# - id: プレフィックスリストのID（例: "pl-0123456789abcdef0"）
# - arn: プレフィックスリストのARN
# - owner_id: プレフィックスリストを所有するAWSアカウントID
# - version: プレフィックスリストの現在のバージョン番号（更新の度にインクリメント）
# - tags_all: デフォルトタグを含む全てのタグ
