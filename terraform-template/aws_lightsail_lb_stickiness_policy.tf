#---------------------------------------------------------------
# AWS Lightsail ロードバランサー スティッキーセッションポリシー
#---------------------------------------------------------------
#
# Lightsail ロードバランサーのスティッキーセッション（セッション持続性）を
# 管理するリソースです。スティッキーセッションを有効にすると、クライアントからの
# リクエストが常に同じインスタンスにルーティングされます。
#
# AWS公式ドキュメント:
#   - Lightsail ロードバランサーのスティッキーセッション:
#     https://docs.aws.amazon.com/lightsail/latest/userguide/enable-set-up-sticky-sessions-on-lightsail-load-balancer.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/lightsail_lb_stickiness_policy
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_lightsail_lb_stickiness_policy" "example" {
  #-------------------------------------------------------------
  # ロードバランサー設定
  #-------------------------------------------------------------

  # lb_name (Required)
  # 設定内容: スティッキーセッションポリシーを適用する Lightsail ロードバランサーの名前を指定します。
  # 設定可能な値: 有効な Lightsail ロードバランサー名の文字列
  lb_name = "example-lb"

  #-------------------------------------------------------------
  # スティッキーセッション設定
  #-------------------------------------------------------------

  # enabled (Required)
  # 設定内容: スティッキーセッションを有効または無効にするかを指定します。
  # 設定可能な値:
  #   - true: スティッキーセッションを有効化。クライアントのリクエストが
  #           常に同じインスタンスにルーティングされます。
  #   - false: スティッキーセッションを無効化。リクエストは通常の
  #            ラウンドロビン方式でルーティングされます。
  enabled = true

  # cookie_duration (Required)
  # 設定内容: スティッキーセッションの持続時間を秒単位で指定します。
  #   この期間中、クライアントからのリクエストは同一インスタンスに送信されます。
  # 設定可能な値: 1〜604800 の整数（1秒〜7日間）
  cookie_duration = 900

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

