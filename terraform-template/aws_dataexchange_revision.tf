#-----------------------------------------------------------------------
# AWS Data Exchangeでデータセットの新しいリビジョンを作成・管理するリソース。
# データセットへのデータ追加やコンテンツの更新時に使用され、
# データの公開やサブスクライバーへの配信前にリビジョン単位でバージョン管理を実現します。
#
# 主な機能:
# - データセット内のリビジョン作成とメタデータ管理
# - コメントによる変更履歴の記録
# - タグベースのバージョン管理と分類
# - リージョン単位でのデータ管理

resource "aws_dataexchange_revision" "example" {
  #-----------------------------------------------------------------------
  # データセット識別
  #-----------------------------------------------------------------------
  # 設定内容: このリビジョンが属するData Exchangeデータセットの一意識別子
  # 有効な値: 既存のData ExchangeデータセットID（ds-xxxxxxxxxxxxxxxxx形式）
  # 補足事項: リビジョン作成後は変更不可、データセットは事前に作成されている必要がある
  data_set_id = "ds-1234567890abcdef0"

  #-----------------------------------------------------------------------
  # リビジョンメタデータ
  #-----------------------------------------------------------------------
  # 設定内容: リビジョンに関する説明やコメント（変更内容の記録等）
  # 有効な値: 任意のテキスト（最大16384文字）
  # 省略時: コメントなしでリビジョンが作成される
  comment = "2024年1月のデータ更新: 新規顧客データ500件追加"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 有効な値: AWSリージョンコード（us-east-1、ap-northeast-1等）
  # 省略時: プロバイダー設定のリージョンが使用される
  # 補足事項: データセットと同じリージョンを指定する必要がある
  region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # 設定内容: リビジョンに付与するタグのキー・バリューペア
  # 有効な値: 最大50個のタグ、キーと値は各128文字まで
  # 補足事項: バージョン管理やコスト配分、検索用途で使用
  tags = {
    Name        = "monthly-customer-data-revision"
    Environment = "production"
    Version     = "2024.01"
    DataType    = "customer-records"
    Frequency   = "monthly"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# この設定により以下の属性を他リソースから参照可能:
#
# arn         - リビジョンのARN（例: arn:aws:dataexchange:us-east-1:123456789012:data-sets/ds-xxx/revisions/rev-xxx）
# id          - リビジョンのTerraform識別子（data_set_id:revision_id形式）
# revision_id - AWS Data Exchangeが自動生成するリビジョン固有識別子（rev-xxxxxxxxxxxxxxxxx形式）
# tags_all    - デフォルトタグとリソースタグをマージした全タグのマップ
#
# 参照例: aws_dataexchange_revision.example.revision_id
