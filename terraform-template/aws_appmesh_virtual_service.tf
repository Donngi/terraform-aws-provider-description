resource "aws_appmesh_virtual_service" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required, Forces new resource)
  # 設定内容: バーチャルサービスの名前を指定します。
  # 設定可能な値: 1-255文字の文字列
  # 推奨: ターゲットとなる実際のサービスのサービスディスカバリ名
  #       （例: my-service.default.svc.cluster.local）を使用することで、
  #       コード変更なしにバーチャルサービスと実際のサービスを紐付けられます。
  # 注意: 名前はループバック以外のIPアドレスに解決される必要があります。
  #       アプリケーションコンテナがEnvoyプロキシにリクエストを送信する前に
  #       名前解決が成功する必要があるためです。
  name = "servicea.simpleapp.local"

  # mesh_name (Required, Forces new resource)
  # 設定内容: バーチャルサービスを作成するサービスメッシュの名前を指定します。
  # 設定可能な値: 1-255文字の文字列
  mesh_name = "my-app-mesh"

  # mesh_owner (Optional)
  # 設定内容: サービスメッシュ所有者のAWSアカウントIDを指定します。
  # 設定可能な値: 有効なAWSアカウントID
  # 省略時: 現在接続しているAWSプロバイダーのアカウントID
  # 用途: 他のAWSアカウントと共有されているメッシュを使用する場合に指定
  mesh_owner = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # 仕様設定 (spec)
  #-------------------------------------------------------------

  # spec (Required)
  # 設定内容: バーチャルサービスの仕様を定義します。
  # 関連機能: App Mesh Virtual Service Specification
  #   バーチャルサービスがどのようにトラフィックをルーティングするかを定義します。
  #   プロバイダーとしてバーチャルノードまたはバーチャルルーターを指定できます。
  spec {
    #-----------------------------------------------------------
    # プロバイダー設定 (provider)
    #-----------------------------------------------------------

    # provider (Optional)
    # 設定内容: バーチャルサービスのプロバイダーを指定します。
    # 注意: virtual_nodeまたはvirtual_routerのいずれか一方のみ指定可能
    # 用途:
    #   - virtual_router: 複数のバーチャルノードにトラフィックを分散する場合
    #   - virtual_node: 単一のバーチャルノードに直接ルーティングする場合
    #   - 指定なし: プロバイダーを後で設定する場合（まだノード/ルーターが存在しない場合等）
    provider {
      #---------------------------------------------------------
      # バーチャルノードプロバイダー (virtual_node)
      #---------------------------------------------------------

      # virtual_node (Optional)
      # 設定内容: バーチャルサービスに関連付けるバーチャルノードを指定します。
      # 注意: virtual_routerと排他的（どちらか一方のみ指定可能）
      # 関連機能: App Mesh Virtual Node
      #   バーチャルノードはサービスメッシュ内のマイクロサービスインスタンスを表します。
      #   2020年7月29日以降に定義されたバーチャルノードプロバイダーには、
      #   App Meshがデフォルトのenvoyルートリトライポリシーを自動的に作成する場合があります。
      # virtual_node {
      #   # virtual_node_name (Required)
      #   # 設定内容: サービスプロバイダーとして機能するバーチャルノードの名前を指定します。
      #   # 設定可能な値: 1-255文字の文字列
      #   virtual_node_name = "serviceb-node"
      # }

      #---------------------------------------------------------
      # バーチャルルータープロバイダー (virtual_router)
      #---------------------------------------------------------

      # virtual_router (Optional)
      # 設定内容: バーチャルサービスに関連付けるバーチャルルーターを指定します。
      # 注意: virtual_nodeと排他的（どちらか一方のみ指定可能）
      # 関連機能: App Mesh Virtual Router
      #   バーチャルルーターは複数のバーチャルノード間でトラフィックをルーティングします。
      #   トラフィック分割、フィルタリング、ミラーリングなどの機能を実装できます。
      virtual_router {
        # virtual_router_name (Required)
        # 設定内容: サービスプロバイダーとして機能するバーチャルルーターの名前を指定します。
        # 設定可能な値: 1-255文字の文字列
        virtual_router_name = "servicea-router"
      }
    }
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 関連機能: AWSリソースタグ付け
  #   プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #   一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "servicea-virtual-service"
    Environment = "production"
  }
}

