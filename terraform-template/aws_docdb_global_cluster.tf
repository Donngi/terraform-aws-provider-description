#-------------------------------------------------------------------------------------------------------
# DocumentDB Global Cluster
#-------------------------------------------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# NOTE:
#   このテンプレートは全てのパラメータをコメントアウトした状態で提供されます。
#   実際の使用時には必要なパラメータのコメントを外して値を設定してください。
#
# 概要:
#   DocumentDB Global Clusterは、1つのプライマリリージョンと最大5つの読み取り専用セカンダリ
#   リージョンで構成されるグローバルデータベースクラスタを管理します。プライマリリージョンの
#   プライマリクラスタに書き込み操作を発行すると、Amazon DocumentDBは専用インフラストラクチャを
#   使用してデータをセカンダリリージョンに自動的にレプリケートします。
#
# 主な用途:
#   - マルチリージョンでの低レイテンシ読み取りアクセス
#   - リージョン障害時のディザスタリカバリ
#   - グローバルなデータ分散とコンプライアンス対応
#
# 参考ドキュメント:
#   - https://docs.aws.amazon.com/documentdb/latest/developerguide/global-clusters.html
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/docdb_global_cluster
#-------------------------------------------------------------------------------------------------------

resource "aws_docdb_global_cluster" "example" {
  #-------------------------------------------------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------------------------------------------------
  # グローバルクラスタ識別子（必須）
  # 設定内容: グローバルクラスタの一意の識別子
  # 注意事項: 変更すると新しいリソースが作成されます
  global_cluster_identifier = "example-global-cluster"

  #-------------------------------------------------------------------------------------------------------
  # エンジン設定
  #-------------------------------------------------------------------------------------------------------
  # データベースエンジン
  # 設定内容: グローバルクラスタで使用するデータベースエンジン名
  # 設定可能な値: docdb（DocumentDB）
  # 省略時: docdb
  # 注意事項:
  #   - source_db_cluster_identifierと同時指定不可
  #   - 変更すると新しいリソースが作成されます
  engine = "docdb"

  # エンジンバージョン
  # 設定内容: グローバルデータベースのエンジンバージョン
  # 省略時: 最新の利用可能なバージョン
  # 注意事項:
  #   - バージョンアップグレードを実行すると全クラスタメンバーが即座に更新されます
  #   - メジャーバージョンのアップグレードはサポートされていません
  engine_version = "4.0.0"

  #-------------------------------------------------------------------------------------------------------
  # データベース設定
  #-------------------------------------------------------------------------------------------------------
  # データベース名
  # 設定内容: クラスタ作成時に自動作成されるデータベースの名前
  # 注意事項: 変更すると新しいリソースが作成されます
  database_name = "example_db"

  #-------------------------------------------------------------------------------------------------------
  # セキュリティ設定
  #-------------------------------------------------------------------------------------------------------
  # ストレージ暗号化
  # 設定内容: DBクラスタを暗号化するかどうか
  # 設定可能な値: true（暗号化有効）、false（暗号化無効）
  # 省略時: source_db_cluster_identifier指定時は既存クラスタの設定に従う、未指定時はfalse
  # 注意事項: 変更すると新しいリソースが作成されます
  storage_encrypted = true

  # 削除保護
  # 設定内容: グローバルクラスタの削除保護を有効にするかどうか
  # 設定可能な値: true（削除保護有効）、false（削除保護無効）
  # 省略時: false
  deletion_protection = true

  #-------------------------------------------------------------------------------------------------------
  # 既存クラスタからの作成設定
  #-------------------------------------------------------------------------------------------------------
  # ソースDBクラスタ識別子
  # 設定内容: グローバルクラスタ作成時にプライマリDBクラスタとして使用する既存クラスタのARN
  # 注意事項:
  #   - engineパラメータと同時指定不可
  #   - 既存クラスタのglobal_cluster_identifier属性は自動的に更新されるため、
  #     既存クラスタ側でignore_changesを設定して循環参照を回避する必要があります
  source_db_cluster_identifier = aws_docdb_cluster.existing.arn

  #-------------------------------------------------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------------------------------------------------
  # リージョン
  # 設定内容: このリソースが管理されるリージョン
  # 省略時: プロバイダー設定のリージョン
  # 注意事項: AWS General Referenceのリージョナルエンドポイントを参照
  region = "us-east-1"

  #-------------------------------------------------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------------------------------------------------
  timeouts {
    # 作成タイムアウト
    # 設定内容: リソース作成の最大待機時間
    # 省略時: デフォルトのタイムアウト値
    # create = "30m"

    # 更新タイムアウト
    # 設定内容: リソース更新の最大待機時間
    # 省略時: デフォルトのタイムアウト値
    # update = "30m"

    # 削除タイムアウト
    # 設定内容: リソース削除の最大待機時間
    # 省略時: デフォルトのタイムアウト値
    # delete = "30m"
  }
}

#-------------------------------------------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-------------------------------------------------------------------------------------------------------
# arn                          - グローバルクラスタのAmazon Resource Name（ARN）
# global_cluster_members       - グローバルクラスタメンバーを含むオブジェクトのセット
#   - db_cluster_arn            - メンバーDBクラスタのARN
#   - is_writer                 - メンバーがプライマリDBクラスタかどうか
# global_cluster_resource_id   - グローバルデータベースクラスタのAWSリージョン固有の不変識別子
#                                KMSキーアクセス時のCloudTrailログに記録されます
# id                          - DocumentDB Global ClusterのID
# status                      - グローバルクラスタの現在のステータス
