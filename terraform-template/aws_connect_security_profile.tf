#-----------------------------------------------------------------------
# Amazon Connect セキュリティプロファイル (Security Profile)
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/connect_security_profile
#
# NOTE:
#   Amazon Connectインスタンス内でユーザーの権限を管理するセキュリティプロファイル。
#   コンタクトセンターのエージェント、スーパーバイザー、管理者などの役割に応じて
#   アクセス権限を細かく制御できます。
#
# 用途:
#   - Amazon Connectインスタンス内でのユーザー権限管理
#   - コンタクトセンターオペレーター、スーパーバイザー、管理者などの役割定義
#   - きめ細かいアクセス制御による運用セキュリティの確保
#
# 主な機能:
#   - ユーザーアクション権限の細かい制御（通話録音、顧客情報閲覧など）
#   - 組織階層に応じたリソースアクセス範囲の設定
#   - 標準プロファイルのカスタマイズや新規プロファイル作成
#
# 関連リソース:
#   - aws_connect_instance: Connectインスタンス本体
#   - aws_connect_user: セキュリティプロファイルを割り当てるユーザー
#   - aws_connect_routing_profile: ルーティング設定と組み合わせて利用
#-----------------------------------------------------------------------

#------------------------------------------------------------------------------------
# 基本設定
#------------------------------------------------------------------------------------
resource "aws_connect_security_profile" "example" {
  # 設定内容: セキュリティプロファイルを作成するAmazon ConnectインスタンスのID
  # 形式: instance/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx形式
  instance_id = "arn:aws:connect:ap-northeast-1:123456789012:instance/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

  # 設定内容: セキュリティプロファイルの名前（インスタンス内で一意）
  # 制約: 1～127文字、英数字とハイフン、アンダースコアが使用可能
  # 例: "CallCenterAgent", "Supervisor", "Admin"
  name = "CallCenterAgent"

  # 設定内容: セキュリティプロファイルの説明（オプション）
  # 用途: プロファイルの目的や権限範囲の概要説明
  # 制約: 最大250文字
  description = "コンタクトセンターエージェント用の標準権限プロファイル"

  #------------------------------------------------------------------------------------
  # 権限設定
  #------------------------------------------------------------------------------------
  # 設定内容: ユーザーに付与する権限のリスト
  # 形式: Amazon Connect APIの権限名を指定（例: "BasicAgentAccess", "OutboundCallAccess"）
  # 省略時: 権限なし（最小権限の原則）
  # 注意: 必要最小限の権限のみを付与することを推奨
  permissions = [
    # エージェント基本権限
    "BasicAgentAccess",

    # 発信権限
    "OutboundCallAccess",

    # コンタクト履歴の閲覧
    "AccessMetrics",
  ]

  #------------------------------------------------------------------------------------
  # リージョン設定
  #------------------------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 用途: マルチリージョン環境でのリソース配置制御
  region = "ap-northeast-1"

  #------------------------------------------------------------------------------------
  # タグ設定
  #------------------------------------------------------------------------------------
  # 設定内容: リソース管理用のタグ（キー・バリューペア）
  # 用途: コスト配分、環境識別、運用管理
  tags = {
    Name        = "CallCenterAgentProfile"
    Environment = "Production"
    Department  = "CustomerSupport"
    ManagedBy   = "Terraform"
  }
}

#-----------------------------------------------------------------------
# 出力値 (Attributes Reference)
#-----------------------------------------------------------------------
# この設定により以下の属性が参照可能になります:
#
# - arn: セキュリティプロファイルのARN
#   形式: arn:aws:connect:region:account-id:instance/instance-id/security-profile/security-profile-id
#
# - id: Terraform管理用の内部ID（instance_id:security_profile_id形式）
#
# - security_profile_id: セキュリティプロファイルの一意識別子（UUID形式）
#
# - organization_resource_id: 組織リソースID（該当する場合）
#
# - region: リソースが作成されたAWSリージョン
#
# - tags_all: デフォルトタグを含む全てのタグ
#-----------------------------------------------------------------------
