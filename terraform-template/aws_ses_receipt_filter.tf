#==================================================================================
# AWS SES Receipt Filter
#==================================================================================
# SES受信フィルターは、特定のIPアドレスまたはIPアドレス範囲からの
# インバウンドメールを許可またはブロックするために使用されます。
#
# ユースケース:
# - スパム送信者からのメールをブロック
# - 特定の信頼できるIPアドレスからのメールのみを許可
# - セキュリティポリシーに基づいてメール受信を制御
#
# 重要な考慮事項:
# - フィルターは受信ルールより前に評価されます
# - 複数のフィルターを設定できます
# - Allow/Block両方のポリシーを組み合わせて使用可能
# - 0.0.0.0/0をブロックしてから特定IPを許可することで、
#   ホワイトリスト方式を実装できます
#
# 参考資料:
# - https://docs.aws.amazon.com/ses/latest/DeveloperGuide/receiving-email-ip-filters.html
# - https://docs.aws.amazon.com/ses/latest/APIReference/API_ReceiptIpFilter.html
#==================================================================================

#----------------------------------------------------------------------------------
# 基本的な使用例: 特定のIPアドレスをブロック
#----------------------------------------------------------------------------------
resource "aws_ses_receipt_filter" "block_spammer" {
  # (必須) フィルターの名前
  # - 64文字以内の英数字、ハイフン、アンダースコア
  # - 英字または数字で開始・終了する必要があります
  name = "block-spammer-ip"

  # (必須) フィルタリングするIPアドレスまたはアドレス範囲（CIDR表記）
  # CIDR表記の例:
  # - 単一IP: 10.10.10.10/32 または 10.10.10.10
  # - IP範囲: 192.168.1.0/24 (192.168.1.0 - 192.168.1.255)
  # - 広範囲: 10.0.0.0/8 (10.0.0.0 - 10.255.255.255)
  # - 全てのIPv4: 0.0.0.0/0
  # - IPv6もサポート: 2001:db8::/32
  cidr = "203.0.113.10/32"

  # (必須) ポリシー: "Block" または "Allow"
  # - Block: 指定されたCIDRからのメールを拒否
  # - Allow: 指定されたCIDRからのメールを許可
  policy = "Block"

  # (オプション) このリソースが管理されるAWSリージョン
  # デフォルトはプロバイダー設定のリージョンを使用
  # SESの受信機能は特定のリージョンでのみ利用可能です
  # (us-east-1, us-west-2, eu-west-1など)
  # region = "us-east-1"
}

#----------------------------------------------------------------------------------
# IP範囲をブロックする例
#----------------------------------------------------------------------------------
resource "aws_ses_receipt_filter" "block_ip_range" {
  name = "block-suspicious-network"

  # /24ネットワーク全体をブロック（256個のIPアドレス）
  cidr = "198.51.100.0/24"

  policy = "Block"
}

#----------------------------------------------------------------------------------
# ホワイトリスト方式の実装例
#----------------------------------------------------------------------------------
# ステップ1: 全てのIPアドレスをブロック
resource "aws_ses_receipt_filter" "block_all" {
  name   = "block-all-ips"
  cidr   = "0.0.0.0/0"
  policy = "Block"
}

# ステップ2: 信頼できる特定のIPアドレスを許可
resource "aws_ses_receipt_filter" "allow_trusted_ip_1" {
  name   = "allow-trusted-ip-1"
  cidr   = "203.0.113.50/32"
  policy = "Allow"

  # depends_onは不要ですが、論理的な順序を明示するために使用可能
  depends_on = [aws_ses_receipt_filter.block_all]
}

resource "aws_ses_receipt_filter" "allow_trusted_ip_2" {
  name   = "allow-trusted-ip-2"
  cidr   = "203.0.113.51/32"
  policy = "Allow"

  depends_on = [aws_ses_receipt_filter.block_all]
}

# ステップ3: 信頼できるネットワーク範囲を許可
resource "aws_ses_receipt_filter" "allow_corporate_network" {
  name   = "allow-corporate-network"
  cidr   = "10.0.0.0/8"
  policy = "Allow"

  depends_on = [aws_ses_receipt_filter.block_all]
}

#----------------------------------------------------------------------------------
# 動的なフィルター作成の例（複数のIPをループで作成）
#----------------------------------------------------------------------------------
locals {
  # ブロックしたいIPアドレスのリスト
  blocked_ips = [
    "192.0.2.10",
    "192.0.2.20",
    "192.0.2.30",
  ]
}

resource "aws_ses_receipt_filter" "block_multiple_ips" {
  for_each = toset(local.blocked_ips)

  # IPアドレスをフィルター名に含める（ドットをハイフンに置換）
  name = "block-${replace(each.value, ".", "-")}"

  # 単一IPアドレスの場合、/32を追加
  cidr = "${each.value}/32"

  policy = "Block"
}

#----------------------------------------------------------------------------------
# IPv6アドレスのフィルタリング例
#----------------------------------------------------------------------------------
resource "aws_ses_receipt_filter" "block_ipv6_range" {
  name = "block-ipv6-network"

  # IPv6 CIDR表記
  cidr = "2001:db8:1234::/48"

  policy = "Block"
}

#----------------------------------------------------------------------------------
# 出力例
#----------------------------------------------------------------------------------
# フィルターのIDとARNを出力

output "ses_receipt_filter_id" {
  description = "SES受信フィルターの名前（ID）"
  value       = aws_ses_receipt_filter.block_spammer.id
}

output "ses_receipt_filter_arn" {
  description = "SES受信フィルターのARN"
  value       = aws_ses_receipt_filter.block_spammer.arn
}

# 複数のフィルターIDを出力
output "blocked_ip_filter_ids" {
  description = "ブロックされた複数のIPフィルターのID"
  value       = { for k, v in aws_ses_receipt_filter.block_multiple_ips : k => v.id }
}

#==================================================================================
# 属性リファレンス
#==================================================================================
# このリソースは以下の属性をエクスポートします:
#
# - id  : SES受信フィルター名
# - arn : SES受信フィルターのARN
#
#==================================================================================
# インポート
#==================================================================================
# 既存のSES受信フィルターは、フィルター名を使用してインポートできます:
#
# terraform import aws_ses_receipt_filter.block_spammer block-spammer-ip
#
#==================================================================================
# ベストプラクティス
#==================================================================================
# 1. フィルター名の命名規則
#    - 目的が明確な名前を使用（例: block-spammer-*, allow-corporate-*）
#    - 環境やチーム名をプレフィックスとして追加（例: prod-block-*）
#
# 2. セキュリティ
#    - ホワイトリスト方式を推奨（デフォルトでブロック、信頼できるIPのみ許可）
#    - 定期的にフィルターリストを見直す
#    - 必要最小限のIP範囲のみを許可
#
# 3. CIDR範囲の設定
#    - 可能な限り狭い範囲を指定
#    - 単一IPの場合は/32を明示的に指定（IPv4）
#    - /8, /16などの広範囲は慎重に使用
#
# 4. フィルター評価順序
#    - Allowフィルターが優先されます
#    - 同じIPが複数のフィルターにマッチする場合、Allowが優先
#    - フィルターは受信ルールセットより前に評価されます
#
# 5. リージョンの考慮事項
#    - SES受信機能は特定リージョンでのみ利用可能
#    - 主要リージョン: us-east-1, us-west-2, eu-west-1
#    - 使用するリージョンで受信機能が有効か確認
#
# 6. モニタリングとログ
#    - CloudWatch Logsでブロックされたメールを追跡
#    - SESメトリクスでフィルターの効果を確認
#    - 誤ってブロックされたメールがないか定期的に確認
#
# 7. テストとバリデーション
#    - 本番環境適用前にテスト環境で検証
#    - 重要なメール送信者が誤ってブロックされないことを確認
#    - 段階的にフィルターを追加（一度に全てをブロックしない）
#
#==================================================================================
# トラブルシューティング
#==================================================================================
# Q: フィルターを設定したのにメールが届く
# A: - フィルターのCIDR範囲が正しいか確認
#    - ポリシーがBlockになっているか確認
#    - 他のAllowフィルターが優先されていないか確認
#
# Q: 重要なメールがブロックされる
# A: - ホワイトリスト方式の場合、送信者IPを確認
#    - 適切なAllowフィルターを追加
#    - CloudWatch Logsで詳細を確認
#
# Q: IPv6アドレスをフィルタリングしたい
# A: - cidrにIPv6のCIDR表記を使用（例: 2001:db8::/32）
#    - IPv4とIPv6で別々のフィルターが必要
#
# Q: フィルターの数に制限はあるか
# A: - デフォルトで100個まで作成可能
#    - より多くが必要な場合はAWSサポートにクォータ増加を依頼
#
