#######################################################################
# AWS DataSync S3ロケーション
#######################################################################
# Provider Version: 6.28.0
# Generated: 2026-02-14
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/datasync_location_s3
#
# NOTE:
# AWS DataSyncタスクのソースまたはターゲットとして使用するS3バケットの
# ロケーション設定を管理します。
#
# 主な用途:
# - オンプレミスからS3へのデータ転送エンドポイント設定
# - S3間のデータ同期・レプリケーション用ロケーション
# - AWS Outposts上のS3バケットへのアクセス設定
# - ストレージクラスを指定した効率的なデータ配置
#
# 制約事項:
# - s3_bucket_arnとsubdirectoryは作成後変更不可（要再作成）
# - IAMロールにはDataSync用の適切な権限が必要
# - S3 on Outposts使用時はagent_arnsの指定が必須
# - KMS暗号化バケット使用時はキーポリシーにIAMロール追加が必要
#
# 注意事項:
# - ストレージクラスは転送コストに影響（特にGLACIER系）
# - subdirectoryは必ず"/"で始まる必要がある
# - バケットポリシーでDataSync用IAMロールへのアクセス許可が必要
# - VPC制限バケットの場合は適切なバケットポリシー設定が必要
#
# 参考: https://docs.aws.amazon.com/datasync/latest/userguide/create-s3-location.html
#-----------------------------------------------------------------------

resource "aws_datasync_location_s3" "example" {
  #-----------------------------------------------------------------------
  # 基本設定
  #-----------------------------------------------------------------------
  # 設定内容: DataSyncロケーションとして使用するS3バケットのARN
  # 形式: arn:aws:s3:::bucket-name
  # 省略時: 必須パラメータのため省略不可
  # 備考: 作成後変更不可（変更する場合はリソース再作成が必要）
  s3_bucket_arn = "arn:aws:s3:::example-bucket"

  # 設定内容: DataSyncが読み書きするS3バケット内のプレフィックス（サブディレクトリ）
  # 形式: 必ず"/"で始まる文字列（例: "/prefix/path" または "/"）
  # 省略時: 必須パラメータのため省略不可
  # 備考:
  # - 作成後変更不可（変更する場合はリソース再作成が必要）
  # - ソースロケーションの場合はこのパス配下から読み取り
  # - ターゲットロケーションの場合はこのパス配下へ書き込み
  # - "//"のような二重スラッシュや、末尾のスラッシュは不可
  subdirectory = "/data"

  #-----------------------------------------------------------------------
  # IAM設定（必須ブロック）
  #-----------------------------------------------------------------------
  # 設定内容: DataSyncがS3バケットにアクセスするために使用するIAMロール設定
  # 省略時: 必須ブロックのため省略不可
  s3_config {
    # 設定内容: DataSyncがS3バケットにアクセスするために使用するIAMロールのARN
    # 必要な権限: s3:GetBucketLocation, s3:ListBucket, s3:ListBucketMultipartUploads,
    #           s3:GetObject*, s3:PutObject*, s3:DeleteObject, s3:AbortMultipartUpload
    # 省略時: 必須パラメータのため省略不可
    # 備考:
    # - KMS暗号化バケットの場合はkms:Decrypt, kms:Encrypt権限も必要
    # - 信頼ポリシーでdatasync.amazonaws.comからのAssumeRoleを許可すること
    bucket_access_role_arn = "arn:aws:iam::123456789012:role/DataSyncS3Role"
  }

  #-----------------------------------------------------------------------
  # ストレージ設定
  #-----------------------------------------------------------------------
  # 設定内容: ターゲットロケーションとして使用する際に作成するオブジェクトのストレージクラス
  # 設定可能な値:
  # - STANDARD: 標準ストレージ（デフォルト、頻繁なアクセスに最適）
  # - INTELLIGENT_TIERING: アクセスパターンに応じた自動階層化
  # - STANDARD_IA: 低頻度アクセス用標準ストレージ
  # - ONEZONE_IA: 単一AZの低頻度アクセスストレージ
  # - GLACIER: アーカイブストレージ（取得に数分～数時間）
  # - GLACIER_IR: 即時取得可能なアーカイブストレージ
  # - DEEP_ARCHIVE: 長期アーカイブストレージ（取得に12時間以上）
  # - OUTPOSTS: AWS Outpostsストレージクラス
  # 省略時: STANDARD
  # 備考:
  # - GLACIERやDEEP_ARCHIVEはリクエストコストが高いため注意
  # - ソースロケーションの場合は無視される
  s3_storage_class = "STANDARD"

  #-----------------------------------------------------------------------
  # エージェント設定（S3 on Outposts用）
  #-----------------------------------------------------------------------
  # 設定内容: AWS Outposts上のS3バケットにアクセスするために使用するDataSyncエージェントのARNリスト
  # 形式: ["arn:aws:datasync:region:account-id:agent/agent-id"]
  # 省略時: 空（通常のS3バケット使用時は不要）
  # 備考:
  # - AWS Outposts上のS3バケットを使用する場合のみ指定
  # - 通常のリージョンS3バケットの場合は指定不要
  # - 複数のエージェントARNを指定可能
  agent_arns = []

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # 設定内容: このロケーションを管理するAWSリージョン
  # 省略時: プロバイダーで設定されたリージョンを使用
  # 備考: 明示的に指定する必要がある場合に使用
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  # 設定内容: ロケーションに付与するタグ（キー・バリューペア）
  # 用途: リソースの分類、コスト配分、アクセス制御などに使用
  # 省略時: タグなし
  tags = {
    Name        = "example-datasync-s3-location"
    Environment = "production"
    Purpose     = "data-migration"
  }
}

#-----------------------------------------------------------------------
# 補足: Attributes Reference（参照専用属性）
#-----------------------------------------------------------------------
# このリソースでは以下の属性を参照できます:
#
# arn - DataSyncロケーションのARN
#   例: arn:aws:datasync:us-east-1:123456789012:location/loc-xxxxx
#   用途: DataSyncタスクのソース/ターゲット指定に使用
#
# id - DataSyncロケーションのARN（arnと同じ）
#
# uri - S3ロケーションのURI
#   形式: s3://bucket-name/subdirectory
#   用途: ロケーションの識別や表示に使用
#
# tags_all - デフォルトタグを含むすべてのタグ
#   プロバイダーレベルで設定されたdefault_tagsとリソース固有のtagsをマージした値
#-----------------------------------------------------------------------
