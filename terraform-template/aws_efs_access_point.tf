#-----------------------------------------------------------------------
# Amazon EFS Access Point
#-----------------------------------------------------------------------
# EFSファイルシステムへのアプリケーション固有のエントリーポイントを作成します。
# アクセスポイントを使用すると、共有データセットへのアクセス管理が簡素化され、
# ユーザーIDや異なるルートディレクトリを強制できます。
#
# 主な機能:
# - アプリケーション固有のエントリーポイント
# - POSIXユーザーIDとグループの強制
# - カスタムルートディレクトリの指定
# - IAMポリシーによるアクセス制御
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: このテンプレートは実際のデプロイ前に要件に応じてカスタマイズしてください
#
# 参照: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/efs_access_point

#-----------------------------------------------------------------------
# Basic Configuration
#-----------------------------------------------------------------------

resource "aws_efs_access_point" "example" {
  # 必須: アクセスポイントを作成するEFSファイルシステムのID
  # 設定内容: EFSファイルシステムの一意識別子
  file_system_id = "fs-12345678"

  #-----------------------------------------------------------------------
  # POSIX User Configuration
  #-----------------------------------------------------------------------

  # posix_user {
  #   # 必須: アクセスポイントを使用する際に適用されるPOSIXグループID
  #   # 設定内容: NFSクライアントのグループID (0-4294967295)
  #   # 用途: ファイルシステムアクセス時の権限制御
  #   # gid = 1000
  #
  #   # 必須: アクセスポイントを使用する際に適用されるPOSIXユーザーID
  #   # 設定内容: NFSクライアントのユーザーID (0-4294967295)
  #   # 用途: ファイルシステムアクセス時の所有者制御
  #   # uid = 1000
  #
  #   # 任意: 追加のPOSIXグループIDのリスト
  #   # 設定内容: 補助グループIDの配列 (各値 0-4294967295)
  #   # 用途: 複数グループへのアクセス権限付与
  #   # 省略時: 補助グループなし
  #   # secondary_gids = [1001, 1002]
  # }

  #-----------------------------------------------------------------------
  # Root Directory Configuration
  #-----------------------------------------------------------------------

  # root_directory {
  #   # 任意: アクセスポイントのルートディレクトリとして公開するパス
  #   # 設定内容: EFSファイルシステム上のディレクトリパス
  #   # 形式: 最大4階層のサブディレクトリ、最大100文字
  #   # 用途: NFSクライアントに特定のディレクトリをルートとして提示
  #   # 省略時: ファイルシステムのルートディレクトリ (/)
  #   # 注意: パスが存在しない場合、creation_infoの指定が必要
  #   # path = "/exports/data"
  #
  #   # ルートディレクトリの自動作成設定
  #   # creation_info {
  #     # 必須: ルートディレクトリの所有者グループID
  #     # 設定内容: POSIXグループID (0-4294967295)
  #     # 用途: ディレクトリ作成時の所有権設定
  #     # owner_gid = 1000
  #
  #     # 必須: ルートディレクトリの所有者ユーザーID
  #     # 設定内容: POSIXユーザーID (0-4294967295)
  #     # 用途: ディレクトリ作成時の所有者設定
  #     # owner_uid = 1000
  #
  #     # 必須: ルートディレクトリに適用するPOSIX権限
  #     # 設定内容: 8進数形式の権限 (例: "0755")
  #     # 用途: ディレクトリのアクセス権限制御
  #     # 一般的な値:
  #     #   - "0755": 所有者=rwx、グループ=rx、その他=rx
  #     #   - "0750": 所有者=rwx、グループ=rx、その他=なし
  #     #   - "0700": 所有者=rwx、グループ=なし、その他=なし
  #     # permissions = "0755"
  #   # }
  # }

  #-----------------------------------------------------------------------
  # Region Configuration
  #-----------------------------------------------------------------------

  # 任意: リソースを管理するAWSリージョン
  # 設定内容: AWSリージョンコード
  # 省略時: プロバイダー設定のリージョンを使用
  region = null

  #-----------------------------------------------------------------------
  # Tagging
  #-----------------------------------------------------------------------

  # 任意: リソースに付与するタグ
  # 設定内容: キーバリュー形式のタグマップ
  # 用途: リソースの識別、管理、コスト配分
  tags = {
    Name        = "example-access-point"
    Environment = "production"
    Application = "data-processing"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference
#-----------------------------------------------------------------------
# 以下の属性がリソース作成後に参照可能です:
#
# - id: アクセスポイントの一意識別子
# - arn: アクセスポイントのAmazon Resource Name
# - file_system_arn: EFSファイルシステムのARN
# - owner_id: アクセスポイントを所有するAWSアカウントID
# - tags_all: デフォルトタグを含む全タグのマップ
# - region: リソースが作成されたリージョン
