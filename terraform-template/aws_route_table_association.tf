#---------------------------------------------------------------
# AWS Route Table Association
#---------------------------------------------------------------
#
# ルートテーブルとサブネット、またはルートテーブルとインターネットゲートウェイ/
# 仮想プライベートゲートウェイの関連付けを作成するリソースです。
# VPC 内のネットワークルーティングを制御するための重要なリソースです。
#
# サブネット関連付けの場合、そのサブネットからのトラフィックがどのルートテーブルを
# 使用してルーティングされるかを決定します。
# ゲートウェイ関連付けの場合、VPC の境界におけるルーティングを制御します。
#
# NOTE: subnet_id と gateway_id は排他的で、どちらか一方のみを指定する必要があります。
#
# AWS公式ドキュメント:
#   - Route Tables 概要: https://docs.aws.amazon.com/vpc/latest/userguide/VPC_Route_Tables.html
#   - Subnet Route Table Association: https://docs.aws.amazon.com/vpc/latest/userguide/VPC_Route_Tables.html#subnet-route-tables
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/route_table_association
#
# Provider Version: 6.28.0
# Generated: 2026-02-04
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_route_table_association" "example" {
  #-------------------------------------------------------------
  # ルートテーブル設定
  #-------------------------------------------------------------

  # route_table_id (Required)
  # 設定内容: 関連付けるルートテーブルの ID を指定します。
  # 設定可能な値: 有効な AWS ルートテーブル ID（例: rtb-xxxxxxxxxxxxxxxxx）
  # 注意: このルートテーブルは関連付け対象のサブネット/ゲートウェイと同じ VPC に
  #       属している必要があります。
  # 関連機能: VPC Route Tables
  #   ルートテーブルは VPC 内のネットワークトラフィックの方向を決定するルールの
  #   集合です。各エントリはデスティネーションと次のホップを定義します。
  route_table_id = "rtb-xxxxxxxxxxxxxxxxx"

  #-------------------------------------------------------------
  # 関連付けターゲット設定（サブネット）
  #-------------------------------------------------------------

  # subnet_id (Optional)
  # 設定内容: ルートテーブルに関連付けるサブネット ID を指定します。
  # 設定可能な値: 有効な AWS サブネット ID（例: subnet-xxxxxxxxxxxxxxxxx）
  # 注意:
  #   - gateway_id と排他的です（どちらか一方のみ指定可能）
  #   - subnet_id または gateway_id のどちらかを必ず指定する必要があります
  # 関連機能: Subnet Route Table Association
  #   サブネット内のリソースからのトラフィックが指定されたルートテーブルの
  #   ルールに従ってルーティングされるようになります。
  # 使用例: プライベートサブネットをカスタムルートテーブルに関連付けて、
  #         NAT Gateway 経由でインターネットアクセスを設定する場合など
  subnet_id = "subnet-xxxxxxxxxxxxxxxxx"

  #-------------------------------------------------------------
  # 関連付けターゲット設定（ゲートウェイ）
  #-------------------------------------------------------------

  # gateway_id (Optional)
  # 設定内容: ルートテーブルに関連付けるゲートウェイ ID を指定します。
  # 設定可能な値:
  #   - インターネットゲートウェイ ID（例: igw-xxxxxxxxxxxxxxxxx）
  #   - 仮想プライベートゲートウェイ ID（例: vgw-xxxxxxxxxxxxxxxxx）
  # 注意:
  #   - subnet_id と排他的です（どちらか一方のみ指定可能）
  #   - subnet_id または gateway_id のどちらかを必ず指定する必要があります
  # 関連機能: Gateway Route Table Association
  #   VPC の境界（インターネットゲートウェイや仮想プライベートゲートウェイ）で
  #   のトラフィックルーティングを制御します。
  # 使用例: インターネットゲートウェイをカスタムルートテーブルに関連付けて、
  #         特定のルーティングポリシーを適用する場合など
  gateway_id = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効な AWS リージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - id: ルートテーブル関連付けの ID
#
#---------------------------------------------------------------

#---------------------------------------------------------------
# 使用例1: サブネットとルートテーブルの関連付け
#---------------------------------------------------------------
# resource "aws_route_table_association" "subnet_association" {
#   subnet_id      = aws_subnet.private.id
#   route_table_id = aws_route_table.private.id
# }

#---------------------------------------------------------------
# 使用例2: インターネットゲートウェイとルートテーブルの関連付け
#---------------------------------------------------------------
# resource "aws_route_table_association" "gateway_association" {
#   gateway_id     = aws_internet_gateway.main.id
#   route_table_id = aws_route_table.public.id
# }

#---------------------------------------------------------------
# 補足説明
#---------------------------------------------------------------
#
# 1. サブネットの関連付け:
#    - 各サブネットは常に1つのルートテーブルに関連付けられます
#    - 明示的に関連付けない場合、VPC のメインルートテーブルが使用されます
#    - 複数のサブネットを同じルートテーブルに関連付けることが可能です
#
# 2. ゲートウェイの関連付け:
#    - インターネットゲートウェイや仮想プライベートゲートウェイを
#      カスタムルートテーブルに関連付けることができます
#    - これにより VPC の境界でのトラフィックルーティングを細かく制御できます
#
# 3. ルートテーブルの変更:
#    - 既存の関連付けの route_table_id を変更すると、関連付けが
#      新しいルートテーブルに移動します
#    - これにより、リソースの再作成なしにルーティングを変更できます
#
# 4. 削除時の動作:
#    - サブネット関連付けを削除すると、サブネットは VPC のメイン
#      ルートテーブルに自動的に関連付けられます
#
#---------------------------------------------------------------
