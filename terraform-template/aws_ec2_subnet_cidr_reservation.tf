#-----------------------------------------------------------------------
# 用途: サブネット内の特定のCIDRブロックを予約し、自動割り当てから除外する
#
# 主な機能:
# - サブネット内CIDRブロックの予約管理
# - プレフィックス型/明示型予約の選択
# - AWS管理サービス用のアドレス空間確保
# - サブネット内アドレス競合の防止
#
# 料金への影響:
# - このリソース自体に課金は発生しない
# - 予約されたCIDRブロックは使用できないがコストは不要
#
# 制限事項:
# - サブネットのCIDRブロック範囲内である必要がある
# - 既存のENI等と重複する予約はできない
# - 予約後は他のリソースが自動割り当てで使用不可
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# リソース定義
#-----------------------------------------------------------------------
resource "aws_ec2_subnet_cidr_reservation" "example" {
  #-----------------------------------------------------------------------
  # 必須パラメータ
  #-----------------------------------------------------------------------

  # 予約するCIDRブロック
  # 設定内容: サブネット内で予約する具体的なCIDRブロック
  # 設定可能な値: サブネットのCIDRブロック内の有効なCIDR表記（例: 10.0.1.0/28）
  # 注意事項: サブネットのCIDRブロック範囲内である必要がある
  cidr_block = "10.0.1.0/28"

  # 予約タイプ
  # 設定内容: 予約するCIDRブロックの用途・タイプを指定
  # 設定可能な値:
  #   - "prefix" (プレフィックス予約: AWS管理サービスが使用)
  #   - "explicit" (明示的予約: ユーザーが特定用途で予約)
  # 注意事項: タイプに応じて予約の扱いが異なる
  reservation_type = "explicit"

  # サブネットID
  # 設定内容: CIDRブロックを予約するサブネットのID
  # 設定可能な値: 有効なサブネットID（例: subnet-12345678）
  # 注意事項: 指定したサブネット内でのみ予約が有効
  subnet_id = "subnet-12345678"

  #-----------------------------------------------------------------------
  # オプションパラメータ - 説明情報
  #-----------------------------------------------------------------------

  # 予約の説明
  # 設定内容: この予約の目的や用途を説明するテキスト
  # 設定可能な値: 任意の文字列（255文字以内推奨）
  # 省略時: 説明なし
  # 推奨用途: 予約理由や関連サービス名を記録
  description = "Reserved for future ELB deployment"

  #-----------------------------------------------------------------------
  # オプションパラメータ - リージョン管理
  #-----------------------------------------------------------------------

  # リージョン指定
  # 設定内容: このリソースを管理するAWSリージョン
  # 設定可能な値: AWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意事項: 明示的に指定しない限りプロバイダー設定が優先される
  region = "ap-northeast-1"
}

