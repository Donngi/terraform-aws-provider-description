#---------------------------------------------------------------
# AWS AppStream User
#---------------------------------------------------------------
#
# Amazon AppStream 2.0のユーザーをプロビジョニングするリソースです。
# AppStream 2.0は、デスクトップアプリケーションをユーザーのブラウザに
# ストリーミングするフルマネージドサービスです。
# ユーザーリソースは、ユーザープール認証を使用してAppStreamにアクセスする
# ユーザーを管理するために使用されます。
#
# AWS公式ドキュメント:
#   - AppStream 2.0とは: https://docs.aws.amazon.com/appstream2/latest/developerguide/what-is-appstream.html
#   - ユーザープール管理: https://docs.aws.amazon.com/appstream2/latest/developerguide/user-pool.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/appstream_user
#
# Provider Version: 6.28.0
# Generated: 2026-01-18
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_appstream_user" "example" {
  #-------------------------------------------------------------
  # 必須設定
  #-------------------------------------------------------------

  # authentication_type (Required)
  # 設定内容: ユーザーの認証タイプを指定します。
  # 設定可能な値:
  #   - "USERPOOL": ユーザープール認証（必須で指定する必要があります）
  #   - "API": API認証
  #   - "SAML": SAML認証
  # 注意: ユーザーリソースを作成する場合は、USERPOOLを指定する必要があります。
  authentication_type = "USERPOOL"

  # user_name (Required)
  # 設定内容: ユーザーのメールアドレスを指定します。
  # 設定可能な値: 有効なメールアドレス形式の文字列
  # 注意: このメールアドレスはユーザーの一意識別子として使用され、
  #       ログイン時に使用されます。
  user_name = "user@example.com"

  #-------------------------------------------------------------
  # ユーザー情報設定
  #-------------------------------------------------------------

  # first_name (Optional)
  # 設定内容: ユーザーの名（ファーストネーム）を指定します。
  # 設定可能な値: 文字列
  # 省略時: 設定なし
  first_name = "Taro"

  # last_name (Optional)
  # 設定内容: ユーザーの姓（ラストネーム）を指定します。
  # 設定可能な値: 文字列
  # 省略時: 設定なし
  last_name = "Yamada"

  #-------------------------------------------------------------
  # ユーザー状態設定
  #-------------------------------------------------------------

  # enabled (Optional)
  # 設定内容: ユーザープール内のユーザーを有効にするかどうかを指定します。
  # 設定可能な値:
  #   - true: ユーザーを有効化（AppStreamにアクセス可能）
  #   - false: ユーザーを無効化（AppStreamにアクセス不可）
  # 省略時: true（デフォルトで有効）
  enabled = true

  #-------------------------------------------------------------
  # 通知設定
  #-------------------------------------------------------------

  # send_email_notification (Optional)
  # 設定内容: ユーザー作成時にメール通知を送信するかどうかを指定します。
  # 設定可能な値:
  #   - true: ウェルカムメールを送信（接続手順と一時パスワードを含む）
  #   - false: メール通知を送信しない
  # 省略時: 設定なし
  # 注意: 初回作成時のみ有効です。一度falseで作成した後にtrueに変更しても
  #       メールは送信されません。
  send_email_notification = true

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null
}

