resource "aws_iam_user_policy" "example" {
  #-------------------------------------------------------------
  # 対象ユーザー設定
  #-------------------------------------------------------------

  # user (Required)
  # 設定内容: このインラインポリシーをアタッチするIAMユーザー名を指定します。
  # 設定可能な値: 有効なIAMユーザー名（aws_iam_user リソースの name 属性を参照可能）
