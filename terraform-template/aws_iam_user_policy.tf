  #       意図しない差分が発生する場合があります。
  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = [
          "ec2:Describe*",
        ]
        Effect   = "Allow"
        Resource = "*"
      },
    ]
  })

  #-------------------------------------------------------------
  # ポリシー名設定
  #-------------------------------------------------------------

  # name (Optional)
  # 設定内容: インラインポリシーの名前を指定します。
