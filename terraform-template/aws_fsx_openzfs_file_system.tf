#-----------------------------------------------------------------------
# AWS FSx for OpenZFS ファイルシステム
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-17
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/fsx_openzfs_file_system
#
# 用途: OpenZFSプロトコルを使用した高性能なファイルシステムを提供
# 特徴:
#   - NFS v3/v4/v4.1/v4.2プロトコルサポート
#   - データ圧縮機能（LZ4/ZSTD）
#   - スナップショット機能
#   - ユーザー・グループ別のクォータ設定
# ドキュメント: https://docs.aws.amazon.com/fsx/latest/OpenZFSGuide/what-is-fsx.html
#
# NOTE: このテンプレートは全設定項目を網羅していますが、実際の利用時は
#       必要な項目のみコメント解除して使用してください。
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------
resource "aws_fsx_openzfs_file_system" "example" {
  # デプロイタイプ
  # 設定内容: ファイルシステムのデプロイメント構成
  # 設定可能な値:
  #   - SINGLE_AZ_1: 単一AZ構成（SSDストレージ）
  #   - SINGLE_AZ_2: 単一AZ構成（第2世代）
  #   - MULTI_AZ_1: マルチAZ構成（高可用性）
  deployment_type = "SINGLE_AZ_1"

  # サブネットID
  # 設定内容: ファイルシステムがアクセス可能なサブネットのリスト
  # 補足: SINGLE_AZ構成では1つ、MULTI_AZ構成では2つ指定
  subnet_ids = ["subnet-12345678"]

  # スループット容量
  # 設定内容: ファイルシステムのスループット（MB/s）
  # 設定可能な値（SINGLE_AZ_1）: 64, 128, 256, 512, 1024, 2048, 3072, 4096
  # 設定可能な値（SINGLE_AZ_2）: 160, 320, 640, 1280, 2560, 3840, 5120, 7680, 10240
  throughput_capacity = 64

  #-----------------------------------------------------------------------
  # ストレージ設定
  #-----------------------------------------------------------------------
  # ストレージ容量
  # 設定内容: ファイルシステムの容量（GiB）
  # 設定可能な値: 64〜524288
  # 補足: storage_typeがSSDの場合は必須、INTELLIGENT_TIERINGの場合は設定不可
  storage_capacity = 64

  # ストレージタイプ
  # 設定内容: ファイルシステムのストレージタイプ
  # 設定可能な値:
  #   - SSD: SSDストレージ
  #   - INTELLIGENT_TIERING: インテリジェント階層化ストレージ（MULTI_AZ_1のみ）
  # 省略時: SSD
  storage_type = "SSD"

  #-----------------------------------------------------------------------
  # IOPS設定
  #-----------------------------------------------------------------------
  # ディスクIOPS設定
  # disk_iops_configuration {
  #   # IOPSモード
  #   # 設定内容: IOPSの設定方法
  #   # 設定可能な値:
  #   #   - AUTOMATIC: 自動設定（スループット容量に基づく）
  #   #   - USER_PROVISIONED: ユーザー指定
  #   # 省略時: AUTOMATIC
  #   mode = "AUTOMATIC"
  #
  #   # IOPS値
  #   # 設定内容: プロビジョニングするIOPS数
  #   # 補足: modeがUSER_PROVISIONEDの場合に設定
  #   # iops = 3000
  # }

  #-----------------------------------------------------------------------
  # 読み取りキャッシュ設定（Intelligent-Tiering専用）
  #-----------------------------------------------------------------------
  # 読み取りキャッシュ設定
  # 補足: storage_typeがINTELLIGENT_TIERINGの場合に必須
  # read_cache_configuration {
  #   # サイジングモード
  #   # 設定内容: 読み取りキャッシュのサイズ設定方法
  #   # 設定可能な値:
  #   #   - NO_CACHE: キャッシュなし
  #   #   - USER_PROVISIONED: ユーザー指定
  #   #   - PROPORTIONAL_TO_THROUGHPUT_CAPACITY: スループット容量に比例
  #   sizing_mode = "PROPORTIONAL_TO_THROUGHPUT_CAPACITY"
  #
  #   # キャッシュサイズ
  #   # 設定内容: SSD読み取りキャッシュのサイズ（GiB）
  #   # 補足: sizing_modeがUSER_PROVISIONEDの場合に必須
  #   # size = 100
  # }

  #-----------------------------------------------------------------------
  # ネットワーク設定
  #-----------------------------------------------------------------------
  # セキュリティグループID
  # 設定内容: ファイルシステムアクセス用ネットワークインターフェースに適用するセキュリティグループ
  security_group_ids = ["sg-12345678"]

  # 優先サブネットID
  # 設定内容: 優先ファイルサーバーを配置するサブネット
  # 補足: deployment_typeがMULTI_AZ_1の場合に必須
  preferred_subnet_id = "subnet-12345678"

  # エンドポイントIPアドレス範囲
  # 設定内容: ファイルシステムアクセス用エンドポイントが作成されるIPアドレス範囲
  # 補足: マルチAZ構成でのみ使用
  endpoint_ip_address_range = "198.19.255.0/24"

  # ルートテーブルID
  # 設定内容: ファイルサーバーへのトラフィックルーティング用ルートテーブル
  # 補足: マルチAZ構成でのみ使用
  route_table_ids = ["rtb-12345678"]

  #-----------------------------------------------------------------------
  # バックアップ設定
  #-----------------------------------------------------------------------
  # 自動バックアップ保持期間
  # 設定内容: 自動バックアップの保持日数（日）
  # 設定可能な値: 0〜90（0で自動バックアップ無効化）
  # 省略時: 0
  automatic_backup_retention_days = 0

  # 日次自動バックアップ開始時刻
  # 設定内容: 自動バックアップの開始時刻（HH:MM形式、UTC）
  # 補足: automatic_backup_retention_daysの設定が必要
  daily_automatic_backup_start_time = "03:00"

  # バックアップへのタグコピー
  # 設定内容: ファイルシステムのタグをバックアップにコピーするかどうか
  # 省略時: false
  copy_tags_to_backups = false

  # ボリュームへのタグコピー
  # 設定内容: ファイルシステムのタグをスナップショットにコピーするかどうか
  # 省略時: false
  copy_tags_to_volumes = false

  # バックアップからの復元
  # 設定内容: 復元元バックアップのID
  backup_id = "backup-12345678"

  # 最終バックアップのタグ
  # 設定内容: ファイルシステム削除時の最終バックアップに適用するタグ
  final_backup_tags = {
    Purpose = "FinalBackup"
  }

  # 最終バックアップのスキップ
  # 設定内容: 削除時の最終バックアップをスキップするかどうか
  # 省略時: false
  # 補足: 削除前に個別に適用する必要がある
  skip_final_backup = false

  #-----------------------------------------------------------------------
  # 削除オプション
  #-----------------------------------------------------------------------
  # 削除オプション
  # 設定内容: ファイルシステム削除時の動作設定
  # 設定可能な値:
  #   - DELETE_CHILD_VOLUMES_AND_SNAPSHOTS: 子ボリュームとスナップショットを削除
  delete_options = ["DELETE_CHILD_VOLUMES_AND_SNAPSHOTS"]

  #-----------------------------------------------------------------------
  # 暗号化設定
  #-----------------------------------------------------------------------
  # KMSキーID
  # 設定内容: 保存時の暗号化に使用するKMSキーのARN
  # 省略時: AWS管理のKMSキーを使用
  kms_key_id = "arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012"

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------
  # リージョン
  # 設定内容: リソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  region = "us-east-1"

  #-----------------------------------------------------------------------
  # ルートボリューム設定
  #-----------------------------------------------------------------------
  # ルートボリューム設定
  # root_volume_configuration {
  #   # データ圧縮タイプ
  #   # 設定内容: ボリュームデータの圧縮方式
  #   # 設定可能な値:
  #   #   - NONE: 圧縮なし
  #   #   - LZ4: LZ4圧縮
  #   #   - ZSTD: Zstandard圧縮
  #   # 補足: 子ボリュームは親ボリュームの設定を継承
  #   data_compression_type = "LZ4"
  #
  #   # レコードサイズ
  #   # 設定内容: OpenZFSルートボリュームのレコードサイズ（KiB）
  #   # 設定可能な値: 4, 8, 16, 32, 64, 128, 256, 512, 1024
  #   # 省略時: 128
  #   record_size_kib = 128
  #
  #   # 読み取り専用
  #   # 設定内容: ボリュームを読み取り専用にするかどうか
  #   # 省略時: false
  #   read_only = false
  #
  #   # スナップショットへのタグコピー
  #   # 設定内容: ファイルシステムのタグをスナップショットにコピーするかどうか
  #   # 省略時: false
  #   copy_tags_to_snapshots = false
  #
  #   # NFSエクスポート設定
  #   nfs_exports {
  #     # クライアント設定
  #     # 補足: 最大25個まで設定可能
  #     client_configurations {
  #       # クライアント
  #       # 設定内容: ファイルシステムをマウント可能なクライアント
  #       # 設定可能な値: ワイルドカード（*）、IPアドレス、CIDR（例: 192.0.2.0/24）
  #       # 省略時: ワイルドカード（*）
  #       clients = "*"
  #
  #       # マウントオプション
  #       # 設定内容: ファイルシステムマウント時のオプション（最大20個）
  #       # 省略時: crossmountとsyncを使用
  #       # 補足: Linux NFS exportsのマニュアルを参照
  #       options = ["rw", "crossmount", "sync"]
  #     }
  #   }
  #
  #   # ユーザー・グループクォータ
  #   # 補足: 最大100個まで設定可能
  #   user_and_group_quotas {
  #     # ID
  #     # 設定内容: ユーザーまたはグループのID
  #     # 設定可能な値: 0〜2147483647
  #     id = 1001
  #
  #     # ストレージ容量クォータ
  #     # 設定内容: ユーザーまたはグループが使用可能なストレージ容量（GiB）
  #     # 設定可能な値: 0〜2147483647
  #     storage_capacity_quota_gib = 100
  #
  #     # タイプ
  #     # 設定内容: クォータの適用対象
  #     # 設定可能な値:
  #     #   - USER: ユーザー
  #     #   - GROUP: グループ
  #     type = "USER"
  #   }
  # }

  #-----------------------------------------------------------------------
  # メンテナンス設定
  #-----------------------------------------------------------------------
  # 週次メンテナンス開始時刻
  # 設定内容: 週次メンテナンスの開始時刻（d:HH:MM形式、UTC）
  # 補足: dは曜日（1=月曜日、7=日曜日）
  weekly_maintenance_start_time = "1:03:00"

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------
  timeouts {
    # 作成タイムアウト
    # 設定内容: リソース作成時のタイムアウト時間
    # 省略時: 60m
    create = "60m"

    # 更新タイムアウト
    # 設定内容: リソース更新時のタイムアウト時間
    # 省略時: 60m
    update = "60m"

    # 削除タイムアウト
    # 設定内容: リソース削除時のタイムアウト時間
    # 省略時: 60m
    delete = "60m"
  }

  #-----------------------------------------------------------------------
  # タグ設定
  #-----------------------------------------------------------------------
  tags = {
    Name        = "example-fsx-openzfs"
    Environment = "production"
    ManagedBy   = "terraform"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照専用の属性）
#-----------------------------------------------------------------------
# 以下の属性はリソース作成後に参照可能です:
#
# arn                     : ファイルシステムのARN
# dns_name                : ファイルシステムのDNS名
# endpoint_ip_address     : エンドポイントのIPアドレス
# id                      : ファイルシステムID
# network_interface_ids   : ネットワークインターフェースIDセット
# owner_id                : 所有者のAWSアカウントID
# root_volume_id          : ルートボリュームID
# tags_all                : 全タグマップ
# vpc_id                  : VPC ID
#-----------------------------------------------------------------------
# 参照例:
#
# output "fsx_dns_name" {
#   value = aws_fsx_openzfs_file_system.example.dns_name
# }
#-----------------------------------------------------------------------
