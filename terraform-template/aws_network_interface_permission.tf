resource "aws_network_interface_permission" "example" {
  #-------------------------------------------------------------
  # ネットワークインターフェース設定
  #-------------------------------------------------------------

  # network_interface_id (Required)
  # 設定内容: アクセス許可を付与するネットワークインターフェースのIDを指定します。
  # 設定可能な値: 有効なネットワークインターフェースID (例: eni-0123456789abcdef0)
  network_interface_id = "eni-0123456789abcdef0"

  # aws_account_id (Required)
  # 設定内容: ネットワークインターフェースへのアクセスを許可するAWSアカウントIDを指定します。
  # 設定可能な値: 有効な12桁のAWSアカウントID
  # 関連機能: クロスアカウントアクセス
  #   このアカウントIDで識別されるAWSアカウントが、指定した許可を実行できるようになります。
  aws_account_id = "123456789012"

  # permission (Required)
  # 設定内容: 付与するアクセス許可の種類を指定します。
  # 設定可能な値:
  #   - "INSTANCE-ATTACH" : 別アカウントがネットワークインターフェースをEC2インスタンスにアタッチすることを許可します
  #   - "EIP-ASSOCIATE"   : 別アカウントがElastic IPアドレスをネットワークインターフェースに関連付けることを許可します
  permission = "INSTANCE-ATTACH"

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード (例: "ap-northeast-1")
  # 省略時: プロバイダー設定で指定されたリージョンが使用されます。
  region = "ap-northeast-1"

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソース作成のタイムアウト時間を指定します。
    # 設定可能な値: 期間文字列 (例: "30s", "5m", "1h")
    # 省略時: プロバイダーのデフォルト値が使用されます。
    create = "5m"

    # delete (Optional)
    # 設定内容: リソース削除のタイムアウト時間を指定します。
    # 設定可能な値: 期間文字列 (例: "30s", "5m", "1h")
    # 省略時: プロバイダーのデフォルト値が使用されます。
    delete = "5m"
  }
}

