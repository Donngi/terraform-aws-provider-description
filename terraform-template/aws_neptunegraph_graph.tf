#---------------------------------------------------------------
# Amazon Neptune Analytics Graph
#---------------------------------------------------------------
#
# Neptune Analytics グラフをプロビジョニングします。
# Neptune Analytics は、大規模なグラフに対してインメモリで高速に
# グラフアルゴリズムを実行できるマネージド型のグラフ分析サービスです。
# openCypher 言語を使用したビジネスインテリジェンスやカスタム分析クエリ、
# 事前構築されたグラフアルゴリズムの実行が可能です。
#
# AWS公式ドキュメント:
#   - Neptune Analytics Features: https://docs.aws.amazon.com/neptune-analytics/latest/userguide/neptune-analytics-features.html
#   - Creating a new Neptune Analytics graph: https://docs.aws.amazon.com/neptune-analytics/latest/userguide/create-graph-using-console.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/neptunegraph_graph
#
# Provider Version: 6.28.0
# Generated: 2026-01-31
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_neptunegraph_graph" "example" {
  #---------------------------------------------------------------
  # 必須パラメータ
  #---------------------------------------------------------------

  # グラフに使用するメモリ最適化 Neptune Capacity Units (m-NCUs) を指定します。
  # グラフサイズに基づいて自動的に分析ワークロードに必要な
  # コンピューティングリソースがプロビジョニングされます。
  # 値は 128 から 1024 の範囲で指定します。
  provisioned_memory = 128

  #---------------------------------------------------------------
  # オプションパラメータ - グラフの識別と命名
  #---------------------------------------------------------------

  # グラフ名を指定します。例: my-graph-1
  # 1〜63文字の英字、数字、ハイフンを含めることができます。
  # 最初の文字は英字である必要があり、ハイフンで終わることはできません。
  # また、2つの連続するハイフンを含めることはできません。
  # 指定しない場合、graph-for プレフィックスにスタック名とUUIDの組み合わせで
  # 一意のグラフ名が自動生成されます。
  # graph_name と graph_name_prefix は同時に指定できません。
  graph_name = null

  # グラフ名のプレフィックスを指定し、残りの名前を自動生成します。
  # graph_name と graph_name_prefix は同時に指定できません。
  graph_name_prefix = null

  #---------------------------------------------------------------
  # オプションパラメータ - セキュリティと保護
  #---------------------------------------------------------------

  # グラフで削除保護が有効かどうかを示す値です。
  # 削除保護が有効な場合、グラフを削除できません。
  # デフォルトは true です。
  deletion_protection = true

  # 新しいグラフのデータを暗号化するために使用する KMS キーを指定します。
  # 値は KMS キーの ARN である必要があります。
  # 例: arn:aws:kms:us-east-1:123456789012:key/12345678-1234-1234-1234-123456789012
  kms_key_identifier = null

  #---------------------------------------------------------------
  # オプションパラメータ - ネットワークと可用性
  #---------------------------------------------------------------

  # グラフがインターネット経由で到達可能かどうかを指定します。
  # すべてのグラフへのアクセスは IAM 認証されます。
  # グラフが公開されている場合、そのドメインネームシステム(DNS)エンドポイントは
  # インターネットからのパブリック IP アドレスに解決されます。
  # グラフが公開されていない場合、DNS 名が VPC から到達可能なプライベート IP
  # アドレスに解決されるように、指定された VPC に PrivateGraphEndpoint を
  # 作成する必要があります。
  public_connectivity = false

  # 他のアベイラビリティーゾーンのレプリカ数を指定します。
  # 値は 0 から 2 の範囲で指定します。
  # レプリカを使用することで、高可用性と読み取りスケーラビリティを向上できます。
  replica_count = 0

  # このリソースが管理されるリージョンを指定します。
  # デフォルトはプロバイダー設定で設定されたリージョンになります。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #---------------------------------------------------------------
  # オプションパラメータ - タグ
  #---------------------------------------------------------------

  # グラフに割り当てるタグのマップです。
  # リソースの整理、コスト追跡、アクセス制御などに使用できます。
  tags = {
    Environment = "Development"
    ManagedBy   = "Terraform"
  }

  #---------------------------------------------------------------
  # ネストブロック - ベクトル検索設定
  #---------------------------------------------------------------

  # Neptune Graph のベクトル検索設定を指定します。
  # ベクトル埋め込みを使用した類似性検索やレコメンデーションシステムに使用します。
  vector_search_configuration {
    # ベクトル埋め込みの次元数を指定します。
    # 値は 1 から 65,535 の範囲で指定します。
    # 一般的な値は 128, 256, 512, 1024 などです。
    # 使用する機械学習モデルの出力次元に合わせて設定してください。
    vector_search_dimension = 128
  }

  #---------------------------------------------------------------
  # ネストブロック - タイムアウト設定
  #---------------------------------------------------------------

  # リソース操作のタイムアウト設定を指定します。
  timeouts {
    # グラフ作成時のタイムアウトを指定します。
    # 例: "30s", "2h45m"
    # 有効な時間単位: "s"(秒), "m"(分), "h"(時間)
    create = null

    # グラフ更新時のタイムアウトを指定します。
    # 例: "30s", "2h45m"
    update = null

    # グラフ削除時のタイムアウトを指定します。
    # 例: "30s", "2h45m"
    # destroy 操作の前に変更が state に保存される場合にのみ適用されます。
    delete = null
  }
}

