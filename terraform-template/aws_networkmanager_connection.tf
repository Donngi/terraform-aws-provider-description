resource "aws_networkmanager_connection" "example" {
  #-------------------------------------------------------------
  # グローバルネットワーク設定
  #-------------------------------------------------------------

  # global_network_id (Required)
  # 設定内容: 接続が所属するグローバルネットワークのIDを指定します。
  # 設定可能な値: 有効なグローバルネットワークID文字列
  global_network_id = "network-1234567890abcdef0"

  #-------------------------------------------------------------
  # デバイス設定
  #-------------------------------------------------------------

  # device_id (Required)
  # 設定内容: 接続における1台目のデバイスのIDを指定します。
  # 設定可能な値: 有効なデバイスID文字列
  device_id = "device-1234567890abcdef0"

  # connected_device_id (Required)
  # 設定内容: 接続における2台目のデバイスのIDを指定します。
  # 設定可能な値: 有効なデバイスID文字列
  connected_device_id = "device-0fedcba9876543210"

  #-------------------------------------------------------------
  # リンク設定
  #-------------------------------------------------------------

  # link_id (Optional)
  # 設定内容: 1台目のデバイスに関連付けるリンクのIDを指定します。
  # 設定可能な値: 有効なリンクID文字列
  # 省略時: リンクは関連付けられません。
  link_id = null

  # connected_link_id (Optional)
  # 設定内容: 2台目のデバイスに関連付けるリンクのIDを指定します。
  # 設定可能な値: 有効なリンクID文字列
  # 省略時: リンクは関連付けられません。
  connected_link_id = null

  #-------------------------------------------------------------
  # 説明設定
  #-------------------------------------------------------------

  # description (Optional)
  # 設定内容: 接続の説明を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なしで作成されます。
  description = "接続の説明"

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなしで作成されます。
  # 注意: プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "example-connection"
    Environment = "production"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソースの作成完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    create = "30m"

    # update (Optional)
    # 設定内容: リソースの更新完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    update = "30m"

    # delete (Optional)
    # 設定内容: リソースの削除完了を待機する最大時間を指定します。
    # 設定可能な値: Goのtime.Duration形式の文字列（例: "30m", "1h"）
    # 省略時: プロバイダーのデフォルトタイムアウトが使用されます。
    delete = "30m"
  }
}

