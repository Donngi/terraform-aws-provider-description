#-----------------------------------------------------------------------
# Amazon DocumentDB クラスターインスタンス
#-----------------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-14
#
# Amazon DocumentDBクラスター内の個別のデータベースインスタンスを管理します。
# DocumentDBは、MongoDBワークロード向けに設計された高速かつ拡張可能な
# フルマネージド型ドキュメントデータベースサービスです。
#
# 主な用途:
#   - MongoDBワークロードのマネージド環境での実行
#   - 高可用性を実現するためのマルチAZ配置
#   - リードレプリカによる読み取りスケーリング
#   - JSONドキュメントの保存と検索
#
# 制約事項:
#   - cluster_identifierで指定されたクラスターが事前に存在する必要がある
#   - インスタンスの停止機能はなく、削除のみ可能
#   - リージョン内のAZに配置される（グローバルデータベースは別リソース）
#   - ストレージ暗号化の有効/無効はクラスターレベルで決定される
#
# 関連リソース:
#   - aws_docdb_cluster: DocumentDBクラスター本体
#   - aws_docdb_cluster_parameter_group: クラスターパラメータグループ
#   - aws_docdb_subnet_group: サブネットグループ
#   - aws_docdb_cluster_snapshot: クラスタースナップショット
#
# 参考ドキュメント:
#   - https://docs.aws.amazon.com/documentdb/latest/developerguide/what-is.html
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/docdb_cluster_instance
#
# NOTE: identifier_prefixはコメントアウトされていますが、identifierの代わりに
#       使用することで、Terraformがユニークな識別子を自動生成できます。
#-----------------------------------------------------------------------

#----------------------------------------------------------------------
# 基本設定
#----------------------------------------------------------------------
resource "aws_docdb_cluster_instance" "example" {
  # 設定内容: このインスタンスが属するDocumentDBクラスターの識別子
  # 省略時: エラー（必須）
  cluster_identifier = "my-docdb-cluster"

  # 設定内容: インスタンスの一意な識別子（最大63文字、英小文字・数字・ハイフン）
  # 省略時: Terraformが自動生成（identifier_prefixが未設定の場合）
  # 注意: identifierとidentifier_prefixは排他的（両方設定不可）
  identifier = "my-docdb-instance-1"

  # 設定内容: インスタンス識別子のプレフィックス（Terraformが残りを自動生成）
  # 省略時: null
  identifier_prefix = "docdb-"

  # 設定内容: インスタンスのコンピュートとメモリ容量を定義するクラス
  # 設定可能な値: db.t3.medium, db.r5.large, db.r5.xlarge, db.r5.2xlarge など
  # 省略時: エラー（必須）
  instance_class = "db.t3.medium"

  # 設定内容: このインスタンスが使用するデータベースエンジン
  # 設定可能な値: "docdb"（現時点でこの値のみサポート）
  # 省略時: クラスターのエンジン設定を継承
  engine = "docdb"

  #----------------------------------------------------------------------
  # 可用性とネットワーク設定
  #----------------------------------------------------------------------
  # 設定内容: インスタンスをデプロイするアベイラビリティゾーン
  # 省略時: AWSが自動選択
  # 注意: マルチAZ構成では各インスタンスを異なるAZに配置
  availability_zone = "ap-northeast-1a"

  # 設定内容: フェイルオーバー時の昇格優先度（0-15の整数、小さいほど優先）
  # 省略時: 0（最高優先度）
  # 注意: 同じ優先度の場合はインスタンスサイズが大きい方が優先される
  promotion_tier = 0

  #----------------------------------------------------------------------
  # メンテナンスとアップグレード設定
  #----------------------------------------------------------------------
  # 設定内容: マイナーバージョンの自動アップグレードを有効化
  # 設定可能な値: true（自動）/ false（手動）
  # 省略時: true
  auto_minor_version_upgrade = true

  # 設定内容: メンテナンスウィンドウの開始時刻（UTC、ddd:hh24:mi-ddd:hh24:mi形式）
  # 省略時: クラスターのメンテナンスウィンドウ設定を継承
  # 例: "mon:03:00-mon:04:00"
  preferred_maintenance_window = "sun:18:00-sun:19:00"

  # 設定内容: 変更を次のメンテナンスウィンドウではなく即座に適用
  # 設定可能な値: true（即座）/ false（次回メンテナンス時）
  # 省略時: false
  # 注意: 一部の変更は再起動を伴うためダウンタイムが発生
  apply_immediately = false

  #----------------------------------------------------------------------
  # セキュリティとモニタリング設定
  #----------------------------------------------------------------------
  # 設定内容: CA証明書の識別子
  # 省略時: デフォルトのCA証明書を使用
  # 注意: クラスター作成後の変更は再起動を伴う
  ca_cert_identifier = "rds-ca-rsa2048-g1"

  # 設定内容: Performance Insightsを有効化
  # 設定可能な値: true（有効）/ false（無効）
  # 省略時: false
  enable_performance_insights = true

  # 設定内容: Performance Insightsデータの暗号化に使用するKMSキーID
  # 省略時: デフォルトのRDS KMSキーを使用
  # 注意: enable_performance_insights = true の場合のみ有効
  performance_insights_kms_key_id = "arn:aws:kms:ap-northeast-1:123456789012:key/abcd1234-a123-456a-a12b-a123b4cd56ef"

  #----------------------------------------------------------------------
  # バックアップとタグ設定
  #----------------------------------------------------------------------
  # 設定内容: インスタンスのタグをスナップショットにコピー
  # 設定可能な値: true（コピー）/ false（コピーしない）
  # 省略時: false
  copy_tags_to_snapshot = true

  # 設定内容: リソースに割り当てるタグのマップ
  # 省略時: タグなし
  tags = {
    Name        = "my-docdb-instance"
    Environment = "production"
    Application = "api-backend"
  }

  #----------------------------------------------------------------------
  # リージョン設定
  #----------------------------------------------------------------------
  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: クラスターと同じリージョンである必要がある
  region = "ap-northeast-1"

  #----------------------------------------------------------------------
  # タイムアウト設定
  #----------------------------------------------------------------------
  timeouts {
    # 設定内容: インスタンス作成のタイムアウト時間
    # 省略時: 90分
    create = "90m"

    # 設定内容: インスタンス更新のタイムアウト時間
    # 省略時: 90分
    update = "90m"

    # 設定内容: インスタンス削除のタイムアウト時間
    # 省略時: 90分
    delete = "90m"
  }
}

#-----------------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#-----------------------------------------------------------------------
# このリソースをデプロイした後、以下の属性を参照できます。
#
# arn                      - インスタンスのARN（Amazon Resource Name）
# dbi_resource_id          - リージョン固有の不変識別子（DBI Resource ID）
# endpoint                 - インスタンスへの接続エンドポイント（ホスト名）
# engine_version           - 実際に実行されているデータベースエンジンバージョン
# id                       - インスタンスの識別子（identifierと同値）
# identifier               - インスタンスの一意な識別子（入力値またはTerraform生成）
# identifier_prefix        - インスタンス識別子のプレフィックス（入力値または計算値）
# kms_key_id              - ストレージ暗号化に使用されるKMSキーのARN
# port                     - データベース接続ポート番号（デフォルト: 27017）
# preferred_backup_window  - 日次自動バックアップの実行時間帯（UTC）
# publicly_accessible      - インスタンスがパブリックアクセス可能か
# storage_encrypted        - ストレージが暗号化されているか
# writer                   - このインスタンスがクラスターの書き込みインスタンスか
# db_subnet_group_name     - インスタンスが属するDBサブネットグループ名
# tags_all                 - プロバイダーのdefault_tagsとリソースのtagsをマージした結果
#-----------------------------------------------------------------------
