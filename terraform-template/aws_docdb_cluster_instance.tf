#-----------------------------------------------------------------------
# Terraform AWS DocumentDB クラスターインスタンス リソーステンプレート
#-----------------------------------------------------------------------
# Provider Version: 6.36.0
# Resource Type: aws_docdb_cluster_instance
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.36.0/docs/resources/docdb_cluster_instance
# Generated: 2026-03-18
#
# NOTE: このテンプレートは実際の使用前に必ず内容を確認・調整してください
#-----------------------------------------------------------------------
# 【概要】
# Amazon DocumentDB クラスター内の個別のデータベースインスタンスを管理します。
# DocumentDBはMongoDBワークロード向けに設計された高速かつ拡張可能な
# フルマネージド型ドキュメントデータベースサービスです。
#
# 【主な機能】
# - クラスター内の個別インスタンスのコンピュートとメモリ容量を管理
# - フェイルオーバー優先度による自動昇格制御
# - Performance Insightsによるパフォーマンスモニタリング
# - マルチAZ配置による高可用性構成
# - メンテナンスウィンドウの柔軟な設定
#
# 【使用上の注意】
# - cluster_identifierで指定されたクラスターが事前に存在する必要がある
# - プライマリ/レプリカの指定は不要（DocumentDBが自動管理）
# - countメタ引数で複数インスタンスを同一クラスターに参加可能
# - ストレージ暗号化の有効/無効はクラスターレベルで決定される
# - identifierとidentifier_prefixは排他的（両方同時に設定不可）
#
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# 基本設定
#-----------------------------------------------------------------------

resource "aws_docdb_cluster_instance" "example" {
  # 設定内容: このインスタンスが属するDocumentDBクラスターの識別子
  # 省略時: エラー（必須）
  cluster_identifier = "my-docdb-cluster"

  # 設定内容: インスタンスの一意な識別子（最大63文字、英小文字・数字・ハイフン）
  # 省略時: Terraformが自動生成（identifier_prefixが未設定の場合）
  # 注意: identifierとidentifier_prefixは排他的（両方設定不可）。変更時は再作成。
  identifier = "my-docdb-instance-1"

  # 設定内容: インスタンス識別子のプレフィックス（Terraformが残りを自動生成）
  # 省略時: null（identifierが優先される）
  # 注意: 変更時はリソースの再作成が発生
  # identifier_prefix = "docdb-"

  # 設定内容: インスタンスのコンピュートとメモリ容量を定義するクラス
  # 設定可能な値: db.t3.medium, db.r5.large, db.r5.xlarge, db.r5.2xlarge, db.r6g.large, db.serverless など
  # 省略時: エラー（必須）
  instance_class = "db.r5.large"

  # 設定内容: このインスタンスが使用するデータベースエンジン
  # 設定可能な値: "docdb"（現時点でこの値のみサポート）
  # 省略時: "docdb"
  engine = "docdb"

  #-----------------------------------------------------------------------
  # 可用性とネットワーク設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスをデプロイするアベイラビリティゾーン
  # 省略時: AWSが自動選択
  # 注意: マルチAZ構成では各インスタンスを異なるAZに配置することを推奨
  availability_zone = "ap-northeast-1a"

  # 設定内容: フェイルオーバー時の昇格優先度
  # 設定可能な値: 0-15の整数（小さいほど優先度が高い）
  # 省略時: 0（最高優先度）
  # 注意: 同じ優先度の場合はインスタンスサイズが大きい方が優先される
  promotion_tier = 0

  #-----------------------------------------------------------------------
  # メンテナンスとアップグレード設定
  #-----------------------------------------------------------------------

  # 設定内容: マイナーバージョンの自動アップグレード設定
  # 設定可能な値: true / false
  # 省略時: true
  # 注意: Amazon DocumentDBはこの値に関係なくマイナーバージョンの自動アップグレードを行わない
  auto_minor_version_upgrade = true

  # 設定内容: メンテナンスウィンドウの時間帯（UTC）
  # 設定可能な値: ddd:hh24:mi-ddd:hh24:mi形式（例: "Mon:00:00-Mon:03:00"）
  # 省略時: AWSが自動的に時間帯を選択
  preferred_maintenance_window = "sun:18:00-sun:19:00"

  # 設定内容: 変更を次のメンテナンスウィンドウではなく即座に適用するか
  # 設定可能な値: true（即座に適用）/ false（次回メンテナンス時）
  # 省略時: false
  # 注意: 一部の変更は再起動を伴うためダウンタイムが発生する可能性あり
  apply_immediately = false

  #-----------------------------------------------------------------------
  # セキュリティとモニタリング設定
  #-----------------------------------------------------------------------

  # 設定内容: CA証明書の識別子
  # 省略時: デフォルトのCA証明書を使用
  # 注意: 証明書の変更は再起動を伴う場合がある
  ca_cert_identifier = "rds-ca-rsa2048-g1"

  # 設定内容: CA証明書ローテーション後にインスタンスを再起動するかどうか
  # 設定可能な値: 任意の文字列（設定するとローテーション適用のため再起動がトリガーされる）
  # 省略時: null（自動再起動しない）
  # certificate_rotation_restart = null

  # 設定内容: Performance Insightsを有効化
  # 設定可能な値: true（有効）/ false（無効）
  # 省略時: false
  enable_performance_insights = true

  # 設定内容: Performance Insightsデータの暗号化に使用するKMSキーID
  # 省略時: デフォルトのRDS KMSキーを使用
  # 注意: enable_performance_insights = true の場合のみ有効
  performance_insights_kms_key_id = "arn:aws:kms:ap-northeast-1:123456789012:key/abcd1234-a123-456a-a12b-a123b4cd56ef"

  #-----------------------------------------------------------------------
  # バックアップとタグ設定
  #-----------------------------------------------------------------------

  # 設定内容: インスタンスのタグをスナップショットにコピー
  # 設定可能な値: true（コピーする）/ false（コピーしない）
  # 省略時: false
  copy_tags_to_snapshot = true

  # 設定内容: リソースに割り当てるタグのマップ
  # 省略時: タグなし
  tags = {
    Name        = "my-docdb-instance"
    Environment = "production"
    ManagedBy   = "Terraform"
  }

  #-----------------------------------------------------------------------
  # リージョン設定
  #-----------------------------------------------------------------------

  # 設定内容: このリソースを管理するAWSリージョン
  # 省略時: プロバイダー設定のリージョンを使用
  # 注意: クラスターと同じリージョンである必要がある
  # region = "ap-northeast-1"

  #-----------------------------------------------------------------------
  # タイムアウト設定
  #-----------------------------------------------------------------------

  # timeouts {
  #   # 設定内容: インスタンス作成の最大待機時間
  #   # 省略時: 90m
  #   create = "90m"
  #
  #   # 設定内容: インスタンス更新の最大待機時間
  #   # 省略時: 90m
  #   update = "90m"
  #
  #   # 設定内容: インスタンス削除の最大待機時間
  #   # 省略時: 90m
  #   delete = "90m"
  # }
}

#-----------------------------------------------------------------------
# Attributes Reference (参照可能な属性)
#-----------------------------------------------------------------------
# このリソースでは以下の属性が参照可能です:
#
# - arn: インスタンスのARN
# - dbi_resource_id: リージョン固有の不変識別子
# - endpoint: インスタンスへの接続エンドポイント
# - engine_version: 実行中のエンジンバージョン
# - kms_key_id: ストレージ暗号化に使用されるKMSキーARN
# - port: データベース接続ポート番号（デフォルト: 27017）
# - preferred_backup_window: 日次自動バックアップの実行時間帯
# - publicly_accessible: パブリックアクセス可能かどうか
# - storage_encrypted: ストレージが暗号化されているか
# - writer: 書き込みインスタンスかどうか
# - db_subnet_group_name: DBサブネットグループ名
# - tags_all: default_tagsとtagsをマージした全タグ
#-----------------------------------------------------------------------
