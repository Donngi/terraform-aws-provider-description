#---------------------------------------------------------------
# Amazon IVS Chat Room
#---------------------------------------------------------------
#
# Amazon IVS (Interactive Video Service) Chatのチャットルームをプロビジョニングするリソースです。
# チャットルームは、ライブビデオストリームと組み合わせて、またはスタンドアロンで
# リアルタイムのメッセージングを提供するマネージドチャット機能です。
# メッセージの最大文字数・送信レートの制御や、Lambdaを使用したメッセージレビュー、
# ロギング設定のアタッチが可能です。
#
# AWS公式ドキュメント:
#   - Amazon IVS Chat チャットルームの作成: https://docs.aws.amazon.com/ivs/latest/ChatUserGuide/getting-started-chat.html
#   - Amazon IVS Chat コンソールでのチャットルーム作成: https://docs.aws.amazon.com/ivs/latest/ChatUserGuide/create-room-console.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/ivschat_room
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_ivschat_room" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Optional)
  # 設定内容: チャットルームの名前を指定します。
  # 設定可能な値: 文字列
  # 省略時: 名前なしでチャットルームが作成されます。
  name = "tf-room"

  #-------------------------------------------------------------
  # メッセージ制御設定
  #-------------------------------------------------------------

  # maximum_message_length (Optional)
  # 設定内容: 1つのメッセージの最大文字数を指定します。
  #           メッセージはUTF-8エンコードであることが前提で、バイト数ではなく
  #           ルーン/コードポイント数に制限が適用されます。
  # 設定可能な値: 数値（文字数）
  # 省略時: AWSのデフォルト値が適用されます。
  maximum_message_length = 500

  # maximum_message_rate_per_second (Optional)
  # 設定内容: チャットルームに対して（全クライアント合計で）1秒間に送信できる
  #           メッセージの最大数を指定します。
  # 設定可能な値: 数値（メッセージ数/秒）
  # 省略時: AWSのデフォルト値が適用されます。
  maximum_message_rate_per_second = 10

  #-------------------------------------------------------------
  # ロギング設定
  #-------------------------------------------------------------

  # logging_configuration_identifiers (Optional)
  # 設定内容: チャットルームにアタッチするロギング設定のARNのリストを指定します。
  #           ロギング設定はAmazon S3、Amazon CloudWatch Logs、
  #           Amazon Kinesis Data Firehoseへのメッセージ配信を設定します。
  # 設定可能な値: aws_ivschat_logging_configurationリソースのARNのリスト
  # 省略時: ロギング設定はアタッチされません。
  logging_configuration_identifiers = []

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するAWSリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用します。
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # メッセージレビュー設定
  #-------------------------------------------------------------

  # message_review_handler (Optional)
  # 設定内容: メッセージの任意レビューの設定情報を指定します。
  #           Lambdaを使用してメッセージの内容を確認・フィルタリングできます。
  message_review_handler {
    # fallback_result (Optional)
    # 設定内容: ハンドラーが有効なレスポンスを返さない、エラーが発生する、
    #           またはタイムアウトした場合のフォールバック動作（メッセージを許可するか拒否するか）を指定します。
    # 設定可能な値:
    #   - "ALLOW": メッセージを許可する
    #   - "DENY": メッセージを拒否する
    # 省略時: AWSのデフォルト値（ALLOW）が適用されます。
    fallback_result = "ALLOW"

    # uri (Optional)
    # 設定内容: Lambdaメッセージレビューハンドラー関数のARNを指定します。
    # 設定可能な値: aws_lambda_functionリソースのARN
    # 省略時: メッセージレビューハンドラーは設定されません。
    uri = "arn:aws:lambda:ap-northeast-1:123456789012:function:my-message-review-handler"
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: チャットルームの作成操作のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" のようなGoの時間文字列
    # 省略時: プロバイダーのデフォルトタイムアウトが適用されます。
    create = "30m"

    # update (Optional)
    # 設定内容: チャットルームの更新操作のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" のようなGoの時間文字列
    # 省略時: プロバイダーのデフォルトタイムアウトが適用されます。
    update = "30m"

    # delete (Optional)
    # 設定内容: チャットルームの削除操作のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" のようなGoの時間文字列
    # 省略時: プロバイダーのデフォルトタイムアウトが適用されます。
    delete = "30m"
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグは設定されません。
  # 注意: プロバイダーレベルのdefault_tags設定ブロックで定義されたタグと
  #       一致するキーを持つタグは、プロバイダーレベルで定義されたものを上書きします。
  tags = {
    Name        = "tf-room"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: チャットルームのAmazon Resource Name (ARN)
#
# - id: チャットルームのID
#
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ。
#---------------------------------------------------------------
