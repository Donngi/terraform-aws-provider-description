#--------------------------------------------------------------
# Amazon Connect コンタクトフローモジュール
#--------------------------------------------------------------
# Provider Version: 6.28.0
# Generated: 2026-02-13
# Terraform Registry: https://registry.terraform.io/providers/hashicorp/aws/6.28.0/docs/resources/connect_contact_flow_module
# NOTE: contentとfilenameは同時に指定不可
#
# 用途: Amazon Connectコンタクトセンター内で再利用可能なフローモジュールを作成
# 主な機能:
#   - 再利用可能なフローロジックの定義
#   - モジュール化されたコンタクトフロー構成要素の管理
#   - JSONベースのフロー定義またはファイルからの読み込み
#   - 複数のコンタクトフローから参照可能なモジュール作成
#
# 制限事項:
#   - Amazon Connectインスタンスが必要
#   - フロー定義はAmazon Connect仕様に準拠したJSON形式が必須
#   - contentとfilenameは同時に指定できない
#
# 関連リソース:
#   - aws_connect_instance: 親となるConnectインスタンス
#   - aws_connect_contact_flow: フローモジュールを利用するコンタクトフロー
#--------------------------------------------------------------

resource "aws_connect_contact_flow_module" "example" {
  #---------------------------------------
  # 必須設定
  #---------------------------------------
  # 設定内容: Connectインスタンスの一意識別子
  # 形式: インスタンスID（例: "12345678-1234-1234-1234-123456789012"）
  instance_id = "12345678-1234-1234-1234-123456789012"

  # 設定内容: フローモジュールの一意名称
  # 制約: 1-127文字、英数字とアンダースコア・ハイフン使用可能
  name = "example-flow-module"

  #---------------------------------------
  # フロー定義設定
  #---------------------------------------
  # 設定内容: フローモジュールのJSON定義（インライン指定）
  # 形式: Amazon Connect仕様準拠のJSON文字列
  # 注意: filenameと同時指定不可
  # 省略時: 空のフローモジュールとして作成される
  content = jsonencode({
    Version     = "2019-10-30"
    StartAction = "12345678-1234-1234-1234-123456789012"
    Actions = [
      {
        Identifier = "12345678-1234-1234-1234-123456789012"
        Type       = "MessageParticipant"
        Transitions = {
          NextAction = "EndFlowModuleExecution"
        }
        Parameters = {
          Text = "モジュールが実行されました"
        }
      }
    ]
  })

  #---------------------------------------
  # ファイルベース定義設定
  #---------------------------------------
  # 設定内容: フローモジュールのJSON定義ファイルパス
  # 形式: ローカルファイルパス（Terraformワークスペース基準の相対パスまたは絶対パス）
  # 注意: contentと同時指定不可
  # 省略時: contentによるインライン定義が必要
  filename = "flows/module.json"

  #---------------------------------------
  # 変更検知設定
  #---------------------------------------
  # 設定内容: フロー定義の変更検知用ハッシュ値
  # 用途: contentやfilename変更時の再デプロイトリガーとして使用
  # 推奨: filemd5()やmd5()関数で自動生成
  # 省略時: ハッシュ検証なし
  content_hash = filemd5("flows/module.json")

  #---------------------------------------
  # 説明・メタデータ設定
  #---------------------------------------
  # 設定内容: フローモジュールの説明文
  # 制約: 最大500文字
  # 省略時: 説明なし
  description = "顧客への自動応答を行う再利用可能なフローモジュール"

  #---------------------------------------
  # リージョン設定
  #---------------------------------------
  # 設定内容: リソースを管理するAWSリージョン
  # 設定可能な値: 標準AWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  region = "ap-northeast-1"

  #---------------------------------------
  # タグ設定
  #---------------------------------------
  # 設定内容: リソース管理用のタグ
  # 形式: キー=値のマップ
  # 用途: コスト配分、リソース分類、運用管理
  tags = {
    Name        = "example-flow-module"
    Environment = "production"
    Service     = "customer-support"
    ManagedBy   = "terraform"
  }
}

#--------------------------------------------------------------
# Attributes Reference（参照可能な属性）
#--------------------------------------------------------------
# このリソース作成後、以下の属性を他リソースから参照可能:
#
# - id: フローモジュールの一意識別子（<instance_id>:<contact_flow_module_id>形式）
# - arn: フローモジュールのARN
# - contact_flow_module_id: フローモジュールの一意ID
# - tags_all: デフォルトタグを含む全タグのマップ
# - content: 設定されたフロー定義JSON（contentまたはfilenameで指定された内容）
# - region: リソースが管理されているリージョン
