#---------------------------------------------------------------
# AWS Glue Trigger
#---------------------------------------------------------------
#
# AWS Glueのトリガーをプロビジョニングするリソースです。
# トリガーはGlueジョブやクローラーの実行を開始するためのイベントを定義します。
# オンデマンド・スケジュール・条件付き・イベントの4種類のトリガータイプを
# サポートし、ワークフロー内のジョブオーケストレーションに使用されます。
#
# AWS公式ドキュメント:
#   - AWS Glue トリガー: https://docs.aws.amazon.com/glue/latest/dg/trigger-job.html
#   - スケジュール式の構文: https://docs.aws.amazon.com/glue/latest/dg/monitor-data-warehouse-schedule.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/glue_trigger
#
# Provider Version: 6.28.0
# Generated: 2026-02-17
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_glue_trigger" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: トリガーの一意な名前を指定します。
  # 設定可能な値: 1-255文字の文字列。英数字、ハイフン、アンダースコアが使用可能
  name = "example-trigger"

  # type (Required)
  # 設定内容: トリガーの種類を指定します。
  # 設定可能な値:
  #   - "ON_DEMAND": 手動実行トリガー。APIやコンソールから手動で起動
  #   - "SCHEDULED": スケジュール実行トリガー。schedule属性でcron式を指定
  #   - "CONDITIONAL": 条件付きトリガー。predicate属性で他のジョブ/クローラーの状態を条件として指定
  #   - "EVENT": イベントトリガー。Amazon EventBridgeイベントに基づいて起動
  type = "SCHEDULED"

  # description (Optional)
  # 設定内容: トリガーの説明文を指定します。
  # 設定可能な値: 任意の文字列
  # 省略時: 説明なし
  description = "example trigger"

  #-------------------------------------------------------------
  # スケジュール設定
  #-------------------------------------------------------------

  # schedule (Optional)
  # 設定内容: スケジュール実行のcron式を指定します。type = "SCHEDULED" の場合に使用します。
  # 設定可能な値: cron式（例: "cron(15 12 * * ? *)"）
  # 省略時: スケジュールなし
  # 参考: https://docs.aws.amazon.com/glue/latest/dg/monitor-data-warehouse-schedule.html
  schedule = "cron(15 12 * * ? *)"

  #-------------------------------------------------------------
  # 有効化設定
  #-------------------------------------------------------------

  # enabled (Optional)
  # 設定内容: トリガーを有効化するかを指定します。
  # 設定可能な値:
  #   - true (デフォルト): トリガーを有効化して起動
  #   - false: トリガーを無効化
  # 省略時: true
  enabled = true

  # start_on_creation (Optional)
  # 設定内容: リソース作成時に SCHEDULED または CONDITIONAL トリガーを即座に開始するかを指定します。
  # 設定可能な値:
  #   - true: 作成直後にトリガーを開始
  #   - false: 作成後も停止状態を維持
  # 省略時: false
  # 注意: ON_DEMAND トリガーには true を指定できません
  start_on_creation = false

  #-------------------------------------------------------------
  # ワークフロー設定
  #-------------------------------------------------------------

  # workflow_name (Optional)
  # 設定内容: このトリガーを関連付けるGlueワークフローの名前を指定します。
  # 設定可能な値: 既存のGlueワークフロー名
  # 省略時: ワークフローへの関連付けなし
  # 注意: ワークフローグラフ（DAG）には開始トリガー（ON_DEMAND または SCHEDULED タイプ）が
  #       1つ必要で、追加のCONDITIONALトリガーを複数含めることができます
  workflow_name = null

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # アクション設定
  #-------------------------------------------------------------

  # actions (Required)
  # 設定内容: トリガーが発火したときに実行するジョブまたはクローラーのアクションリストを指定します。
  # 注意: job_name と crawler_name は排他的（どちらか一方のみ指定可能）
  actions {

    # job_name (Optional)
    # 設定内容: 実行するGlueジョブの名前を指定します。
    # 設定可能な値: 既存のGlueジョブ名
    # 注意: crawler_name と排他的（どちらか一方のみ指定可能）
    job_name = "example-job"

    # crawler_name (Optional)
    # 設定内容: 実行するGlueクローラーの名前を指定します。
    # 設定可能な値: 既存のGlueクローラー名
    # 注意: job_name と排他的（どちらか一方のみ指定可能）
    crawler_name = null

    # arguments (Optional)
    # 設定内容: ジョブに渡す引数のマップを指定します。
    # 設定可能な値: 文字列のキーバリューマップ
    # 省略時: 引数なし
    arguments = {}

    # timeout (Optional)
    # 設定内容: ジョブ実行のタイムアウト時間（分）を指定します。ジョブのデフォルトタイムアウトを上書きします。
    # 設定可能な値: 正の整数（分単位）
    # 省略時: ジョブに設定されたタイムアウト値を使用
    timeout = null

    # security_configuration (Optional)
    # 設定内容: このアクションで使用するセキュリティ設定の名前を指定します。
    # 設定可能な値: 既存のGlueセキュリティ設定名
    # 省略時: セキュリティ設定なし
    security_configuration = null

    #-----------------------------------------------------------
    # 通知プロパティ設定
    #-----------------------------------------------------------

    # notification_property (Optional)
    # 設定内容: ジョブ実行通知の設定ブロックを指定します。
    notification_property {

      # notify_delay_after (Optional)
      # 設定内容: ジョブ実行開始後、ジョブ実行遅延通知を送信するまでの待機時間（分）を指定します。
      # 設定可能な値: 正の整数（分単位）
      # 省略時: 通知遅延なし
      notify_delay_after = null
    }
  }

  #-------------------------------------------------------------
  # 述語設定（CONDITIONAL トリガー用）
  #-------------------------------------------------------------

  # predicate (Optional)
  # 設定内容: トリガーが発火する条件を定義する述語ブロックを指定します。
  # 設定可能な値: 1ブロックのみ指定可能
  # 注意: type = "CONDITIONAL" の場合は必須です
  predicate {

    # logical (Optional)
    # 設定内容: 複数条件の結合方法を指定します。
    # 設定可能な値:
    #   - "AND" (デフォルト): 全条件が満たされた場合に発火
    #   - "ANY": いずれか1つの条件が満たされた場合に発火
    # 省略時: "AND"
    logical = "AND"

    #---------------------------------------------------------
    # 条件設定
    #---------------------------------------------------------

    # conditions (Required)
    # 設定内容: トリガー発火の条件リストを指定します。
    # 注意: job_name と crawler_name は排他的（どちらか一方のみ指定可能）
    conditions {

      # job_name (Optional)
      # 設定内容: 監視対象のGlueジョブ名を指定します。
      # 設定可能な値: 既存のGlueジョブ名
      # 注意: state も同時に指定が必要。crawler_name と排他的
      job_name = "example-upstream-job"

      # state (Optional)
      # 設定内容: 条件とするジョブの実行状態を指定します。
      # 設定可能な値:
      #   - "SUCCEEDED": 正常完了
      #   - "STOPPED": 停止
      #   - "TIMEOUT": タイムアウト
      #   - "FAILED": 失敗
      # 注意: job_name も同時に指定が必要。crawl_state と排他的
      state = "SUCCEEDED"

      # crawler_name (Optional)
      # 設定内容: 監視対象のGlueクローラー名を指定します。
      # 設定可能な値: 既存のGlueクローラー名
      # 注意: crawl_state も同時に指定が必要。job_name と排他的
      crawler_name = null

      # crawl_state (Optional)
      # 設定内容: 条件とするクローラーの実行状態を指定します。
      # 設定可能な値:
      #   - "RUNNING": 実行中
      #   - "SUCCEEDED": 正常完了
      #   - "CANCELLED": キャンセル
      #   - "FAILED": 失敗
      # 注意: crawler_name も同時に指定が必要。state と排他的
      crawl_state = null

      # logical_operator (Optional)
      # 設定内容: 条件に使用する論理演算子を指定します。
      # 設定可能な値:
      #   - "EQUALS" (デフォルト): 指定した状態と一致する場合に条件を満たす
      # 省略時: "EQUALS"
      logical_operator = "EQUALS"
    }
  }

  #-------------------------------------------------------------
  # イベントバッチ条件設定（EVENT トリガー用）
  #-------------------------------------------------------------

  # event_batching_condition (Optional)
  # 設定内容: EventBridgeイベントトリガーが発火するためのバッチ条件を指定します。
  # 注意: type = "EVENT" の場合に使用します
  event_batching_condition {

    # batch_size (Required)
    # 設定内容: トリガーが発火するまでに受信する必要があるEventBridgeイベントの数を指定します。
    # 設定可能な値: 正の整数
    batch_size = 1

    # batch_window (Optional)
    # 設定内容: EventBridgeイベントトリガーが発火するまでの時間ウィンドウ（秒）を指定します。
    #           最初のイベントを受信した時点でウィンドウが開始します。
    # 設定可能な値: 正の整数（秒単位）
    # 省略時: 900（15分）
    batch_window = 900
  }

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  # timeouts (Optional)
  # 設定内容: リソース操作のタイムアウト時間を指定します。
  timeouts {

    # create (Optional)
    # 設定内容: リソース作成操作のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" などのGoのtime.Duration形式の文字列
    # 省略時: プロバイダーのデフォルト値を使用
    create = null

    # update (Optional)
    # 設定内容: リソース更新操作のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" などのGoのtime.Duration形式の文字列
    # 省略時: プロバイダーのデフォルト値を使用
    update = null

    # delete (Optional)
    # 設定内容: リソース削除操作のタイムアウト時間を指定します。
    # 設定可能な値: "30m", "1h" などのGoのtime.Duration形式の文字列
    # 省略時: プロバイダーのデフォルト値を使用
    delete = null
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに割り当てるタグのマップを指定します。
  # 設定可能な値: キーと値のペアのマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-trigger"
    Environment = "production"
  }
}

#---------------------------------------------------------------
# Attributes Reference (読み取り専用属性)
#---------------------------------------------------------------
# このリソースは以下の属性をエクスポートします:
#
# - arn: GlueトリガーのAmazon Resource Name (ARN)
# - id: トリガー名
# - state: トリガーの現在の状態
# - tags_all: プロバイダーのdefault_tags設定ブロックから継承されたタグを含む、
#             リソースに割り当てられたすべてのタグのマップ
#---------------------------------------------------------------
