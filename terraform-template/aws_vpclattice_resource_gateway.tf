#---------------------------------------------------------------
# AWS VPC Lattice Resource Gateway
#---------------------------------------------------------------
#
# Amazon VPC Latticeのリソースゲートウェイをプロビジョニングするリソースです。
# リソースゲートウェイは、VPC Lattice サービスネットワークと
# VPC内のターゲットリソース（RDS、ELBなど）の間の通信を仲介します。
# サービスネットワークに登録されたリソースへのトラフィックを
# 特定のVPCのサブネット経由でルーティングするために使用します。
#
# AWS公式ドキュメント:
#   - VPC Lattice リソースゲートウェイ: https://docs.aws.amazon.com/vpc-lattice/latest/ug/resource-gateways.html
#   - VPC Lattice リソース設定: https://docs.aws.amazon.com/vpc-lattice/latest/ug/resource-configurations.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/vpclattice_resource_gateway
#
# Provider Version: 6.28.0
# Generated: 2026-02-19
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_vpclattice_resource_gateway" "example" {
  #-------------------------------------------------------------
  # 基本設定
  #-------------------------------------------------------------

  # name (Required)
  # 設定内容: リソースゲートウェイの名前を指定します。
  # 設定可能な値: 文字列（3〜63文字、英数字とハイフンのみ）
  name = "example-resource-gateway"

  # vpc_id (Required)
  # 設定内容: リソースゲートウェイを作成するVPCのIDを指定します。
  # 設定可能な値: 有効なVPC ID（例: vpc-xxxxxxxx）
  # 関連機能: VPC Lattice リソースゲートウェイ
  #   このVPC内のサブネットにENIが作成され、
  #   VPC Lattice サービスネットワーク経由でリソースへのトラフィックを
  #   ルーティングします。
  vpc_id = aws_vpc.example.id

  # subnet_ids (Required)
  # 設定内容: リソースゲートウェイのENIを配置するサブネットIDのセットを指定します。
  # 設定可能な値: 有効なサブネットIDのセット（複数指定可能）
  # 注意: 指定するサブネットは vpc_id で指定したVPCに属している必要があります。
  #       高可用性のため、複数のAZにまたがるサブネットを指定することを推奨します。
  subnet_ids = [
    aws_subnet.example_a.id,
    aws_subnet.example_c.id,
  ]

  #-------------------------------------------------------------
  # ネットワーク設定
  #-------------------------------------------------------------

  # ip_address_type (Optional)
  # 設定内容: リソースゲートウェイのIPアドレスタイプを指定します。
  # 設定可能な値: "IPV4" | "IPV6" | "DUALSTACK"
  # 省略時: AWSのデフォルト値が使用されます（通常 "IPV4"）
  ip_address_type = "IPV4"

  # ipv4_addresses_per_eni (Optional)
  # 設定内容: ENIあたりに割り当てるIPv4アドレスの数を指定します。
  # 設定可能な値: 正の整数
  # 省略時: AWSのデフォルト値が使用されます
  # 注意: この設定はリソースゲートウェイのスループットに影響します。
  ipv4_addresses_per_eni = null

  # security_group_ids (Optional)
  # 設定内容: リソースゲートウェイに関連付けるセキュリティグループIDのセットを指定します。
  # 設定可能な値: 有効なセキュリティグループIDのセット
  # 省略時: AWSのデフォルトのセキュリティグループが使用されます
  # 注意: セキュリティグループは vpc_id で指定したVPCに属している必要があります。
  security_group_ids = [
    aws_security_group.example.id,
  ]

  #-------------------------------------------------------------
  # リージョン設定
  #-------------------------------------------------------------

  # region (Optional)
  # 設定内容: このリソースを管理するリージョンを指定します。
  # 設定可能な値: 有効なAWSリージョンコード（例: ap-northeast-1, us-east-1）
  # 省略時: プロバイダー設定のリージョンを使用
  # 参考: https://docs.aws.amazon.com/general/latest/gr/rande.html#regional-endpoints
  region = null

  #-------------------------------------------------------------
  # タイムアウト設定
  #-------------------------------------------------------------

  timeouts {
    # create (Optional)
    # 設定内容: リソース作成のタイムアウト時間を指定します。
    # 設定可能な値: 時間を表す文字列（例: "30s", "5m", "1h30m"）
    # 省略時: プロバイダーのデフォルト値を使用
    create = null

    # update (Optional)
    # 設定内容: リソース更新のタイムアウト時間を指定します。
    # 設定可能な値: 時間を表す文字列（例: "30s", "5m", "1h30m"）
    # 省略時: プロバイダーのデフォルト値を使用
    update = null

    # delete (Optional)
    # 設定内容: リソース削除のタイムアウト時間を指定します。
    # 設定可能な値: 時間を表す文字列（例: "30s", "5m", "1h30m"）
    # 省略時: プロバイダーのデフォルト値を使用
    delete = null
  }

  #-------------------------------------------------------------
  # タグ設定
  #-------------------------------------------------------------

  # tags (Optional)
  # 設定内容: リソースに付与するタグをキーと値のマップで指定します。
  # 設定可能な値: 文字列のキーと値のマップ
  # 省略時: タグなし
  tags = {
    Name        = "example-resource-gateway"
    Environment = "production"
  }
}

