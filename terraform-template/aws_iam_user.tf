#---------------------------------------------------------------
# IAM User
#---------------------------------------------------------------
#
# AWS Identity and Access Management (IAM) ユーザーをプロビジョニングします。
# IAM ユーザーは、AWS アカウント内で作成されるエンティティで、人間のユーザーまたは
# AWS リソースと対話するワークロードを表します。IAM ユーザーは、名前と認証情報で構成され、
# コンソールパスワード、アクセスキー、SSH キー、またはサーバー証明書を使用して
# AWS にアクセスできます。
#
# AWS公式ドキュメント:
#   - IAM users: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_users.html
#
# Terraform Registry:
#   - https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/iam_user
#
# Provider Version: 6.28.0
# Generated: 2026-01-27
# NOTE: 本テンプレートは生成時点の情報に基づきAIが生成しています。
#       情報が古くなっている可能性、誤りを含む可能性があるため、
#       正確な最新仕様は公式ドキュメントを参照してください。
#
#---------------------------------------------------------------

resource "aws_iam_user" "example" {
  #---------------------------------------------------------------
  # Required Parameters
  #---------------------------------------------------------------

  # ユーザーの名前
  # 大文字小文字の英数字（スペースなし）で構成する必要があります。
  # 以下の文字も含めることができます: =,.@-_.
  # ユーザー名は大文字小文字を区別しません。たとえば、"TESTUSER" と "testuser" の
  # 両方を作成することはできません。
  name = "example-user"

  #---------------------------------------------------------------
  # Optional Parameters
  #---------------------------------------------------------------

  # リソースの ID
  # optional かつ computed 属性です。
  # 通常は Terraform が自動的に生成しますが、明示的に設定することも可能です。
  # 設定しない場合、ユーザー名（name）と同じ値になります。
  id = null

  # ユーザーを作成するパス
  # デフォルト: "/"
  # パスは IAM ユーザーを階層的に整理するために使用できます。
  # 例: "/division_abc/subdivision_xyz/"
  path = "/system/"

  # ユーザーのアクセス許可境界として使用されるポリシーの ARN
  # アクセス許可境界は、アイデンティティベースのポリシーによって IAM エンティティに
  # 付与できる最大アクセス許可を定義する高度な機能です。
  # 例: "arn:aws:iam::aws:policy/PowerUserAccess"
  permissions_boundary = null

  # このユーザーを削除する際、Terraform で管理されていない IAM アクセスキー、
  # ログインプロファイル、または MFA デバイスが存在する場合でも削除します
  # デフォルト: false
  # 注意: force_destroy を false にした場合、Terraform で管理されていないアクセスキーや
  # ログインプロファイルが存在するユーザーは削除に失敗します。
  # ポリシーが aws_iam_policy_attachment リソース経由で添付されており、ユーザー名や
  # パスを変更する場合は、force_destroy を true に設定してから操作を実行する必要があります。
  force_destroy = false

  # IAM ユーザーのキーと値のマップ形式のタグ
  # プロバイダーで default_tags 設定ブロックが設定されている場合、
  # 一致するキーを持つタグはプロバイダーレベルで定義されたものを上書きします。
  tags = {
    Environment = "production"
    Team        = "platform"
  }

  # タグ（プロバイダーの default_tags から継承されたものを含む）のマップ
  # 通常は computed 属性ですが、明示的に設定することも可能です。
  # ただし、一般的には tags パラメータを使用し、tags_all は読み取り専用として扱うことを推奨します。
  tags_all = null
}

#---------------------------------------------------------------
# Attributes Reference
#---------------------------------------------------------------
# 以下の属性は computed only であり、リソース作成後に参照可能です:
#
# - arn: AWS によって割り当てられたユーザーの ARN
# - unique_id: AWS によって割り当てられた一意の ID
# - id: ユーザーの名前（name と同じ値）
#
# 使用例:
# output "user_arn" {
#   value = aws_iam_user.example.arn
# }
#---------------------------------------------------------------
