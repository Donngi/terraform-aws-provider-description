# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AWS Lake Formation Data Cells Filter
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Terraformリソース: aws_lakeformation_data_cells_filter
# AWSサービス: AWS Lake Formation
# プロバイダーバージョン: 6.28.0
#
# 【概要】
# AWS Lake Formation Data Cells Filterは、データレイク内の特定のテーブルに対して、
# カラムレベルおよび行レベルのアクセス制御を提供します。これにより、機密データを
# 保護しながら、必要なデータへのアクセスを細かく制御できます。
#
# 【主な用途】
# - データセキュリティ: 機密カラム（PII、クレジットカード情報など）へのアクセス制限
# - 行レベルフィルタリング: PartiQL述語を使用した行レベルのアクセス制御
# - データガバナンス: データカタログのテーブルに対する細かいアクセス制御
# - コンプライアンス: GDPR、HIPAA等の規制要件への対応
#
# 【重要なポイント】
# - table_dataブロックは必須で、フィルターを適用するテーブル情報を定義
# - column_namesまたはcolumn_wildcardのいずれかを指定してカラムフィルターを設定
# - row_filterで行レベルのフィルタリング条件を定義可能
# - Data Catalog IDは通常、AWSアカウントIDを使用
#
# 【前提条件】
# - AWS Glueカタログデータベースとテーブルが作成済みであること
# - Lake Formationの適切な権限が設定されていること
# - IAMロール/ユーザーにLake Formationの操作権限があること
#
# 【参考リンク】
# - AWS Lake Formation: https://docs.aws.amazon.com/lake-formation/
# - Data Cells Filter: https://docs.aws.amazon.com/lake-formation/latest/dg/data-filters-about.html
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 基本的な使用例: 特定カラムと行フィルターを使用したData Cells Filter
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resource "aws_lakeformation_data_cells_filter" "basic_example" {
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # テーブルデータ設定（必須）
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Data Cells Filterを適用するテーブルの情報を定義します。
  # このブロックは必須で、最低でも1つのtable_dataブロックが必要です。
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  table_data {
    # ────────────────────────────────────────────────────────────────────────
    # データベース名（必須）
    # ────────────────────────────────────────────────────────────────────────
    # AWS Glueカタログに登録されているデータベースの名前を指定します。
    # このデータベースには、フィルターを適用するテーブルが含まれている必要があります。
    #
    # 例: "customer_database", "sales_db", "analytics_database"
    # ────────────────────────────────────────────────────────────────────────
    database_name = "example_database"

    # ────────────────────────────────────────────────────────────────────────
    # Data Cells Filter名（必須）
    # ────────────────────────────────────────────────────────────────────────
    # このData Cells Filterを識別するための一意の名前です。
    # 同じテーブルに対して複数のフィルターを作成する場合は、それぞれ異なる名前を
    # 付ける必要があります。
    #
    # 命名規則の推奨:
    # - 目的を明確にする: "pii_filter", "sales_region_filter"
    # - 環境を含める: "prod_customer_filter", "dev_test_filter"
    # ────────────────────────────────────────────────────────────────────────
    name = "example_filter"

    # ────────────────────────────────────────────────────────────────────────
    # テーブルカタログID（必須）
    # ────────────────────────────────────────────────────────────────────────
    # AWS Glueデータカタログを所有するAWSアカウントのIDです。
    # 通常は、現在のAWSアカウントIDを使用します。
    #
    # クロスアカウントアクセスの場合は、別のアカウントIDを指定できます。
    # data.aws_caller_identity.current.account_id で取得可能です。
    # ────────────────────────────────────────────────────────────────────────
    table_catalog_id = "123456789012"

    # ────────────────────────────────────────────────────────────────────────
    # テーブル名（必須）
    # ────────────────────────────────────────────────────────────────────────
    # AWS Glueカタログに登録されているテーブルの名前を指定します。
    # このテーブルに対してData Cells Filterが適用されます。
    # ────────────────────────────────────────────────────────────────────────
    table_name = "example_table"

    # ────────────────────────────────────────────────────────────────────────
    # カラム名リスト（オプション）
    # ────────────────────────────────────────────────────────────────────────
    # フィルターで許可する特定のカラム名のリストです。
    # ここで指定されたカラムのみがアクセス可能になります。
    #
    # 【重要】column_names と column_wildcard は排他的です。
    # どちらか一方のみを使用してください。
    #
    # 使用例:
    # - PII除外: ["user_id", "order_date", "amount"]（個人情報カラムを除外）
    # - 特定カラムのみ: ["public_column1", "public_column2"]
    #
    # ネストされたカラムもサポート:
    # - 構造体の場合: ["address.city", "address.state"]
    # ────────────────────────────────────────────────────────────────────────
    column_names = ["customer_id", "order_date", "product_name", "quantity"]

    # ────────────────────────────────────────────────────────────────────────
    # バージョンID（オプション、計算済み）
    # ────────────────────────────────────────────────────────────────────────
    # Data Cells Filterのバージョン識別子です。
    # 通常はAWSによって自動的に管理されます（computed属性）。
    #
    # フィルターを更新すると、新しいバージョンIDが自動的に生成されます。
    # 特定のバージョンを指定したい場合にのみ設定します。
    # ────────────────────────────────────────────────────────────────────────
    # version_id = "1"

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # 行フィルター設定（オプション）
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # PartiQL述語を使用して、どの行をユーザーに表示するかを制御します。
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    row_filter {
      # ──────────────────────────────────────────────────────────────────────
      # フィルター式（オプション、計算済み）
      # ──────────────────────────────────────────────────────────────────────
      # PartiQL形式のフィルター条件を指定します。
      # この条件に一致する行のみがユーザーに表示されます。
      #
      # PartiQL式の例:
      # - 単純な条件: "region = 'us-east-1'"
      # - 複数条件: "region = 'us-east-1' AND status = 'active'"
      # - 日付フィルター: "order_date >= '2024-01-01'"
      # - IN句: "department IN ('sales', 'marketing')"
      # - 数値範囲: "price BETWEEN 100 AND 1000"
      #
      # 【重要】
      # - カラム名は実際のテーブルスキーマと一致する必要があります
      # - filter_expressionとall_rows_wildcardは排他的です
      # - 条件はデータ型に応じて適切に指定してください
      # ──────────────────────────────────────────────────────────────────────
      filter_expression = "region = 'us-east-1'"

      # ──────────────────────────────────────────────────────────────────────
      # 全行ワイルドカード（オプション）
      # ──────────────────────────────────────────────────────────────────────
      # すべての行を許可する場合に使用します。
      # filter_expressionの代わりにこのブロックを使用できます。
      #
      # 使用シーン:
      # - カラムフィルターのみで行フィルターが不要な場合
      # - すべての行へのアクセスを許可し、カラムのみを制限したい場合
      # ──────────────────────────────────────────────────────────────────────
      # all_rows_wildcard {}
    }
  }

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # リージョン設定（オプション、計算済み）
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # このリソースを管理するAWSリージョンを明示的に指定します。
  # 指定しない場合は、プロバイダー設定のリージョンが使用されます。
  #
  # マルチリージョン環境で特定のリージョンに配置する必要がある場合に使用します。
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # region = "us-east-1"

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # タイムアウト設定（オプション）
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # リソース操作のタイムアウト時間を指定します。
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # timeouts {
  #   # リソース作成のタイムアウト（デフォルト: 適切な時間が設定されています）
  #   # 形式: "30s", "5m", "1h" など
  #   create = "5m"
  # }
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 使用例2: カラムワイルドカードを使用した除外パターン
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# すべてのカラムを許可しつつ、特定の機密カラムのみを除外する場合の設定例です。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resource "aws_lakeformation_data_cells_filter" "column_wildcard_example" {
  table_data {
    database_name    = "customer_database"
    name             = "exclude_pii_filter"
    table_catalog_id = "123456789012"
    table_name       = "customers"

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # カラムワイルドカード設定（オプション）
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # すべてのカラムを許可しつつ、特定のカラムを除外する場合に使用します。
    # column_namesの代わりに使用できます（排他的）。
    #
    # 使用シーン:
    # - ほとんどのカラムは公開したいが、一部の機密情報のみ隠したい
    # - PIIデータ（ssn, credit_card_numberなど）のみを除外
    # - テーブルに新しいカラムが追加されても自動的に含まれるようにしたい
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    column_wildcard {
      # ──────────────────────────────────────────────────────────────────────
      # 除外カラム名リスト（オプション）
      # ──────────────────────────────────────────────────────────────────────
      # アクセスを拒否するカラム名のリストです。
      # ここで指定されたカラム以外のすべてのカラムがアクセス可能になります。
      #
      # PII（個人識別情報）の例:
      # - "ssn": 社会保障番号
      # - "credit_card_number": クレジットカード番号
      # - "email": メールアドレス
      # - "phone_number": 電話番号
      # - "address": 住所
      # ──────────────────────────────────────────────────────────────────────
      excluded_column_names = ["ssn", "credit_card_number", "email", "phone_number"]
    }

    # 行フィルターは指定しないため、すべての行が表示されます
    # （カラムフィルターのみが適用されます）
  }
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 使用例3: すべての行を許可する行フィルター
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# カラムレベルのフィルタリングのみを行い、すべての行へのアクセスを許可する例です。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resource "aws_lakeformation_data_cells_filter" "all_rows_example" {
  table_data {
    database_name    = "analytics_database"
    name             = "public_columns_filter"
    table_catalog_id = "123456789012"
    table_name       = "sales_data"

    # 特定のカラムのみを公開
    column_names = ["product_id", "sale_date", "quantity", "total_amount"]

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # 全行ワイルドカードを使用した行フィルター
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # すべての行へのアクセスを許可します。
    # filter_expressionを使用しない場合の代替手段です。
    #
    # 使用シーン:
    # - カラムレベルのフィルタリングのみが必要な場合
    # - 行レベルの制限は不要だが、明示的に指定したい場合
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    row_filter {
      all_rows_wildcard {}
    }
  }
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 使用例4: 複雑な行フィルター条件
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 複数の条件を組み合わせた高度な行レベルフィルタリングの例です。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resource "aws_lakeformation_data_cells_filter" "complex_filter_example" {
  table_data {
    database_name    = "ecommerce_database"
    name             = "regional_sales_filter"
    table_catalog_id = "123456789012"
    table_name       = "orders"

    # すべてのカラムを許可（ワイルドカード使用、除外なし）
    column_wildcard {
      excluded_column_names = []
    }

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # 複雑なPartiQL式を使用した行フィルター
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # 複数の条件を組み合わせて、特定の行のみを表示します。
    #
    # PartiQL高度な使用例:
    # - AND/OR論理演算子の使用
    # - 日付範囲の指定
    # - IN句による複数値のマッチング
    # - 数値範囲の指定（BETWEEN）
    #
    # 以下の例では:
    # - regionが'us-east-1'または'us-west-2'
    # - かつ、order_dateが2024年以降
    # - かつ、statusが'completed'または'shipped'
    # の条件に一致する行のみが表示されます。
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    row_filter {
      filter_expression = "region IN ('us-east-1', 'us-west-2') AND order_date >= '2024-01-01' AND status IN ('completed', 'shipped')"
    }
  }
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 使用例5: ネストされたカラムのフィルタリング
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 構造体やマップ型のカラム内の特定のフィールドのみを許可する例です。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resource "aws_lakeformation_data_cells_filter" "nested_column_example" {
  table_data {
    database_name    = "user_database"
    name             = "nested_address_filter"
    table_catalog_id = "123456789012"
    table_name       = "user_profiles"

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # ネストされたカラムの指定
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # Glueテーブルが構造体カラムを持つ場合、ドット記法でネストされたフィールドを
    # 指定できます。
    #
    # 例えば、以下のようなテーブルスキーマの場合:
    # - user_id: string
    # - name: string
    # - address: struct<
    #     street: string,
    #     city: string,
    #     state: string,
    #     zip: string
    #   >
    #
    # "address.city" と "address.state" のみを許可し、
    # "address.street" と "address.zip" を除外できます。
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    column_names = [
      "user_id",
      "name",
      "address.city",   # 構造体内のcityフィールドのみ許可
      "address.state",  # 構造体内のstateフィールドのみ許可
    ]

    row_filter {
      all_rows_wildcard {}
    }
  }
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 使用例6: 部門別アクセス制御
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 組織の部門ごとに異なるデータへのアクセスを制御する実践的な例です。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resource "aws_lakeformation_data_cells_filter" "department_filter_sales" {
  table_data {
    database_name    = "company_database"
    name             = "sales_department_filter"
    table_catalog_id = "123456789012"
    table_name       = "employee_data"

    # 営業部門に公開するカラム
    # 給与情報は除外し、営業関連の情報のみを許可
    column_names = [
      "employee_id",
      "name",
      "department",
      "sales_target",
      "sales_achieved",
      "commission",
      "territory"
    ]

    # 営業部門のデータのみを表示
    row_filter {
      filter_expression = "department = 'sales'"
    }
  }
}

resource "aws_lakeformation_data_cells_filter" "department_filter_hr" {
  table_data {
    database_name    = "company_database"
    name             = "hr_department_filter"
    table_catalog_id = "123456789012"
    table_name       = "employee_data"

    # 人事部門には全カラムへのアクセスを許可
    column_wildcard {
      excluded_column_names = []
    }

    # すべての従業員データを表示（人事部門は全員のデータにアクセス可能）
    row_filter {
      all_rows_wildcard {}
    }
  }
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 属性参照（Attributes）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# aws_lakeformation_data_cells_filterリソースの出力属性:
#
# - id (string)
#   プロバイダーが生成した一意の識別子
#   形式: "database_name,name,table_catalog_id,table_name"
#   例: "customer_database,pii_filter,123456789012,customers"
#
#   使用例:
#   output "filter_id" {
#     value = aws_lakeformation_data_cells_filter.basic_example.id
#   }
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 出力例
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Data Cells Filterの識別子を出力して、他のリソースから参照できるようにします。
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
output "data_cells_filter_id" {
  description = "Data Cells Filterの一意の識別子（database_name,name,table_catalog_id,table_name形式）"
  value       = aws_lakeformation_data_cells_filter.basic_example.id
}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ベストプラクティスとセキュリティに関する注意事項
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【セキュリティのベストプラクティス】
#
# 1. 最小権限の原則
#    - 必要最小限のカラムのみを公開する
#    - 機密情報（PII、金融データなど）は常に除外する
#    - 部門やロールに応じて適切なフィルターを設定する
#
# 2. データ分類
#    - データの機密度レベルに応じてフィルターを作成
#    - Public/Internal/Confidential/Restrictedなどの分類を使用
#    - 各分類に応じた適切なアクセス制御を実装
#
# 3. 行レベルセキュリティ
#    - 地理的制約がある場合はregionフィルターを使用
#    - 時間制約がある場合は日付フィルターを使用
#    - 部門やチームでデータを分離する場合は適切な条件を設定
#
# 4. 監査とコンプライアンス
#    - CloudTrailでData Cells Filterの作成・変更を記録
#    - 定期的にアクセス権限をレビュー
#    - コンプライアンス要件（GDPR、HIPAA等）に準拠
#
# 5. テストと検証
#    - 本番環境に適用する前に開発環境でフィルターをテスト
#    - 意図しないデータ露出がないことを確認
#    - さまざまなユーザーロールでアクセステストを実施
#
# 【パフォーマンスの考慮事項】
#
# 1. フィルター式の最適化
#    - 複雑すぎるPartiQL式は避ける
#    - インデックス可能なカラムを使用する
#    - 必要に応じて複数のシンプルなフィルターに分割
#
# 2. カラム選択
#    - column_namesは必要なカラムのみを指定
#    - column_wildcardは大きなテーブルで慎重に使用
#    - ネストされたカラムは必要な場合のみ使用
#
# 【運用上の推奨事項】
#
# 1. 命名規則
#    - フィルター名に目的を明示: "pii_filter", "region_filter"
#    - 環境プレフィックスを使用: "prod_", "dev_", "test_"
#    - 部門やチーム名を含める: "sales_", "hr_", "finance_"
#
# 2. バージョン管理
#    - Terraformコードはgitで管理
#    - 変更履歴を追跡可能にする
#    - PRレビューを通じてフィルター変更を承認
#
# 3. ドキュメンテーション
#    - 各フィルターの目的を明確に記載
#    - アクセス権限の設計思想を文書化
#    - 変更時には理由と影響範囲を記録
#
# 4. モニタリング
#    - CloudWatch Logsでアクセスログを監視
#    - Lake Formationのメトリクスを追跡
#    - 異常なアクセスパターンを検出
#
# 【トラブルシューティング】
#
# 1. アクセス拒否エラー
#    - Lake Formationの権限設定を確認
#    - IAMポリシーとLake Formation権限の整合性を確認
#    - Data Cells Filterが正しく適用されているか確認
#
# 2. フィルターが機能しない
#    - カラム名が正確か確認（大文字小文字の違いに注意）
#    - PartiQL式の構文が正しいか確認
#    - テーブルスキーマとフィルター設定が一致しているか確認
#
# 3. パフォーマンス問題
#    - 複雑なrow_filter式を最適化
#    - 必要に応じてテーブルのパーティショニングを見直し
#    - クエリ実行計画を分析
#
# 【関連リソース】
#
# - aws_lakeformation_permissions: Data Cells Filterへのアクセス権限を管理
# - aws_glue_catalog_database: フィルターを適用するデータベース
# - aws_glue_catalog_table: フィルターを適用するテーブル
# - aws_lakeformation_resource: Lake Formationで管理するリソースの登録
#
# 【参考リンク】
#
# - Terraform AWS Provider Documentation:
#   https://registry.terraform.io/providers/hashicorp/aws/latest/docs/resources/lakeformation_data_cells_filter
#
# - AWS Lake Formation Data Filters:
#   https://docs.aws.amazon.com/lake-formation/latest/dg/data-filters-about.html
#
# - PartiQL for Lake Formation:
#   https://docs.aws.amazon.com/lake-formation/latest/dg/partiql-row-filter.html
#
# - Lake Formation Best Practices:
#   https://docs.aws.amazon.com/lake-formation/latest/dg/best-practices.html
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
